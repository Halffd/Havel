// audio.hv — Application audio wrapper (re-exports std/audio)
use "std/audio" as audio

fn volume(_val) { audio.volume(_val) }
fn mute(_val) { audio.mute(_val) }
fn toggleMute() { audio.toggleMute() }
fn sinks() { audio.sinks() }
fn defaultSink() { audio.defaultSink() }
fn sinkVolume(id, _val) { audio.sinkVolume(id, _val) }
fn sinkMute(id, _val) { audio.sinkMute(id, _val) }
fn setSinkDefault(id) { audio.setSinkDefault(id) }
fn sources() { audio.sources() }
fn defaultSource() { audio.defaultSource() }
fn sourceVolume(id, _val) { audio.sourceVolume(id, _val) }
fn sourceMute(id, _val) { audio.sourceMute(id, _val) }
fn setSourceDefault(id) { audio.setSourceDefault(id) }
fn apps() { audio.apps() }
fn appVolume(id, _val) { audio.appVolume(id, _val) }
fn appMute(id, _val) { audio.appMute(id, _val) }
fn increaseActiveAppVolume(step) { audio.increaseActiveAppVolume(step) }
fn decreaseActiveAppVolume(step) { audio.decreaseActiveAppVolume(step) }
fn volumeUp(step) { audio.volumeUp(step) }
