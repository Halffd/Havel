// === BEGIN MODULE: ast ===
// Havel AST — pure Havel implementation
// Represents parsed source code as a tree of node objects
// Each node has: kind, line, col, and kind-specific fields

NODE_TYPES = {
    "Program": true,
    "BlockStatement": true,
    "ExpressionStatement": true,
    "NumberLiteral": true,
    "StringLiteral": true,
    "BooleanLiteral": true,
    "NullLiteral": true,
    "Identifier": true,
    "BinaryExpression": true,
    "UnaryExpression": true,
    "CallExpression": true,
    "MemberExpression": true,
    "IndexExpression": true,
    "AssignmentExpression": true,
    "CompoundAssignment": true,
    "UpdateExpression": true,
    "ArrayLiteral": true,
    "ObjectLiteral": true,
    "ObjectField": true,
    "IfStatement": true,
    "WhileStatement": true,
    "ForStatement": true,
    "LoopStatement": true,
    "RepeatStatement": true,
    "BreakStatement": true,
    "ContinueStatement": true,
    "FnDeclaration": true,
    "ReturnStatement": true,
    "LetDeclaration": true,
    "ValDeclaration": true,
    "UseStatement": true,
    "ImportStatement": true,
    "HotkeyBinding": true,
    "BacktickExpression": true,
    "ShellCommand": true,
    "RangeExpression": true,
    "TernaryExpression": true,
    "SpreadExpression": true,
    "ThrowStatement": true,
    "TryStatement": true,
    "MatchExpression": true,
    "MatchCase": true,
    "PipelineExpression": true,
    "LambdaExpression": true,
    "InterpolatedString": true,
    "RegexLiteral": true,
    "AtExpression": true,
    "AtAtExpression": true,
    "ConfigBlock": true,
  "SleepStatement": true,
  "ErrorNode": true,
  "StructDeclaration": true,
  "ClassDeclaration": true,
  "EnumDeclaration": true,
  "ProtocolDeclaration": true,
  "ImplDeclaration": true,
  "SetLiteral": true,
}

BINARY_OPS = {
    "+": "+", "-": "-", "*": "*", "/": "/", "%": "%",
    "**": "**", "\\": "\\", "\\\\": "\\\\", "%%": "%%",
    "==": "==", "!=": "!=", "<": "<", ">": ">",
    "<=": "<=", ">=": ">=",
    "&&": "&&", "||": "||",
    "&": "&", "|": "|", "^": "^", "<<": "<<", ">>": ">>",
    "??": "??",
    "in": "in", "is": "is", "matches": "matches", "not in": "not in",
}

COMPOUND_ASSIGN_OPS = {
    "+=": "+=", "-=": "-=", "*=": "*=", "/=": "/=", "%=": "%=",
    "**=": "**=", "\\=": "\\=", "%%=": "%%=",
    "&=": "&=", "|=": "|=", "^=": "^=",
    "<<=": "<<=", ">>=": ">>=",
}

UNARY_OPS = {
  "-": "-", "!": "!", "not": "not", "#": "#", "~": "~",
}

fn Program(body, line, col) {
    {kind: "Program", line: line, col: col, body: body}

}
fn BlockStatement(body, line, col) {
    {kind: "BlockStatement", line: line, col: col, body: body}

}
fn ExpressionStatement(expr, line, col) {
    {kind: "ExpressionStatement", line: line, col: col, expr: expr}

}
fn NumberLiteral(value, line, col) {
    {kind: "NumberLiteral", line: line, col: col, value: value}

}
fn StringLiteral(value, line, col) {
    {kind: "StringLiteral", line: line, col: col, value: value}

}
fn BooleanLiteral(value, line, col) {
    {kind: "BooleanLiteral", line: line, col: col, value: value}

}
fn NullLiteral(line, col) {
    {kind: "NullLiteral", line: line, col: col}

}
fn Identifier(name, line, col) {
    {kind: "Identifier", line: line, col: col, name: name}

}
fn BinaryExpression(left, oper, right, line, col) {
    {kind: "BinaryExpression", line: line, col: col, left: left, oper: oper, right: right}

}
fn UnaryExpression(oper, operand, line, col) {
    {kind: "UnaryExpression", line: line, col: col, oper: oper, operand: operand}

}
fn UpdateExpression(operand, oper, prefix, line, col) {
    {kind: "UpdateExpression", line: line, col: col, operand: operand, oper: oper, prefix: prefix}

}
fn CallExpression(callee, args, line, col) {
    {kind: "CallExpression", line: line, col: col, callee: callee, args: args}

}
fn MemberExpression(obj, property, line, col) {
    {kind: "MemberExpression", line: line, col: col, obj: obj, property: property}

}
fn IndexExpression(obj, index, line, col) {
    {kind: "IndexExpression", line: line, col: col, obj: obj, index: index}

}
fn AssignmentExpression(target, value, line, col) {
    {kind: "AssignmentExpression", line: line, col: col, target: target, value: value}

}
fn CompoundAssignment(target, oper, value, line, col) {
    {kind: "CompoundAssignment", line: line, col: col, target: target, oper: oper, value: value}

}
fn ArrayLiteral(elements, line, col) {
    {kind: "ArrayLiteral", line: line, col: col, elements: elements}

}
fn ObjectLiteral(fields, line, col) {
    {kind: "ObjectLiteral", line: line, col: col, fields: fields}

}
fn ObjectField(key, value, line, col) {
    {kind: "ObjectField", line: line, col: col, key: key, value: value}

}
fn SpreadExpression(value, line, col) {
    {kind: "SpreadExpression", line: line, col: col, value: value}

}
fn IfStatement(condition, then_branch, else_branch, line, col) {
    n = {kind: "IfStatement", line: line, col: col, condition: condition, then: then_branch}
    n["else"] = else_branch
    n

}
fn WhileStatement(condition, body, line, col) {
    {kind: "WhileStatement", line: line, col: col, condition: condition, body: body}

}
fn ForStatement(name, iterator, body, line, col) {
    {kind: "ForStatement", line: line, col: col, name: name, iterator: iterator, body: body}

}
fn LoopStatement(body, line, col) {
    {kind: "LoopStatement", line: line, col: col, body: body}

}
fn RepeatStatement(count, body, line, col) {
    {kind: "RepeatStatement", line: line, col: col, count: count, body: body}

}
fn BreakStatement(line, col) {
    {kind: "BreakStatement", line: line, col: col}

}
fn ContinueStatement(line, col) {
    {kind: "ContinueStatement", line: line, col: col}

}
fn FnDeclaration(name, params, body, line, col) {
    {kind: "FnDeclaration", line: line, col: col, name: name, params: params, body: body}

}
fn LambdaExpression(params, body, line, col) {
    {kind: "LambdaExpression", line: line, col: col, params: params, body: body}

}
fn ReturnStatement(value, line, col) {
    {kind: "ReturnStatement", line: line, col: col, value: value}

}
fn LetDeclaration(name, value, line, col) {
    {kind: "LetDeclaration", line: line, col: col, name: name, value: value}

}
fn ValDeclaration(name, value, line, col) {
    {kind: "ValDeclaration", line: line, col: col, name: name, value: value}

}
fn UseStatement(module, names, line, col, opts) {
  n = {kind: "UseStatement", line: line, col: col, module: module, names: names,
       isFileImport: false, isNamedImport: false, isWildcard: false,
       filePath: null, alias: null, importNames: [], importAliases: [],
       moduleNames: []}
  if opts != null {
    for k in opts.keys() {
      n[k] = opts[k]
    }
  }
  n
}
fn ImportStatement(module, names, line, col, opts) {
  n = {kind: "ImportStatement", line: line, col: col, module: module, names: names,
       importNames: [], importAliases: []}
  iNames = []
  iAliases = []
  if names != null {
    for name in names {
      parts = name.split(" as ")
      iNames.push(parts[0])
      if #parts > 1 {
        iAliases.push(parts[1])
      }
      else {
        iAliases.push(parts[0])
      }
    }
  }
  n.importNames = iNames
  n.importAliases = iAliases
  if opts != null {
    for k in opts.keys() {
      n[k] = opts[k]
    }
  }
  n
}
fn HotkeyBinding(key, body, line, col) {
    {kind: "HotkeyBinding", line: line, col: col, key: key, body: body}

}
fn BacktickExpression(command, line, col) {
    {kind: "BacktickExpression", line: line, col: col, command: command}

}
fn ShellCommand(command, capture, line, col) {
    {kind: "ShellCommand", line: line, col: col, command: command, capture: capture}

}
fn RangeExpression(start, end, inclusive, line, col) {
    {kind: "RangeExpression", line: line, col: col, start: start, end: end, inclusive: inclusive}

}
fn TernaryExpression(condition, true_expr, false_expr, line, col) {
    {kind: "TernaryExpression", line: line, col: col, condition: condition, true_expr: true_expr, false_expr: false_expr}

}
fn PipelineExpression(left, right, line, col) {
    {kind: "PipelineExpression", line: line, col: col, left: left, right: right}

}
fn ThrowStatement(value, line, col) {
    {kind: "ThrowStatement", line: line, col: col, value: value}

}
fn TryStatement(try_block, catch_param, catch_block, finally_block, line, col) {
    {kind: "TryStatement", line: line, col: col, try_block: try_block, catch_param: catch_param, catch_block: catch_block, finally_block: finally_block}

}
fn MatchExpression(subject, cases, line, col) {
    {kind: "MatchExpression", line: line, col: col, subject: subject, cases: cases}

}
fn MatchCase(pattern, guard, body, line, col) {
    {kind: "MatchCase", line: line, col: col, pattern: pattern, guard: guard, body: body}

}
fn InterpolatedString(parts, line, col) {
    {kind: "InterpolatedString", line: line, col: col, parts: parts}

}
fn RegexLiteral(pattern, flags, line, col) {
    {kind: "RegexLiteral", line: line, col: col, pattern: pattern, flags: flags}

}
fn AtExpression(field, line, col) {
    {kind: "AtExpression", line: line, col: col, field: field}

}
fn AtAtExpression(field, line, col) {
    {kind: "AtAtExpression", line: line, col: col, field: field}

}
fn ConfigBlock(name, body, line, col) {
    {kind: "ConfigBlock", line: line, col: col, name: name, body: body}

}
fn SleepStatement(duration, line, col) {
    {kind: "SleepStatement", line: line, col: col, duration: duration}

}
fn ErrorNode(msg, line, col) {
    {kind: "ErrorNode", line: line, col: col, msg: msg}

}
fn StructDeclaration(name, fields, methods, protocols, line, col) {
    {
        kind: "StructDeclaration",
        line: line,
        col: col,
        name: name,
        definition: {
            fields: fields,
            methods: methods
        },
        protocols: protocols
    }

}
fn ClassDeclaration(name, parentName, fields, methods, line, col) {
  {
    kind: "ClassDeclaration",
    line: line,
    col: col,
    name: name,
    parentName: parentName,
    definition: {
      fields: fields,
      methods: methods
    }
  }

}
fn EnumDeclaration(name, variants, line, col) {
  {
    kind: "EnumDeclaration",
    line: line,
    col: col,
    name: name,
    variants: variants
  }

}
fn ProtocolDeclaration(name, methods, line, col) {
  {
    kind: "ProtocolDeclaration",
    line: line,
    col: col,
    name: name,
    methods: methods
  }

}
fn ImplDeclaration(typeName, traitName, funcs, line, col) {
  {
    kind: "ImplDeclaration",
    line: line,
    col: col,
    typeName: typeName,
    traitName: traitName,
    funcs: funcs
  }

}
fn SetLiteral(elements, line, col) {
  {kind: "SetLiteral", line: line, col: col, elements: elements}

}
// --- AST utilities ---

fn isNode(v) {
    if v == null: false
    else if type(v) != "object": false
    else if v.kind == null: false
    else: NODE_TYPES[v.kind] != null

}
fn nodeKind(v) {
    result = null
    if isNode(v) {
        result = v.kind
    }
    result

}
// --- Pretty printer ---

fn _indent(depth) {
    s = ""
    i = 0
    while i < depth {
        s = s + " "
        i = i + 1
    }
    s

}
fn _fmtVal(v) {
    result = null
    if v == null {
        result = "null"
    }
    else if v.kind == "NumberLiteral" {
        result = str(v.value)
    }
    else if v.kind == "StringLiteral" {
        result = "\"" + v.value + "\""
    }
    else if v.kind == "BooleanLiteral" {
        if v.value {
            result = "true"
        }
        else {
            result = "false"
        }
    }
    else if v.kind == "NullLiteral" {
        result = "null"
    }
    else if v.kind == "Identifier" {
        result = v.name
    }
    result

}
fn prettyPrint(node, depth) {
    if node == null {
        print(_indent(depth) + "null")
        return

    }
    if type(node) == "array" {
        for s in node {
            prettyPrint(s, depth)
        }
        return

    }
    prefix = _indent(depth)
    k = node.kind

    if k == "Program" {
        print(prefix + "Program:")
        for s in node.body {
            prettyPrint(s, depth + 1)

        }
    }
    else if k == "BlockStatement" {
        print(prefix + "Block:")
        for s in node.body {
            prettyPrint(s, depth + 1)

        }
    }
    else if k == "ExpressionStatement" {
        print(prefix + "ExprStmt:")
        prettyPrint(node.expr, depth + 1)

    }
    else if k == "NumberLiteral" {
        print(prefix + "Num(" + str(node.value) + ")")

    }
    else if k == "StringLiteral" {
        print(prefix + "Str(\"" + node.value + "\")")

    }
    else if k == "BooleanLiteral" {
        print(prefix + "Bool(" + str(node.value) + ")")

    }
    else if k == "NullLiteral" {
        print(prefix + "Null")

    }
    else if k == "Identifier" {
        print(prefix + "Id(" + node.name + ")")

    }
    else if k == "BinaryExpression" {
        print(prefix + "Bin(" + node.oper + "):")
        prettyPrint(node.left, depth + 1)
        prettyPrint(node.right, depth + 1)

    }
    else if k == "UnaryExpression" {
        print(prefix + "Unary(" + node.oper + "):")
        prettyPrint(node.operand, depth + 1)

    }
    else if k == "UpdateExpression" {
        pre = "pre"
        if !node.prefix: pre = "post"
        print(prefix + "Update(" + node.oper + " " + pre + "):")
        prettyPrint(node.operand, depth + 1)

    }
    else if k == "CallExpression" {
        print(prefix + "Call:")
        prettyPrint(node.callee, depth + 1)
        if node.args.len > 0 {
            print(_indent(depth + 1) + "args:")
            for a in node.args {
                prettyPrint(a, depth + 2)

            }
        }
    }
    else if k == "MemberExpression" {
        print(prefix + "Member(.):")
        prettyPrint(node.obj, depth + 1)
        print(_indent(depth + 1) + "." + node.property)

    }
    else if k == "IndexExpression" {
        print(prefix + "Index([]):")
        prettyPrint(node.obj, depth + 1)
        prettyPrint(node.index, depth + 1)

    }
    else if k == "AssignmentExpression" {
        print(prefix + "Assign:")
        prettyPrint(node.target, depth + 1)
        prettyPrint(node.value, depth + 1)

    }
    else if k == "CompoundAssignment" {
        print(prefix + "CompoundAssign(" + node.oper + "):")
        prettyPrint(node.target, depth + 1)
        prettyPrint(node.value, depth + 1)

    }
    else if k == "ArrayLiteral" {
        print(prefix + "Array:")
        for e in node.elements {
            prettyPrint(e, depth + 1)

        }
    }
    else if k == "ObjectLiteral" {
        print(prefix + "Object:")
        for f in node.fields {
            if f.kind == "ObjectField" {
                print(_indent(depth + 1) + f.key + ":")
                prettyPrint(f.value, depth + 2)

            }
        }
    }
    else if k == "SpreadExpression" {
        print(prefix + "Spread:")
        prettyPrint(node.value, depth + 1)

    }
    else if k == "IfStatement" {
        print(prefix + "If:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "then:")
        prettyPrint(node.then, depth + 2)
        if node.else != null {
            print(_indent(depth + 1) + "else:")
            prettyPrint(node.else, depth + 2)

        }
    }
    else if k == "WhileStatement" {
        print(prefix + "While:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "body:")
        prettyPrint(node.body, depth + 2)

    }
    else if k == "ForStatement" {
        print(prefix + "For(" + node.name + " in):")
        prettyPrint(node.iterator, depth + 1)
        print(_indent(depth + 1) + "body:")
        prettyPrint(node.body, depth + 2)

    }
    else if k == "LoopStatement" {
        print(prefix + "Loop:")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "RepeatStatement" {
        print(prefix + "Repeat:")
        prettyPrint(node.count, depth + 1)
        print(_indent(depth + 1) + "body:")
        prettyPrint(node.body, depth + 2)

    }
    else if k == "BreakStatement" {
        print(prefix + "Break")

    }
    else if k == "ContinueStatement" {
        print(prefix + "Continue")

    }
    else if k == "FnDeclaration" {
        params = node.params.join(", ")
        print(prefix + "Fn(" + node.name + "(" + params + ")):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "LambdaExpression" {
        params = node.params.join(", ")
        print(prefix + "Lambda(" + params + "):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "ReturnStatement" {
        print(prefix + "Return:")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "LetDeclaration" {
        print(prefix + "Let(" + node.name + "):")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "ValDeclaration" {
        print(prefix + "Val(" + node.name + "):")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "UseStatement" {
        names = ""
        if node.names != null and node.names.len > 0 {
            names = " {" + node.names.join(", ") + "}"
        }
        print(prefix + "Use(" + node.module + names + ")")

    }
    else if k == "ImportStatement" {
        names = ""
        if node.names != null and node.names.len > 0 {
            names = " {" + node.names.join(", ") + "}"
        }
        print(prefix + "Import(" + node.module + names + ")")

    }
    else if k == "HotkeyBinding" {
        print(prefix + "Hotkey(" + node.key + "):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "BacktickExpression" {
        print(prefix + "Backtick(`" + node.command + "`)")

    }
    else if k == "ShellCommand" {
        cap = "$"
        if node.capture: cap = "$!"
        print(prefix + "Shell(" + cap + " " + node.command + ")")

    }
    else if k == "RangeExpression" {
        rdot = ".."
        if node.inclusive: rdot = "..="
        print(prefix + "Range(" + rdot + "):")
        prettyPrint(node.start, depth + 1)
        prettyPrint(node.end, depth + 1)

    }
    else if k == "TernaryExpression" {
        print(prefix + "Ternary:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "true:")
        prettyPrint(node.true_expr, depth + 2)
        print(_indent(depth + 1) + "false:")
        prettyPrint(node.false_expr, depth + 2)

    }
    else if k == "PipelineExpression" {
        print(prefix + "Pipeline(|>):")
        prettyPrint(node.left, depth + 1)
        prettyPrint(node.right, depth + 1)

    }
    else if k == "ThrowStatement" {
        print(prefix + "Throw:")
        prettyPrint(node.value, depth + 1)

    }
    else if k == "TryStatement" {
        print(prefix + "Try:")
        prettyPrint(node.try_block, depth + 1)
        if node.catch_param != null {
            print(_indent(depth + 1) + "catch(" + node.catch_param + "):")
            prettyPrint(node.catch_block, depth + 2)
        }
        if node.finally_block != null {
            print(_indent(depth + 1) + "finally:")
            prettyPrint(node.finally_block, depth + 2)

        }
    }
    else if k == "MatchExpression" {
        print(prefix + "Match:")
        prettyPrint(node.subject, depth + 1)
        for c in node.cases {
            prettyPrint(c, depth + 1)

        }
    }
    else if k == "MatchCase" {
        print(prefix + "Case:")
        prettyPrint(node.pattern, depth + 1)
        if node.guard != null {
            print(_indent(depth + 1) + "when:")
            prettyPrint(node.guard, depth + 2)
        }
        prettyPrint(node.body, depth + 1)

    }
    else if k == "InterpolatedString" {
        print(prefix + "InterpStr:")
        for p in node.parts {
            prettyPrint(p, depth + 1)

        }
    }
    else if k == "RegexLiteral" {
        print(prefix + "Regex(/" + node.pattern + "/" + node.flags + ")")

    }
    else if k == "AtExpression" {
        print(prefix + "At(." + node.field + ")")

    }
    else if k == "AtAtExpression" {
        print(prefix + "AtAt(." + node.field + ")")

    }
    else if k == "ConfigBlock" {
        print(prefix + "Config(" + node.name + "):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "SleepStatement" {
        print(prefix + "Sleep:")
        prettyPrint(node.duration, depth + 1)

    }
    else if k == "ErrorNode" {
        print(prefix + "ERROR: " + node.msg)

    }
    else {
        print(prefix + "Unknown(" + k + ")")

    }
}
// === END MODULE: ast ===

// === BEGIN MODULE: scope ===
// scope.hv — Lexical scope, variable resolution, upvalue tracking
// Works with bc.add_upvalue() to register closure captures with the VM

fn Scope(parent) {
    {parent: parent, locals: {}, count: 0, upvalues: {}, upcount: 0}

}
fn scopeDeclare(scope, name) {
    existing = scope.locals[name]
    if existing != null {
        return existing
    }
    idx = scope.count
    scope.locals[name] = idx
    scope.count = idx + 1
    return idx

}
fn scopeResolveLocal(scope, name) {
    entry = scope.locals[name]
    if entry != null {
        return {kind: "local", index: entry, scope: scope}
    }
    if scope.parent != null {
        return scopeResolveLocal(scope.parent, name)
    }
    null

}
fn scopeResolveUpvalue(scope, name) {
    existing = scope.upvalues[name]
    if existing != null {
        return existing
    }
    outer = scopeResolveLocal(scope.parent, name)
    if outer == null {
        return -1
    }
    upidx = scope.upcount
    scope.upvalues[name] = upidx
    scope.upcount = upidx + 1
    if outer.kind == "local" {
        bc.add_upvalue(outer.index, 1)
    }
    else {
        bc.add_upvalue(outer.index, 0)
    }
    return upidx

}
fn scopeResolve(scope, name) {
    localEntry = scope.locals[name]
    if localEntry != null {
        return {kind: "local", index: localEntry}
    }
    if scope.parent == null {
        return null
    }
    outer = scopeResolveLocal(scope.parent, name)
    if outer != null {
        upidx = scopeResolveUpvalue(scope, name)
        return {kind: "upvalue", index: upidx}
    }
    null

}
fn scopeDepth(scope) {
    d = 0
    s = scope
    while s.parent != null {
        d = d + 1
        s = s.parent
    }
    d

}
fn scopeLocalCount(scope) {
    scope.count

}
// === END MODULE: scope ===

// === BEGIN MODULE: error ===
// error.hv — unified error reporting for the self-hosted Havel compiler
// Mirrors the C++ ErrorSystem.h + ErrorPrinter.hpp design
// Provides: ErrorReporter singleton, caret-style formatting, error codes,
// severity/stage classification, source line extraction

// ============================================================
// Constants
// ============================================================

SEVERITY_ERROR = 0
SEVERITY_WARNING = 1
SEVERITY_INFO = 2

STAGE_LEXER = 0
STAGE_PARSER = 1
STAGE_EMITTER = 2
STAGE_TYPES = 3
STAGE_RUNTIME = 4

SEVERITY_NAMES = {
  "0": "error",
  "1": "warning",
  "2": "info"
}

STAGE_NAMES = {
  "0": "Lexer",
  "1": "Parser",
  "2": "Emitter",
  "3": "Types",
  "4": "Runtime"
}

// ANSI color codes
RED = "\033[1;31m"
YELLOW = "\033[1;33m"
CYAN = "\033[36m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"

// Error codes (mirrors C++ ErrorSystem.h codes namespace)
E001 = "E001"  // INVALID_CHAR
E002 = "E002"  // UNTERMINATED_STRING
E003 = "E003"  // UNTERMINATED_COMMENT
E004 = "E004"  // INVALID_NUMBER
E005 = "E005"  // INVALID_ESCAPE

E010 = "E010"  // UNEXPECTED_TOKEN
E011 = "E011"  // EXPECTED_EXPRESSION
E012 = "E012"  // EXPECTED_IDENTIFIER
E013 = "E013"  // UNTERMINATED_PARENS
E014 = "E014"  // UNTERMINATED_BRACKET
E015 = "E015"  // UNTERMINATED_BRACE
E016 = "E016"  // EXPECTED_STATEMENT

E020 = "E020"  // INVALID_TYPE
E021 = "E021"  // DUPLICATE_FIELD
E022 = "E022"  // INVALID_PATTERN

E030 = "E030"  // UNDEFINED_VARIABLE
E031 = "E031"  // UNDEFINED_FUNCTION
E032 = "E032"  // TYPE_MISMATCH
E033 = "E033"  // ARITY_MISMATCH
E034 = "E034"  // NOT_CALLABLE
E035 = "E035"  // NOT_INDEXABLE
E036 = "E036"  // INVALID_ASSIGN_TARGET

E040 = "E040"  // INVALID_OPCODE
E041 = "E041"  // STACK_OVERFLOW
E042 = "E042"  // STACK_UNDERFLOW

E050 = "E050"  // DIVISION_BY_ZERO
E051 = "E051"  // INDEX_OUT_OF_BOUNDS
E052 = "E052"  // NULL_DEREFERENCE
E055 = "E055"  // ASSERTION_FAILED

E060 = "E060"  // MODULE_NOT_FOUND
E061 = "E061"  // CIRCULAR_IMPORT

// ============================================================
// Source line cache — avoids re-reading the same file
// ============================================================

sourceCache = {}

fn readSourceLine(filePath, lineNum) {
  if lineNum == null || lineNum < 1 { return "" }
  if filePath == null || filePath == "" || filePath == "<memory>" || filePath == "<stdin>" { return "" }
  cached = sourceCache[filePath]
  if cached == null {
    content = fs.read(filePath)
    if content == null { return "" }
    cached = string.split(content, "\n")
    sourceCache[filePath] = cached
  }
  idx = lineNum - 1
  if idx < 0 || idx >= #cached { return "" }
  cached[idx]
}

fn clearSourceCache() {
  sourceCache = {}
}

// ============================================================
// Error object constructor
// ============================================================

fn HavelError(severity, stage, msg) {
  {
    severity: severity,
    stage: stage,
    msg: msg,
    line: null,
    col: null,
    length: 1,
    file: null,
    code: null,
    sourceLine: null
  }
}

fn errorAtLocation(err, line, col, length) {
  err.line = line
  err.col = col
  if length != null { err.length = length }
  err
}

fn file(err, filePath) {
  err.file = filePath
  err
}

fn withCode(err, code) {
  err.code = code
  err
}

fn withSourceLine(err, line) {
  err.sourceLine = line
  err
}

// ============================================================
// ErrorReporter — singleton-style error accumulation
// ============================================================

fn ErrorReporter() {
  {
    errors: [],
    errorCount: 0,
    warningCount: 0,
    sourceFile: null
  }
}

// Global reporter instance
reporter = ErrorReporter()

fn setSourceFile(filePath) {
  reporter.sourceFile = filePath
}

fn report(err) {
  reporter.errors.push(err)
  if err.severity == SEVERITY_ERROR { reporter.errorCount = reporter.errorCount + 1 }
  if err.severity == SEVERITY_WARNING { reporter.warningCount = reporter.warningCount + 1 }
}

fn hasErrors() { reporter.errorCount > 0 }

fn clear() {
  reporter.errors = []
  reporter.errorCount = 0
  reporter.warningCount = 0
}

// Convenience: report an error at a location
fn errorAt(stage, msg, line, col, code) {
  err = HavelError(SEVERITY_ERROR, stage, msg)
  errorAtLocation(err, line, col, 1)
  if reporter.sourceFile != null { file(err, reporter.sourceFile) }
  if code != null { withCode(err, code) }
  report(err)
  err
}

fn warningAt(stage, msg, line, col) {
  err = HavelError(SEVERITY_WARNING, stage, msg)
  errorAtLocation(err, line, col, 1)
  if reporter.sourceFile != null { file(err, reporter.sourceFile) }
  report(err)
  err
}

fn infoAt(stage, msg, line, col) {
  err = HavelError(SEVERITY_INFO, stage, msg)
  errorAtLocation(err, line, col, 1)
  if reporter.sourceFile != null { file(err, reporter.sourceFile) }
  report(err)
  err
}

// Convenience: just a plain error (no location)
fn reportError(stage, msg) {
  err = HavelError(SEVERITY_ERROR, stage, msg)
  if reporter.sourceFile != null { file(err, reporter.sourceFile) }
  report(err)
  err
}

fn warning(stage, msg) {
  err = HavelError(SEVERITY_WARNING, stage, msg)
  if reporter.sourceFile != null { file(err, reporter.sourceFile) }
  report(err)
  err
}

// ============================================================
// Formatting — rust-style caret errors with ANSI colors
// ============================================================

fn severityColor(severity) {
  if severity == SEVERITY_ERROR { return RED }
  if severity == SEVERITY_WARNING { return YELLOW }
  CYAN
}

fn severityLabel(severity) {
  label = SEVERITY_NAMES[severity]
  if label == null { label = "error" }
  label
}

fn stageLabel(stage) {
  label = STAGE_NAMES[stage]
  if label == null { label = "Compiler" }
  label
}

fn padLeft(n, width) {
  s = str(n)
  while #s < width { s = " " + s }
  s
}

// Format a single error with caret-style output
// Produces output like:
//   error: unknown binary opr 'foo'
//    --> file.hv:12:8
//     |
//   12 | let x = foo + 1
//     |         ^^^
fn formatError(err, useColor) {
  if useColor == null { useColor = true }

  color = severityColor(err.severity)
  label = severityLabel(err.severity)
  stage = stageLabel(err.stage)

  // Header line: "error[E030]: unknown binary opr 'foo'"
  header = label
  if err.code != null { header = header + "[" + err.code + "]" }
  header = header + ": " + err.msg

  if useColor {
    header = color + header + RESET
  }

  // No location — just the header
  if err.line == null || err.line < 1 {
    return header
  }

  // Location line: " --> file.hv:12:8"
  loc = " --> "
  if err.file != null && err.file != "" { loc = loc + err.file + ":" }
  loc = loc + str(err.line) + ":" + str(err.col)
  if useColor { loc = CYAN + loc + RESET }

  // Try to get source line
  sourceLine = err.sourceLine
  if sourceLine == null && err.file != null && err.file != "" {
    sourceLine = readSourceLine(err.file, err.line)
  }
  if sourceLine == null { sourceLine = "" }

  if sourceLine == "" {
    return header + "\n" + loc
  }

  // Trim trailing whitespace from source line for display
  trimmed = string.trimEnd(sourceLine)

  lineStr = str(err.line)
  lineW = #lineStr
  if lineW < 3 { lineW = 3 }

  // "   |"
  pipePad = padLeft("", lineW)
  // "12 | let x = foo + 1"
  sourceOut = lineStr + " | " + trimmed
  // "   |         ^^^"
  caretCount = err.length
  if caretCount == null || caretCount < 1 { caretCount = 1 }
  colOffset = err.col
  if colOffset == null || colOffset < 1 { colOffset = 1 }
  spaces = colOffset - 1
  caretStr = ""
  i = 0
  while i < spaces { caretStr = caretStr + " "; i = i + 1 }
  i = 0
  while i < caretCount { caretStr = caretStr + "^"; i = i + 1 }
  if useColor { caretStr = color + caretStr + RESET }
  caretLine = pipePad + " | " + caretStr

  header + "\n" + loc + "\n" + pipePad + " |" + "\n" + sourceOut + "\n" + caretLine
}

// Format all accumulated errors
fn formatAll(useColor) {
  if useColor == null { useColor = true }
  out = ""
  for err in reporter.errors {
    if out != "" { out = out + "\n" }
    out = out + formatError(err, useColor)
  }
  out
}

// Print all accumulated errors to stdout
fn printAll(useColor) {
  if useColor == null { useColor = true }
  for err in reporter.errors {
    print(formatError(err, useColor))
  }
}

// Print summary line: "2 error(s), 1 warning(s)"
fn printSummary() {
  if reporter.errorCount > 0 || reporter.warningCount > 0 {
    msg = ""
    if reporter.errorCount > 0 { msg = msg + str(reporter.errorCount) + " error(s)" }
    if reporter.warningCount > 0 {
      if msg != "" { msg = msg + ", " }
      msg = msg + str(reporter.warningCount) + " warning(s)"
    }
    print(msg)
  }
}

// ============================================================
// Quick-report helpers for each pipeline stage
// ============================================================

// Lexer errors
fn lexerError(msg, line, col, code) { errorAt(STAGE_LEXER, msg, line, col, code) }

// Parser errors
fn parserError(msg, line, col, code) { errorAt(STAGE_PARSER, msg, line, col, code) }

// Emitter errors
fn emitterError(msg, line, col, code) { errorAt(STAGE_EMITTER, msg, line, col, code) }

// Type inference errors
fn typeError(msg, line, col, code) { errorAt(STAGE_TYPES, msg, line, col, code) }

// Runtime errors
fn runtimeError(msg, line, col, code) { errorAt(STAGE_RUNTIME, msg, line, col, code) }

// ============================================================
// Compatibility: convert old-style {msg, line, col} objects
// ============================================================

fn importLegacyErrors(errors, stage, sourceFile) {
  if errors == null { return }
  for err in errors {
    newErr = HavelError(SEVERITY_ERROR, stage, err.msg)
    errorAtLocation(newErr, err.line, err.col, 1)
    if sourceFile != null { file(newErr, sourceFile) }
    report(newErr)
  }
}

// === END MODULE: error ===

// === BEGIN MODULE: debug ===
// debug.hv — debug flag system and trace logging for the self-hosted Havel compiler
// Mirrors the C++ Debug.hpp + DebugFlags.hpp design
// Provides: flag bag, trace helpers, token/AST/bytecode dump utilities

// ============================================================
// ANSI color codes (shared with error.hv but self-contained)
// ============================================================

DBG_RED = "\033[1;31m"
DBG_GREEN = "\033[1;32m"
DBG_YELLOW = "\033[1;33m"
DBG_CYAN = "\033[36m"
DBG_MAGENTA = "\033[35m"
DBG_DIM = "\033[2m"
DBG_BOLD = "\033[1m"
DBG_RESET = "\033[0m"

// ============================================================
// Debug flag bag — parsed from CLI args, consumed by pipeline
// ============================================================

fn DebugFlags() {
  {
    lexer: false,
    parser: false,
    ast: false,
    bytecode: false,
    gc: false,
    scope: false,
    emitter: false,
    types: false,
    all: false,
    color: true,
    timing: false,
    verbose: false
  }
}

// Global debug flags instance
flags = DebugFlags()

fn isOn(flagName) {
  if flags.all { return true }
  rval = flags[flagName]
  if rval != null { return rval }
  false
}

fn setFlag(flagName, value) {
  flags[flagName] = value
  if flagName == "all" && value {
    flags.lexer = true
    flags.parser = true
    flags.ast = true
    flags.bytecode = true
    flags.scope = true
    flags.emitter = true
    flags.types = true
  }
}

// ============================================================
// CLI arg parser for debug flags
// Returns: updated cfg object with debug flags set
// ============================================================

fn parseDebugArgs(args) {
  i = 0
  while i < #args {
    arg = args[i]
    if arg == "-d" || arg == "--debug" {
      flags.all = true
      flags.verbose = true
    }
    if arg == "-dl" || arg == "--debug-lexer" { flags.lexer = true }
    if arg == "-dp" || arg == "--debug-parser" { flags.parser = true }
    if arg == "-da" || arg == "--debug-ast" { flags.ast = true }
    if arg == "-dbc" || arg == "--debug-bytecode" { flags.bytecode = true }
    if arg == "-dgc" || arg == "--debug-gc" { flags.gc = true }
    if arg == "-ds" || arg == "--debug-scope" { flags.scope = true }
    if arg == "-de" || arg == "--debug-emitter" { flags.emitter = true }
    if arg == "-dt" || arg == "--debug-types" { flags.types = true }
    if arg == "--no-color" { flags.color = false }
    if arg == "--timing" { flags.timing = true }
    if arg == "-v" || arg == "--verbose" { flags.verbose = true }
    i = i + 1
  }
  if flags.all {
    flags.lexer = true
    flags.parser = true
    flags.ast = true
    flags.bytecode = true
    flags.scope = true
    flags.emitter = true
    flags.types = true
  }
  flags
}

// ============================================================
// Trace output — conditional print based on debug flags
// ============================================================

fn colorize(text, color) {
  if flags.color { return color + text + DBG_RESET }
  text
}

// Stage-prefixed trace: "[LEXER] ..." etc
fn trace(stage, msg) {
  prefix = "[" + stage + "]"
  if flags.color {
    prefix = DBG_DIM + prefix + DBG_RESET
  }
  print(prefix + " " + msg)
}

fn traceLexer(msg) { if isOn("lexer") { trace("LEXER", msg) } }
fn traceParser(msg) { if isOn("parser") { trace("PARSER", msg) } }
fn traceAst(msg) { if isOn("ast") { trace("AST", msg) } }
fn traceBytecode(msg) { if isOn("bytecode") { trace("BC", msg) } }
fn traceScope(msg) { if isOn("scope") { trace("SCOPE", msg) } }
fn traceEmitter(msg) { if isOn("emitter") { trace("EMIT", msg) } }
fn traceTypes(msg) { if isOn("types") { trace("TYPES", msg) } }
fn traceGc(msg) { if isOn("gc") { trace("GC", msg) } }

// ============================================================
// Token dump — for --debug-lexer
// ============================================================

fn dumpToken(tok) {
  if tok == null { return "<null>" }
  rval = tok.value
  if rval == null { rval = "" }
  ttype = tok.type
  if ttype == null { ttype = "?" }
  line = tok.line
  col = tok.col
  if line == null { line = 0 }
  if col == null { col = 0 }
  s = str(line) + ":" + str(col) + " " + ttype + " '" + str(rval) + "'"
  if flags.color {
    if ttype == "Number" { s = DBG_CYAN + s + DBG_RESET }
    if ttype == "String" { s = DBG_GREEN + s + DBG_RESET }
    if ttype == "Identifier" { s = DBG_YELLOW + s + DBG_RESET }
    if ttype == "NewLine" { s = DBG_DIM + s + DBG_RESET }
    if ttype == "Keyword" { s = DBG_MAGENTA + s + DBG_RESET }
  }
  s
}

fn dumpTokenList(tokens) {
  if !isOn("lexer") { return }
  traceLexer("--- token stream (" + str(#tokens) + " tokens) ---")
  for tok in tokens {
    traceLexer("  " + dumpToken(tok))
  }
  traceLexer("--- end token stream ---")
}

// ============================================================
// AST dump — for --debug-ast
// ============================================================

fn astKindName(node) {
  if node == null { return "<null>" }
  k = node.kind
  if k == null { return "<unknown>" }
  k
}

fn dumpAstNode(node, indent) {
  if indent == null { indent = 0 }
  if node == null {
    traceAst("  " * indent + "null")
    return
  }
  k = node.kind
  if k == null { k = "?" }
  pad = "  " * indent

  // Summary line varies by node type
  info = k
  if k == "NumberLiteral" { info = k + " " + str(node.value) }
  if k == "StringLiteral" { info = k + " \"" + str(node.value) + "\"" }
  if k == "BoolLiteral" { info = k + " " + str(node.value) }
  if k == "Identifier" { info = k + " " + str(node.name) }
  if k == "FnDeclaration" {
    name = node.name
    if name == null { name = "<anon>" }
    pcount = 0
    if node.params != null { pcount = #node.params }
    info = k + " " + name + "(" + str(pcount) + " params)"
  }
  if k == "VarDeclaration" { info = k + " " + str(node.name) }
  if k == "LetDeclaration" { info = k + " " + str(node.name) }
  if k == "Assignment" { info = k }
  if k == "BinaryExpression" { info = k + " " + str(node.oper) }
  if k == "UnaryExpression" { info = k + " " + str(node.oper) }
  if k == "CallExpression" {
    callee = node.callee
    cname = "<expr>"
    if callee != null && callee.kind == "Identifier" { cname = callee.name }
    info = k + " " + cname
  }
  if k == "MemberExpression" { info = k + " ." + str(node.field) }
  if k == "IndexExpression" { info = k }
  if k == "ReturnStatement" { info = k }
  if k == "IfStatement" { info = k }
  if k == "WhileStatement" { info = k }
  if k == "ForStatement" { info = k }
  if k == "BlockStatement" {
    count = 0
    if node.body != null { count = #node.body }
    info = k + " (" + str(count) + " stmts)"
  }
  if k == "ClassDeclaration" { info = k + " " + str(node.name) }
  if k == "UseStatement" || k == "ImportStatement" { info = k + " " + str(node.module) }

  line = node.line
  col = node.col
  if line != null { info = info + " @ " + str(line) + ":" + str(col) }

  traceAst(pad + info)

  // Recurse into children
  if k == "BlockStatement" && node.body != null {
    for child in node.body { dumpAstNode(child, indent + 1) }
  }
  if k == "FnDeclaration" {
    if node.params != null {
      for p in node.params { dumpAstNode(p, indent + 1) }
    }
    if node.body != null { dumpAstNode(node.body, indent + 1) }
  }
  if k == "IfStatement" {
    if node.condition != null { dumpAstNode(node.condition, indent + 1) }
    if node.body != null { dumpAstNode(node.body, indent + 1) }
    elseBranch = node["else"]
    if elseBranch != null { dumpAstNode(elseBranch, indent + 1) }
  }
  if k == "WhileStatement" || k == "LoopStatement" {
    if node.condition != null { dumpAstNode(node.condition, indent + 1) }
    if node.body != null { dumpAstNode(node.body, indent + 1) }
  }
  if k == "ForStatement" {
    if node.init != null { dumpAstNode(node.init, indent + 1) }
    if node.condition != null { dumpAstNode(node.condition, indent + 1) }
    if node.update != null { dumpAstNode(node.update, indent + 1) }
    if node.body != null { dumpAstNode(node.body, indent + 1) }
  }
  if k == "BinaryExpression" {
    if node.left != null { dumpAstNode(node.left, indent + 1) }
    if node.right != null { dumpAstNode(node.right, indent + 1) }
  }
  if k == "UnaryExpression" || k == "UpdateExpression" {
    if node.operand != null { dumpAstNode(node.operand, indent + 1) }
  }
  if k == "CallExpression" {
    if node.callee != null { dumpAstNode(node.callee, indent + 1) }
    if node.args != null {
      for a in node.args { dumpAstNode(a, indent + 1) }
    }
  }
  if k == "MemberExpression" {
    if node.object != null { dumpAstNode(node.object, indent + 1) }
  }
  if k == "IndexExpression" {
    if node.obj != null { dumpAstNode(node.obj, indent + 1) }
    if node.index != null { dumpAstNode(node.index, indent + 1) }
  }
  if k == "Assignment" || k == "CompoundAssignment" {
    if node.target != null { dumpAstNode(node.target, indent + 1) }
    if node.value != null { dumpAstNode(node.value, indent + 1) }
  }
  if k == "ReturnStatement" {
    if node.value != null { dumpAstNode(node.value, indent + 1) }
  }
  if k == "ClassDeclaration" {
    if node.definition != null { dumpAstNode(node.definition, indent + 1) }
  }
}

fn dumpAst(program) {
  if !isOn("ast") { return }
  traceAst("--- AST dump ---")
  if program == null {
    traceAst("<null program>")
    return
  }
  if program.body != null {
    for node in program.body { dumpAstNode(node, 0) }
  }
  traceAst("--- end AST dump ---")
}

// ============================================================
// Bytecode dump — for --debug-bytecode
// ============================================================

fn dumpBytecode() {
  if !isOn("bytecode") { return }
  traceBytecode("--- bytecode dump ---")
  bc.debug_print()
  traceBytecode("--- end bytecode dump ---")
}

// ============================================================
// Timing helpers — for --timing flag
// ============================================================

timers = {}

fn startTimer(name) {
  timers[name] = time.now()
}

fn endTimer(name) {
  start = timers[name]
  if start == null { return }
  elapsed = time.now() - start
  ms = int(elapsed * 1000)
  trace("TIMER", name + ": " + str(ms) + "ms")
}

// ============================================================
// Scope dump — for --debug-scope
// ============================================================

fn dumpScope(scope, indent) {
  if indent == null { indent = 0 }
  if scope == null {
    traceScope("  " * indent + "<null scope>")
    return
  }
  pad = "  " * indent
  name = scope.name
  if name == null { name = "<anon>" }
  count = scope.count
  if count == null { count = 0 }
  traceScope(pad + name + " (vars: " + str(count) + ")")
  if scope.children != null {
    for child in scope.children { dumpScope(child, indent + 1) }
  }
}

// === END MODULE: debug ===

// === BEGIN MODULE: lexer ===
// Havel lexer — pure Havel implementation
// Tokenizes Havel source code into a list of {type, value, line, col} objects


// --- Token types ---
TOKEN_TYPES = {
    "Identifier": "Identifier",
    "Number": "Number",
    "String": "String",
    "RegexString": "RegexString",
    "MultilineString": "MultilineString",
    "InterpolatedString": "InterpolatedString",
    "Backtick": "Backtick",
    "InterpolatedBacktick": "InterpolatedBacktick",
    "RegexLiteral": "RegexLiteral",
    "Hotkey": "Hotkey",
    "True": "True",
    "False": "False",
    "Null": "Null",
    "Let": "Let",
    "Val": "Val",
    "Const": "Const",
    "If": "If",
    "Else": "Else",
    "While": "While",
    "Do": "Do",
    "Switch": "Switch",
    "For": "For",
    "In": "In",
    "Loop": "Loop",
    "Break": "Break",
    "Continue": "Continue",
    "Match": "Match",
    "Case": "Case",
    "Default": "Default",
    "Fn": "Fn",
    "Op": "Op",
    "Return": "Return",
    "Ret": "Ret",
    "Struct": "Struct",
    "Class": "Class",
    "Enum": "Enum",
    "Trait": "Trait",
    "Prot": "Prot",
    "Impl": "Impl",
    "This": "This",
    "Try": "Try",
    "Catch": "Catch",
    "Finally": "Finally",
    "Throw": "Throw",
    "Thread": "Thread",
    "Interval": "Interval",
    "Timeout": "Timeout",
    "Yield": "Yield",
    "Sleep": "Sleep",
    "Go": "Go",
    "Sync": "Sync",
    "Async": "Async",
    "Channel": "Channel",
    "Co": "Co",
    "Config": "Config",
    "Devices": "Devices",
    "Modes": "Modes",
    "Pool": "Pool",
    "Signal": "Signal",
    "Group": "Group",
    "On": "On",
    "Off": "Off",
    "When": "When",
    "Mode": "Mode",
    "Repeat": "Repeat",
    "Dsl": "Dsl",
    "Del": "Del",
    "Import": "Import",
