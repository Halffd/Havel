// Aliases — map alternate key names to canonical names in _NAME_TO_CODE
_ALIAS_MAP = {
  "escape": "esc", "return": "enter", "pageup": "pgup",
  "pagedown": "pgdn", "super": "win", "meta": "win",
  "lwin": "win", "lmeta": "win", "rmeta": "rwin",
  "leftbracket": "leftbrace", "rightbracket": "rightbrace",
  "equals": "equal", "backtick": "grave", "quote": "apostrophe",
  "del": "delete", "ins": "insert", "bksp": "backspace",
  "prior": "pgup", "next": "pgdn",
  "ctrl": "lctrl", "shift": "lshift", "alt": "lalt",
  "lcmd": "win", "rcmd": "rwin", "cmd": "win",
  "apps": "menu",
  "numpadplus": "numpadadd", "numpadminus": "numpadsub",
  "numpadmult": "numpadmul", "numpadasterisk": "numpadmul",
  "numpaddot": "numpaddec", "numpaddel": "numpaddec",
  "numpadperiod": "numpaddec", "numpaddecimal": "numpaddec",
  "mediaplay": "playpause", "mediastop": "stopcd",
