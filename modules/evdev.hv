  "eject": "ejectcd", "calculator": "calc",
  "printscreen": "sysrq", "pausebreak": "pause",
  "wifi": "wlan",
  "-": "minus", "=": "equal", "[": "leftbrace", "]": "rightbrace",
  ";": "semicolon", "'": "apostrophe", "`": "grave", "\\": "backslash",
  ",": "comma", ".": "dot", "/": "slash",
  "browser_home": "homepage", "browser_back": "back",
  "browser_forward": "forward", "browser_search": "search",
  "browser_bookmarks": "bookmarks", "browser_favorites": "favorites",
  "browser_refresh": "refresh",
}

// Evdev code to name mapping (reverse of _NAME_TO_CODE)
_CODE_TO_NAME = {}
for _n in _NAME_TO_CODE { _CODE_TO_NAME.set(_NAME_TO_CODE[_n], _n) }

fn nameToCode(name) {
  if name == null { return 0 }
  _l = name.lower()
  _alias = _ALIAS_MAP[_l]
  if _alias != null { _l = _alias }
  _c = _NAME_TO_CODE[_l]
  if _c != null { return _c }
  0
}

fn codeToName(code) {
  if code == null { return "" }
  _n = _CODE_TO_NAME[code]
  if _n != null { return _n }
  ""
}

// Open an evdev device at /dev/input/eventX
// Returns a handle object or null on failure
fn open(path) {
  if path == null { return null }
  _path_cs = ffi.cstring(path)
  _fd = ffi.call(_open, "int32", ["pointer", "int32"], _path_cs, _O_RDONLY)
  ffi.free(_path_cs)
  if _fd < 0 { return null }

  // Read device name via EVIOCGNAME(256)
  _name_ioctl = _EVIOCGNAME_BASE | (256 << 16)
  _name_buf = ffi.allocBytes(256)
  ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], _fd, _name_ioctl, _name_buf)
  _devname = ffi.string(_name_buf)
  ffi.free(_name_buf)

  // Read device ID (struct input_id: 4 x uint16 = 8 bytes)
  _id_buf = ffi.allocBytes(8)
  ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], _fd, _EVIOCGID, _id_buf)
  _bustype = ffi.get_u16(_id_buf)
  _vendor = ffi.get_u16(ffi.ptr_add(_id_buf, 2))
  _product = ffi.get_u16(ffi.ptr_add(_id_buf, 4))
  _version = ffi.get_u16(ffi.ptr_add(_id_buf, 6))
  ffi.free(_id_buf)

  ({fd: _fd, path: path, name: _devname, bustype: _bustype, vendor: _vendor,
    product: _product, version: _version, _nonblock: false})
}

// Close an evdev device handle
fn close(handle) {
  if handle == null { return }
  ffi.call(_close, "int32", ["int32"], handle.fd)
}

// Grab (exclusive access) the device
fn grab(handle) {
  if handle == null { return false }
  _ret = ffi.call(_ioctl, "int32", ["int32", "uint64", "int32"], handle.fd, _EVIOCGRAB, 1)
  _ret == 0
}

// Ungrab the device
fn ungrab(handle) {
  if handle == null { return false }
  _ret = ffi.call(_ioctl, "int32", ["int32", "uint64", "int32"], handle.fd, _EVIOCGRAB, 0)
  _ret == 0
}

// Get device name via EVIOCGNAME
fn name(handle) {
  if handle == null { return "" }
  _name_ioctl = _EVIOCGNAME_BASE | (256 << 16)
  _name_buf = ffi.allocBytes(256)
  ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _name_ioctl, _name_buf)
  _devname = ffi.string(_name_buf)
  ffi.free(_name_buf)
  _devname
}

// Get physical path via EVIOCGPHYS
fn phys(handle) {
  if handle == null { return "" }
  _phys_ioctl = _EVIOCGPHYS_BASE | (256 << 16)
  _phys_buf = ffi.allocBytes(256)
  ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _phys_ioctl, _phys_buf)
  _physname = ffi.string(_phys_buf)
  ffi.free(_phys_buf)
  _physname
}

// Get device ID as {bustype, vendor, product, version}
fn deviceId(handle) {
  if handle == null { return null }
  _id_buf = ffi.allocBytes(8)
  ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _EVIOCGID, _id_buf)
  _bustype = ffi.get_u16(_id_buf)
  _vendor = ffi.get_u16(ffi.ptr_add(_id_buf, 2))
  _product = ffi.get_u16(ffi.ptr_add(_id_buf, 4))
  _version = ffi.get_u16(ffi.ptr_add(_id_buf, 6))
  ffi.free(_id_buf)
  ({bustype: _bustype, vendor: _vendor, product: _product, version: _version})
}

// Read the current key state bitmask via EVIOCGKEY
// Returns a map of {code: true} for all currently pressed keys
fn keyState(handle) {
  if handle == null { return {} }
  _key_bits_len = ((_KEY_MAX + 7) / 8)
  _key_ioctl = _EVIOCGKEY_BASE | (_key_bits_len << 16)
  _buf = ffi.allocBytes(_key_bits_len)
  _ret = ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _key_ioctl, _buf)
  _result = {}
  if _ret >= 0 {
    _key = 0
    while _key < _KEY_MAX {
      _byte_idx = _key / 8
      _bit_idx = _key % 8
      _byte_val = ffi.get_u8(ffi.ptr_add(_buf, _byte_idx))
      if (_byte_val & (1 << _bit_idx)) != 0 {
        _result.set(_key, true)
      }
      _key = _key + 1
    }
  }
  ffi.free(_buf)
  _result
}

// Check if a specific key is currently pressed
fn isKeyDown(handle, code) {
  if handle == null { return false }
  if code == null { return false }
  _key_bits_len = ((_KEY_MAX + 7) / 8)
  _key_ioctl = _EVIOCGKEY_BASE | (_key_bits_len << 16)
  _buf = ffi.allocBytes(_key_bits_len)
  _ret = ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _key_ioctl, _buf)
  _down = false
  if _ret >= 0 {
    _byte_idx = code / 8
    _bit_idx = code % 8
    _byte_val = ffi.get_u8(ffi.ptr_add(_buf, _byte_idx))
    _down = (_byte_val & (1 << _bit_idx)) != 0
  }
  ffi.free(_buf)
  _down
}

// Get event type capability bitmask via EVIOCGBIT
// Returns array of byte values for the requested event type
fn keyBits(handle, evType, len) {
  if handle == null { return null }
  if len == null { len = 128 }
  _ioctl_code = _EVIOCGBIT_BASE | (evType) | (len << 16)
  _buf = ffi.allocBytes(len)
  _ret = ffi.call(_ioctl, "int32", ["int32", "uint64", "pointer"], handle.fd, _ioctl_code, _buf)
  if _ret < 0 {
    ffi.free(_buf)
    return null
  }
  // Convert to array of byte values
  _result = []
  _i = 0
  while _i < len {
    _result.push(ffi.get_u8(ffi.ptr_add(_buf, _i)))
    _i = _i + 1
  }
  ffi.free(_buf)
  _result
}

// Parse raw input_event bytes (24 bytes on 64-bit)
fn _parseEvent(buf) {
  // timeval: sec at offset 0 (i64), usec at offset 8 (i64)
  // type at offset 16 (u16), code at offset 18 (u16), value at offset 20 (i32)
  _sec = ffi.get_i64(buf)
  _usec = ffi.get_i64(ffi.ptr_add(buf, 8))
  _type = ffi.get_u16(ffi.ptr_add(buf, 16))
  _code = ffi.get_u16(ffi.ptr_add(buf, 18))
  _value = ffi.get_i32(ffi.ptr_add(buf, 20))
  _type_name = "unknown"
  if _type == EV_SYN { _type_name = "sync" }
  else if _type == EV_KEY { _type_name = "key" }
  else if _type == EV_REL { _type_name = "relative" }
  else if _type == EV_ABS { _type_name = "absolute" }
  else if _type == EV_MSC { _type_name = "misc" }
  else if _type == EV_SW { _type_name = "switch" }
  else if _type == EV_LED { _type_name = "led" }
  else if _type == EV_SND { _type_name = "sound" }

  _key_name = ""
  if _type == EV_KEY { _key_name = codeToName(_code) }
  else if _type == EV_REL {
    if _code == REL_X { _key_name = "x" }
    else if _code == REL_Y { _key_name = "y" }
    else if _code == REL_WHEEL { _key_name = "wheel" }
    else if _code == REL_HWHEEL { _key_name = "hwheel" }
  } else if _type == EV_ABS {
    if _code == ABS_X { _key_name = "x" }
    else if _code == ABS_Y { _key_name = "y" }
  }

  ({sec: _sec, usec: _usec, type: _type, type_name: _type_name,
    code: _code, value: _value, key_name: _key_name})
}

// Read a single input event (blocking)
fn read(handle) {
  if handle == null { return null }
  _buf = ffi.allocBytes(_INPUT_EVENT_SIZE)
  _n = ffi.call(_read, "int64", ["int32", "pointer", "int64"], handle.fd, _buf, _INPUT_EVENT_SIZE)
  if _n != _INPUT_EVENT_SIZE {
    ffi.free(_buf)
    return null
  }
  _ev = _parseEvent(_buf)
  ffi.free(_buf)
  _ev
}

// Read a single input event (non-blocking)
// Switches to O_NONBLOCK mode on first call
fn readNonBlock(handle) {
  if handle == null { return null }
  if !handle._nonblock {
    ffi.call(_close, "int32", ["int32"], handle.fd)
    _path_cs = ffi.cstring(handle.path)
    handle.fd = ffi.call(_open, "int32", ["pointer", "int32"], _path_cs, (_O_RDONLY | _O_NONBLOCK))
    ffi.free(_path_cs)
    if handle.fd < 0 { return null }
    handle._nonblock = true
  }
  _buf = ffi.allocBytes(_INPUT_EVENT_SIZE)
  _n = ffi.call(_read, "int64", ["int32", "pointer", "int64"], handle.fd, _buf, _INPUT_EVENT_SIZE)
  if _n != _INPUT_EVENT_SIZE {
    ffi.free(_buf)
    return null
  }
  _ev = _parseEvent(_buf)
  ffi.free(_buf)
  _ev
}
