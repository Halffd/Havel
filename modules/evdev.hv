// input_event struct size on 64-bit Linux = 24 bytes
// Layout: timeval(16: i64 sec + i64 usec) + u16 type(2) + u16 code(2) + i32 value(4)
_INPUT_EVENT_SIZE = 24

// ioctl request codes (verified against compiled C on this system)
// _IOC(dir, type, nr, size) = (dir << 30) | (size << 16) | (type << 8) | nr
// 'E' = 0x45 = 69

// EVIOCGRAB = _IOW('E', 0x90, int) = (1<<30)|(4<<16)|(69<<8)|0x90
_EVIOCGRAB = 1074021776

// EVIOCGVERSION = _IOR('E', 0x01, int) = (2<<30)|(4<<16)|(69<<8)|0x01
_EVIOCGVERSION = 2147763457

// EVIOCGID = _IOR('E', 0x02, struct input_id) = (2<<30)|(8<<16)|(69<<8)|0x02
_EVIOCGID = 2148025602

// EVIOCGNAME(len) = _IOC(2, 69, 0x06, len) = (2<<30)|(len<<16)|(69<<8)|6
// Base without len: (2<<30)|(69<<8)|6 = 2147501318
_EVIOCGNAME_BASE = 2147501318

// EVIOCGKEY(len) = _IOC(2, 69, 0x18, len) = (2<<30)|(len<<16)|(69<<8)|24
// Base without len: (2<<30)|(69<<8)|24 = 2147501336
_EVIOCGKEY_BASE = 2147501336

// EVIOCGPHYS(len) = _IOC(2, 69, 0x07, len) = (2<<30)|(len<<16)|(69<<8)|7
// Base without len: (2<<30)|(69<<8)|7 = 2147501319
_EVIOCGPHYS_BASE = 2147501319

// EVIOCGBIT(ev, len) = _IOC(2, 69, 0x20+ev, len) = (2<<30)|(len<<16)|(69<<8)|(32+ev)
// Base without ev/len: (2<<30)|(69<<8)|32 = 2147501344
_EVIOCGBIT_BASE = 2147501344

