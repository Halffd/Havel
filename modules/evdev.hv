// evdev.hv — Linux evdev raw input device access via FFI
// Provides: evdev.open, evdev.close, evdev.read, evdev.readNonBlock,
// evdev.name, evdev.grab, evdev.ungrab, evdev.keyState,
// evdev.deviceId, evdev.phys, evdev.keyBits,
// evdev.codeToName, evdev.nameToCode,
// Event type/code constants: EV_SYN, EV_KEY, EV_REL, EV_ABS, etc.

use ffi

_c = ffi.open("libc.so.6")
if _c == 0 { _c = ffi.open("libc.so") }

_open = ffi.sym(_c, "open")
_close = ffi.sym(_c, "close")
_read = ffi.sym(_c, "read")
_ioctl = ffi.sym(_c, "ioctl")
_write = ffi.sym(_c, "write")

_O_RDONLY = 0
_O_WRONLY = 1
_O_NONBLOCK = 2048

