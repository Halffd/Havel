// keyboard.hv — Keyboard state querying and simulation via X11/Xtst FFI
// Provides: keyboard.isDown, keyboard.pressed, keyboard.press,
// keyboard.release, keyboard.tap, keyboard.type, keyboard.grab,
// keyboard.ungrab, keyboard.leds, keyboard.keycode, keyboard.keysym

use ffi

_xlib = ffi.open("libX11.so.6")
if _xlib == 0 { _xlib = ffi.open("libX11.so") }

_xtst = ffi.open("libXtst.so.6")
if _xtst == 0 { _xtst = ffi.open("libXtst.so") }

_XOpenDisplay = ffi.sym(_xlib, "XOpenDisplay")
_XCloseDisplay = ffi.sym(_xlib, "XCloseDisplay")
_XDefaultRootWindow = ffi.sym(_xlib, "DefaultRootWindow")
_XQueryKeymap = ffi.sym(_xlib, "XQueryKeymap")
_XKeysymToKeycode = ffi.sym(_xlib, "XKeysymToKeycode")
_XStringToKeysym = ffi.sym(_xlib, "XStringToKeysym")
_XKeycodeToKeysym = ffi.sym(_xlib, "XKeycodeToKeysym")
_XFlush = ffi.sym(_xlib, "XFlush")
_XGrabKey = ffi.sym(_xlib, "XGrabKey")
_XUngrabKey = ffi.sym(_xlib, "XUngrabKey")

_XkbGetState = ffi.sym(_xlib, "XkbGetState")

_XTestFakeKeyEvent = ffi.sym(_xtst, "XTestFakeKeyEvent")

_t_p = ["pointer"]

fn _openDisplay() {
  ffi.call(_XOpenDisplay, "pointer", _t_p, 0)
}

fn _closeDisplay(dpy) {
  ffi.call(_XCloseDisplay, "int32", _t_p, dpy)
}

fn _rootWindow(dpy) {
  ffi.call(_XDefaultRootWindow, "uint64", ["pointer"], dpy)
}

fn _stringToKeysym(name) {
  _cs = ffi.cstring(name)
  _ks = ffi.call(_XStringToKeysym, "uint64", ["pointer"], _cs)
  ffi.free(_cs)
  _ks
}

fn _keysymToKeycode(dpy, ks) {
  ffi.call(_XKeysymToKeycode, "uint64", ["pointer", "uint64"], dpy, ks)
}

fn _keycodeToKeysym(dpy, kc) {
  ffi.call(_XKeycodeToKeysym, "uint64", ["pointer", "uint64", "int32"], dpy, kc, 0)
}

fn _queryKeymap(dpy) {
  _buf = ffi.allocBytes(32)
  ffi.call(_XQueryKeymap, "void", ["pointer", "pointer"], dpy, _buf)
  _buf
}

fn _isKeycodeDown(buf, kc) {
  _byte_idx = kc / 8
  _bit_idx = kc % 8
  _byte_val = ffi.get_u8(ffi.ptr_add(buf, _byte_idx))
  (_byte_val & (1 << _bit_idx)) != 0
}

fn _fakeKey(dpy, kc, press) {
  ffi.call(_XTestFakeKeyEvent, "int32", ["pointer", "uint64", "int32", "uint64"], dpy, kc, press, 0)
  ffi.call(_XFlush, "int32", _t_p, dpy)
}

