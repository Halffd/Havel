fn _nameToKeysym(name) {
  _l = name.lower()
  _single = 0
  if #_l == 1 {
    _c = _l[0:1]
    _cv = _c.code()
    if _cv >= 97 && _cv <= 122 { return _cv }
    if _cv >= 48 && _cv <= 57 { return _cv }
  }
  if _l == "esc" || _l == "escape" { return _XK_Escape }
  if _l == "enter" || _l == "return" { return _XK_Return }
  if _l == "space" { return _XK_space }
  if _l == "tab" { return _XK_Tab }
  if _l == "backspace" { return _XK_BackSpace }
  if _l == "delete" || _l == "del" { return _XK_Delete }
  if _l == "home" { return _XK_Home }
  if _l == "end" { return _XK_End }
  if _l == "pgup" || _l == "pageup" { return _XK_Page_Up }
  if _l == "pgdn" || _l == "pagedown" { return _XK_Page_Down }
  if _l == "insert" || _l == "ins" { return _XK_Insert }
  if _l == "left" { return _XK_Left }
  if _l == "right" { return _XK_Right }
  if _l == "up" { return _XK_Up }
  if _l == "down" { return _XK_Down }
  if _l == "ctrl" || _l == "lctrl" || _l == "control" { return _XK_Control_L }
  if _l == "rctrl" || _l == "rcontrol" { return _XK_Control_R }
  if _l == "shift" || _l == "lshift" { return _XK_Shift_L }
  if _l == "rshift" { return _XK_Shift_R }
  if _l == "alt" || _l == "lalt" { return _XK_Alt_L }
  if _l == "ralt" { return _XK_Alt_R }
  if _l == "win" || _l == "lwin" || _l == "meta" || _l == "lmeta" || _l == "super" { return _XK_Super_L }
  if _l == "rwin" || _l == "rmeta" || _l == "rsuper" { return _XK_Super_R }
  if _l == "capslock" || _l == "caps" { return _XK_Caps_Lock }
  if _l == "numlock" || _l == "num" { return _XK_Num_Lock }
  if _l == "scrolllock" || _l == "scroll" { return _XK_Scroll_Lock }
  if _l == "f1" { return _XK_F1 }
  if _l == "f2" { return _XK_F2 }
  if _l == "f3" { return _XK_F3 }
  if _l == "f4" { return _XK_F4 }
  if _l == "f5" { return _XK_F5 }
  if _l == "f6" { return _XK_F6 }
  if _l == "f7" { return _XK_F7 }
  if _l == "f8" { return _XK_F8 }
  if _l == "f9" { return _XK_F9 }
  if _l == "f10" { return _XK_F10 }
  if _l == "f11" { return _XK_F11 }
  if _l == "f12" { return _XK_F12 }
  if _l == "f13" { return _XK_F13 }
  if _l == "f14" { return _XK_F14 }
  if _l == "f15" { return _XK_F15 }
  if _l == "f16" { return _XK_F16 }
  if _l == "f17" { return _XK_F17 }
  if _l == "f18" { return _XK_F18 }
  if _l == "f19" { return _XK_F19 }
  if _l == "f20" { return _XK_F20 }
  if _l == "f21" { return _XK_F21 }
  if _l == "f22" { return _XK_F22 }
  if _l == "f23" { return _XK_F23 }
  if _l == "f24" { return _XK_F24 }
  if _l == "numpad0" { return _XK_KP_0 }
  if _l == "numpad1" { return _XK_KP_1 }
  if _l == "numpad2" { return _XK_KP_2 }
  if _l == "numpad3" { return _XK_KP_3 }
  if _l == "numpad4" { return _XK_KP_4 }
  if _l == "numpad5" { return _XK_KP_5 }
  if _l == "numpad6" { return _XK_KP_6 }
  if _l == "numpad7" { return _XK_KP_7 }
  if _l == "numpad8" { return _XK_KP_8 }
  if _l == "numpad9" { return _XK_KP_9 }
  if _l == "numpadadd" || _l == "numpadplus" { return _XK_KP_Add }
  if _l == "numpadsub" || _l == "numpadminus" { return _XK_KP_Subtract }
  if _l == "numpadmul" || _l == "numpadmult" || _l == "numpadasterisk" { return _XK_KP_Multiply }
  if _l == "numpaddiv" { return _XK_KP_Divide }
  if _l == "numpaddec" || _l == "numpaddot" || _l == "numpaddel" || _l == "numpadperiod" || _l == "numpaddecimal" { return _XK_KP_Decimal }
  if _l == "numpadenter" { return _XK_KP_Enter }
  if _l == "numpadequal" { return _XK_KP_Equal }
  if _l == "numpadcomma" { return _XK_KP_Separator }
  if _l == "minus" || _l == "-" { return _XK_minus }
  if _l == "equal" || _l == "equals" || _l == "=" { return _XK_equal }
  if _l == "leftbrace" || _l == "[" { return _XK_bracketleft }
  if _l == "rightbrace" || _l == "]" { return _XK_bracketright }
  if _l == "semicolon" || _l == ";" { return _XK_semicolon }
  if _l == "apostrophe" || _l == "'" { return _XK_apostrophe }
  if _l == "grave" || _l == "`" { return _XK_grave }
  if _l == "backslash" || _l == "\\" { return _XK_backslash }
  if _l == "comma" || _l == "," { return _XK_comma }
  if _l == "dot" || _l == "period" || _l == "." { return _XK_period }
  if _l == "slash" || _l == "/" { return _XK_slash }
  if _l == "printscreen" || _l == "print" || _l == "sysrq" { return _XK_Print }
  if _l == "pause" || _l == "pausebreak" { return _XK_Pause }
  if _l == "menu" || _l == "apps" { return _XK_Menu }
  if _l == "help" { return _XK_Help }
  if _l == "playpause" || _l == "mediaplay" { return _XF86AudioPlay }
  if _l == "stopcd" || _l == "mediastop" { return _XF86AudioStop }
  if _l == "previoussong" || _l == "prev" || _l == "previous" || _l == "mediaprev" { return _XF86AudioPrev }
  if _l == "nextsong" || _l == "next" || _l == "medianext" { return _XF86AudioNext }
  if _l == "volumeup" { return _XF86AudioRaiseVolume }
  if _l == "volumedown" { return _XF86AudioLowerVolume }
  if _l == "mute" || _l == "volumemute" { return _XF86AudioMute }
  if _l == "micmute" { return _XF86AudioMicMute }
  if _l == "ejectcd" || _l == "eject" || _l == "mediaeject" { return _XF86Eject }
  if _l == "homepage" { return _XF86HomePage }
  if _l == "back" { return _XF86Back }
  if _l == "forward" { return _XF86Forward }
  if _l == "search" { return _XF86Search }
  if _l == "refresh" { return _XF86Refresh }
  if _l == "power" { return _XF86PowerOff }
  if _l == "sleep" { return _XF86Sleep }
  if _l == "wakeup" { return _XF86WakeUp }
  if _l == "brightnessup" { return _XF86MonBrightnessUp }
  if _l == "brightnessdown" { return _XF86MonBrightnessDown }
  if _l == "kbdillumup" { return _XF86KbdBrightnessUp }
  if _l == "kbdillumdown" { return _XF86KbdBrightnessDown }
  if _l == "wlan" || _l == "wifi" { return _XF86WLAN }
  if _l == "bluetooth" { return _XF86Bluetooth }
  if _l == "battery" { return _XF86Battery }
  if _l == "calc" || _l == "calculator" { return _XF86Calculator }
  if _l == "mail" { return _XF86Mail }
  if _l == "www" { return _XF86WWW }
  if _l == "copy" { return _XF86Copy }
  if _l == "paste" { return _XF86Paste }
  if _l == "cut" { return _XF86Cut }
  if _l == "open" { return _XF86Open }
  if _l == "save" { return _XF86Save }
  if _l == "close" { return _XF86Close }
  if _l == "file" { return _XF86Documents }
  if _l == "zoomin" { return _XF86ZoomIn }
  if _l == "zoomout" { return _XF86ZoomOut }
  if _l == "favorites" || _l == "bookmarks" { return _XF86Favorites }
  if _l == "messenger" { return _XF86Messenger }
  if _l == "finance" { return _XF86Finance }
  if _l == "shop" { return _XF86Shop }
  if _l == "record" || _l == "mediarecord" { return 269016106 }
  if _l == "rewind" || _l == "mediarewind" { return 269016101 }
  if _l == "fastforward" || _l == "mediaforward" { return 269016103 }
  if #_l >= 5 && _l[0:5] == "xk_" { return _stringToKeysym(_l[3:]) }
  _stringToKeysym(name)
}

fn _keysymToName(ks) {
  if ks == 0 { return "" }
  _n = _KN[ks]
  if _n != null { return _n }
  ""
}

fn _charToKeysym(ch) {
  _cv = ch.code()
  if _cv >= 97 && _cv <= 122 { return _cv }
  if _cv >= 48 && _cv <= 57 { return _cv }
  if _cv >= 65 && _cv <= 90 { return _cv }
  if _cv == 32 { return _XK_space }
  if ch == "!" { return _XK_exclam }
  if ch == "@" { return _XK_at }
  if ch == "#" { return _XK_numbersign }
  if ch == "$" { return _XK_dollar }
  if ch == "%" { return _XK_percent }
  if ch == "^" { return _XK_asciicircum }
  if ch == "&" { return _XK_ampersand }
  if ch == "*" { return _XK_asterisk }
  if ch == "(" { return _XK_parenleft }
  if ch == ")" { return _XK_parenright }
  if ch == "_" { return _XK_underscore }
  if ch == "+" { return _XK_plus }
  if ch == "{" { return _XK_braceleft }
  if ch == "}" { return _XK_braceright }
  if ch == ":" { return _XK_colon }
  if ch == "\"" { return _XK_quotedbl }
  if ch == "~" { return _XK_asciitilde }
  if ch == "|" { return _XK_bar }
  if ch == "<" { return _XK_less }
  if ch == ">" { return _XK_greater }
  if ch == "?" { return _XK_question }
  if ch == "-" { return _XK_minus }
  if ch == "=" { return _XK_equal }
  if ch == "[" { return _XK_bracketleft }
  if ch == "]" { return _XK_bracketright }
  if ch == ";" { return _XK_semicolon }
  if ch == "'" { return _XK_apostrophe }
  if ch == "`" { return _XK_grave }
  if ch == "\\" { return _XK_backslash }
  if ch == "," { return _XK_comma }
  if ch == "." { return _XK_period }
  if ch == "/" { return _XK_slash }
  if ch == "\t" { return _XK_Tab }
  if ch == "\n" { return _XK_Return }
  _cv
}

fn _charNeedsShift(ch) {
  _cv = ch.code()
  if _cv >= 65 && _cv <= 90 { return true }
  if ch == "!" { return true }
  if ch == "@" { return true }
  if ch == "#" { return true }
  if ch == "$" { return true }
  if ch == "%" { return true }
  if ch == "^" { return true }
  if ch == "&" { return true }
  if ch == "*" { return true }
  if ch == "(" { return true }
  if ch == ")" { return true }
  if ch == "_" { return true }
  if ch == "+" { return true }
  if ch == "{" { return true }
  if ch == "}" { return true }
  if ch == ":" { return true }
  if ch == "\"" { return true }
  if ch == "~" { return true }
  if ch == "|" { return true }
  if ch == "<" { return true }
  if ch == ">" { return true }
  if ch == "?" { return true }
  false
}

fn keysym(name) {
  _nameToKeysym(name)
}

fn keycode(name) {
  _ks = _nameToKeysym(name)
  if _ks == 0 { return 0 }
  _dpy = _openDisplay()
  if _dpy == 0 { return 0 }
  _kc = _keysymToKeycode(_dpy, _ks)
  _closeDisplay(_dpy)
  _kc
}

fn isDown(name) {
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  _buf = _queryKeymap(_dpy)
  _down = _isKeycodeDown(_buf, _kc)
  ffi.free(_buf)
  _closeDisplay(_dpy)
  _down
}

fn pressed() {
  _dpy = _openDisplay()
  if _dpy == 0 { return [] }
  _buf = _queryKeymap(_dpy)
  _result = []
  _kc = 8
  while _kc < 256 {
    if _isKeycodeDown(_buf, _kc) {
      _ks = _keycodeToKeysym(_dpy, _kc)
      if _ks != 0 {
        _n = _keysymToName(_ks)
        if #_n > 0 {
          _found = false
          for _existing in _result {
            if _existing == _n { _found = true }
          }
          if !_found { _result.push(_n) }
        }
      }
    }
    _kc = _kc + 1
  }
  ffi.free(_buf)
  _closeDisplay(_dpy)
  _result
}

fn press(name) {
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  _fakeKey(_dpy, _kc, 1)
  _closeDisplay(_dpy)
  true
}

fn release(name) {
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  _fakeKey(_dpy, _kc, 0)
  _closeDisplay(_dpy)
  true
}

fn tap(name, ms) {
  if ms == null { ms = 50 }
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  ffi.call(_XTestFakeKeyEvent, "int32", ["pointer", "uint64", "int32", "uint64"], _dpy, _kc, 1, 0)
  ffi.call(_XFlush, "int32", _t_p, _dpy)
  if ms > 0 { time.sleep(ms) }
  ffi.call(_XTestFakeKeyEvent, "int32", ["pointer", "uint64", "int32", "uint64"], _dpy, _kc, 0, 0)
  ffi.call(_XFlush, "int32", _t_p, _dpy)
  _closeDisplay(_dpy)
  true
}

fn type(text) {
  if text == null || #text == 0 { return }
  _dpy = _openDisplay()
  if _dpy == 0 { return }
  _shift_kc = _keysymToKeycode(_dpy, _XK_Shift_L)
  _i = 0
  while _i < #text {
    _ch = text[_i:_i + 1]
    _ks = _charToKeysym(_ch)
    if _ks == 0 { _i = _i + 1; continue }
    _kc = _keysymToKeycode(_dpy, _ks)
    if _kc == 0 { _i = _i + 1; continue }
    _needShift = _charNeedsShift(_ch)
    if _needShift && _shift_kc != 0 {
      _fakeKey(_dpy, _shift_kc, 1)
    }
    ffi.call(_XTestFakeKeyEvent, "int32", ["pointer", "uint64", "int32", "uint64"], _dpy, _kc, 1, 0)
    ffi.call(_XFlush, "int32", _t_p, _dpy)
    ffi.call(_XTestFakeKeyEvent, "int32", ["pointer", "uint64", "int32", "uint64"], _dpy, _kc, 0, 0)
    ffi.call(_XFlush, "int32", _t_p, _dpy)
    if _needShift && _shift_kc != 0 {
      _fakeKey(_dpy, _shift_kc, 0)
    }
    time.sleep(10)
    _i = _i + 1
  }
  _closeDisplay(_dpy)
}

fn grab(name, modifiers) {
  if modifiers == null { modifiers = 0 }
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  _root = _rootWindow(_dpy)
  _ret = ffi.call(_XGrabKey, "int32", ["pointer", "uint64", "uint64", "uint64", "int32", "int32", "int32"], _dpy, _kc, modifiers, _root, 0, 0, 0)
  ffi.call(_XFlush, "int32", _t_p, _dpy)
  _closeDisplay(_dpy)
  _ret == 0
}

fn ungrab(name, modifiers) {
  if modifiers == null { modifiers = 0 }
  _ks = _nameToKeysym(name)
  if _ks == 0 { return false }
  _dpy = _openDisplay()
  if _dpy == 0 { return false }
  _kc = _keysymToKeycode(_dpy, _ks)
  if _kc == 0 {
    _closeDisplay(_dpy)
    return false
  }
  _root = _rootWindow(_dpy)
  ffi.call(_XUngrabKey, "int32", ["pointer", "uint64", "uint64", "uint64"], _dpy, _kc, modifiers, _root)
  ffi.call(_XFlush, "int32", _t_p, _dpy)
  _closeDisplay(_dpy)
  true
}

fn leds() {
  _dpy = _openDisplay()
  if _dpy == 0 { return {caps: false, num: false, scroll: false} }
  _state = ffi.allocBytes(40)
  ffi.call(_XkbGetState, "int32", ["pointer", "uint64", "pointer"], _dpy, 256, _state)
  _locked = ffi.get_u16(ffi.ptr_add(_state, 12))
  ffi.free(_state)
  _closeDisplay(_dpy)
  ({caps: (_locked & 2) != 0, num: (_locked & 16) != 0, scroll: (_locked & 4) != 0})
}
