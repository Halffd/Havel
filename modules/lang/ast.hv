// --- AST utilities ---

fn isNode(v) {
    if v == null: false
    else if type(v) != "object": false
    else if v.kind == null: false
    else: NODE_TYPES[v.kind] != null

}
fn nodeKind(v) {
    result = null
    if isNode(v) {
        result = v.kind
    }
    result

}
// --- Pretty printer ---

fn _indent(depth) {
    s = ""
    i = 0
    while i < depth {
        s = s + " "
        i = i + 1
    }
    s

}
fn _fmtVal(v) {
    result = null
    if v == null {
        result = "null"
    }
    else if v.kind == "NumberLiteral" {
        result = str(v.value)
    }
    else if v.kind == "StringLiteral" {
        result = "\"" + v.value + "\""
    }
    else if v.kind == "BooleanLiteral" {
        if v.value {
            result = "true"
        }
        else {
            result = "false"
        }
    }
    else if v.kind == "NullLiteral" {
        result = "null"
    }
    else if v.kind == "Identifier" {
        result = v.name
    }
    result

}
fn prettyPrint(node, depth) {
    if node == null {
        print(_indent(depth) + "null")
        return

    }
    if type(node) == "array" {
        for s in node {
            prettyPrint(s, depth)
        }
        return

    }
    prefix = _indent(depth)
    k = node.kind

    if k == "Program" {
        print(prefix + "Program:")
        for s in node.body {
            prettyPrint(s, depth + 1)

        }
    }
    else if k == "BlockStatement" {
        print(prefix + "Block:")
        for s in node.body {
            prettyPrint(s, depth + 1)

        }
    }
    else if k == "ExpressionStatement" {
        print(prefix + "ExprStmt:")
        prettyPrint(node.expr, depth + 1)

    }
    else if k == "NumberLiteral" {
        print(prefix + "Num(" + str(node.value) + ")")

    }
    else if k == "StringLiteral" {
        print(prefix + "Str(\"" + node.value + "\")")

    }
    else if k == "BooleanLiteral" {
        print(prefix + "Bool(" + str(node.value) + ")")

    }
    else if k == "NullLiteral" {
        print(prefix + "Null")

    }
    else if k == "Identifier" {
        print(prefix + "Id(" + node.name + ")")

    }
    else if k == "BinaryExpression" {
        print(prefix + "Bin(" + node.oper + "):")
        prettyPrint(node.left, depth + 1)
        prettyPrint(node.right, depth + 1)

    }
    else if k == "UnaryExpression" {
        print(prefix + "Unary(" + node.oper + "):")
        prettyPrint(node.operand, depth + 1)

    }
    else if k == "UpdateExpression" {
        pre = "pre"
        if !node.prefix: pre = "post"
        print(prefix + "Update(" + node.oper + " " + pre + "):")
        prettyPrint(node.operand, depth + 1)

    }
    else if k == "CallExpression" {
        print(prefix + "Call:")
        prettyPrint(node.callee, depth + 1)
        if node.args.len > 0 {
            print(_indent(depth + 1) + "args:")
            for a in node.args {
                prettyPrint(a, depth + 2)

            }
        }
    }
    else if k == "MemberExpression" {
        print(prefix + "Member(.):")
        prettyPrint(node.obj, depth + 1)
        print(_indent(depth + 1) + "." + node.property)

    }
    else if k == "IndexExpression" {
        print(prefix + "Index([]):")
        prettyPrint(node.obj, depth + 1)
        prettyPrint(node.index, depth + 1)

    }
    else if k == "AssignmentExpression" {
        print(prefix + "Assign:")
        prettyPrint(node.target, depth + 1)
        prettyPrint(node.value, depth + 1)

    }
    else if k == "CompoundAssignment" {
        print(prefix + "CompoundAssign(" + node.oper + "):")
        prettyPrint(node.target, depth + 1)
        prettyPrint(node.value, depth + 1)

    }
    else if k == "ArrayLiteral" {
        print(prefix + "Array:")
        for e in node.elements {
            prettyPrint(e, depth + 1)

        }
    }
    else if k == "ObjectLiteral" {
        print(prefix + "Object:")
        for f in node.fields {
            if f.kind == "ObjectField" {
                print(_indent(depth + 1) + f.key + ":")
                prettyPrint(f.value, depth + 2)

            }
        }
    }
  else if k == "SpreadExpression" {
    print(prefix + "Spread:")
    prettyPrint(node.value, depth + 1)

  }
  else if k == "WildcardPattern" {
    print(prefix + "_")
  }
  else if k == "ArrayPattern" {
    print(prefix + "ArrayPattern:")
    if node.elements != null {
      for el in node.elements { prettyPrint(el, depth + 1) }
    }
    if node.rest != null {
      print(_indent(depth + 1) + "rest:")
      prettyPrint(node.rest, depth + 2)
    }
  }
  else if k == "ObjectPattern" {
    print(prefix + "ObjectPattern:")
    if node.properties != null {
      for prop in node.properties {
        print(_indent(depth + 1) + str(prop.key) + ":")
        prettyPrint(prop.value, depth + 2)
      }
    }
    if node.rest != null {
      print(_indent(depth + 1) + "rest:")
      prettyPrint(node.rest, depth + 2)
    }
  }
  else if k == "ConstructorPattern" {
    print(prefix + "ConstructorPattern(" + str(node.name) + "):")
    if node.args != null {
      for a in node.args { prettyPrint(a, depth + 1) }
    }
  }
  else if k == "OrPattern" {
    print(prefix + "OrPattern:")
    if node.alternatives != null {
      for alt in node.alternatives { prettyPrint(alt, depth + 1) }
    }
  }
  else if k == "RangePattern" {
    print(prefix + "RangePattern:")
    prettyPrint(node.start, depth + 1)
    print(_indent(depth + 1) + "..=")
    prettyPrint(node.end, depth + 1)
  }
    else if k == "IfStatement" {
        print(prefix + "If:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "then:")
        prettyPrint(node.then, depth + 2)
        if node.else != null {
            print(_indent(depth + 1) + "else:")
            prettyPrint(node.else, depth + 2)

        }
    }
    else if k == "WhileStatement" {
        print(prefix + "While:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "body:")
        prettyPrint(node.body, depth + 2)

    }
else if k == "ForStatement" {
print(prefix + "For(" + node.name + " in):")
prettyPrint(node.iterator, depth + 1)
print(_indent(depth + 1) + "body:")
prettyPrint(node.body, depth + 2)

}
else if k == "ForExpression" {
print(prefix + "ForExpression:")
print(_indent(depth + 1) + "expr:")
prettyPrint(node.expr, depth + 2)
print(_indent(depth + 1) + "binding: " + node.binding)
print(_indent(depth + 1) + "iterable:")
prettyPrint(node.iterable, depth + 2)

    }
    else if k == "LoopStatement" {
        print(prefix + "Loop:")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "RepeatStatement" {
        print(prefix + "Repeat:")
        prettyPrint(node.count, depth + 1)
        print(_indent(depth + 1) + "body:")
        prettyPrint(node.body, depth + 2)

    }
    else if k == "BreakStatement" {
        print(prefix + "Break")

    }
    else if k == "ContinueStatement" {
        print(prefix + "Continue")

    }
    else if k == "FnDeclaration" {
        params = node.params.join(", ")
        print(prefix + "Fn(" + node.name + "(" + params + ")):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "LambdaExpression" {
        params = node.params.join(", ")
        name = ""
        if node.name != null { name = " " + node.name }
        print(prefix + "Lambda(" + name + params + "):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "ReturnStatement" {
        print(prefix + "Return:")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "LetDeclaration" {
        print(prefix + "Let(" + node.name + "):")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "ValDeclaration" {
        print(prefix + "Val(" + node.name + "):")
        if node.value != null {
            prettyPrint(node.value, depth + 1)

        }
    }
    else if k == "UseStatement" {
        names = ""
        if node.names != null and node.names.len > 0 {
            names = " {" + node.names.join(", ") + "}"
        }
        print(prefix + "Use(" + node.module + names + ")")

    }
    else if k == "ImportStatement" {
        names = ""
        if node.names != null and node.names.len > 0 {
            names = " {" + node.names.join(", ") + "}"
        }
        print(prefix + "Import(" + node.module + names + ")")

    }
	else if k == "HotkeyBinding" {
 attr = ""
 if node.mode != null && node.mode != "" { attr += " mode=" + node.mode }
 if node.policy != null && node.policy != "" { attr += " policy=" + node.policy
 keyStr = ""
 if node.hotkeys != null && #node.hotkeys > 0 {
  for h in node.hotkeys {
   if keyStr != "": keyStr += ", "
   if type(h) == "str": keyStr += h
   else if h.kind == "HotkeyLiteral": keyStr += h.combination
   else: keyStr += str(h)
  }
 }
 else if node.key != null { keyStr = node.key }
 print(prefix + "Hotkey(" + keyStr + attr + "):")
 actionNode = node.action != null ? node.action : node.body
 prettyPrint(actionNode, depth + 1)

	}
    else if k == "BacktickExpression" {
        print(prefix + "Backtick(`" + node.command + "`)")

    }
    else if k == "ShellCommand" {
        cap = "$"
        if node.capture: cap = "$!"
        print(prefix + "Shell(" + cap + " " + node.command + ")")

    }
    else if k == "RangeExpression" {
        rdot = ".."
        if node.inclusive: rdot = "..="
        print(prefix + "Range(" + rdot + "):")
        prettyPrint(node.start, depth + 1)
        prettyPrint(node.end, depth + 1)

    }
    else if k == "TernaryExpression" {
        print(prefix + "Ternary:")
        print(_indent(depth + 1) + "cond:")
        prettyPrint(node.condition, depth + 2)
        print(_indent(depth + 1) + "true:")
        prettyPrint(node.true_expr, depth + 2)
        print(_indent(depth + 1) + "false:")
        prettyPrint(node.false_expr, depth + 2)

    }
    else if k == "PipelineExpression" {
        print(prefix + "Pipeline(|>):")
        prettyPrint(node.left, depth + 1)
        prettyPrint(node.right, depth + 1)

    }
    else if k == "ThrowStatement" {
        print(prefix + "Throw:")
        prettyPrint(node.value, depth + 1)

    }
    else if k == "TryStatement" {
        print(prefix + "Try:")
        prettyPrint(node.try_block, depth + 1)
        if node.catch_param != null {
            print(_indent(depth + 1) + "catch(" + node.catch_param + "):")
            prettyPrint(node.catch_block, depth + 2)
        }
        if node.finally_block != null {
            print(_indent(depth + 1) + "finally:")
            prettyPrint(node.finally_block, depth + 2)

        }
    }
    else if k == "MatchExpression" {
        print(prefix + "Match:")
        prettyPrint(node.subject, depth + 1)
        for c in node.cases {
            prettyPrint(c, depth + 1)

        }
    }
    else if k == "MatchCase" {
        print(prefix + "Case:")
        prettyPrint(node.pattern, depth + 1)
        if node.guard != null {
            print(_indent(depth + 1) + "when:")
            prettyPrint(node.guard, depth + 2)
        }
        prettyPrint(node.body, depth + 1)

    }
    else if k == "InterpolatedString" {
        print(prefix + "InterpStr:")
        for p in node.parts {
            prettyPrint(p, depth + 1)

        }
    }
    else if k == "RegexLiteral" {
        print(prefix + "Regex(/" + node.pattern + "/" + node.flags + ")")

    }
    else if k == "AtExpression" {
        print(prefix + "At(." + node.field + ")")

    }
    else if k == "AtAtExpression" {
        print(prefix + "AtAt(." + node.field + ")")

    }
    else if k == "ConfigBlock" {
        print(prefix + "Config(" + node.name + "):")
        prettyPrint(node.body, depth + 1)

    }
    else if k == "EnumDeclaration" {
        variants = ""
        for v in node.variants {
            if variants != "" { variants += ", " }
            variants += v.name
            if v.payloadType != null { variants += "(" + str(v.payloadType) + ")" }
        }
        print(prefix + "Enum(" + node.name + " { " + variants + " })")
    }
    else if k == "TraitDeclaration" {
        print(prefix + "Trait(" + node.name + "):")
        for m in node.methods {
            params = ""
            if m.params != null { params = m.params.join(", ") }
            print(_indent(depth + 1) + "fn " + m.name + "(" + params + ")")
            if m.body != null { prettyPrint(m.body, depth + 2) }
        }
    }
    else if k == "ProtocolDeclaration" {
        print(prefix + "Protocol(" + node.name + "):")
        for m in node.methods {
            params = ""
            if m.params != null { params = m.params.join(", ") }
            print(_indent(depth + 1) + "fn " + m.name + "(" + params + ")")
            if m.body != null { prettyPrint(m.body, depth + 2) }
        }
    }
    else if k == "ImplDeclaration" {
        if node.traitName != null && node.traitName != "" {
            print(prefix + "Impl(" + node.typeName + " for " + node.traitName + "):")
        } else {
            print(prefix + "Impl(" + node.typeName + "):")
        }
        for f in node.funcs {
            prettyPrint(f, depth + 1)
        }
    }
    else if k == "ClassDeclaration" {
        print(prefix + "Class(" + node.name + "):")
        for m in node.methods {
            params = ""
            if m.params != null { params = m.params.join(", ") }
            print(_indent(depth + 1) + "fn " + m.name + "(" + params + ")")
            if m.body != null { prettyPrint(m.body, depth + 2) }
        }
        for f in node.fields {
            print(_indent(depth + 1) + "field " + f)
        }
    }
    else if k == "StructDeclaration" {
        print(prefix + "Struct(" + node.name + "):")
        for f in node.fields {
            print(_indent(depth + 1) + "field " + f)
        }
    }
else if k == "SleepStatement" {
	print(prefix + "Sleep:")
	prettyPrint(node.duration, depth + 1)

}
else if k == "DeferStatement" {
	print(prefix + "Defer:")
	prettyPrint(node.expression, depth + 1)

}
else if k == "WaitExpression" {
	print(prefix + "Wait:")
	prettyPrint(node.target, depth + 1)

}
else if k == "WaitGroupExpression" {
	print(prefix + "WaitGroup()")

}
    else if k == "ErrorNode" {
        print(prefix + "ERROR: " + node.msg)

    }
    else if k == "CastExpression" {
        print(prefix + "Cast(" + node.targetType + "):")
        prettyPrint(node.expr, depth + 1)
    }
else if k == "HotkeyLiteral" {
 print(prefix + "HotkeyLiteral(" + node.combination + ")")
 }
 else if k == "HotkeyExpression" {
 if node.key != null && type(node.key) != "str" && node.key.kind == "HotkeyBinding" {
  print(prefix + "HotkeyExpr:")
  prettyPrint(node.key, depth + 1)
 }
 else {
  print(prefix + "Hotkey(" + node.key + ")")
 }
 }
    else if k == "DoWhileStatement" {
        print(prefix + "DoWhile:")
        prettyPrint(node.body, depth + 1)
        prettyPrint(node.condition, depth + 1)
    }
    else if k == "WhenBlock" {
        print(prefix + "When:")
        prettyPrint(node.condition, depth + 1)
        prettyPrint(node.body, depth + 1)
    }
else if k == "WithStatement" {
print(prefix + "With:")
prettyPrint(node.object, depth + 1)
if node.alias != null { print(prefix + " as " + node.alias.name) }
prettyPrint(node.body, depth + 1)
}
    else if k == "OnModeStatement" {
        print(prefix + "OnMode(" + node.modeName + "):")
        prettyPrint(node.body, depth + 1)
    }
    else if k == "OffModeStatement" {
        print(prefix + "OffMode(" + node.modeName + "):")
        prettyPrint(node.body, depth + 1)
    }
    else if k == "OnReloadStatement" {
        print(prefix + "OnReload:")
        prettyPrint(node.body, depth + 1)
    }
    else if k == "OnStartStatement" {
        print(prefix + "OnStart:")
        prettyPrint(node.body, depth + 1)
    }
    else if k == "ModesBlock" {
        print(prefix + "Modes:")
        for m in node.modes { prettyPrint(m, depth + 1) }
    }
 else if k == "ModeBlock" {
  print(prefix + "ModeBlock(" + node.modeName + "):")
  if node.statements != null {
   for s in node.statements { prettyPrint(s, depth + 1) }
  }
 }    else if k == "ModeDefinition" {
        print(prefix + "Mode(" + node.name + "):")
        if node.condition != null { prettyPrint(node.condition, depth + 1) }
        if node.enter != null { prettyPrint(node.enter, depth + 1) }
        if node.exit != null { prettyPrint(node.exit, depth + 1) }
    }
    else if k == "DecoratorStatement" {
        print(prefix + "Decorator:")
        prettyPrint(node.target, depth + 1)
    }
    else if k == "MultipleAssignment" {
        print(prefix + "MultiAssign:")
        prettyPrint(node.value, depth + 1)
    }
    else if k == "QueryExpression" {
        print(prefix + "Query(" + node.varName + "):")
        prettyPrint(node.source, depth + 1)
    }
    else if k == "ConfigSection" {
        print(prefix + "Config(" + node.sectionName + "):")
    }
else if k == "InputStatement" {
print(prefix + "Input:")
}
else if k == "GoStatement" {
print(prefix + "Go:")
prettyPrint(node.call, depth + 1)
}
else if k == "WaitStatement" {
print(prefix + "Wait:")
prettyPrint(node.condition, depth + 1)
}
else {
        print(prefix + "Unknown(" + k + ")")

    }
}
}
