BINARY_OPS = {
    "+": "+", "-": "-", "*": "*", "/": "/", "%": "%",
    "**": "**", "\\": "\\", "\\\\": "\\\\", "%%": "%%",
    "==": "==", "!=": "!=", "<": "<", ">": ">",
    "<=": "<=", ">=": ">=",
    "&&": "&&", "||": "||",
    "&": "&", "|": "|", "^": "^", "<<": "<<", ">>": ">>",
    "??": "??",
    "in": "in", "is": "is", "matches": "matches", "not in": "not in",
}

COMPOUND_ASSIGN_OPS = {
    "+=": "+=", "-=": "-=", "*=": "*=", "/=": "/=", "%=": "%=",
    "**=": "**=", "\\=": "\\=", "%%=": "%%=",
    "&=": "&=", "|=": "|=", "^=": "^=",
    "<<=": "<<=", ">>=": ">>=",
}

UNARY_OPS = {
  "-": "-", "!": "!", "not": "not", "#": "#", "~": "~",
}

fn Program(body, line, col) {
    {kind: "Program", line: line, col: col, body: body}

}
fn BlockStatement(body, line, col) {
    {kind: "BlockStatement", line: line, col: col, body: body}

}
