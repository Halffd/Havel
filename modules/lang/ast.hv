fn TryStatement(try_block, catch_param, catch_block, finally_block, line, col) {
    {kind: "TryStatement", line: line, col: col, try_block: try_block, catch_param: catch_param, catch_block: catch_block, finally_block: finally_block}

}
fn MatchExpression(subject, cases, line, col) {
  n = {kind: "MatchExpression", line: line, col: col, subject: subject, cases: cases}
  if subject != null {
    if subject.kind != null {
      n.discriminants = [subject]
    }
    else {
      n.discriminants = subject
    }
  }
  n
}
fn MatchCase(pattern, guard, body, line, col) {
  n = {kind: "MatchCase", line: line, col: col, pattern: pattern, guard: guard, body: body}
  if pattern != null && pattern.kind == null {
    n.patterns = pattern
  }
  else {
    n.patterns = [pattern]
  }
  n
}
