      // x | obj.method → pipeVal.method()
      bc.emit("LOAD_VAR", pipeSlot)
      propIdx = bc.add_chunk_string(right.property)
      bc.emit("CALL_METHOD", bc.str_id(propIdx), 0)
    }
    else {
      // Default: call right with pipe value as argument
      emitExpr(emitter, right)
      bc.emit("LOAD_VAR", pipeSlot)
      bc.emit("CALL", 1)
    }
    // Store result back to pipe slot for chained pipelines
    bc.emit("DUP")
    bc.emit("STORE_VAR", pipeSlot)
    return

  }
  if k == "RegexLiteral" {
    // Emit regex as a string constant, tagged for runtime
    idx = bc.add_string(node.pattern)
    bc.emit("LOAD_CONST", idx)
    return

  }
if k == "AtExpression" {
  if node.field != null {
    fname = node.field
    if fname.kind == "Identifier" { fname = fname.name }
    bc.emit("LOAD_VAR", 0)
    keyIdx = bc.add_string(fname)
    bc.emit("LOAD_CONST", keyIdx)
    bc.emit("OBJECT_GET")
    directives = {"disable": true, "enable": true, "remove": true, "toggle": true}
    if directives[fname] != null {
      bc.emit("CALL", 0)
    }
  }
  else {
    emitError("@ expression field must be identifier", node.line, node.col)
  }
  return
}
    if k == "AtAtExpression" {
        if node.field != null {
            fname = node.field
            if type(fname) == "object" && fname.kind == "Identifier" { fname = fname.name }
            name = "__static__" + fname
            sid = globalIdx(emitter, name)
            bc.emit("LOAD_GLOBAL", bc.str_id(sid))
        }
        else {
            emitError("@@ expression field must be identifier", node.line, node.col)
        }
        return
    }
    if k == "CastExpression" {

        emitExpr(emitter, node.expr)
        typeIdx = bc.add_chunk_string(node.typeName)
        bc.emit("PROT_CAST", bc.str_id(typeIdx))
        return
    }

	if k == "ShellCommand" {
		// Shell command: $cmd or $!cmd
		// Emit as call to run() or runCapture() host functions
		if node.capture {
			sid = globalIdx(emitter, "runCapture")
		}
		else {
			sid = globalIdx(emitter, "run")
		}
		bc.emit("LOAD_GLOBAL", bc.str_id(sid))
		cmdIdx = bc.add_string(node.command)
		bc.emit("LOAD_CONST", cmdIdx)
		bc.emit("CALL", 1)
		// Handle pipe chain: $! cmd1 | cmd2 | ...
		next = node.next
		while next != null {
			sid = globalIdx(emitter, "run")
			bc.emit("LOAD_GLOBAL", bc.str_id(sid))
			if next.command != null {
				cmdIdx = bc.add_string(next.command)
				bc.emit("LOAD_CONST", cmdIdx)
				bc.emit("CALL", 1)
				bc.emit("POP")
			}
			next = next.next
		}
		return

	}
	if k == "BacktickExpression" {
		// Backtick: `cmd` — same as ShellCommand without capture
		sid = globalIdx(emitter, "run")
		bc.emit("LOAD_GLOBAL", bc.str_id(sid))
		cmdIdx = bc.add_string(node.command)
		bc.emit("LOAD_CONST", cmdIdx)
		bc.emit("CALL", 1)
		return

  }
  if k == "MatchExpression" {
    emitMatchExpr(emitter, node)
    return

  }
    if k == "SetLiteral" {
        bc.emit("SET_NEW")
        for el in node.elements {
            bc.emit("DUP")
            bc.emit("LOAD_CONST", bc.add_const(true))
            emitExpr(emitter, el)
            bc.emit("SET_SET")
        }
        return

    }
if k == "ThrowStatement" {
	if node.value != null {
		emitExpr(emitter, node.value)
	}
	else {
		bc.emit("PUSH_NULL")
	}
	bc.emit("THROW")
	bc.emit("PUSH_NULL")
	return
}
if k == "WaitExpression" {
	emitExpr(emitter, node.target)
	bc.emit("THREAD_JOIN")
	return
}
  if k == "WaitGroupExpression" {
    bc.emit("WAITGROUP_NEW")
    return
  }
  if k == "ThisExpression" {
    if emitter.currentClassName != null && emitter.currentClassName != "" {
      bc.emit("LOAD_VAR", 0)
    }
    else {
      bc.emit("LOAD_GLOBAL", bc.str_id(globalIdx(emitter, "this")))
    }
    return
  }
  if k == "TupleExpression" {
    bc.emit("ARRAY_NEW")
    if node.elements != null {
      for el in node.elements {
        if el != null {
          emitExpr(emitter, el)
        }
        else {
          bc.emit("PUSH_NULL")
        }
        bc.emit("ARRAY_PUSH")
      }
    }
    bc.emit("ARRAY_FREEZE")
    return
  }
  if k == "BlockExpression" {
    if node.body != null {
      for s in node.body {
        emitStmt(emitter, s)
        if s.kind == "ExpressionStatement" {
          bc.emit("POP")
        }
      }
    }
    if node.value != null {
      emitExpr(emitter, node.value)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    return
  }
  if k == "IfExpression" {
    emitExpr(emitter, node.condition)
    elseJump = bc.emit("JUMP_IF_FALSE", 0)
    if node.then != null {
      emitBlockWithReturn(emitter, node.then)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    endJump = bc.emit("JUMP", 0)
    bc.patch_jump(elseJump, bc.instr_count())
    elseBranch = node["else"]
    if elseBranch != null {
      emitBlockWithReturn(emitter, elseBranch)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    bc.patch_jump(endJump, bc.instr_count())
    return
  }
  if k == "ThreadExpression" {
    sid = globalIdx(emitter, "thread.spawn")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    emitClosureBody(emitter, node.body, "<thread>")
    bc.emit("CALL", 1)
    return
  }
  if k == "GoExpression" {
    sid = globalIdx(emitter, "thread_spawn")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    if node.call != null {
      emitExpr(emitter, node.call)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    bc.emit("CALL", 1)
    return
  }
  if k == "YieldExpression" {
    if node.value != null {
      emitExpr(emitter, node.value)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    bc.emit("YIELD")
    return
  }
  if k == "AwaitExpression" {
    if node.argument != null {
      if node.argument.kind == "CallExpression" {
        callee = node.argument.callee
        if callee.kind == "Identifier" && callee.name == "sleep" {
          if #node.argument.args == 1 {
            emitExpr(emitter, node.argument.args[0])
            bc.emit("FIBER_SLEEP")
            return
          }
        }
      }
      emitExpr(emitter, node.argument)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    bc.emit("FIBER_AWAIT")
    return
  }
if k == "ChannelExpression" {
  sid = globalIdx(emitter, "channel.new")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  bc.emit("CALL", 0)
  return
}
if k == "AsyncExpression" {
  sid = globalIdx(emitter, "thread_spawn")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  if node.body != null {
    if node.body.kind == "BlockStatement" {
      block = node.body
      lam = LambdaExpression([], block, node.line, node.col)
      emitExpr(emitter, lam)
    }
    else if node.body.kind == "FnDeclaration" {
      // async fn name() → compile as closure
      fnDecl = node.body
      result = compileFuncDecl(emitter, fnDecl.name, fnDecl.params, fnDecl.body, -1, fnDecl.line)
      upcount = result[0]
      chunkIdx = result[1]
      emitter.func_map[fnDecl.name] = chunkIdx
      if upcount > 0 { bc.emit("CLOSURE", chunkIdx) }
      else {
        fnObj = bc.make_function_obj(chunkIdx)
        fnConstIdx = bc.add_const(fnObj)
        bc.emit("LOAD_CONST", fnConstIdx)
      }
    }
    else { emitStmt(emitter, node.body) }
  }
  else { bc.emit("PUSH_NULL") }
  bc.emit("CALL", 1)
  return
}
  if k == "IntervalExpression" {
    sid = globalIdx(emitter, "interval.start")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    if node.intervalMs != null {
      emitExpr(emitter, node.intervalMs)
    }
    else {
      bc.emit("LOAD_CONST", bc.add_const(0))
    }
    emitClosureBody(emitter, node.body, "<interval>")
    bc.emit("CALL", 2)
    return
  }
  if k == "UpdateBlockExpression" {
    sid = globalIdx(emitter, "update")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    if node.intervalMs != null {
      emitExpr(emitter, node.intervalMs)
    }
    else {
      bc.emit("LOAD_CONST", bc.add_const(0))
    }
    emitClosureBody(emitter, node.body, "<update>")
    bc.emit("CALL", 2)
    return
  }
  if k == "TimeoutExpression" {
    sid = globalIdx(emitter, "timeout.start")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    if node.delayMs != null {
      emitExpr(emitter, node.delayMs)
    }
    else {
      bc.emit("LOAD_CONST", bc.add_const(0))
    }
    emitClosureBody(emitter, node.body, "<timeout>")
    bc.emit("CALL", 2)
    return
  }
if k == "HotkeyLiteral" {
 idx = bc.add_string(node.combination)
 bc.emit("LOAD_CONST", idx)
    return
  }
  if k == "CharLiteral" {
    bc.emit("LOAD_CONST", bc.add_const(node.value))
    return
  }
  if k == "TryExpression" {
    emitTryExpr(emitter, node)
    return
  }
  if k == "GetInputExpression" {
    if node.timeout != null {
      sid = globalIdx(emitter, "get_input")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      emitExpr(emitter, node.timeout)
      bc.emit("CALL", 1)
    }
    else {
      sid = globalIdx(emitter, "get_input")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      bc.emit("CALL", 0)
    }
    return
  }
  emitError("unsupported expr: " + k, node.line, node.col)
  bc.emit("PUSH_NULL")

}

fn emitDel(emitter, node) {
  k = node.kind
  if k == "Identifier" {
    binding = scopeResolve(emitter.scope, node.name)
    if binding != null && binding.kind == "local" {
      bc.emit("PUSH_NULL")
      bc.emit("STORE_VAR", binding.slot)
    } else if binding != null && binding.kind == "upvalue" {
      emitError("cannot del upvalue binding", node.line, node.col)
    } else {
      bc.emit("PUSH_NULL")
      bc.emit("STORE_GLOBAL", node.name)
    }
    return
  }
  if k == "MemberExpression" {
    emitExpr(emitter, node.obj)
    keyIdx = bc.add_string(node.property)
    bc.emit("LOAD_CONST", keyIdx)
    bc.emit("OBJECT_DELETE")
    return
  }
  if k == "IndexExpression" {
    emitExpr(emitter, node.obj)
    emitExpr(emitter, node.index)
    bc.emit("ARRAY_DEL")
    return
  }
  emitError("del target must be identifier, member, or index", node.line, node.col)
}

// ============================================================
// Statement emission
// ============================================================

fn emitStmt(emitter, node) {
  if node == null {
    return
  }
  if node.line != null {
    bc.set_source(node.line, node.col)
  }
  k = node.kind

    // ForStatement handler (inlined emitExpr for iterator to work around arg passing bug)
if k == "ForStatement" {
iterNameRaw = node.name
iterName = iterNameRaw
if iterNameRaw.kind == "Identifier" {
iterName = iterNameRaw.name
}
iterNode = node.iterator
if iterNode.kind == "RangeExpression" {
emitExpr(emitter, iterNode.start)
emitExpr(emitter, iterNode.end)
if iterNode.step != null {
emitExpr(emitter, iterNode.step)
bc.emit("RANGE_STEP_NEW")
} else {
bc.emit("RANGE_NEW")
}
}
if iterNode.kind != "RangeExpression" {
emitExpr(emitter, iterNode)
}
bc.emit("STRING_PROMOTE")
	// Push loop scope AFTER evaluating iterable
	oldScope = emitter.scope
    loopScope = Scope(oldScope, null, null)
	emitter.scope = loopScope
	// Store iterable in temp slot
	iterableIdx = scopeDeclare(loopScope, "__iterable__")
	bc.emit("STORE_VAR", iterableIdx)
	// Create iterator
	bc.emit("LOAD_VAR", iterableIdx)
	bc.emit("ITER_NEW")
	iterIdx = scopeDeclare(loopScope, "__iter__")
	bc.emit("STORE_VAR", iterIdx)
	// Loop start
	localIdx = scopeDeclare(loopScope, iterName)
	loopTop = bc.instr_count()
	emitter.breakStack.push([])
	emitter.continueStack.push(loopTop)
	// Call ITER_NEXT
	bc.emit("LOAD_VAR", iterIdx)
	bc.emit("ITER_NEXT")
	// Store result in temp
	resultIdx = scopeDeclare(loopScope, "__result__")
	bc.emit("STORE_VAR", resultIdx)
// Check result.done
bc.emit("LOAD_VAR", resultIdx)
doneSid = bc.str_id(bc.add_chunk_string("done"))
bc.emit("LOAD_CONST", bc.add_const(doneSid))
bc.emit("OBJECT_GET")
      doneJump = bc.emit("JUMP_IF_TRUE", 0)
      // Check if keyVar is set (for a, b in arr => keyVar=a, name=b)
      keyVar = node.keyVar
      hasKeyVar = keyVar != null
      if hasKeyVar {
        // Get result.first (the key/index)
        bc.emit("LOAD_VAR", resultIdx)
        firstSid = bc.str_id(bc.add_chunk_string("first"))
        bc.emit("LOAD_CONST", bc.add_const(firstSid))
        bc.emit("OBJECT_GET")
        keyIdx = scopeDeclare(loopScope, keyVar)
        bc.emit("STORE_VAR", keyIdx)
      }
      // Get result.second (the value)
      bc.emit("LOAD_VAR", resultIdx)
      secondSid = bc.str_id(bc.add_chunk_string("second"))
      bc.emit("LOAD_CONST", bc.add_const(secondSid))
      bc.emit("OBJECT_GET")
      bc.emit("STORE_VAR", localIdx)
	// Body
	emitBlock(emitter, node.body)
	// Loop back
	bc.emit("JUMP", loopTop)
	// Exit
	bc.patch_jump(doneJump, bc.instr_count())
	bc.emit("PUSH_NULL")
	// Patch break jumps
	breakTarget = bc.instr_count()
	breakList = emitter.breakStack[#emitter.breakStack - 1]
	i = 0
	while i < #breakList:
		bc.patch_jump(breakList[i], breakTarget)
		i = i + 1
	emitter.breakStack.pop()
	emitter.continueStack.pop()
	// Propagate scope count to parent
	oldScope.count = loopScope.count
	emitter.scope = oldScope
	return
}

	if k == "ExpressionStatement" {
		if node.isDel {
			emitDel(emitter, node.expr)
			return
		}
		emitExpr(emitter, node.expr)
		isYield = node.expr.kind == "YieldExpression"
		if !emitter.inTailPosition && !isYield {
			bc.emit("POP")
		}
		return

	}
	if k == "IfStatement" {
		emitExpr(emitter, node.condition)
		elseJump = bc.emit("JUMP_IF_FALSE", 0)
		elseBranch = node["else"]
		wasTail = emitter.inTailPosition
		if elseBranch != null {
			if wasTail {
				emitter.emittedTailCall = false
			}
			emitBlockWithReturn(emitter, node.then)
			consequenceWasTail = emitter.emittedTailCall
			if wasTail && !consequenceWasTail {
				bc.emit("RETURN")
			}
			endJump = bc.emit("JUMP", 0)
			bc.patch_jump(elseJump, bc.instr_count())
			if wasTail {
				emitter.emittedTailCall = false
			}
			emitBlockWithReturn(emitter, elseBranch)
			alternativeWasTail = emitter.emittedTailCall
			if wasTail && !alternativeWasTail {
				bc.emit("RETURN")
			}
			bc.patch_jump(endJump, bc.instr_count())
			if wasTail {
				emitter.emittedTailCall = consequenceWasTail && alternativeWasTail
			}
		}
		else {
			emitBlockWithReturn(emitter, node.then)
			endJump = bc.emit("JUMP", 0)
			bc.patch_jump(elseJump, bc.instr_count())
			bc.emit("PUSH_NULL")
			bc.patch_jump(endJump, bc.instr_count())
			if wasTail {
				emitter.emittedTailCall = false
			}
		}
		return

	}

    if k == "WhileStatement" {
        loopTop = bc.instr_count()
        emitter.breakStack.push([])
        emitter.continueStack.push(loopTop)
	emitExpr(emitter, node.condition)
	exitJump = bc.emit("JUMP_IF_FALSE", 0)
	// Push scope for body
	oldWhileScope = emitter.scope
	whileScope = Scope(oldWhileScope, null, null)
	emitter.scope = whileScope
	emitBlock(emitter, node.body)
	oldWhileScope.count = whileScope.count
	emitter.scope = oldWhileScope
	bc.emit("JUMP", loopTop)
	bc.patch_jump(exitJump, bc.instr_count())
        // Patch break jumps
        breakTarget = bc.instr_count()
        breakList = emitter.breakStack[#emitter.breakStack - 1]
        i = 0
        while i < #breakList:
            bc.patch_jump(breakList[i], breakTarget)
            i = i + 1
        emitter.breakStack.pop()
	emitter.continueStack.pop()
	return
}
if k == "DoWhileStatement" {
	loopTop = bc.instr_count()
	emitter.breakStack.push([])
	emitter.continueStack.push(loopTop)
	// Push scope for body
	oldScope = emitter.scope
	doScope = Scope(oldScope, null, null)
	emitter.scope = doScope
	emitBlock(emitter, node.body)
	oldScope.count = doScope.count
	emitter.scope = oldScope
	emitExpr(emitter, node.condition)
	bc.emit("JUMP_IF_TRUE", loopTop)
	// Patch break jumps
	breakTarget = bc.instr_count()
	breakList = emitter.breakStack[#emitter.breakStack - 1]
	i = 0
	while i < #breakList:
		bc.patch_jump(breakList[i], breakTarget)
		i = i + 1
	emitter.breakStack.pop()
		emitter.continueStack.pop()
		return
	}

	if k == "LoopStatement" {
	// Check for count-based loop: loop N { ... }
	if node.count != null {
		emitExpr(emitter, node.count)
		countSlot = scopeDeclare(emitter.scope, "__loop_count__")
		bc.emit("STORE_VAR", countSlot)
		counterSlot = scopeDeclare(emitter.scope, "__loop_counter__")
		bc.emit("LOAD_CONST", bc.add_const(0))
		bc.emit("STORE_VAR", counterSlot)
		loopTop = bc.instr_count()
		emitter.breakStack.push([])
		emitter.continueStack.push(loopTop)
		oldLoopScope = emitter.scope
		loopScope = Scope(oldLoopScope)
		emitter.scope = loopScope
		bc.emit("LOAD_VAR", counterSlot)
		bc.emit("LOAD_VAR", countSlot)
		bc.emit("LT")
		endJump = bc.emit("JUMP_IF_FALSE", 0)
		emitBlock(emitter, node.body)
		oldLoopScope.count = loopScope.count
		emitter.scope = oldLoopScope
		bc.emit("LOAD_VAR", counterSlot)
		bc.emit("LOAD_CONST", bc.add_const(1))
		bc.emit("ADD")
		bc.emit("STORE_VAR", counterSlot)
		bc.emit("JUMP", loopTop)
		breakTarget = bc.instr_count()
		bc.patch_jump(endJump, breakTarget)
		breakList = emitter.breakStack[#emitter.breakStack - 1]
		i = 0
		while i < #breakList:
			bc.patch_jump(breakList[i], breakTarget)
			i = i + 1
		emitter.breakStack.pop()
		emitter.continueStack.pop()
		return
	}

	// Check for condition-based loop: loop while condition { ... }
	if node.condition != null {
		loopTop = bc.instr_count()
		emitter.breakStack.push([])
		emitter.continueStack.push(loopTop)
		oldLoopScope = emitter.scope
		loopScope = Scope(oldLoopScope)
		emitter.scope = loopScope
		emitExpr(emitter, node.condition)
		endJump = bc.emit("JUMP_IF_FALSE", 0)
		emitBlock(emitter, node.body)
		oldLoopScope.count = loopScope.count
		emitter.scope = oldLoopScope
		bc.emit("JUMP", loopTop)
		breakTarget = bc.instr_count()
		bc.patch_jump(endJump, breakTarget)
		breakList = emitter.breakStack[#emitter.breakStack - 1]
		i = 0
		while i < #breakList:
			bc.patch_jump(breakList[i], breakTarget)
			i = i + 1
		emitter.breakStack.pop()
		emitter.continueStack.pop()
		return
	}

	// Infinite loop: loop { ... }
	loopTop = bc.instr_count()
	emitter.breakStack.push([])
	emitter.continueStack.push(loopTop)
	oldLoopScope = emitter.scope
	loopScope = Scope(oldLoopScope)
	emitter.scope = loopScope
	emitBlock(emitter, node.body)
	oldLoopScope.count = loopScope.count
	emitter.scope = oldLoopScope
	bc.emit("JUMP", loopTop)
	breakTarget = bc.instr_count()
	breakList = emitter.breakStack[#emitter.breakStack - 1]
	i = 0
	while i < #breakList:
		bc.patch_jump(breakList[i], breakTarget)
		i = i + 1
	emitter.breakStack.pop()
	emitter.continueStack.pop()
	return

}
if k == "RepeatStatement" {
	// repeat count { body } → for i in 0..(count-1) { body }
	bc.emit("LOAD_CONST", bc.add_const(0))
	emitExpr(emitter, node.count)
	bc.emit("LOAD_CONST", bc.add_const(1))
	bc.emit("SUB")
	bc.emit("RANGE_NEW")
	bc.emit("STRING_PROMOTE")
	bc.emit("ITER_NEW")
	// Push scope for loop internals
	oldRepeatScope = emitter.scope
    repeatScope = Scope(oldRepeatScope, null, null)
	emitter.scope = repeatScope
	iterIdx = scopeDeclare(repeatScope, "_repeat_iter")
	bc.emit("STORE_VAR", iterIdx)
	_dummyIdx = scopeDeclare(repeatScope, "_repeat_i")
	loopTop = bc.instr_count()
	emitter.breakStack.push([])
	emitter.continueStack.push(loopTop)
	bc.emit("LOAD_VAR", iterIdx)
	bc.emit("ITER_NEXT")
	resultIdx = scopeDeclare(repeatScope, "_repeat_result")
	bc.emit("STORE_VAR", resultIdx)
	bc.emit("LOAD_VAR", resultIdx)
	doneSid = bc.str_id(bc.add_chunk_string("done"))
	bc.emit("LOAD_CONST", bc.add_const(doneSid))
	bc.emit("OBJECT_GET")
	exitJump = bc.emit("JUMP_IF_TRUE", 0)
	bc.emit("LOAD_VAR", resultIdx)
	secondSid = bc.str_id(bc.add_chunk_string("second"))
	bc.emit("LOAD_CONST", bc.add_const(secondSid))
	bc.emit("OBJECT_GET")
	bc.emit("STORE_VAR", _dummyIdx)
	emitBlock(emitter, node.body)
	bc.emit("JUMP", loopTop)
	bc.patch_jump(exitJump, bc.instr_count())
	bc.emit("PUSH_NULL")
	breakTarget = bc.instr_count()
	breakList = emitter.breakStack[#emitter.breakStack - 1]
	i = 0
	while i < #breakList:
		bc.patch_jump(breakList[i], breakTarget)
		i = i + 1
	emitter.breakStack.pop()
	emitter.continueStack.pop()
	oldRepeatScope.count = repeatScope.count
	emitter.scope = oldRepeatScope
	return

}
	if k == "ReturnStatement" {
		if node.value != null {
			savedTail = emitter.inTailPosition
			emitter.inTailPosition = true
			emitter.emittedTailCall = false
			emitExpr(emitter, node.value)
			wasTail = emitter.emittedTailCall
			emitter.inTailPosition = savedTail
			if !wasTail {
				bc.emit("RETURN")
			}
		}
		else {
			bc.emit("PUSH_NULL")
			bc.emit("RETURN")
		}
		return

	}
	if k == "LetDeclaration" {
		if node.isSignal == true {
			// signal binding: compile expression as re-evaluable function
			sigScope = Scope(null)
			prevSigScope = emitter.scope
