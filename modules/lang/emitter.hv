        }
        else {
          sid = globalIdx(emitter, name)
          bc.emit("PUSH_NULL")
          bc.emit("STORE_GLOBAL", bc.str_id(sid))
        }
      }
      else if node.target.kind == "MemberExpression" {
        emitExpr(emitter, node.target.obj)
        propIdx = bc.add_string(node.target.property)
        bc.emit("LOAD_CONST", propIdx)
        bc.emit("OBJECT_DELETE")
      }
      else if node.target.kind == "IndexExpression" {
        emitExpr(emitter, node.target.obj)
        emitExpr(emitter, node.target.index)
        bc.emit("ARRAY_DEL")
      }
    }
    return
  }
  if k == "WithStatement" {
    if node.object != null {
      emitExpr(emitter, node.object)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    if node.alias != null {
      aliasName = node.alias
      if type(aliasName) == "object" { aliasName = aliasName.name }
      slot = scopeDeclare(emitter.scope, aliasName)
      bc.emit("STORE_IMMUT_VAR", slot)
    }
    else {
      bc.emit("POP")
    }
    if node.body != null {
      if node.body.kind == "BlockStatement" {
        for s in node.body.body {
          emitStmt(emitter, s)
        }
      }
      else {
        emitStmt(emitter, node.body)
      }
    }
    return
  }
  if k == "TraitDeclaration" {
    // Same as ProtocolDeclaration: prot.register(name, method1, method2, ...)
    sid = globalIdx(emitter, "prot.register")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    traitName = node.name
    if type(traitName) == "object" { traitName = traitName.name }
    nameIdx = bc.add_string(traitName)
    bc.emit("LOAD_CONST", nameIdx)
    methodCount = 1
    if node.methods != null {
      for m in node.methods {
        mName = m.name
        if type(mName) == "object" { mName = mName.name }
        if mName != null {
          midx = bc.add_string(mName)
          bc.emit("LOAD_CONST", midx)
          methodCount = methodCount + 1
        }
      }
    }
    bc.emit("CALL", methodCount)
    nameSid = globalIdx(emitter, traitName)
    bc.emit("STORE_GLOBAL", bc.str_id(nameSid))
    return
  }
  if k == "DecoratorStatement" {
    emitDecoratorStatement(emitter, node)
    return
  }
  if k == "InputStatement" {
    emitInputStatement(emitter, node)
    return
  }
if k == "SwitchStatement" {
 if node.subject != null {
  emitExpr(emitter, node.subject)
  bc.emit("POP")
 }
 if node.cases != null {
  for caseNode in node.cases {
   if caseNode.body != null {
    if caseNode.body.kind == "BlockStatement" {
     for s in caseNode.body.body {
      emitStmt(emitter, s)
     }
    }
    else {
     emitStmt(emitter, caseNode.body)
    }
   }
  }
 }
 if node.defaultCase != null && node.defaultCase.body != null {
  if node.defaultCase.body.kind == "BlockStatement" {
   for s in node.defaultCase.body.body {
    emitStmt(emitter, s)
   }
  }
  else {
   emitStmt(emitter, node.defaultCase.body)
  }
 }
 return
 }
 if k == "OffModeStatement" {
  if node.body != null {
   emitStmt(emitter, node.body)
  }
  return
 }
  emitError("unsupported stmt: " + k, node.line, node.col)

}
// ============================================================
// Block emission
// ============================================================

fn emitIfExpr(emitter, node) {
    emitExpr(emitter, node.condition)
    elseJump = bc.emit("JUMP_IF_FALSE", 0)
    elseBranch = node["else"]
    if elseBranch != null {
        emitBlockWithReturn(emitter, node.then)
        endJump = bc.emit("JUMP", 0)
        bc.patch_jump(elseJump, bc.instr_count())
        emitBlockWithReturn(emitter, elseBranch)
        bc.patch_jump(endJump, bc.instr_count())
    }
    else {
        emitBlockWithReturn(emitter, node.then)
        endJump = bc.emit("JUMP", 0)
        bc.patch_jump(elseJump, bc.instr_count())
        bc.emit("PUSH_NULL")
        bc.patch_jump(endJump, bc.instr_count())

    }
}
fn emitTryExpr(emitter, node) {
    emitter.tryDepth = emitter.tryDepth + 1
    tryEnterIp = bc.emit("TRY_ENTER", 0, 0)
    emitBlockWithReturn(emitter, node.try_block)
    bc.emit("TRY_EXIT")
    // Finally block on normal exit
    finallyIp = 0
    if node.finally_block != null {
        finallyIp = bc.instr_count()
        emitBlock(emitter, node.finally_block)
    }
    overJump = bc.emit("JUMP", 0)
    // Catch handler
    catchIp = bc.instr_count()
    if node.catch_param != null {
        bc.emit("LOAD_EXCEPTION")
        cpIdx = scopeDeclare(emitter.scope, node.catch_param)
        bc.emit("STORE_VAR", cpIdx)
    }
    else {
        bc.emit("LOAD_EXCEPTION")
        bc.emit("POP")
    }
    if node.catch_block != null {
        emitBlockWithReturn(emitter, node.catch_block)
    }
    else {
        bc.emit("PUSH_NULL")
    }
    // After catch, execute finally again
    if node.finally_block != null {
        emitBlock(emitter, node.finally_block)
    }
    endJump = bc.emit("JUMP", 0)
    // Patch TRY_ENTER with catch_ip and finally_ip
    bc.patch_operand(tryEnterIp, 0, catchIp)
    if finallyIp > 0 {
        bc.patch_operand(tryEnterIp, 1, finallyIp)
    }
    bc.patch_jump(overJump, bc.instr_count())
    bc.patch_jump(endJump, bc.instr_count())
    emitter.tryDepth = emitter.tryDepth - 1
}
fn emitBlock(emitter, node) {
if node == null {
return
}
if node.kind == "BlockStatement" {
oldScope = emitter.scope
    blockScope = Scope(oldScope, null, null)
emitter.scope = blockScope
for stmt in node.body {
emitStmt(emitter, stmt)
}
oldScope.count = blockScope.count
emitter.scope = oldScope
return
}
if node.kind == "Program" {
for stmt in node.body {
emitStmt(emitter, stmt)
}
return
}
emitStmt(emitter, node)

}
fn emitBlockWithReturn(emitter, node) {
if node == null {
    bc.emit("PUSH_NULL")
    return
  }
if node.kind == "BlockStatement" {
  oldScope = emitter.scope
    blockScope = Scope(oldScope, oldScope.funcIdx, oldScope.bcFuncIdx)
  emitter.scope = blockScope
stmts = node.body
n = #stmts
if n == 0 {
oldScope.count = blockScope.count
emitter.scope = oldScope
bc.emit("PUSH_NULL")
return
}
isBuggyNullExpr = false
if n == 1 {
if stmts[0].kind == "ExpressionStatement" {
if stmts[0].expr == null {
isBuggyNullExpr = true
}
}
}
if isBuggyNullExpr {
oldScope.count = blockScope.count
emitter.scope = oldScope
bc.emit("PUSH_NULL")
return
}
		si = 0
		while si < n - 1 {
			emitStmt(emitter, stmts[si])
			si = si + 1
		}
	last = stmts[n - 1]
	// Propagate tail position to last statement in block (only if already in tail position from outer context)
	savedTail = emitter.inTailPosition
    if last.kind == "ReturnStatement" {
      emitter.inTailPosition = true
    }
    // For ExpressionStatement/IfStatement, only keep tail position if already set from outer context
    // (e.g., function body set it; nested blocks inherit it)
		if last.kind == "ExpressionStatement" {
			if last.expr != null {
				emitExpr(emitter, last.expr)
			} else {
				bc.emit("PUSH_NULL")
			}
			emitter.inTailPosition = savedTail
			oldScope.count = blockScope.count
			emitter.scope = oldScope
			return
		}
		if last.kind == "ReturnStatement" {
			emitStmt(emitter, last)
			emitter.inTailPosition = savedTail
			oldScope.count = blockScope.count
			emitter.scope = oldScope
			return
		}
		if last.kind == "IfStatement" {
			emitStmt(emitter, last)
			emitter.inTailPosition = savedTail
			oldScope.count = blockScope.count
			emitter.scope = oldScope
			return
		}
		emitStmt(emitter, last)
bc.emit("PUSH_NULL")
oldScope.count = blockScope.count
emitter.scope = oldScope
return
}
  if node.kind == "IfStatement" {
emitIfExpr(emitter, node)
return
}
if node.kind == "ExpressionStatement" {
    if node.expr != null {
      emitExpr(emitter, node.expr)
    }
    else {
      bc.emit("PUSH_NULL")
    }
    return
  }
  emitStmt(emitter, node)
  bc.emit("PUSH_NULL")
}
// ============================================================
// Function compilation (with upvalue registration)
// ============================================================

fn compileFuncDecl(emitter, name, params, bodyNode, funcIdx, sourceLine, isInstanceMethod) {
  if isInstanceMethod == null { isInstanceMethod = false }
  oldScope = emitter.scope
  fid = emitter.nextFuncId
  emitter.nextFuncId = fid + 1
  newScope = Scope(oldScope, fid, null) // bcFuncIdx set after func_new
  newScope.tag = name + str(fid)
  emitter.lastFuncScope = newScope
  emitter.scope = newScope
   // Bind function name in the function's own scope for recursion
   if name != null {
       scopeDeclare(newScope, name)
   }
   for p in params {
 if type(p) == "object" {
 if p.name != null { scopeDeclare(newScope, p.name) }
 else { scopeDeclare(newScope, p) }
 }
 else { scopeDeclare(newScope, p) }
 }
  paramCount = #params
  localCount = paramCount + 16
  bc.func_push()
  actualIdx = bc.func_new(name, paramCount, localCount)
  newScope.bcFuncIdx = actualIdx
  // Set parameter names for kwargs support
  paramNameStrIds = []
  for p in params {
    if type(p) == "object" && p.name != null {
      sid = bc.add_chunk_string(p.name)
      paramNameStrIds.push(sid)
    }
    else if type(p) == "object" && p.value != null {
      sid = bc.add_chunk_string(p.value)
      paramNameStrIds.push(sid)
    }
    else if type(p) == "str" {
      sid = bc.add_chunk_string(p)
      paramNameStrIds.push(sid)
    }
  }
  bc.set_param_names(paramNameStrIds)
  traceEmitter("func_new " + name + " params=" + str(paramCount) + " locals=" + str(localCount) + " bcIdx=" + str(actualIdx))
  if sourceLine != null {
    bc.set_func_source_line(sourceLine)
  }
  di = 0
  for p in params {
    if type(p) == "object" && (p.defval != null || p.default != null) {
      dv = p.defval != null ? p.defval : p.default
      _handled = false
      if type(dv) == "object" && dv.kind == "StringLiteral" {
        sid = bc.add_chunk_string(dv.value)
        bc.set_default_value(di, bc.str_id(sid))
        _handled = true
      }
      if !_handled && type(dv) == "object" && dv.kind == "NumberLiteral" {
        bc.set_default_value(di, num(dv.value))
        _handled = true
      }
      if !_handled && type(dv) == "object" && dv.kind == "BooleanLiteral" {
bv = dv.value == "true" || dv.value == true
  bc.set_default_value(di, bv)
  _handled = true
}
            if !_handled && type(dv) == "object" && dv.kind == "NullLiteral" {
                bc.set_default_value(di, null)
            }
            if !_handled && type(dv) == "object" && dv.kind == "ArrayLiteral" {
                if dv.elements == null || #dv.elements == 0 {
                    bc.set_default_value(di, true)
                }
            }
}
di = di + 1
  }
  // Instance methods: store self (slot 0) into global 'this' for @field access
  if isInstanceMethod {
    thisSid = globalIdx(emitter, "this")
    bc.emit("LOAD_VAR", 0)
    bc.emit("STORE_GLOBAL", bc.str_id(thisSid))
  }
  emitBlockWithReturn(emitter, bodyNode)
    bc.emit("RETURN")
    rootCheck = scopeFindFuncRoot(newScope)
    actualLocals = scopeLocalCount(newScope)
bc.set_local_count(actualLocals)
 upcount = newScope.upcount
 bc.func_pop()
 emitter.scope = oldScope
 [upcount, actualIdx]

 }
fn compileLambda(emitter, name, params, bodyNode, sourceLine) {
 lamId = emitter.nextFuncId
 emitter.nextFuncId = lamId + 1
 if name == null { name = "lambda_" + str(lamId) }
 oldScope = emitter.scope
 fid = emitter.nextFuncId
 emitter.nextFuncId = fid + 1
 newScope = Scope(oldScope, fid, null) // bcFuncIdx set after func_new
 emitter.scope = newScope
  // Bind function name in the function's own scope for recursion
  if name != null {
      scopeDeclare(oldScope, name)
  }
  for p in params {
 if type(p) == "object" {
 if p.name != null { scopeDeclare(newScope, p.name) }
 else { scopeDeclare(newScope, p) }
 }
 else { scopeDeclare(newScope, p) }
 }
  paramCount = #params
  localCount = paramCount + 16
  bc.func_push()
  actualIdx = bc.func_new(name, paramCount, localCount)
  newScope.bcFuncIdx = actualIdx
  // Set parameter names for kwargs support
  paramNameStrIds = []
  for p in params {
    if type(p) == "object" && p.name != null {
      sid = bc.add_chunk_string(p.name)
      paramNameStrIds.push(sid)
    }
    else if type(p) == "object" && p.value != null {
      sid = bc.add_chunk_string(p.value)
      paramNameStrIds.push(sid)
    }
    else if type(p) == "str" {
      sid = bc.add_chunk_string(p)
      paramNameStrIds.push(sid)
    }
  }
  bc.set_param_names(paramNameStrIds)
  traceEmitter("func_new " + name + " params=" + str(paramCount) + " bcIdx=" + str(actualIdx))
 if sourceLine != null {
 bc.set_func_source_line(sourceLine)
 }
 di = 0
 for p in params {
 if type(p) == "object" && (p.defval != null || p.default != null) {
 dv = p.defval != null ? p.defval : p.default
 _handled = false
 if type(dv) == "object" && dv.kind == "StringLiteral" {
 sid = bc.add_chunk_string(dv.value)
 bc.set_default_value(di, bc.str_id(sid))
 _handled = true
 }
 if !_handled && type(dv) == "object" && dv.kind == "NumberLiteral" {
 bc.set_default_value(di, num(dv.value))
 _handled = true
 }
 if !_handled && type(dv) == "object" && dv.kind == "BooleanLiteral" {
 bv = dv.value == "true" || dv.value == true
   bc.set_default_value(di, bv)
   _handled = true
 }
 if !_handled && type(dv) == "object" && dv.kind == "NullLiteral" {
   bc.set_default_value(di, null)
  }
  }
  di = di + 1
  }
  
  // If named, initialize the recursive call variable
  if name != null {
      // Need to assign the function object to the variable in the scope.
      // But we don't have the function object yet!
      // This is a known limitation of recursive lambdas in some languages.
      // Havel might need special handling (e.g. pre-allocating the closure).
  }
  
  emitBlockWithReturn(emitter, bodyNode)
  bc.emit("RETURN")
  actualLocals = scopeLocalCount(newScope)
  bc.set_local_count(actualLocals)
  upcount = newScope.upcount
  bc.func_pop()
  traceEmitter("func_pop " + name + " upcount=" + str(upcount))
  emitter.scope = oldScope
  [upcount, actualIdx, localIdx]

 }
 // ============================================================
// Import / Use statement emission
// ============================================================

fn emitUseStatement(emitter, node) {

  // Form 5: use module as alias — bare module with alias (check before Form 1)
  if node.alias != null {
    if node.module != null {
      if node.isFileImport != true {
      if !node.isNamedImport {
        if !node.isWildcard {
          pathIdx = bc.add_string(node.module)
          bc.emit("LOAD_CONST", pathIdx)
          bc.emit("IMPORT")
          sid = bc.add_chunk_string(node.alias)
          bc.emit("STORE_GLOBAL", bc.str_id(sid))
          return
        }
      }
      }
    }
  }

  // Form 1: use mod1, mod2 — bare module names, import each as whole object
  if node.moduleNames != null {
    if node.isFileImport != true {
      for modName in node.moduleNames {
      pathIdx = bc.add_string(modName)
      bc.emit("LOAD_CONST", pathIdx)
      bc.emit("IMPORT")
      sid = bc.add_chunk_string(modName)
      bc.emit("STORE_GLOBAL", bc.str_id(sid))
      }
      return
    }
  }

  // Form 2: use * from "module" or use module.* — wildcard
  if node.isWildcard == true {
    path = node.filePath
    if path == null { path = node.module }
    pathIdx = bc.add_string(path)
    bc.emit("LOAD_CONST", pathIdx)
    bc.emit("IMPORT")
    bc.emit("IMPORT_WILDCARD")
    return
  }

  // Form 3: use { a, b as c } from "module" — named imports
  if node.isNamedImport == true {
    path = node.filePath
    if path == null { path = node.module }
    pathIdx = bc.add_string(path)
    bc.emit("LOAD_CONST", pathIdx)
    bc.emit("IMPORT")
    iNames = node.importNames
    iAliases = node.importAliases
if iNames != null {
ii = 0
        while ii < #iNames {
          name = iNames[ii]
          if name == "*" && node.isWildcard == true {
            bc.emit("IMPORT_WILDCARD")
            return
          }
          alias = name
          if iAliases != null {
            if ii < #iAliases {
              alias = iAliases[ii]
            }
          }
          bc.emit("DUP")
          keyIdx = bc.add_string(name)
          bc.emit("LOAD_CONST", keyIdx)
          bc.emit("OBJECT_GET")
          sid = bc.add_chunk_string(alias)
          bc.emit("STORE_GLOBAL", bc.str_id(sid))
          ii = ii + 1
        }
}
    bc.emit("POP")
    return
  }

  // Form 4: use "file.hv" as alias or use "file.hv" — file import
  if node.isFileImport == true {
    if node.filePath != null {
    pathIdx = bc.add_string(node.filePath)
    bc.emit("LOAD_CONST", pathIdx)
    bc.emit("IMPORT")
      if node.alias != null {
        sid = bc.add_chunk_string(node.alias)
        bc.emit("STORE_GLOBAL", bc.str_id(sid))
      }
      else {
        fname = node.filePath
        dot = #fname - 1
      while dot >= 0 {
        if fname[dot] == "." { break }
        dot = dot - 1
      }
      slash = -1
      i = #fname - 1
      while i >= 0 {
        if fname[i] == "/" { slash = i; break }
        i = i - 1
      }
      if dot > slash {
        stem = fname.slice(slash + 1, dot)
      }
      else {
        stem = fname.slice(slash + 1)
      }
      sid = bc.add_chunk_string(stem)
      bc.emit("STORE_GLOBAL", bc.str_id(sid))
    }
  return
}

// Fallback: use module — bare module import as global
  if node.module != null {
    pathIdx = bc.add_string(node.module)
    bc.emit("LOAD_CONST", pathIdx)
    bc.emit("IMPORT")
    sid = bc.add_chunk_string(node.module)
    bc.emit("STORE_GLOBAL", bc.str_id(sid))
    return
  }
  }
}

fn emitImportStatement(emitter, node) {
  module = node.module

  // import { a, b as c } from "module"
  if node.importNames != null {
    pathIdx = bc.add_string(module)
bc.emit("LOAD_CONST", pathIdx)
bc.emit("IMPORT")
ii2 = 0
while ii2 < #node.importNames {
name = node.importNames[ii2]
alias = name
if node.importAliases != null {
if ii2 < #node.importAliases {
alias = node.importAliases[ii2]
}
}
if name == "*" {
bc.emit("IMPORT_WILDCARD")
return
}
bc.emit("DUP")
keyIdx = bc.add_string(name)
bc.emit("LOAD_CONST", keyIdx)
bc.emit("OBJECT_GET")
sid = bc.add_chunk_string(alias)
bc.emit("STORE_GLOBAL", bc.str_id(sid))
ii2 = ii2 + 1
}
    bc.emit("POP")
    return
  }

  // bare: import "module" — store as global with module stem name
  pathIdx = bc.add_string(module)
  bc.emit("LOAD_CONST", pathIdx)
  bc.emit("IMPORT")
  sid = bc.add_chunk_string(module)
  bc.emit("STORE_GLOBAL", bc.str_id(sid))
}

// ============================================================
// Program compilation (two-pass: functions first, then main)
// ============================================================

fn compileProgram(emitter, program, skip_execute = false, sourceFile = null, entryName = "__main__", noReset = false) {
  traceEmitter("compileProgram entryName=" + entryName + " skip_execute=" + str(skip_execute))
  if !noReset {
    bc.reset()
  }
 if sourceFile != null {
  bc.set_source_file(sourceFile)
 }
    // parse() returns {errors, ast} — unwrap if needed
    if program.ast != null {
        program = program.ast
    }
body = program.body
topStmts = []
funcDecls = []
for stmt in body {
  if stmt.kind == "FnDeclaration" {
    funcDecls.push(stmt)
  }
  else if stmt.kind == "ImplDeclaration" {
    topStmts.push(stmt)
    if stmt.funcs != null {
      for m in stmt.funcs {
        if m != null && m.kind == "FnDeclaration" { funcDecls.push(m) }
      }
    }
  }
  else {
            topStmts.push(stmt)

        }
    }
 // Module scope — used as parent for top-level functions
    moduleScope = Scope(null, null, null)
 emitter.scope = moduleScope
 // Pass 1: compile all function bodies
 funcUpcounts = []
 funcChunkIdxs = []
 fi = 0
 while fi < #funcDecls {
 decl = funcDecls[fi]
 result = compileFuncDecl(emitter, decl.name, decl.params, decl.body, -1, decl.line)
 uc = result[0]
 chunkIdx = result[1]
 emitter.func_map[decl.name] = chunkIdx
 funcUpcounts.push(uc)
 funcChunkIdxs.push(chunkIdx)
 fi = fi + 1
 }
 // Pass 2: compile __main__
 mainChunkIdx = bc.func_new(entryName, 0, 64)
 traceEmitter("func_new " + entryName + " (main) bcIdx=" + str(mainChunkIdx))
 emitter.scope = moduleScope
 // Emit CLOSURE or LOAD_CONST + STORE_GLOBAL for each top-level function
 fi2 = 0
 while fi2 < #funcDecls {
 decl = funcDecls[fi2]
 fidx = emitter.func_map[decl.name]
 if funcUpcounts[fi2] > 0 {
 bc.emit("CLOSURE", fidx)
 }
 else {
 fnConstIdx = bc.add_const(bc.make_function_obj(fidx))
 bc.emit("LOAD_CONST", fnConstIdx)
 }
bc.emit("STORE_GLOBAL", bc.str_id(globalIdx(emitter, decl.name)))
fi2 = fi2 + 1
}
// Emit top-level statements (all except last)
n = #topStmts
si = 0
while si < n - 1 {
emitStmt(emitter, topStmts[si])
si = si + 1
}
    // Last expression is the return rvalue
  if n > 0 {
    last = topStmts[n - 1]
    lastExpr = last.expr
    if last.kind == "ExpressionStatement" {
      emitExpr(emitter, lastExpr)
            bc.emit("RETURN")
        }
        if last.kind == "IfStatement" {
            emitIfExpr(emitter, last)
            bc.emit("RETURN")
        }
	if last.kind != "ExpressionStatement" {
		if last.kind != "IfStatement" {
			if last.kind == "TryStatement" {
				emitTryExpr(emitter, last)
				bc.emit("RETURN")
			}
			else {
				emitStmt(emitter, last)
				bc.emit("PUSH_NULL")
				bc.emit("RETURN")
			}
        }
      }
    }
    if n == 0 {
      bc.emit("PUSH_NULL")
      bc.emit("RETURN")
    }
    bc.set_local_count(scopeLocalCount(emitter.scope))
    emitter.scope = null
    if !skip_execute {
      traceEmitter("execute_persistent " + entryName)
      return bc.execute_persistent(entryName)
    }

  }

// ============================================================
// Match expression emission
// ============================================================

fn emitMatchExpr(emitter, node) {
  // Evaluate discriminants and store in temp slots
  discs = node.discriminants
  if discs == null {
    // Fallback: single subject
    if node.subject != null {
      if node.subject.kind != null {
        discs = [node.subject]
      }
      else {
        discs = node.subject
      }
    }
  }
  discSlots = []
  if discs != null {
    i = 0
    while i < #discs {
      emitExpr(emitter, discs[i])
      slot = scopeDeclare(emitter.scope, "_match_disc_" + str(i))
      bc.emit("STORE_VAR", slot)
      discSlots.push(slot)
      i = i + 1
    }
  }
  // Track whether all patterns match across discriminants
  matchSlot = scopeDeclare(emitter.scope, "_match_ok")
  // Compile each case
  caseJumps = []
  for c in node.cases {
    // Initialize match status to true
    bc.emit("LOAD_CONST", bc.add_const(true))
    bc.emit("STORE_VAR", matchSlot)
    // Get patterns array — may be c.patterns (multi) or c.pattern (single)
    pats = c.patterns
    if pats == null { pats = [c.pattern] }
    // Match each pattern against corresponding discriminant
    pi = 0
    while pi < #pats && pi < #discSlots {
      pat = pats[pi]
      if pat != null {
        // Load current match status first
        bc.emit("LOAD_VAR", matchSlot)
        // Compile pattern match for this discriminant
        emitPatternMatch(emitter, pat, discSlots[pi])
        // AND the match status with the comparison result
        bc.emit("AND")
        bc.emit("STORE_VAR", matchSlot)
      }
      pi = pi + 1
    }
    // Check if all patterns matched
    bc.emit("LOAD_VAR", matchSlot)
    // If pattern doesn't match, jump to next case
    failJump = bc.emit("JUMP_IF_FALSE", 0)
    // Check guard if present
    if c.guard != null {
      emitExpr(emitter, c.guard)
      guardFailJump = bc.emit("JUMP_IF_FALSE", 0)
      // Emit result
      if c.body != null {
        if c.body.kind == "BlockStatement" {
          emitBlockWithReturn(emitter, c.body)
        }
        else {
          emitExpr(emitter, c.body)
        }
      }
      else {
        bc.emit("PUSH_NULL")
      }
      caseJumps.push(bc.emit("JUMP", 0))
      bc.patch_jump(guardFailJump, bc.instr_count())
    }
    else {
      // No guard — emit result
      if c.body != null {
        if c.body.kind == "BlockStatement" {
          emitBlockWithReturn(emitter, c.body)
        }
        else {
          emitExpr(emitter, c.body)
        }
      }
      else {
        bc.emit("PUSH_NULL")
      }
      caseJumps.push(bc.emit("JUMP", 0))
    }
    // Patch pattern failure jump to next case
    bc.patch_jump(failJump, bc.instr_count())
  }
  // Default case
  if node.defaultCase != null {
    if node.defaultCase.kind == "BlockStatement" {
      emitBlockWithReturn(emitter, node.defaultCase)
    } else {
      emitExpr(emitter, node.defaultCase)
    }
  } else {
    bc.emit("PUSH_NULL")
  }
  // Patch all case jumps to end
  endTarget = bc.instr_count()
  for j in caseJumps {
    bc.patch_jump(j, endTarget)
  }

}

fn emitPatternMatch(emitter, pattern, discSlot) {
  if pattern == null {
    bc.emit("LOAD_CONST", bc.add_const(true))
    return
  }
  k = pattern.kind
  if k == "OrPattern" {
    if pattern.alternatives != null && #pattern.alternatives > 0 {
      emitPatternMatch(emitter, pattern.alternatives[0], discSlot)
      i = 1
      while i < #pattern.alternatives {
        emitPatternMatch(emitter, pattern.alternatives[i], discSlot)
        bc.emit("OR")
        i = i + 1
      }
    }
    return
  }
  if k == "ArrayPattern" {
    bc.emit("LOAD_CONST", bc.add_const(true))
    expectedLen = 0
    if pattern.elements != null { expectedLen = #pattern.elements }
    bc.emit("LOAD_VAR", discSlot)
    bc.emit("ARRAY_LEN")
    if pattern.rest != null {
      bc.emit("LOAD_CONST", bc.add_const(expectedLen))
      bc.emit("GTE")
    }
    if pattern.rest == null {
      bc.emit("LOAD_CONST", bc.add_const(expectedLen))
      bc.emit("EQ")
    }
    bc.emit("AND")
    if pattern.elements != null {
      i = 0
      while i < #pattern.elements {
        elem = pattern.elements[i]
        if elem != null && elem.kind == "Identifier" {
          bc.emit("LOAD_VAR", discSlot)
          bc.emit("LOAD_CONST", bc.add_const(i))
          bc.emit("ARRAY_GET")
          bindSlot = scopeDeclare(emitter.scope, elem.name)
          bc.emit("STORE_VAR", bindSlot)
        }
        i = i + 1
      }
    }
    if pattern.rest != null {
      if pattern.rest.kind == "Identifier" {
        bc.emit("LOAD_CONST", bc.add_const(null))
        bindSlot = scopeDeclare(emitter.scope, pattern.rest.name)
        bc.emit("STORE_VAR", bindSlot)
      }
    }
    return
  }
  if k == "ObjectPattern" {
    bc.emit("LOAD_CONST", bc.add_const(true))
    if pattern.properties != null {
      for prop in pattern.properties {
        bc.emit("LOAD_VAR", discSlot)
        fieldIdx = bc.add_string(prop.key)
        bc.emit("LOAD_CONST", fieldIdx)
        bc.emit("OBJECT_GET")
		if prop.value != null {
			if prop.value.kind == "Identifier" {
				bindSlot = scopeDeclare(emitter.scope, prop.value.name)
            bc.emit("DUP")
            bc.emit("STORE_VAR", bindSlot)
            bc.emit("IS_NULL")
            bc.emit("NOT")
            bc.emit("AND")
          }
          else {
			emitExpr(emitter, prop.value)
            bc.emit("EQ")
            bc.emit("AND")
          }
        }
		if prop.value == null {
          bc.emit("IS_NULL")
          bc.emit("NOT")
          bc.emit("AND")
        }
      }
    }
    return
  }
  if k == "ConstructorPattern" || k == "CallExpression" {
    ctorName = pattern.name
    if ctorName == null && pattern.callee != null { ctorName = pattern.callee.name }
    ctorArgs = pattern.args != null ? pattern.args : (pattern.params != null ? pattern.params : [])
    bc.emit("LOAD_CONST", bc.add_const(true))
    bc.emit("LOAD_VAR", discSlot)
    tagIdx = bc.add_string("tag")
    bc.emit("LOAD_CONST", tagIdx)
    bc.emit("OBJECT_GET")
    nameIdx = bc.add_string(ctorName)
    bc.emit("LOAD_CONST", nameIdx)
    bc.emit("EQ")
    bc.emit("AND")
    if ctorArgs != null {
      i = 0
      while i < #ctorArgs {
        arg = ctorArgs[i]
        if arg == null { i = i + 1; continue }
        if arg.kind == "WildcardPattern" { i = i + 1; continue }
        fieldName = "value"
        if i == 1 { fieldName = "error" }
        if i == 2 { fieldName = "message" }
        bc.emit("LOAD_VAR", discSlot)
        fieldIdx = bc.add_string(fieldName)
        bc.emit("LOAD_CONST", fieldIdx)
        bc.emit("OBJECT_GET")
        if arg.kind == "Identifier" {
          bindSlot = scopeDeclare(emitter.scope, arg.name)
          bc.emit("STORE_VAR", bindSlot)
        }
        if arg.kind == "ConstructorPattern" || arg.kind == "ObjectPattern" || arg.kind == "ArrayPattern" || arg.kind == "RangePattern" || arg.kind == "OrPattern" {
          tempSlot = scopeDeclare(emitter.scope, "_pat_tmp")
          bc.emit("STORE_VAR", tempSlot)
          emitPatternMatch(emitter, arg, tempSlot)
          bc.emit("AND")
        }
        if arg.kind != "Identifier" && arg.kind != "ConstructorPattern" && arg.kind != "ObjectPattern" && arg.kind != "ArrayPattern" && arg.kind != "RangePattern" && arg.kind != "OrPattern" && arg.kind != "WildcardPattern" {
          emitExpr(emitter, arg)
          bc.emit("EQ")
          bc.emit("AND")
        }
        i = i + 1
      }
    }
    return
  }
  if k == "RangePattern" {
    bc.emit("LOAD_VAR", discSlot)
    emitExpr(emitter, pattern.start)
    bc.emit("GTE")
    bc.emit("LOAD_VAR", discSlot)
    emitExpr(emitter, pattern.end)
    bc.emit("LTE")
    bc.emit("AND")
    return
  }
  if k == "WildcardPattern" {
    bc.emit("LOAD_CONST", bc.add_const(true))
    return
  }
  if k == "Identifier" {
    bindSlot = scopeDeclare(emitter.scope, pattern.name)
    bc.emit("LOAD_VAR", discSlot)
    bc.emit("STORE_VAR", bindSlot)
    bc.emit("LOAD_CONST", bc.add_const(true))
    return
  }
  // Default: literal comparison — EQ with discSlot
  emitExpr(emitter, pattern)
  bc.emit("LOAD_VAR", discSlot)
  bc.emit("EQ")
}
// ============================================================
// Class/Struct/Enum declaration emission
// ============================================================

fn emitClassDeclaration(emitter, node) {
 emitter.classNames[node.name] = true
 // class.define(name, [instance_fields], parent, [class_fields])
  sid = globalIdx(emitter, "class.define")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  // Name
  nameIdx = bc.add_string(node.name)
  bc.emit("LOAD_CONST", nameIdx)
  // Instance fields array
  bc.emit("ARRAY_NEW")
  if node.definition.fields != null {
    for f in node.definition.fields {
      isField = f.isClassField
      if isField == null {
        fidx = bc.add_string(f.name)
        bc.emit("LOAD_CONST", fidx)
        bc.emit("ARRAY_PUSH")
      }
      else if !isField {
        fidx = bc.add_string(f.name)
        bc.emit("LOAD_CONST", fidx)
        bc.emit("ARRAY_PUSH")
      }
    }
  }
  // Parent
  if node.parentName != null {
    if node.parentName != "" {
      parentSid = globalIdx(emitter, node.parentName)
      bc.emit("LOAD_GLOBAL", bc.str_id(parentSid))
    }
    else {
      bc.emit("PUSH_NULL")
    }
  }
  else {
    bc.emit("PUSH_NULL")
  }
  // Class fields array
  bc.emit("ARRAY_NEW")
  if node.definition.fields != null {
    for f in node.definition.fields {
      isField = f.isClassField
      if isField != null {
        if isField {
          fidx = bc.add_string(f.name)
          bc.emit("LOAD_CONST", fidx)
          bc.emit("ARRAY_PUSH")
        }
      }
    }
  }
  bc.emit("CALL", 4)
  nameSid = globalIdx(emitter, node.name)
  bc.emit("STORE_GLOBAL", bc.str_id(nameSid))
  if node.definition.fields != null {
    for f in node.definition.fields {
      isField = f.isClassField
      if isField != null {
        if isField {
          if f.defaultValue != null {
        bc.emit("LOAD_GLOBAL", bc.str_id(nameSid))
        emitExpr(emitter, f.defaultValue)
        fieldIdx = bc.add_string(f.name)
        bc.emit("LOAD_CONST", fieldIdx)
        bc.emit("OBJECT_SET")
        bc.emit("POP")
          }
        }
      }
    }
  }
  if node.definition.methods != null {
    prevClassName = emitter.currentClassName
		emitter.currentClassName = node.name
    for m in node.definition.methods {
      if m != null {
        emitClassMethodRegister(emitter, node.name, m)
      }
    }
		emitter.currentClassName = prevClassName
	}

}

fn emitClassMethodRegister(emitter, className, method) {
  sid = globalIdx(emitter, "class.method")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  // Load class object
  classSid = globalIdx(emitter, className)
  bc.emit("LOAD_GLOBAL", bc.str_id(classSid))
  // Method name
  mnameIdx = bc.add_string(method.name)
  bc.emit("LOAD_CONST", mnameIdx)
  // Instance methods get 'self' at slot 0, class methods (@@) don't
  isClassMethod = method.isClassMethod != null && method.isClassMethod
  chunkIdx = -1
  if isClassMethod {
    result = compileFuncDecl(emitter, method.name, method.params, method.body, -1, method.line, false)
    chunkIdx = result[1]
  }
  else {
    selfParam = {name: "self", "default": null}
    methodParams = [selfParam]
    for p in method.params {
      methodParams.push(p)
    }
    result = compileFuncDecl(emitter, method.name, methodParams, method.body, -1, method.line, true)
    chunkIdx = result[1]
  }
fnObj = bc.make_function_obj(chunkIdx)
fnConstIdx = bc.add_const(fnObj)
bc.emit("LOAD_CONST", fnConstIdx)
bc.emit("CALL", 3)
bc.emit("POP")

}

fn emitStructMethodRegister(emitter, structName, method) {
  sid = globalIdx(emitter, "struct.method")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  structSid = globalIdx(emitter, structName)
  bc.emit("LOAD_GLOBAL", bc.str_id(structSid))
  mnameIdx = bc.add_string(method.name)
  bc.emit("LOAD_CONST", mnameIdx)
  isClassMethod = method.isClassMethod != null && method.isClassMethod
  chunkIdx = -1
  if isClassMethod {
    result = compileFuncDecl(emitter, method.name, method.params, method.body, -1, method.line, false)
    chunkIdx = result[1]
  }
  else {
    selfParam = {name: "self", "default": null}
    methodParams = [selfParam]
    for p in method.params {
      methodParams.push(p)
    }
    result = compileFuncDecl(emitter, method.name, methodParams, method.body, -1, method.line, true)
    chunkIdx = result[1]
  }
  fnObj = bc.make_function_obj(chunkIdx)
  fnConstIdx = bc.add_const(fnObj)
  bc.emit("LOAD_CONST", fnConstIdx)
  bc.emit("CALL", 3)
  bc.emit("POP")

}


fn emitStructDeclaration(emitter, node) {
  emitter.classNames[node.name] = true
  emitter.structNames[node.name] = true
  // struct Foo(field1, field2) → struct.define("Foo", ["field1", "field2"], [default1, default2])
  sid = globalIdx(emitter, "struct.define")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  // Name
  nameIdx = bc.add_string(node.name)
  bc.emit("LOAD_CONST", nameIdx)
  // Fields array
  bc.emit("ARRAY_NEW")
  if node.definition.fields != null {
    for f in node.definition.fields {
      fname = f
      if type(f) == "object" {
        if f.name != null { fname = f.name }
      }
      fidx = bc.add_string(fname)
      bc.emit("LOAD_CONST", fidx)
      bc.emit("ARRAY_PUSH")
    }
  }
  // Default values array
  bc.emit("ARRAY_NEW")
  if node.definition.fields != null {
    for f in node.definition.fields {
      if type(f) == "object" && f.defaultValue != null {
        emitExpr(emitter, f.defaultValue)
      }
      else {
        bc.emit("PUSH_NULL")
      }
      bc.emit("ARRAY_PUSH")
    }
  }
  bc.emit("CALL", 3)
  // Store as global
  nameSid = globalIdx(emitter, node.name)
  bc.emit("STORE_GLOBAL", bc.str_id(nameSid))
  // Register methods
  if node.definition.methods != null {
    prevClassName = emitter.currentClassName
    emitter.currentClassName = node.name
    for m in node.definition.methods {
      if m != null {
        emitStructMethodRegister(emitter, node.name, m)
      }
    }
    emitter.currentClassName = prevClassName
  }
  // Register protocol conformance: prot.impl(protocolName, structName)
  if node.protocolNames != null {
    for protName in node.protocolNames {
      if protName != null && protName != "" {
        protSid = globalIdx(emitter, "prot.impl")
        bc.emit("LOAD_GLOBAL", bc.str_id(protSid))
        pnIdx = bc.add_string(protName)
        bc.emit("LOAD_CONST", pnIdx)
        cnIdx = bc.add_string(node.name)
        bc.emit("LOAD_CONST", cnIdx)
        bc.emit("CALL", 2)
      bc.emit("POP")
      }
    }
  }
}

fn emitImplDeclaration(emitter, node) {
  typeName = node.typeName
  traitName = node.traitName
  if typeName == null { typeName = "" }
  if traitName == null { traitName = "" }
  isStruct = emitter.structNames.has(typeName)
  methodHostFn = "class.method"
  if isStruct { methodHostFn = "struct.method" }
  if node.funcs != null {
    for method in node.funcs {
      if method == null { continue }
      if method.name == null { continue }
      fidx = emitter.func_map[method.name]
      if fidx == null { continue }
      sid = globalIdx(emitter, methodHostFn)
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      typeSid = globalIdx(emitter, typeName)
      bc.emit("LOAD_GLOBAL", bc.str_id(typeSid))
      mnameIdx = bc.add_string(method.name)
      bc.emit("LOAD_CONST", mnameIdx)
      fnObj = bc.make_function_obj(fidx)
      fnConstIdx = bc.add_const(fnObj)
      bc.emit("LOAD_CONST", fnConstIdx)
      bc.emit("CALL", 3)
      bc.emit("POP")
    }
  }
  if traitName != "" {
    protSid = globalIdx(emitter, "prot.impl")
    bc.emit("LOAD_GLOBAL", bc.str_id(protSid))
    tnIdx = bc.add_string(traitName)
    bc.emit("LOAD_CONST", tnIdx)
    cnIdx = bc.add_string(typeName)
    bc.emit("LOAD_CONST", cnIdx)
    bc.emit("CALL", 2)
    bc.emit("POP")
  }
}

fn emitEnumDeclaration(emitter, node) {
  sid = globalIdx(emitter, "enum.define")
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  nameIdx = bc.add_string(node.name)
  bc.emit("LOAD_CONST", nameIdx)
  // Variant names array
  bc.emit("ARRAY_NEW")
  if node.definition.variants != null {
    for v in node.definition.variants {
      vidx = bc.add_string(v.name)
      bc.emit("LOAD_CONST", vidx)
      bc.emit("ARRAY_PUSH")
    }
  }
  // Payload counts array
  bc.emit("ARRAY_NEW")
  if node.definition.variants != null {
    for v in node.definition.variants {
      pc = 0
      if v.payloadType != null { pc = 1 }
      bc.emit("LOAD_CONST", bc.add_const(pc))
      bc.emit("ARRAY_PUSH")
    }
  }
  bc.emit("CALL", 3)
  // Store as global
  nameSid = globalIdx(emitter, node.name)
  bc.emit("STORE_GLOBAL", bc.str_id(nameSid))
}

// ============================================================
// Hotkey binding emission
// ============================================================

fn emitHotkeyBinding(emitter, node) {
 // Compile action as a function
 oldScope = emitter.scope
 newScope = Scope(null)
 emitter.scope = newScope
 actionChunkIdx = bc.func_new("hotkey_action", 1, 16)
 // Store parameter (this) in local 0
 scopeDeclare(newScope, "this")
 // Compile action
 actionNode = node.action != null ? node.action : node.body
 if actionNode != null {
  if actionNode.kind == "BlockStatement" {
   for s in actionNode.body {
    emitStmt(emitter, s)
   }
  }
  else {
   emitStmt(emitter, actionNode)
  }
 }
 bc.emit("PUSH_NULL")
 bc.emit("RETURN")
 bc.set_local_count(scopeLocalCount(newScope))
 emitter.scope = oldScope
 // Create wrapper that sets this context
 wrapperChunkIdx = bc.func_new("hotkey_wrapper", 1, 8)
 // Mode guard: if mode attr is set, check mode() == "modeName"
 modeSkipJumpIp = -1
 hasMode = node.mode != null && node.mode != ""
 if hasMode {
  modeSid = globalIdx(emitter, "mode")
  bc.emit("LOAD_GLOBAL", bc.str_id(modeSid))
  bc.emit("CALL", 0)
  modeKeyIdx = bc.add_string(node.mode)
  bc.emit("LOAD_CONST", modeKeyIdx)
  bc.emit("EQ")
  modeSkipJumpIp = bc.emit("JUMP_IF_FALSE", 0)
 }
 // Store param 0 as "this" global
 bc.emit("LOAD_VAR", 0)
 thisSid = globalIdx(emitter, "this")
 bc.emit("STORE_GLOBAL", bc.str_id(thisSid))
 // Load "this" and call action
 bc.emit("LOAD_GLOBAL", bc.str_id(thisSid))
 bc.emit("LOAD_CONST", bc.add_const(actionChunkIdx))
 bc.emit("SWAP")
 bc.emit("CALL", 1)
 bc.emit("POP")
 // Patch mode skip jump to land here (after action call, before return)
 if hasMode {
  bc.patch_jump(modeSkipJumpIp, bc.instr_count())
 }
 bc.emit("PUSH_NULL")
 bc.emit("RETURN")
 // Determine hotkey list: use hotkeys array if present, otherwise fall back to key
 hkList = []
 if node.hotkeys != null && #node.hotkeys > 0 {
  hkList = node.hotkeys
 }
 else if node.key != null {
  hkList = [node.key]
 }
 // Register each hotkey
 hasPolicy = node.policy != null && node.policy != ""
 for hk in hkList {
  if emitter.whenConditionFuncIndex != null {
   sid = globalIdx(emitter, "hotkey.register_conditional")
   bc.emit("LOAD_GLOBAL", bc.str_id(sid))
   if type(hk) == "str" {
    keyIdx = bc.add_string(hk)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else if hk.kind == "HotkeyLiteral" {
    keyIdx = bc.add_string(hk.combination)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else {
    emitExpr(emitter, hk)
   }
   bc.emit("LOAD_CONST", bc.add_const(wrapperChunkIdx))
   bc.emit("LOAD_CONST", bc.add_const(emitter.whenConditionFuncIndex))
   if hasPolicy {
    bc.emit("OBJECT_NEW")
    polKeyIdx = bc.add_string(node.policy)
    bc.emit("LOAD_CONST", polKeyIdx)
    polNameIdx = bc.add_string("policy")
    bc.emit("LOAD_CONST", polNameIdx)
    bc.emit("OBJECT_SET")
    bc.emit("CALL", 4)
   }
   else {
    bc.emit("CALL", 3)
   }
  }
  if emitter.whenConditionFuncIndex == null {
   sid = globalIdx(emitter, "hotkey.register")
   bc.emit("LOAD_GLOBAL", bc.str_id(sid))
   if type(hk) == "str" {
    keyIdx = bc.add_string(hk)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else if hk.kind == "HotkeyLiteral" {
    keyIdx = bc.add_string(hk.combination)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else {
    emitExpr(emitter, hk)
   }
   bc.emit("LOAD_CONST", bc.add_const(wrapperChunkIdx))
   if hasPolicy {
    bc.emit("OBJECT_NEW")
    polKeyIdx = bc.add_string(node.policy)
    bc.emit("LOAD_CONST", polKeyIdx)
    polNameIdx = bc.add_string("policy")
    bc.emit("LOAD_CONST", polNameIdx)
    bc.emit("OBJECT_SET")
    bc.emit("CALL", 3)
   }
   else {
    bc.emit("CALL", 2)
   }
  }
  bc.emit("POP")
 }

}



fn emitHotkeyBindingExpr(emitter, node) {
 oldScope = emitter.scope
 newScope = Scope(null)
 emitter.scope = newScope
 actionChunkIdx = bc.func_new("hotkey_action", 1, 16)
 scopeDeclare(newScope, "this")
 actionNode = node.action != null ? node.action : node.body
 if actionNode != null {
  if actionNode.kind == "BlockStatement" {
   for s in actionNode.body {
    emitStmt(emitter, s)
   }
  }
  else {
   emitStmt(emitter, actionNode)
  }
 }
 bc.emit("PUSH_NULL")
 bc.emit("RETURN")
 bc.set_local_count(scopeLocalCount(newScope))
 emitter.scope = oldScope
 wrapperChunkIdx = bc.func_new("hotkey_wrapper", 1, 8)
 // Mode guard: if mode attr is set, check mode() == "modeName"
 modeSkipJumpIp = -1
 hasMode = node.mode != null && node.mode != ""
 if hasMode {
  modeSid = globalIdx(emitter, "mode")
  bc.emit("LOAD_GLOBAL", bc.str_id(modeSid))
  bc.emit("CALL", 0)
  modeKeyIdx = bc.add_string(node.mode)
  bc.emit("LOAD_CONST", modeKeyIdx)
  bc.emit("EQ")
  modeSkipJumpIp = bc.emit("JUMP_IF_FALSE", 0)
 }
 bc.emit("LOAD_VAR", 0)
 thisSid = globalIdx(emitter, "this")
 bc.emit("STORE_GLOBAL", bc.str_id(thisSid))
 bc.emit("LOAD_GLOBAL", bc.str_id(thisSid))
 bc.emit("LOAD_CONST", bc.add_const(actionChunkIdx))
 bc.emit("SWAP")
 bc.emit("CALL", 1)
 bc.emit("POP")
 // Patch mode skip jump to land here
 if hasMode {
  bc.patch_jump(modeSkipJumpIp, bc.instr_count())
 }
 bc.emit("PUSH_NULL")
 bc.emit("RETURN")
 hasPolicy = node.policy != null && node.policy != ""
 hkList = []
 if node.hotkeys != null && #node.hotkeys > 0 {
  hkList = node.hotkeys
 }
 else if node.key != null {
  hkList = [node.key]
 }
 for hk in hkList {
  if emitter.whenConditionFuncIndex != null {
   sid = globalIdx(emitter, "hotkey.register_conditional")
   bc.emit("LOAD_GLOBAL", bc.str_id(sid))
   if type(hk) == "str" {
    keyIdx = bc.add_string(hk)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else if hk.kind == "HotkeyLiteral" {
    keyIdx = bc.add_string(hk.combination)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else {
    emitExpr(emitter, hk)
   }
   bc.emit("LOAD_CONST", bc.add_const(wrapperChunkIdx))
   bc.emit("LOAD_CONST", bc.add_const(emitter.whenConditionFuncIndex))
   if hasPolicy {
    bc.emit("OBJECT_NEW")
    polKeyIdx = bc.add_string(node.policy)
    bc.emit("LOAD_CONST", polKeyIdx)
    polNameIdx = bc.add_string("policy")
    bc.emit("LOAD_CONST", polNameIdx)
    bc.emit("OBJECT_SET")
    bc.emit("CALL", 4)
   }
   else {
    bc.emit("CALL", 3)
   }
  }
  if emitter.whenConditionFuncIndex == null {
   sid = globalIdx(emitter, "hotkey.register")
   bc.emit("LOAD_GLOBAL", bc.str_id(sid))
   if type(hk) == "str" {
    keyIdx = bc.add_string(hk)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else if hk.kind == "HotkeyLiteral" {
    keyIdx = bc.add_string(hk.combination)
    bc.emit("LOAD_CONST", keyIdx)
   }
   else {
    emitExpr(emitter, hk)
   }
   bc.emit("LOAD_CONST", bc.add_const(wrapperChunkIdx))
   if hasPolicy {
    bc.emit("OBJECT_NEW")
    polKeyIdx = bc.add_string(node.policy)
    bc.emit("LOAD_CONST", polKeyIdx)
    polNameIdx = bc.add_string("policy")
    bc.emit("LOAD_CONST", polNameIdx)
    bc.emit("OBJECT_SET")
    bc.emit("CALL", 3)
   }
   else {
    bc.emit("CALL", 2)
   }
  }
  bc.emit("POP")
 }
}


fn compileCondHotkeyCondition(emitter, condition) {
  oldScope = emitter.scope
  newScope = Scope(null)
  emitter.scope = newScope
  condChunkIdx = bc.func_new("condhotkey_condition", 0, 16)
  emitExpr(emitter, condition)
  bc.emit("RETURN")
  bc.set_local_count(scopeLocalCount(newScope))
  emitter.scope = oldScope
  return [null, condChunkIdx]
}

fn emitClosureBody(emitter, body, name) {
  oldScope = emitter.scope
	newScope = Scope(oldScope)
	emitter.scope = newScope
	funcIdx = bc.func_new(name, 0, 16)
  if body != null {
    if body.kind == "BlockStatement" {
      for s in body.body {
        emitStmt(emitter, s)
      }
    }
    else {
      emitStmt(emitter, body)
    }
  }
  bc.emit("PUSH_NULL")
  bc.emit("RETURN")
	bc.set_local_count(scopeLocalCount(newScope))
	emitter.scope = oldScope
	bc.emit("LOAD_CONST", bc.add_const(funcIdx))
}

fn emitWhenBlock(emitter, node) {
  oldScope = emitter.scope
  condScope = Scope(null)
  emitter.scope = condScope
  condChunkIdx = bc.func_new("when_condition", 0, 16)
  if node.condition != null {
    emitExpr(emitter, node.condition)
  }
  if node.condition == null {
    bc.emit("LOAD_CONST", bc.add_const(true))
  }
  bc.emit("RETURN")
  bc.set_local_count(scopeLocalCount(condScope))
  emitter.scope = oldScope
  hotkeyStmts = []
  otherStmts = []
  if node.statements != null {
    for s in node.statements {
      sk = s.kind
      if sk == "HotkeyBinding" || sk == "ConditionalHotkey" || sk == "HotkeyExpression" {
        hotkeyStmts.push(s)
      }
      else {
        otherStmts.push(s)
      }
    }
  }
  if #otherStmts > 0 {
    bodyScope = Scope(null)
    emitter.scope = bodyScope
    bodyChunkIdx = bc.func_new("when_body", 0, 16)
    for s in otherStmts {
      emitStmt(emitter, s)
    }
    bc.emit("PUSH_NULL")
    bc.emit("RETURN")
    bc.set_local_count(scopeLocalCount(bodyScope))
    emitter.scope = oldScope
    sid = globalIdx(emitter, "when.register")
    bc.emit("LOAD_GLOBAL", bc.str_id(sid))
    bc.emit("LOAD_CONST", bc.add_const(condChunkIdx))
    bc.emit("LOAD_CONST", bc.add_const(bodyChunkIdx))
    bc.emit("CALL", 2)
    bc.emit("POP")
  }
  prevWcfi = emitter.whenConditionFuncIndex
  emitter.whenConditionFuncIndex = condChunkIdx
  for s in hotkeyStmts {
    emitStmt(emitter, s)
  }
  emitter.whenConditionFuncIndex = prevWcfi
}

fn emitDecoratorStatement(emitter, node) {
  emitStmt(emitter, node.target)
  fnName = node.target.name
  if type(fnName) == "object" { fnName = fnName.name }
  if fnName == null { fnName = "" }
  slot = scopeDeclare(emitter.scope, fnName)
  decos = node.decorators
  i = #decos - 1
  while i >= 0 {
    deco = decos[i]
    if deco != null {
      emitExpr(emitter, deco)
      bc.emit("LOAD_VAR", slot)
      bc.emit("CALL", 1)
      bc.emit("STORE_VAR", slot)
    }
    i = i - 1
  }
  origNameIdx = bc.add_string(fnName)
  nameKeyIdx = bc.add_string("__name__")
  wrappedKeyIdx = bc.add_string("__wrapped__")
  arityKeyIdx = bc.add_string("__arity__")
  bc.emit("LOAD_VAR", slot)
  bc.emit("LOAD_CONST", origNameIdx)
  bc.emit("LOAD_CONST", nameKeyIdx)
  bc.emit("OBJECT_SET")
  bc.emit("POP")
  if node.target.kind == "FunctionDeclaration" {
    origIdx = emitter.func_map[fnName]
    if origIdx != null {
      bc.emit("LOAD_VAR", slot)
      bc.emit("LOAD_CONST", bc.add_const(origIdx))
      bc.emit("LOAD_CONST", wrappedKeyIdx)
      bc.emit("OBJECT_SET")
      bc.emit("POP")
    }
  }
  if node.target.kind == "FunctionDeclaration" {
    paramCount = 0
    if node.target.params != null { paramCount = #node.target.params }
    bc.emit("LOAD_VAR", slot)
    bc.emit("LOAD_CONST", bc.add_const(paramCount))
    bc.emit("LOAD_CONST", arityKeyIdx)
    bc.emit("OBJECT_SET")
    bc.emit("POP")
  }
}

fn emitInputStatement(emitter, node) {
  if node.commands == null { return }
  for cmd in node.commands {
    ct = cmd.type
    if ct == "SendText" || ct == "sendText" {
      sid = globalIdx(emitter, "io.send")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      textIdx = bc.add_string(cmd.text)
      bc.emit("LOAD_CONST", textIdx)
      bc.emit("CALL", 1)
      bc.emit("POP")
    }
    if ct == "SendKey" || ct == "sendKey" {
      sid = globalIdx(emitter, "io.sendKey")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      keyIdx = bc.add_string(cmd.key)
      bc.emit("LOAD_CONST", keyIdx)
      bc.emit("CALL", 1)
      bc.emit("POP")
    }
    if ct == "MouseClick" || ct == "mouseClick" {
      sid = globalIdx(emitter, "io.click")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      btnIdx = bc.add_string(cmd.text)
      bc.emit("LOAD_CONST", btnIdx)
      bc.emit("CALL", 1)
      bc.emit("POP")
    }
    if ct == "MouseMove" || ct == "mouseMove" {
      sid = globalIdx(emitter, "io.mouseMoveTo")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      xIdx = bc.add_string(cmd.xExprStr)
      bc.emit("LOAD_CONST", xIdx)
      yIdx = bc.add_string(cmd.yExprStr)
      bc.emit("LOAD_CONST", yIdx)
      bc.emit("CALL", 2)
      bc.emit("POP")
    }
    if ct == "MouseRelative" || ct == "mouseRelative" {
      sid = globalIdx(emitter, "io.mouseMoveRel")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      xIdx = bc.add_string(cmd.xExprStr)
      bc.emit("LOAD_CONST", xIdx)
      yIdx = bc.add_string(cmd.yExprStr)
      bc.emit("LOAD_CONST", yIdx)
      bc.emit("CALL", 2)
      bc.emit("POP")
    }
    if ct == "Sleep" || ct == "sleep" {
      sid = globalIdx(emitter, "sleep_ms")
      bc.emit("LOAD_GLOBAL", bc.str_id(sid))
      dur = int(cmd.duration)
      bc.emit("LOAD_CONST", bc.add_const(dur))
      bc.emit("CALL", 1)
      bc.emit("POP")
    }
  }
}

fn emitOnKeyBinding(emitter, registerFn, key, body) {
  oldScope = emitter.scope
  newScope = Scope(null)
  emitter.scope = newScope
  actionChunkIdx = bc.func_new(registerFn + "_action", 1, 16)
  scopeDeclare(newScope, "this")
  if body != null {
    if body.kind == "BlockStatement" {
      for s in body.body { emitStmt(emitter, s) }
    }
    else { emitStmt(emitter, body) }
  }
  bc.emit("PUSH_NULL")
  bc.emit("RETURN")
  bc.set_local_count(scopeLocalCount(newScope))
  emitter.scope = oldScope
  sid = globalIdx(emitter, registerFn)
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  if key != null {
    if type(key) == "str" {
      keyIdx = bc.add_string(key)
      bc.emit("LOAD_CONST", keyIdx)
    }
    else { emitExpr(emitter, key) }
  }
  else { bc.emit("PUSH_NULL") }
  bc.emit("LOAD_CONST", bc.add_const(actionChunkIdx))
  bc.emit("CALL", 2)
  bc.emit("POP")
}

fn emitOnKeyListBinding(emitter, registerFn, keys, body) {
  oldScope = emitter.scope
  newScope = Scope(null)
  emitter.scope = newScope
  actionChunkIdx = bc.func_new(registerFn + "_action", 1, 16)
  scopeDeclare(newScope, "this")
  if body != null {
    if body.kind == "BlockStatement" {
      for s in body.body { emitStmt(emitter, s) }
    }
    else { emitStmt(emitter, body) }
  }
  bc.emit("PUSH_NULL")
  bc.emit("RETURN")
  bc.set_local_count(scopeLocalCount(newScope))
  emitter.scope = oldScope
  sid = globalIdx(emitter, registerFn)
  bc.emit("LOAD_GLOBAL", bc.str_id(sid))
  bc.emit("ARRAY_NEW")
  if keys != null {
    for k in keys {
      if k != null {
        keyIdx = bc.add_string(k)
        bc.emit("LOAD_CONST", keyIdx)
        bc.emit("ARRAY_PUSH")
      }
    }
  }
  bc.emit("LOAD_CONST", bc.add_const(actionChunkIdx))
  bc.emit("CALL", 2)
  bc.emit("POP")
}
