                                nx = lk + 1
                                while nx < n && (cpArr[nx][0] == 32 || cpArr[nx][0] == 9 || cpArr[nx][0] == 10) { nx = nx + 1 }
                                if nx + 1 < n && cpArr[nx][0] == 61 && cpArr[nx + 1][0] == 62 {
                                    lambdaFlag = true
                                    break
                                }
                            }
                            ldp = ldp - 1
                        }
                        else if lc == 44 && ldp == 2 { lambdaFlag = true; break }
                        else if lc == 10 { break }
                        lk = lk + 1
                    }
                    if lambdaFlag { emitTwo = true }
                }
  if emitTwo {
    addToken("OpenParen", "(")
    advance() // consume first '('
    addToken("OpenParen", "(")
    advance() // consume second '('
    parenDepth = parenDepth + 2
    continue
  }
  advance() // consume first '('
  advance() // consume second '('
  inBitwiseExpr = true
  parenDepth = 0
  addToken("DoubleOpenParen", "((")
  continue
            }
            if c == 40 {
                advance()
                parenDepth = parenDepth + 1
                addToken("OpenParen", "(")
                continue
            }
            if c == 41 && cp(1) == 41 && inBitwiseExpr {
                advance()
                advance()
                inBitwiseExpr = false
                addToken("DoubleCloseParen", "))")
                continue
            }
            if c == 41 {
                advance()
                if parenDepth > 0 { parenDepth = parenDepth - 1 }
                addToken("CloseParen", ")")
                continue
            }
            if c == 91 {
                advance()
                addToken("OpenBracket", "[")
                continue
            }
            if c == 93 {
                advance()
                addToken("CloseBracket", "]")
                continue
            }
            if c == 123 {
                advance()
                addToken("OpenBrace", "{")
                continue
            }
            if c == 125 {
                advance()
                addToken("CloseBrace", "}")
                continue
            }
            if c == 44 {
                advance()
                addToken("Comma", ",")
                continue
            }
            if c == 59 {
                advance()
                addToken("Semicolon", ";")
                continue
            }
            if c == 64 && cp(1) == 45 && cp(2) == 62 {
                advance()
                advance()
                advance()
                addToken("SuperArrow", "@->")
                continue
            }
            if c == 64 && cp(1) == 64 {
                advance()
                advance()
                addToken("AtAt", "@@")
                continue
            }
      // @ - context-aware: At vs hotkey
  if c == 64 {
    nextCp = cp(1)
    if afterExpression() || (nextCp != -1 && (isAlphaCp(nextCp) || nextCp == 95)) {
          // Look ahead past identifier and whitespace to decide hotkey vs field access
          lk = idx
          while lk < n && (isAlphaNumCp(cpArr[lk][0]) || cpArr[lk][0] == 95) { lk = lk + 1 }
          while lk < n && (cpArr[lk][0] == 32 || cpArr[lk][0] == 9) { lk = lk + 1 }
          isHK = false
          if lk + 1 < n && cpArr[lk][0] == 61 && cpArr[lk + 1][0] == 62 { isHK = true }
          else if lk < n && cpArr[lk][0] == 38 { isHK = true }
          else if lk < n && cpArr[lk][0] == 58 { isHK = true }
          if isHK {
            scanHotkey()
          } else {
            advance()
            addToken("At", "@")
          }
        } else {
          advance()
          addToken("At", "@")
        }
        continue
      }
            // # - context-aware: Length vs hotkey (with => lookahead)
            if c == 35 {
                isStmtStart = tokens.len == 0
                if !isStmtStart {
                    if STATEMENT_START_TYPES.has(tokens[tokens.len - 1].type) { isStmtStart = true }
                }
                hasModPfx = (cp(1) != -1 && (cp(1) == 33 || cp(1) == 38 || cp(1) == 94))
                hasKeyName = (cp(1) != -1 && isAlphaCp(cp(1)))
                if isStmtStart || (hasModPfx && hasKeyName) {
                    lk = idx
                    while lk < n && isHotkeyCharCp(cpArr[lk][0]) { lk = lk + 1 }
                    while lk < n && (cpArr[lk][0] == 32 || cpArr[lk][0] == 9) { lk = lk + 1 }
                    hasArrow = (lk + 1 < n && cpArr[lk][0] == 61 && cpArr[lk + 1][0] == 62)
                    if hasArrow {
                        scanHotkey()
                        continue
                    }
                }
                advance()
                addToken("Length", "#")
                continue
            }
            // ~ - context-aware: Tilde vs hotkey
            if c == 126 {
                if inBitwiseExpr || afterExpression() {
                    advance()
                    addToken("Tilde", "~")
                } else {
                    advance()
                    s = "~"
                    while current() != -1 && current() != 10 && current() != 123 {
                        if current() == 61 && cp(1) == 62 { break }
                        if !isHotkeyCharCp(current()) { break }
                        s = s + string.fromCodePoint(current())
                        advance()
                    }
                    if s == "~" { addToken("Tilde", "~") }
                    else { addToken("Hotkey", s) }
                }
                continue
            }
      if c == 95 {
        if !isAlphaNumCp(cp(1)) {
          advance()
          addToken("Underscore", "_")
          continue
        }
        scanIdentifier()
        continue
      }
      // Unrecognized character - report error
      error("Unexpected character: " + string.fromCodePoint(c))
      advance()
      // Progress guard: ensure we always make forward progress
      if idx == loopStartIdx && current() != -1 {
        error("lexer made no progress")
        advance()
      }
    }
    addToken("EOF", "")
        {tokens: tokens, errors: errors}
    }
    {run: _scan}
}

fn tokenize(source) {
    lx = Lexer(source)
    result = lx.run()
    result.tokens
}

fn tokenizeWithErrors(source) {
    lx = Lexer(source)
    result = lx.run()
    {tokens: result.tokens, errors: result.errors}
}

fn printTokens(tokens) {
    for t in tokens {
        typeStr = t.type
        valStr = t.value
        if valStr.len > 40 { valStr = valStr.sub(0, 37) + "..." }
        print(typeStr + " " + valStr)
    }
}
