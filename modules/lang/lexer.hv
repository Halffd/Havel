{tokens: result.tokens, errors: result.errors}

}
fn printTokens(tokens) {
for t in tokens {
typeStr = t.type
valStr = t.value
if valStr.len > 40 {
valStr = valStr.sub(0, 37) + "..."
}
print(typeStr + " " + valStr)
}
