// Havel lexer - pure Havel implementation
// Tokenizes Havel source code into a list of {type, tid, value, line, col} objects
// Uses codepoint array indexing for O(1) character access
// tid = integer token type for fast parser dispatch (avoids string comparisons)


// --- Token type integer IDs (for fast parser dispatch) ---
TID = {
    Identifier: 1, Number: 2, String: 3, RegexString: 4, MultilineString: 5,
    InterpolatedString: 6, Backtick: 7, InterpolatedBacktick: 8, RegexLiteral: 9,
    Hotkey: 10, True: 11, False: 12, Null: 13,
    Let: 14, Val: 15, Const: 16, If: 17, Else: 18, While: 19, Do: 20,
    Switch: 21, For: 22, In: 23, Loop: 24, Break: 25, Continue: 26,
    Match: 27, Case: 28, Default: 29, Fn: 30, Op: 31, Return: 32, Ret: 33,
    Struct: 34, Class: 35, Enum: 36, Trait: 37, Prot: 38, Impl: 39, This: 40,
    Try: 41, Catch: 42, Finally: 43, Throw: 44,
    Thread: 45, Interval: 46, Timeout: 47, Yield: 48, Sleep: 49,
    Go: 50, Sync: 51, Async: 52, Channel: 53, Co: 54,
    Config: 55, Devices: 56, Modes: 57, Pool: 58, Signal: 59,
    Group: 60, On: 61, Off: 62, When: 63, Mode: 64, Repeat: 65,
    Dsl: 66, Del: 67, Import: 68, From: 69, As: 70, Use: 71,
    With: 72, Where: 73, Select: 74, And: 75, Or: 76, Not: 77,
    Is: 78, Matches: 79, WaitGroup: 80, Wait: 81, Defer: 82,
    ShellCommand: 83, ShellCommandCapture: 84,
    OpenParen: 85, CloseParen: 86, OpenBrace: 87, CloseBrace: 88,
    BangOpenBrace: 89, OpenBracket: 90, CloseBracket: 91,
    Dot: 92, Comma: 93, Semicolon: 94, Colon: 95, ColonColon: 96,
    Underscore: 97, DotDot: 98, DotDotEquals: 99, Spread: 100,
    Plus: 101, Minus: 102, Multiply: 103, Divide: 104, Modulo: 105,
    Power: 106, Backslash: 107, DoubleBackslash: 108, DoubleModulo: 109,
    BackslashAssign: 110, DoubleModuloAssign: 111,
    PlusPlus: 112, MinusMinus: 113,
    Equals: 114, NotEquals: 115, Less: 116, Greater: 117,
    LessEquals: 118, GreaterEquals: 119,
    Arrow: 120, ReturnType: 121, LeftArrow: 122, Assign: 123,
    PlusAssign: 124, MinusAssign: 125, MultiplyAssign: 126,
    DivideAssign: 127, ModuloAssign: 128, PowerAssign: 129,
    BitwiseAnd: 130, BitwiseOr: 131, BitwiseXor: 132,
    ShiftLeft: 133, ShiftRight: 134,
    BitwiseAndAssign: 135, BitwiseOrAssign: 136, BitwiseXorAssign: 137,
    ShiftLeftAssign: 138, ShiftRightAssign: 139,
    DoubleOpenParen: 140, DoubleCloseParen: 141,
    Nullish: 142, Question: 143, QuestionDot: 144,
    Tilde: 145, At: 146, AtAt: 147, SuperArrow: 148,
    Pipe: 149, PipeRight: 150, Length: 151, NewLine: 152, EOF: 153, CharLiteral: 154,
    Hash: 155,
}

// --- Reverse mapping: integer ID -> string type name ---
TID_NAME = {}
for k, v in TID { TID_NAME[v] = k }

// --- Token types (string names, kept for compatibility) ---
TOKEN_TYPES = {}
for k, v in TID { TOKEN_TYPES[k] = k }

KEYWORDS = {
    "let": "Let", "val": "Val", "const": "Const",
    "if": "If", "else": "Else", "while": "While", "do": "Do",
    "switch": "Switch", "for": "For", "in": "In", "loop": "Loop",
    "break": "Break", "continue": "Continue",
    "match": "Match", "case": "Case", "default": "Default",
    "fn": "Fn", "op": "Op", "return": "Return", "ret": "Ret",
    "struct": "Struct", "class": "Class", "enum": "Enum",
    "trait": "Trait", "prot": "Prot", "impl": "Impl", "this": "This",
    "try": "Try", "catch": "Catch", "finally": "Finally", "throw": "Throw",
    "thread": "Thread", "interval": "Interval", "timeout": "Timeout",
    "yield": "Yield", "sleep": "Sleep",
    "go": "Go", "sync": "Sync", "async": "Async", "channel": "Channel", "co": "Co",
    "config": "Config", "devices": "Devices", "modes": "Modes",
    "pool": "Pool", "signal": "Signal", "group": "Group",
    "on": "On", "off": "Off", "when": "When", "mode": "Mode", "repeat": "Repeat",
    "dsl": "Dsl", "del": "Del", "import": "Import", "from": "From",
    "as": "As", "use": "Use", "with": "With", "where": "Where", "select": "Select",
    "true": "True", "false": "False", "null": "Null", "nil": "Null",
    "and": "And", "or": "Or", "not": "Not", "is": "Is", "matches": "Matches",
    "waitgroup": "WaitGroup", "wait": "Wait", "defer": "Defer",
}

EXPRESSION_TOKENS = {
    "Number", "String", "InterpolatedString", "MultilineString",
    "Identifier", "True", "False", "Null",
    "CloseParen", "CloseBracket", "CloseBrace",
    "Length", "PlusPlus", "MinusMinus", "LeftArrow",
}

// --- Character classification (integer codepoint versions) ---

fn isAlphaCp(cp) {
    (cp >= 97 && cp <= 122) || (cp >= 65 && cp <= 90) || cp == 95
}
fn isDigitCp(cp) {
    cp >= 48 && cp <= 57
}
fn isAlphaNumCp(cp) {
    isAlphaCp(cp) || isDigitCp(cp)
}
fn isHexDigitCp(cp) {
    isDigitCp(cp) || (cp >= 97 && cp <= 102) || (cp >= 65 && cp <= 70)
}
fn isBinDigitCp(cp) {
    cp == 48 || cp == 49
}
fn isOctDigitCp(cp) {
    cp >= 48 && cp <= 55
}
fn isWhitespaceCp(cp) {
    cp == 32 || cp == 9 || cp == 13
}
fn isUnicodeLetterCp(cp) {
    if cp < 0x80 { return false }
    if cp >= 0x00C0 && cp <= 0x00D6 { return true }
    if cp >= 0x00D8 && cp <= 0x00F6 { return true }
    if cp >= 0x00F8 && cp <= 0x00FF { return true }
    if cp >= 0x0100 && cp <= 0x017F { return true }
    if cp >= 0x0180 && cp <= 0x024F { return true }
    if cp >= 0x0400 && cp <= 0x04FF { return true }
    if cp >= 0x0600 && cp <= 0x06FF { return true }
    if cp >= 0x0900 && cp <= 0x097F { return true }
    if cp >= 0xAC00 && cp <= 0xD7AF { return true }
    if cp >= 0x4E00 && cp <= 0x9FFF { return true }
    if cp >= 0x3040 && cp <= 0x309F { return true }
    if cp >= 0x30A0 && cp <= 0x30FF { return true }
    false
}
fn isUnicodeDigitCp(cp) {
    if cp < 0x80 { return false }
    if cp >= 0x0660 && cp <= 0x0669 { return true }
    if cp >= 0xFF10 && cp <= 0xFF19 { return true }
    false
}
fn isUnicodeIdentifierCharCp(cp) {
    if cp < 0 { return false }
    if cp < 0x80 { return isAlphaNumCp(cp) }
    isUnicodeLetterCp(cp) || isUnicodeDigitCp(cp)
}

SIMPLE_ESCAPES = {110: "\n", 116: "\t", 114: "\r", 92: "\\", 48: "\0", 36: "$", 123: "{", 125: "}"}

AFTER_EXPR_TYPES = {"Number", "String", "InterpolatedString", "MultilineString", "RegexString", "Identifier", "True", "False", "Null", "CloseParen", "CloseBracket", "CloseBrace", "Length", "PlusPlus", "MinusMinus", "LeftArrow", "Not", "Or", "And", "Assign", "BitwiseOr", "BitwiseAnd", "BitwiseXor", "ShiftLeft", "ShiftRight", "OpenParen", "If", "While", "For", "In", "Matches", "Tilde", "Comma", "Dot", "Minus", "Fn", "Op"}
AFTER_MINUS_NUMBER_TYPES = {"Number", "String", "InterpolatedString", "MultilineString", "Identifier", "True", "False", "Null", "CloseParen", "CloseBracket", "CloseBrace", "Length", "PlusPlus", "MinusMinus", "LeftArrow"}
REGEX_CONTEXT_TYPES = {"OpenParen", "OpenBracket", "OpenBrace", "Comma", "Assign", "Arrow", "And", "Or", "Not", "In", "Matches", "Tilde", "Colon", "Question", "Pipe", "NewLine", "Semicolon"}
  STATEMENT_START_TYPES = {"NewLine", "Semicolon", "Arrow", "OpenBrace", "CloseBrace"}
  STATEMENT_START_NO_ARROW_TYPES = {"NewLine", "Semicolon", "CloseBrace", "EOF"}
DOUBLE_PAREN_EXPR_TYPES = {"Identifier", "CloseParen", "CloseBracket", "String", "InterpolatedString", "MultilineString", "Number", "Plus", "Minus", "Multiply", "Divide", "Modulo", "Equals", "NotEquals", "Less", "Greater", "LessEquals", "GreaterEquals", "Comma", "Return", "Colon"}

fn Lexer(source) {
    keywords = KEYWORDS
    src = source
    cpArr = string.toCodePointArray(source)
    n = cpArr.length()
    idx = 0
    line = 1
    col = 1
    tokenStartCol = 1
    tokens = []
    errors = []
    inBitwiseExpr = false
    parenDepth = 0

    fn cp(offset) {
        i = idx + offset
        if i >= 0 && i < n { cpArr[i][0] } else { -1 }
    }
    fn current() {
        if idx < n { cpArr[idx][0] } else { -1 }
    }
  fn advance() {
    if idx >= n { return -1 }
    c = cpArr[idx][0]
    idx = idx + 1
    if c == 10 {
      line = line + 1
      col = 1
    } else if c == 9 {
      col = ((col + 7) / 8) * 8 + 1
    } else {
      col = col + 1
    }
    c
  }
    fn matchCp(expected) {
        if current() == expected { advance(); true } else { false }
    }
    fn bytePos() {
        if idx < n { cpArr[idx][1] } else { src.len }
    }
    fn idxAtByte(bp) {
        lo = 0
        hi = n - 1
        while lo <= hi {
            mid = (lo + hi) / 2
            if cpArr[mid][1] < bp {
                lo = mid + 1
            } else if cpArr[mid][1] > bp {
                hi = mid - 1
            } else {
                return mid
            }
        }
        lo
    }
    fn addToken(ttype, value) {
        tokens.push({type: ttype, tid: TID[ttype], value: value, line: line, col: tokenStartCol})
    }
    fn error(msg) {
        errors.push({msg: msg, line: line, col: col})
    }
    fn skipWhitespace() {
        while isWhitespaceCp(current()) { advance() }
    }
    fn skipLineComment() {
        advance()
        advance()
        while current() != -1 && current() != 10 { advance() }
    }
    fn skipBlockComment() {
        advance()
        advance()
        depth = 1
        while depth > 0 && current() != -1 {
            if current() == 42 && cp(1) == 47 {
                advance()
                advance()
                depth = depth - 1
            } else if current() == 47 && cp(1) == 42 {
                advance()
                advance()
                depth = depth + 1
            } else {
                advance()
            }
        }
    }
    fn lastTokenType() {
        if tokens.len > 0 { tokens[tokens.len - 1].type } else { "NewLine" }
    }
  fn afterExpression() {
    AFTER_EXPR_TYPES.has(lastTokenType()) || prevIsKeywordAfterDot()
  }
  fn prevIsKeywordAfterDot() {
    if tokens.len < 2 { return false }
    tokens[tokens.len - 2].type == "Dot"
  }
    fn isHotkeyCharCp(cp) {
        isAlphaNumCp(cp) || cp == 43 || cp == 45 || cp == 94 || cp == 33 || cp == 35 || cp == 64 || cp == 124 || cp == 42 || cp == 38 || cp == 58 || cp == 126 || cp == 36 || cp == 61 || cp == 46 || cp == 44 || cp == 47
    }
    fn decodeHexCp(cp) {
        if cp >= 48 && cp <= 57 { return cp - 48 }
        if cp >= 97 && cp <= 102 { return 10 + cp - 97 }
        if cp >= 65 && cp <= 70 { return 10 + cp - 65 }
        -1
    }
    fn processEscape() {
        if current() == -1 { return "\\" }
        c = current()
        esc = SIMPLE_ESCAPES[c]
        if esc != null {
            advance()
            if c == 36 || c == 123 || c == 125 { return esc }
            return esc
        }
        if c == 34 || c == 39 {
            q = advance()
            return string.fromCodePoint(q)
        }
        if c == 120 {
            advance()
            h1 = current()
            if h1 != -1 && isHexDigitCp(h1) {
                h2 = cp(1)
                if h2 != -1 && isHexDigitCp(h2) {
                    advance()
                    advance()
                    cpv = decodeHexCp(h1) * 16 + decodeHexCp(h2)
                    return string.fromCodePoint(cpv)
                }
                advance()
                error("Invalid hex escape: \\x requires two hex digits")
                return "\\x" + string.fromCodePoint(h1)
            }
            error("Invalid hex escape: \\x requires two hex digits")
            return "\\x"
        }
        if c == 117 {
            advance()
            if current() == -1 {
                error("Invalid unicode escape: \\u requires 4 hex digits")
                return "\\u"
            }
            if current() == 123 {
                error("\\u{...} not supported")
                advance()
                return "\\u{"
            }
            hexStr = ""
            for i in 0..4 {
                if current() != -1 && isHexDigitCp(current()) {
                    hexStr = hexStr + string.fromCodePoint(current())
                    advance()
                } else {
                    error("Invalid unicode escape: \\u requires 4 hex digits")
                    return "\\u" + hexStr
                }
            }
            cpv = 0
            for i in 0..4 {
                d = decodeHexCp(hexStr.codePointAt(i))
                cpv = cpv * 16 + d
            }
            return string.fromCodePoint(cpv)
        }
        advance()
        "\\" + string.fromCodePoint(c)
    }
    fn scanString(quote, isFString, isRegexString) {
        advance()
        s = ""
        isInterpolated = false
        if isFString { isInterpolated = true }
        braceDepth = 0
        chunkStart = bytePos()
        while current() != -1 {
            if braceDepth == 0 && current() == quote { break }
            if braceDepth == 0 && current() == 92 {
                if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                chunkStart = bytePos()
                advance()
                decoded = processEscape()
                s = s + decoded
                chunkStart = bytePos()
            } else if current() == 36 && braceDepth == 0 {
                nextCp = cp(1)
                if isAlphaCp(nextCp) || nextCp == 95 || nextCp == 64 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    isInterpolated = true
                    advance()
                    if isAlphaCp(current()) || current() == 95 {
                        s = s + "{"
                        while current() != -1 && (isAlphaNumCp(current()) || current() == 95) {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        if current() == 63 {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        s = s + "}"
                    } else if current() == 64 {
                        s = s + "{"
                        s = s + string.fromCodePoint(advance())
                        while current() != -1 && (isAlphaNumCp(current()) || current() == 95) {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        s = s + "}"
                    }
                    chunkStart = bytePos()
                } else {
                    s = s + string.fromCodePoint(advance())
                    chunkStart = bytePos()
                }
            } else if current() == 123 && braceDepth == 0 {
                if cp(1) != 123 {
                    nx = cp(1)
                    isExprStart = isAlphaCp(nx) || nx == 95 || nx == 64 || nx == 40 || nx == 36 || nx == 33 || nx == 45 || isDigitCp(nx) || nx == 91
                    if nx == 125 || nx == quote || !isExprStart {
                        s = s + string.fromCodePoint(advance())
                        chunkStart = bytePos()
                    } else {
                        if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                        chunkStart = bytePos()
                        isInterpolated = true
                        s = s + string.fromCodePoint(advance())
                        braceDepth = braceDepth + 1
                        chunkStart = bytePos()
                    }
                } else {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "{"
                }
                chunkStart = bytePos()
            } else if current() == 125 && braceDepth == 0 {
                if cp(1) == 125 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "}"
                } else {
                    s = s + string.fromCodePoint(advance())
                }
                chunkStart = bytePos()
            } else {
                c = advance()
                s = s + string.fromCodePoint(c)
                if braceDepth > 0 {
                    if c == 123 { braceDepth = braceDepth + 1 }
                    else if c == 125 { braceDepth = braceDepth - 1 }
                }
                chunkStart = bytePos()
            }
        }
        if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
        if current() == -1 {
            error("Unterminated string")
        } else {
            advance()
        }
        if isRegexString {
            addToken("RegexString", s)
        } else if isInterpolated {
            addToken("InterpolatedString", s)
        } else {
            addToken("String", s)
        }
    }
    fn scanMultilineString(quote, isFString) {
        advance()
        s = ""
        isInterpolated = false
        braceDepth = 0
        if current() == 10 { advance() }
        chunkStart = bytePos()
        while current() != -1 {
            if current() == quote && cp(1) == quote && cp(2) == quote { break }
            if braceDepth == 0 && current() == 92 {
                if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                chunkStart = bytePos()
                advance()
                decoded = processEscape()
                s = s + decoded
                chunkStart = bytePos()
            } else if current() == 36 && braceDepth == 0 {
                nextCp = cp(1)
                if isAlphaCp(nextCp) || nextCp == 95 || nextCp == 64 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    isInterpolated = true
                    advance()
                    if isAlphaCp(current()) || current() == 95 {
                        s = s + "{"
                        while current() != -1 && (isAlphaNumCp(current()) || current() == 95) {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        if current() == 63 {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        s = s + "}"
                    } else if current() == 64 {
                        s = s + "{"
                        s = s + string.fromCodePoint(advance())
                        while current() != -1 && (isAlphaNumCp(current()) || current() == 95) {
                            s = s + string.fromCodePoint(current())
                            advance()
                        }
                        s = s + "}"
                    }
                    chunkStart = bytePos()
                } else {
                    s = s + string.fromCodePoint(advance())
                    chunkStart = bytePos()
                }
            } else if current() == 123 && braceDepth == 0 {
                if cp(1) != 123 {
                    nx = cp(1)
                    isExprStart = isAlphaCp(nx) || nx == 95 || nx == 64 || nx == 40 || nx == 36 || nx == 33 || nx == 45 || isDigitCp(nx) || nx == 91
                    if nx == 125 || nx == quote || !isExprStart {
                        s = s + string.fromCodePoint(advance())
                        chunkStart = bytePos()
                    } else {
                        if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                        chunkStart = bytePos()
                        isInterpolated = true
                        s = s + string.fromCodePoint(advance())
                        braceDepth = braceDepth + 1
                        chunkStart = bytePos()
                    }
                } else {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "{"
                }
                chunkStart = bytePos()
            } else if current() == 125 && braceDepth == 0 {
                if cp(1) == 125 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "}"
                } else {
                    s = s + string.fromCodePoint(advance())
                }
                chunkStart = bytePos()
            } else {
                c = advance()
                s = s + string.fromCodePoint(c)
                if braceDepth > 0 {
                    if c == 123 { braceDepth = braceDepth + 1 }
                    else if c == 125 { braceDepth = braceDepth - 1 }
                }
            }
        }
        if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
        if current() == -1 {
            error("Unterminated multiline string")
        } else {
            advance()
            advance()
            advance()
        }
        if isInterpolated {
            addToken("InterpolatedString", s)
        } else {
            addToken("MultilineString", s)
        }
    }
    fn scanBacktick() {
        advance()
        isTriple = false
        if current() == 96 && cp(1) == 96 {
            isTriple = true
            advance()
            advance()
        }
        s = ""
        isInterpolated = isTriple
        braceDepth = 0
        if isTriple && current() == 10 { advance() }
        chunkStart = bytePos()
        while current() != -1 {
            if isTriple {
                if current() == 96 && cp(1) == 96 && cp(2) == 96 { break }
            } else {
                if current() == 96 { break }
            }
            if braceDepth == 0 && current() == 92 {
                if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                chunkStart = bytePos()
                advance()
                c = current()
                BT_ESCAPES = {110: "\n", 116: "\t", 114: "\r", 92: "\\", 96: "`"}
                esc = BT_ESCAPES[c]
                if esc != null { s = s + esc; advance() }
                else { s = s + "\\" + string.fromCodePoint(c); advance() }
                chunkStart = bytePos()
            } else if current() == 123 && isTriple && braceDepth == 0 {
                if cp(1) != 123 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    isInterpolated = true
                    s = s + string.fromCodePoint(advance())
                    braceDepth = braceDepth + 1
                } else {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "{"
                }
                chunkStart = bytePos()
            } else if current() == 125 && isTriple && braceDepth == 0 {
                if cp(1) == 125 {
                    if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
                    chunkStart = bytePos()
                    advance()
                    advance()
                    s = s + "}"
                } else {
                    s = s + string.fromCodePoint(advance())
                }
                chunkStart = bytePos()
            } else {
                c = advance()
                s = s + string.fromCodePoint(c)
                if braceDepth > 0 {
                    if c == 123 { braceDepth = braceDepth + 1 }
                    else if c == 125 { braceDepth = braceDepth - 1 }
                }
            }
        }
        if chunkStart < bytePos() { s = s + src.sub(chunkStart, bytePos() - chunkStart) }
        if current() == -1 {
            error("Unterminated backtick string")
        } else if isTriple {
            advance()
            advance()
            advance()
        } else {
            advance()
        }
        if isInterpolated {
            addToken("InterpolatedBacktick", s)
        } else {
            addToken("Backtick", s)
        }
    }
    fn scanNumber() {
        startPos = bytePos()
        if current() == 48 {
            next = cp(1)
            if next == 120 || next == 88 {
                advance()
                advance()
        if isHexDigitCp(current()) {
          while isHexDigitCp(current()) || current() == 95 {
            if current() == 95 && cp(1) != -1 && isHexDigitCp(cp(1)) { advance(); advance() }
            else if isHexDigitCp(current()) { advance() }
            else { break }
          }
                } else {
                    error("Invalid hex literal")
                }
                addToken("Number", src.sub(startPos, bytePos() - startPos))
                return
            }
            if next == 111 || next == 79 {
                advance()
                advance()
        if isOctDigitCp(current()) {
          while isOctDigitCp(current()) || current() == 95 {
            if current() == 95 && cp(1) != -1 && isOctDigitCp(cp(1)) { advance(); advance() }
            else if isOctDigitCp(current()) { advance() }
            else { break }
          }
                } else {
