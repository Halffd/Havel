// modules/lang/math.hv - Math stdlib entry point
// Loaded by `use math` from Havel scripts.
// C++ MathModule loads math/math.hv directly for sidecar merging,
// so this wrapper is for user-level `use math` imports only.
use { TAU, SQRT2, clamp, lerp, sign, fract, deg2rad,
  rad2deg, mod, distance, hypot, log2, log10, cbrt, asin, acos,
  atan2, is_nan, is_inf, is_finite, copysign, fma, rem, sum,
  mean, randint, random_range } from "math/math"
