// Check if object: identifier/string/number followed by colon or =
isObject = false
isObjKeyType = (nextTok.tid == TID.Identifier or nextTok.tid == TID.String or nextTok.tid == TID.MultilineString or nextTok.tid == TID.Number or isKeywordIdent(nextTok.tid))

if isObjKeyType {
    colonLook = lookahead + 1
    while at(colonLook).tid == TID.NewLine {
        colonLook = colonLook + 1
    }
    if at(colonLook).tid == TID.Colon or at(colonLook).tid == TID.Assign {
        isObject = true

    }
}
        if isObject {
            return parseObjectLiteral(false)

        }
