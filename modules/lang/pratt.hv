DOT_ACCESS_KEYWORDS[TID.Trait] = true; DOT_ACCESS_KEYWORDS[TID.Prot] = true; DOT_ACCESS_KEYWORDS[TID.Impl] = true

fn isKeywordIdent(ttype) {
  KEYWORD_IDENTS[ttype] != null
}

fn isDotAccessIdent(ttype) {
  KEYWORD_IDENTS[ttype] != null or DOT_ACCESS_KEYWORDS[ttype] != null
}

// --- Token types that are infix/postfix operators (have led) ---
LED_TOKENS = {}
LED_TOKENS[TID.Assign] = true; LED_TOKENS[TID.PlusAssign] = true; LED_TOKENS[TID.MinusAssign] = true
LED_TOKENS[TID.MultiplyAssign] = true; LED_TOKENS[TID.DivideAssign] = true; LED_TOKENS[TID.ModuloAssign] = true
