  pos = savePos
  syncCur()
  return parseHotkeyStatement()
 }
 // @decorator: followed by fn/class/struct/def
 skipNewlines()
 if current().tid == TID.Fn || current().tid == TID.Class || current().tid == TID.Struct || current().tid == TID.Def {
  pos = savePos
  syncCur()
  return parseAtDecoratorStatement()
 }
 // Otherwise @x is an expression (self-field access) — fall through
 pos = savePos
 syncCur()
}
	// Identifier + When/If/Arrow at statement start => hotkey
	// e.g. F1 => { ... } or a when mode == "x" => { ... } or F1 mode="gaming" => { ... }
	if tt == TID.Identifier {
		nextTid = at(1).tid
		if nextTid == TID.When || nextTid == TID.If || nextTid == TID.Arrow {
			return parseHotkeyStatement()
		}
		// identifier mode="..." or policy="..." followed by => (hotkey with attrs)
		if nextTid == TID.Identifier && (at(1).value == "mode" || at(1).value == "policy") && isHotkeyIdentifier(current().value) {
			lookPos = 2
			while at(lookPos).tid == TID.Identifier && (at(lookPos).value == "mode" || at(lookPos).value == "policy") && at(lookPos + 1).tid == TID.Assign && at(lookPos + 2).tid == TID.String {
				lookPos = lookPos + 3
			}
			if at(lookPos).tid == TID.Arrow || at(lookPos).tid == TID.When || at(lookPos).tid == TID.If {
				return parseHotkeyStatement()
			}
		}
            // identifier = hotkey => action (e.g. dhk = d => { print @id })
            if nextTid == TID.Assign {
                at2 = at(2).tid
                if at2 == TID.Hotkey || (at2 == TID.Identifier && at(3).tid == TID.Arrow) {
                    return parseHotkeyAssignmentStatement()
                }
            }
        }
        // Variable declarations
        if tt == TID.Let {
            return parseLetDecl("Let", false)
        }
        if tt == TID.Val {
            return parseLetDecl("Val", false)
        }
        if tt == TID.Const {
            return parseLetDecl("Val", false) // const is alias for val
        }
        if tt == TID.AtAt {
            advance()
            return parseLetDecl("Val", true)
        }
        // Control flow
        if tt == TID.If {
            return parseIfStatement()
        }
    if tt == TID.While {
        return parseWhileStatement()
    }
    if tt == TID.Do {
        return parseDoWhileStatement()
    }
        if tt == TID.For {
            return parseForStatement()
        }
        if tt == TID.Loop {
            return parseLoopStatement()
        }
        if tt == TID.Repeat {
            return parseRepeatStatement()
        }
        if tt == TID.Break {
            advance()
            return BreakStatement(l, c)
        }
        if tt == TID.Continue {
            advance()
            return ContinueStatement(l, c)
        }
        if tt == TID.Return or tt == TID.Ret {
            return parseReturnStatement()
        }
        if tt == TID.Throw {
            return parseThrowStatement()
        }
        if tt == TID.Try {
            return parseTryStatement()
        }
        if tt == TID.Switch {
            return parseSwitchStatement()
        }
        if tt == TID.Del {
            return parseDelStatement()

        }
        // Function declaration
        if tt == TID.Fn {
            return parseFnDeclaration()

        }
        // Import / Use
        if tt == TID.Import {
            return parseImportStatement()
        }
        if tt == TID.Use {
            return parseUseStatement()

        }
        // Config block
        if tt == TID.Config {
            return parseConfigBlockStatement()

        }
// Sleep
if tt == TID.Sleep {
	advance()
	duration = parseExpr(0)
	return SleepStatement(duration, l, c)

}
// Defer
if tt == TID.Defer {
	advance()
	if current().tid == TID.OpenBrace {
		advance()
		stmts = []
		skipNewlines()
		while current().tid != TID.CloseBrace and notEOF() {
			if current().tid == TID.NewLine { advance(); continue }
			stmts.push(parseStatement())
			skipNewlines()
		}
expect(TID.CloseBrace)
        block = BlockStatement(stmts, l, c)
        expr = LambdaExpression([], block)
        return DeferStatement(expr, l, c)
	}
	else {
		expr = parseExpr(0)
		return DeferStatement(expr, l, c)
	}
}
        // DSL statements
        if tt == TID.On: return parseOnStatement()
        if tt == TID.Mode: return parseModeBlockStatement()
 if tt == TID.Modes: return parseModesBlockStatement()
        if tt == TID.Group: return parseGroupStatement()
        if tt == TID.Signal: return parseSignalStatement()
        if tt == TID.Pool: return parsePoolStatement()
        if tt == TID.Devices: return parseDevicesBlockStatement()

        // Thread/Interval/Timeout sugar
        if tt == TID.Thread: return parseThreadStatement()
        if tt == TID.Interval: return parseIntervalStatement()
        if tt == TID.Timeout: return parseTimeoutStatement()

 // Type declarations
 if tt == TID.Class { return parseClassDeclaration() }
 if tt == TID.Struct { return parseStructDeclaration() }
 if tt == TID.Enum { return parseEnumDeclaration() }
 if tt == TID.Trait { return parseTraitDeclaration() }
 if tt == TID.Prot { return parseProtocolDeclaration() }
if tt == TID.Impl { return parseImplDeclaration() }
// When block
if tt == TID.When { return parseWhenBlockStatement() }
// With statement
if tt == TID.With { return parseWithStatement() }
// Go statement
if tt == TID.Go { return parseGoStatement() }
// Wait statement
if tt == TID.Wait { return parseWaitStatement() }
// Input statement (> prefix)
if tt == TID.Greater { return parseInputStatement() }
  // Decorator statement ([decorator]) — disambiguate from array literal
  if tt == TID.OpenBracket {
    // C++ lookahead: [identifier] followed by declaration keyword = decorator
    // [anything else] = expression (array literal or indexing)
    if at(1).tid == TID.Identifier && (at(2).tid == TID.CloseBracket || at(2).tid == TID.OpenParen) {
      // Save position, scan through [id] or [id(args)] groups
      savePos = pos
      isDeco = false
      loop {
        advance() // consume '['
        if current().tid != TID.Identifier { break }
        advance() // consume identifier
        if current().tid == TID.OpenParen {
          advance()
          parenD = 1
          while notEOF() && parenD > 0 {
            if current().tid == TID.OpenParen { parenD = parenD + 1 }
            if current().tid == TID.CloseParen { parenD = parenD - 1 }
            advance()
          }
        }
        if current().tid == TID.CloseBracket { advance() }
        else { break }
        skipNewlines()
        // Check if followed by declaration keyword
        if current().tid == TID.Fn || current().tid == TID.Class || current().tid == TID.Let || current().tid == TID.Val {
          isDeco = true
          break
        }
        // Check for stacked decorator [deco1][deco2]
        if current().tid == TID.OpenBracket && at(1).tid == TID.Identifier && (at(2).tid == TID.CloseBracket || at(2).tid == TID.OpenParen) {
          continue
        }
        break
      }
      pos = savePos
      syncCur()
      if isDeco { return parseDecoratorStatement() }
    }
    // Fall through to expression statement (array literal)
  }
// Dsl block
if tt == TID.Dsl {
  advance()
  if current().tid != TID.OpenBrace {
    error("Expected '{' after 'dsl'", current().line, current().col)
  }
  return parseBlockStatement()
}
// Expression statement
    expr = parseExpr(0)
    if expr == null: return null
    if expr.kind == "ErrorNode": return expr
    return ExpressionStatement(expr, l, c)
}
    // ===================================================================
    // STATEMENT: if
    // ===================================================================
fn parseIfStatement() {
 l = current().line
 c = current().col
 advance() // consume 'if'
 skipNewlines()

 prevSugar = allowBraceSugar
 allowBraceSugar = false
 condition = parseExpr(0)
 allowBraceSugar = prevSugar

 skipNewlines()

 thenBranch = null
 if current().tid == TID.OpenBrace {
 thenBranch = parseBlock()
 }
 if thenBranch == null && current().tid == TID.Colon {
 thenBranch = parseBlock()
 }
 if thenBranch == null {
 thenBranch = parseStatement()
 if thenBranch == null: thenBranch = BlockStatement([], l, c)
 }
 skipNewlines()

 elseBranch = null
 if current().tid == TID.Else {
 advance()
 skipNewlines()
 if current().tid == TID.If {
 elseBranch = parseIfStatement()
 }
 if elseBranch == null && current().tid == TID.OpenBrace {
 elseBranch = parseBlock()
 }
 if elseBranch == null && current().tid == TID.Colon {
  elseBranch = parseBlock()
 }
    if elseBranch == null {
      elseBranch = parseStatement()
      if elseBranch == null: elseBranch = BlockStatement([], l, c)
}
}
return IfStatement(condition, thenBranch, elseBranch, l, c)

}
    // ===================================================================
    // STATEMENT: while
    // ===================================================================
fn parseWhileStatement() {
    l = current().line
    c = current().col
    advance() // consume 'while'
    skipNewlines()

    prevSugar = allowBraceSugar
    allowBraceSugar = false
    condition = parseExpr(0)
    allowBraceSugar = prevSugar

    skipNewlines()

    body = null
    if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
    else {
        body = parseStatement()
        if body == null: body = BlockStatement([], l, c)

    }
    return WhileStatement(condition, body, l, c)

}
fn parseDoWhileStatement() {
    l = current().line
    c = current().col
    advance() // consume 'do'
    skipNewlines()

    body = null
    if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
    else {
        body = parseStatement()
        if body == null: body = BlockStatement([], l, c)
    }

    skipNewlines()
    if current().tid != TID.While {
        return error("Expected 'while' after 'do' block", current().line, current().col)
    }
    advance() // consume 'while'
    skipNewlines()

    prevSugar = allowBraceSugar
    allowBraceSugar = false
    condition = parseExpr(0)
    allowBraceSugar = prevSugar

    return DoWhileStatement(body, condition, l, c)

}
    // ===================================================================
    // STATEMENT: for
    // ===================================================================
    fn parseForStatement() {
        l = current().line
        c = current().col
        advance() // consume 'for'
        skipNewlines()

        // Parse iterator variable(s) — may be parenthesized
        names = []
        if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                names.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma: advance()
            }
            expect(TID.CloseParen)
        }
        else {
          names.push(advance().value)
          skipNewlines()
          while current().tid == TID.Comma {
            advance() // consume comma
            skipNewlines()
            names.push(advance().value)
            skipNewlines()
          }
        }
        skipNewlines()

  // Expect 'in' or ':'
  if current().tid == TID.In or current().tid == TID.Colon {
    advance()
  }
  else {
    return error("Expected 'in' or ':' in for statement", l, c)

  }
        skipNewlines()
        iterator = parseExpr(0)
        skipNewlines()

        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        }
        // If multiple names, use first as name and add keyVar
        name = names[0]
        node = ForStatement(name, iterator, body, l, c)
        if names.len > 1 {
            node.keyVar = names[0]
            node.name = names[1]
        }
        node

    }
    // ===================================================================
    // STATEMENT: loop
    // ===================================================================
    fn parseLoopStatement() {
        l = current().line
        c = current().col
        advance() // consume 'loop'
        skipNewlines()
 skipNewlines()

 countExpr = null
 condition = null

 // Check for loop count: loop 5 { ... } or loop n { ... }
 if (current().tid == TID.Number or current().tid == TID.Identifier) && notEOF() {
  savedPos = pos
  // Peek: advance past count token, skip newlines, check for {
  advance()
  skipNewlines()
  if current().tid == TID.OpenBrace {
   // This is a count-based loop - restore and parse count expr
   pos = savedPos
   syncCur()
   if current().tid == TID.Number {
    countExpr = NumberLiteral(current().value, current().line, current().col)
    advance()
   }
   else if current().tid == TID.Identifier {
    countExpr = Identifier(current().value, current().line, current().col)
    advance()
   }
   skipNewlines()
  }
  else {
   // Not a count-based loop - restore position
   pos = savedPos
   syncCur()
  }
 }

 // Check for "while condition"
 if current().tid == TID.While {
  advance() // consume 'while'
  prevSugar = allowBraceSugar
  allowBraceSugar = false
  condition = parseExpr(0)
  allowBraceSugar = prevSugar
  skipNewlines()
 }

 body = null
 if current().tid == TID.OpenBrace or current().tid == TID.Colon {
  body = parseBlock()
 }
 else {
  body = parseStatement()
  if body == null: body = BlockStatement([], l, c)

 }
 node = LoopStatement(body, l, c)
 if countExpr != null { node.count = countExpr }
 if condition != null { node.condition = condition }
 return node
    }
    // ===================================================================
    // STATEMENT: repeat
    // ===================================================================
    fn parseRepeatStatement() {
        l = current().line
        c = current().col
        advance() // consume 'repeat'
        skipNewlines()

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        count = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        }
        return RepeatStatement(count, body, l, c)

    }
    // ===================================================================
    // STATEMENT: return
    // ===================================================================
    fn parseReturnStatement() {
        l = current().line
        c = current().col
        advance() // consume 'return' or 'ret'
        skipNewlines()

        // @ without following identifier -> return this
        if current().tid == TID.At and at(1).tid != TID.Identifier {
            advance()
            return ReturnStatement(Identifier("this", l, c), l, c)

        }
        value = null
        // Return value is optional — check if next token can start expression
        if canStartExpr(current().tid) or (current().tid == TID.Not and isNotIn()) or current().tid == TID.Minus or current().tid == TID.Plus {
            value = parseExpr(0)

        }
        return ReturnStatement(value, l, c)

    }
    // ===================================================================
    // STATEMENT: throw
    // ===================================================================
    fn parseThrowStatement() {
        l = current().line
        c = current().col
        advance() // consume 'throw'
        skipNewlines()
        value = parseExpr(0)
        return ThrowStatement(value, l, c)

    }
    // ===================================================================
    // STATEMENT: try/catch/finally
    // ===================================================================
    fn parseTryStatement() {
        l = current().line
        c = current().col
        advance() // consume 'try'
        skipNewlines()

        tryBlock = parseBlock()
        skipNewlines()

        catchParam = null
        catchBlock = null
        finallyBlock = null

if current().tid == TID.Catch {
advance()
skipNewlines()
if current().tid == TID.OpenParen {
advance() // consume (
skipNewlines()
if current().tid == TID.Identifier {
catchParam = advance().value
}
skipNewlines()
if current().tid == TID.CloseParen {
advance() // consume )
}
}
else if current().tid == TID.Identifier {
catchParam = advance().value
}
skipNewlines()
catchBlock = parseBlock()
skipNewlines()

}
        if current().tid == TID.Finally {
            advance()
            skipNewlines()
            finallyBlock = parseBlock()

        }
        return TryStatement(tryBlock, catchParam, catchBlock, finallyBlock, l, c)

    }
    // ===================================================================
    // STATEMENT: switch
    // ===================================================================
    fn parseSwitchStatement() {
        l = current().line
        c = current().col
        advance() // consume 'switch'
        skipNewlines()

        subject = parseExpr(0)
        skipNewlines()

        if current().tid == TID.OpenBrace {
            advance()
        }
        else if current().tid == TID.Colon {
            advance()
        }
        else {
            return error("Expected '{' or ':' after switch", l, c)

        }
        cases = []
        skipNewlines()
        while current().tid != TID.CloseBrace and notEOF() and current().tid != TID.EOF {
            skipNewlines()
            if current().tid == TID.CloseBrace: break

            if current().tid == TID.Case {
                advance()
                test = parseExpr(0)
            }
            else if current().tid == TID.Default {
                advance()
                test = null
            }
            else {
                // expression as case
                test = parseExpr(0)

            }
            skipNewlines()

            if current().tid == TID.Arrow {
                advance()
            }
            else if current().tid == TID.Colon {
                advance()
            }
            else {
                // Try to continue anyway
                pass

            }
            skipNewlines()
            body = parseBlock()
            cases.push({test: test, body: body})
            skipNewlines()

        }
        if current().tid == TID.CloseBrace {
            advance()

        }
        // Represent as MatchExpression (switch is syntactic sugar for match)
        matchCases = []
        for c in cases {
            matchCases.push(MatchCase(c.test, null, c.body, l, c))
        }
        return MatchExpression(subject, matchCases, l, c)

    }
    // ===================================================================
    // STATEMENT: del
    // ===================================================================
    fn parseDelStatement() {
        l = current().line
        c = current().col
        advance() // consume 'del'
        skipNewlines()

        // del(...) as function call or del expr
        if current().tid == TID.OpenParen {
            // Could be del(expr) — parse as call
            callee = Identifier("del", l, c)
            args = parseCallArgs()
            return ExpressionStatement(CallExpression(callee, args, [], l, c), l, c)

        }
        target = parseExpr(0)
        node = ExpressionStatement(target, l, c)
        node.isDel = true
        node

    }
    // ===================================================================
    // STATEMENT: fn declaration
    // ===================================================================
    fn parseFnDeclaration() {
        l = current().line
        c = current().col
        advance() // consume 'fn'
        skipNewlines()

        // Check if this is a lambda (fn followed by open paren)
        if current().tid == TID.OpenParen {
         lambda = parseLambdaExpr()
         return ExpressionStatement(lambda, l, c)
        
        }
  // Function name
  name = advance().value
  skipNewlines()

    // Parse optional type parameters: fn identity(T)(x: T): T { x }
    // or with bounds: fn calc(T: Number)(a: T, b: T): T { ... }
    typeParams = parseTypeParameterList()

  // Params
  params = []
  if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
      // Param name — must be Identifier or keyword-as-ident (not Fn, it's ambiguous with lambda)
      pt = current().tid
      if pt == TID.Fn {
        return error("'fn' cannot be used as a parameter name (reserved for lambda syntax)", current().line, current().col)
      }
      isVariadic = false
      if pt == TID.Spread {
        isVariadic = true
        advance()
        skipNewlines()
        pt = current().tid
      }
      if pt != TID.Identifier && !isKeywordIdent(pt) {
                return error("Expected parameter name, got " + pt, current().line, current().col)
            }
      pname = advance().value
      p = {name: pname}
      if isVariadic: p.isVariadic = true
      // Type annotation
      if current().tid == TID.Colon {
        advance()
        p.typeAnn = advance().value
        skipNewlines()
      }
      // Default value
      if current().tid == TID.Assign {
        advance()
        p.defval = parseExpr(0)
        skipNewlines()
      }
      params.push(p)
      if current().tid == TID.Comma: advance()
      }
      expect(TID.CloseParen)
      skipNewlines()

        }
        // Return type annotation
        if current().tid == TID.ReturnType {
            advance()
            advance() // consume type name
            skipNewlines()

        }
 // Body
 body = null
 if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
 else if current().tid == TID.If or current().tid == TID.While or current().tid == TID.For or current().tid == TID.Loop or current().tid == TID.Return or current().tid == TID.Ret or current().tid == TID.Let or current().tid == TID.Val or current().tid == TID.Try or current().tid == TID.Switch or current().tid == TID.Break or current().tid == TID.Continue or current().tid == TID.Throw {
  // Statement body — parse multiple statements like colon block
  fnIndent = c
  baseIndent = fnIndent + 1
  stmts = []
  while notEOF() and current().tid != TID.EOF {
   skipNewlines()
   if current().tid == TID.EOF: break
 if current().col < baseIndent: break
 s = parseStatement()
 if s != null and s.kind != "ErrorNode" {
  stmts.push(s)
 }
 skipNewlinesAndSemicolons()
 if current().tid == TID.EOF: break
 if current().col < baseIndent: break
 endTokens = {}
 endTokens[TID.Else] = true; endTokens[TID.Catch] = true; endTokens[TID.Finally] = true; endTokens[TID.Case] = true; endTokens[TID.Default] = true
 if endTokens[current().tid] != null: break
 }
 body = BlockStatement(stmts, l, c)
 }
    else {
        // Expression body
        bodyExpr = parseExpr(0)
        body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

    }
    return FnDeclaration(name, params, body, l, c, typeParams)

    }
    // ===================================================================
    // STATEMENT: let / val declaration
    // ===================================================================
fn parseLetDecl(keyword, isStatic = false) {
  l = current().line
  c = current().col
  advance() // consume 'let'/'val'/'const'
  skipNewlines()

  pattern = null
  name = null

  // Array destructuring: let [a, b] = val
  if current().tid == TID.OpenBracket {
    pattern = parseArrayPatternForMatch()
  }
  // Tuple destructuring: let (a, b) = val
  else if current().tid == TID.OpenParen {
    advance() // consume '('
    elements = []
    while notEOF() && current().tid != TID.CloseParen {
      skipNewlines()
      if current().tid == TID.CloseParen { break }
      if current().tid != TID.Identifier {
        error("Expected identifier in tuple destructuring", current().line, current().col)
        break
      }
      elements.push(Identifier(current().value, current().line, current().col))
      advance()
      skipNewlines()
      if current().tid == TID.Comma { advance() }
    }
    if current().tid == TID.CloseParen { advance() }
    pattern = ArrayPattern(elements, null, l, c)
    pattern.isTuple = true
  }
  // Object destructuring: let {x, y} = val
  else if current().tid == TID.OpenBrace {
    pattern = parseObjectPatternForMatch()
  }
  // Identifier — simple or comma-separated
  else if current().tid == TID.Identifier {
    name = current().value
    advance()
    skipNewlines()
    // Comma-separated: val a, b, c = value
    if current().tid == TID.Comma {
      elements = [Identifier(name, l, c)]
      while current().tid == TID.Comma {
        advance() // consume comma
        skipNewlines()
        if current().tid != TID.Identifier {
          error("Expected identifier after comma", current().line, current().col)
          break
        }
        elements.push(Identifier(current().value, current().line, current().col))
        advance()
        skipNewlines()
      }
      pattern = ArrayPattern(elements, null, l, c)
      name = null
    }
  }
  else {
    error("Expected identifier, '[' or '{' after declaration", current().line, current().col)
  }

  skipNewlines()

  // Type annotation
  typeAnno = null
  if current().tid == TID.Colon {
    advance() // consume ':'
    typeAnno = advance().value // type name
    skipNewlines()
  }

  value = null
  if current().tid == TID.Assign {
    advance()
    skipNewlines()
    value = parseExpr(0)
  }

  if keyword == "Let" {
    node = LetDeclaration(name, value, l, c)
  node.isStatic = isStatic
  }
  else {
    node = ValDeclaration(name, value, l, c)
  node.isStatic = isStatic
  }
  if pattern != null { node.pattern = pattern }
  if typeAnno != null { node.typeAnnotation = typeAnno }
  node
}
    // ===================================================================
    // STATEMENT: import
    // ===================================================================
fn parseImportStatement() {
  l = current().line
  c = current().col
  advance()
  skipNewlines()

  iNames = []
  iAliases = []

  // import * from "module"
  if current().tid == TID.Multiply {
    advance()
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, ["*"], l, c, {isWildcard: true})
  }

  // import { names } from "module" or import a, b from "module"
  if current().tid == TID.OpenBrace {
    advance()
    skipNewlines()
    while current().tid != TID.CloseBrace and notEOF() {
      skipNewlines()
      if current().tid == TID.CloseBrace: break
      n = advance().value
      a = n
      if current().tid == TID.As {
        advance()
        skipNewlines()
        a = advance().value
      }
      iNames.push(n)
      iAliases.push(a)
      skipNewlines()
      if current().tid == TID.Comma: advance()
    }
    expect(TID.CloseBrace)
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, iNames, l, c, {importNames: iNames, importAliases: iAliases})
  }

  // import identifier[, identifier...] from "module"
  if current().tid == TID.Identifier {
    n = advance().value
    iNames.push(n)
    iAliases.push(n)
    skipNewlines()
    while current().tid == TID.Comma {
      advance()
      skipNewlines()
      n = advance().value
      iNames.push(n)
      iAliases.push(n)
      skipNewlines()
    }
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, iNames, l, c, {importNames: iNames, importAliases: iAliases})
  }

  // bare: import "module"
  module = advance().value
  return ImportStatement(module, [], l, c, null)

}
    // ===================================================================
    // STATEMENT: use
    // ===================================================================
fn parseUseStatement() {
  l = current().line
  c = current().col
  advance()
  skipNewlines()

  // use { names } from "module" — named imports
  if current().tid == TID.OpenBrace {
    names = []
    iNames = []
    iAliases = []
    advance()
    skipNewlines()
    while current().tid != TID.CloseBrace and notEOF() {
      skipNewlines()
      if current().tid == TID.CloseBrace: break
      n = advance().value
      a = n
      if current().tid == TID.As {
        advance()
        skipNewlines()
        a = advance().value
      }
      names.push(n)
      iNames.push(n)
      iAliases.push(a)
      skipNewlines()
      if current().tid == TID.Comma: advance()
    }
    expect(TID.CloseBrace)
    skipNewlines()
    if current().tid != TID.From {
      return UseStatement(null, names, l, c, null)
    }
    advance()
    skipNewlines()
    module = advance().value
    return UseStatement(module, names, l, c, {isFileImport: true, isNamedImport: true,
      filePath: module, importNames: iNames, importAliases: iAliases})
  }

  // use * from "module" — wildcard
  if current().tid == TID.Multiply {
    advance()
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return UseStatement(module, ["*"], l, c, {isFileImport: true, isWildcard: true,
      filePath: module})
  }

  // use "file.hv" or use "file.hv" as alias
  if current().tid == TID.String || current().tid == TID.InterpolatedString {
    fpath = advance().value
    skipNewlines()
    alias = null
    if current().tid == TID.As {
      advance()
      skipNewlines()
      alias = advance().value
    }
    if alias != null {
      return UseStatement(fpath, [], l, c, {isFileImport: true, filePath: fpath, alias: alias})
    }
    return UseStatement(fpath, ["*"], l, c, {isFileImport: true, filePath: fpath,
      isWildcard: true})
  }

  // use module or use module as alias or use module, module2
  firstMod = advance().value
  skipNewlines()

  // use module.* — wildcard via dot-star
  if current().tid == TID.Dot {
    advance()
    skipNewlines()
    if current().tid == TID.Multiply {
      advance()
      return UseStatement(firstMod, ["*"], l, c, {isWildcard: true, filePath: firstMod,
        moduleNames: [firstMod]})
    }
    return UseStatement(firstMod, [], l, c, null)
  }

  // use module as alias
  if current().tid == TID.As {
    advance()
    skipNewlines()
    alias = advance().value
    return UseStatement(firstMod, [], l, c, {alias: alias, moduleNames: [firstMod]})
  }

  // use module from "source"
  if current().tid == TID.From {
    advance()
    skipNewlines()
    source = advance().value
    return UseStatement(source, [], l, c, {isFileImport: true, filePath: source, alias: firstMod})
  }

  // use module, module2, ... — multiple bare module names
  mods = [firstMod]
  while current().tid == TID.Comma {
    advance()
    skipNewlines()
    if current().tid == TID.Identifier || current().tid == TID.Keyword {
      mods.push(advance().value)
      skipNewlines()
    }
  }
  return UseStatement(firstMod, [], l, c, {moduleNames: mods})

}
// --- Helper: parse mode="..." policy="..." attributes after hotkey key ---
fn parseHotkeyAttrs() {
  modeAttr = ""
  policyAttr = ""
  while current().tid == TID.Identifier && (current().value == "mode" || current().value == "policy") {
    attrName = current().value
    nextTid = at(1).tid
    if nextTid != TID.Assign { break }
    advance() // consume attr name
    advance() // consume '='
    if current().tid == TID.String {
      attrValue = advance().value
      if attrName == "mode" { modeAttr = attrValue }
      else { policyAttr = attrValue }
    }
  }
  {mode: modeAttr, policy: policyAttr}
}
// ===================================================================
// STATEMENT: hotkey binding
// ===================================================================
fn parseHotkeyStatement() {
        l = current().line
        c = current().col

        // Collect the hotkey token(s)
        key = ""
        if current().tid == TID.Hotkey {
            key = advance().value
        }
        else if current().tid == TID.At {
            advance()
            if current().tid == TID.Identifier {
                key = "@" + advance().value
            }
            else {
                key = "@"

            }
        }
	else if current().tid == TID.Identifier {
		key = advance().value
	}
	skipNewlines()

	// Parse optional inline attributes: mode="name" policy="replace"
	attrs = parseHotkeyAttrs()
	modeAttr = attrs.mode
	policyAttr = attrs.policy
	skipNewlines()

	// Optional when/if prefix condition
        condition = null
        if current().tid == TID.When or current().tid == TID.If {
            advance()
            condition = parseExpr(BP_ASSIGN)

        }
        skipNewlines()

        // Expect => or {
        if current().tid == TID.Arrow {
            advance()
            skipNewlines()
        }
        else if current().tid != TID.OpenBrace and current().tid != TID.Colon {
            return error("Expected '=>' or '{' after hotkey", l, c)

        }
        // Parse body
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        }
	node = HotkeyBinding([key], body, l, c)
	if condition != null: node.condition = condition
	if modeAttr != "": node.mode = modeAttr
	if policyAttr != "": node.policy = policyAttr
	node

}
    // ===================================================================
    // STATEMENT: hotkey assignment (identifier = hotkey => action)
    // ===================================================================
fn parseHotkeyAssignmentStatement() {
	l = current().line
	c = current().col
	target = Identifier(advance().value, l, c)
	advance() // consume =
	hkToken = advance()
	key = hkToken.value
	if hkToken.tid == TID.Identifier { key = hkToken.value }
	skipNewlines()
	// Parse optional inline attributes: mode="name" policy="replace"
	attrs = parseHotkeyAttrs()
	modeAttr = attrs.mode
	policyAttr = attrs.policy
	condition = null
	if current().tid == TID.When or current().tid == TID.If {
            advance()
            condition = parseExpr(BP_ASSIGN)
        }
        skipNewlines()
        if current().tid == TID.Arrow {
            advance()
            skipNewlines()
        }
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
	binding = HotkeyBinding([key], body, l, c)
	if condition != null: binding.condition = condition
	if modeAttr != "": binding.mode = modeAttr
	if policyAttr != "": binding.policy = policyAttr
	hkExpr = HotkeyExpression(binding, l, c)
        assign = AssignmentExpression(target, hkExpr, "=", false, l, c)
        ExpressionStatement(assign, l, c)
    }
    // ===================================================================
    // STATEMENT: config block
    // ===================================================================
    fn parseConfigBlockStatement() {
        l = current().line
        c = current().col
        advance() // consume 'config'
        skipNewlines()
        name = ""
        if current().tid != TID.OpenBrace {
            name = advance().value
            skipNewlines()
        }
        body = parseBlock()
        return ConfigBlock(name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: on
    // ===================================================================
fn parseOnStatement() {
  l = current().line
  c = current().col
  advance() // consume 'on'
  skipNewlines()

  // on mode {name} { ... }
  if current().tid == TID.Mode {
    return parseOnModeStatementBody()
  }

  // on <identifier> ...
  if current().tid == TID.Identifier {
    keyword = current().value

    if keyword == "reload" {
      advance()
      skipNewlines()
      body = parseBlock()
      return OnReloadStatement(body, l, c)
    }
    if keyword == "start" {
      advance()
      skipNewlines()
      body = parseBlock()
      return OnStartStatement(body, l, c)
    }
    if keyword == "tap" || keyword == "combo" {
      return parseOnTapOrComboStatement()
    }
    if keyword == "keydown" || keyword == "keyup" {
      return parseOnKeyDownOrKeyUpStatement()
    }
    // Generic message handler: on <identifier> { ... }
    msgVar = advance().value
    skipNewlines()
    body = parseBlock()
    return OnMessageStatement(msgVar, body, l, c)
  }

  return error("Expected 'mode', 'reload', 'start', 'tap', 'combo', 'keydown', 'keyup', or message variable after 'on'", l, c)
}

fn parseOnModeStatementBody() {
  advance() // consume 'mode'
  skipNewlines()
  modeName = advance().value
  skipNewlines()
  body = parseBlock()
  alternative = null
  skipNewlines()
  if current().tid == TID.Else {
    advance()
    skipNewlines()
    alternative = parseBlock()
  }
  return OnModeStatement(modeName, body, alternative, current().line, current().col)
}

fn parseOnTapOrComboStatement() {
  isTap = current().value == "tap"
  advance() // consume 'tap' or 'combo'
  skipNewlines()
  if current().tid != TID.OpenParen {
    return error("Expected '(' after 'on " + (isTap ? "tap" : "combo") + "'", current().line, current().col)
  }
  advance() // consume '('
  skipNewlines()
  keyName = ""
  if current().tid == TID.Hotkey {
    keyName = advance().value
  } else if current().tid == TID.Identifier {
    keyName = advance().value
  } else {
    return error("Expected key name in on tap/combo", current().line, current().col)
  }
  if current().tid == TID.CloseParen { advance() }
  skipNewlines()
  if current().tid == TID.Arrow { advance() }
  skipNewlines()
  body = parseBlock()
  if isTap {
    return OnTapStatement(keyName, body, current().line, current().col)
  }
  return OnComboStatement(keyName, body, current().line, current().col)
}

fn parseOnKeyDownOrKeyUpStatement() {
  isKeyDown = current().value == "keydown"
  advance() // consume 'keydown' or 'keyup'
  skipNewlines()
  keys = []
  if current().tid == TID.OpenParen {
    advance() // consume '('
    while notEOF() && current().tid != TID.CloseParen {
      skipNewlines()
      if current().tid == TID.CloseParen { break }
      if current().tid == TID.Hotkey {
        keys.push(advance().value)
      } else if current().tid == TID.Identifier {
        keys.push(advance().value)
      } else {
        return error("Expected key name in key list", current().line, current().col)
      }
      skipNewlines()
      if current().tid == TID.Comma { advance() }
      else if current().tid != TID.CloseParen {
        return error("Expected ',' or ')' in key list", current().line, current().col)
      }
    }
    if current().tid == TID.CloseParen { advance() }
  }
  skipNewlines()
  body = parseBlock()
  if isKeyDown {
    return OnKeyDownStatement(keys, body, current().line, current().col)
  }
  return OnKeyUpStatement(keys, body, current().line, current().col)
}
    // ===================================================================
    // STATEMENT: mode block
    // ===================================================================
 fn parseModeBlockStatement() {
 l = current().line
 c = current().col
 advance() // consume 'mode'
 skipNewlines()
 name = advance().value
 skipNewlines()
 // Parse optional priority
 priority = 0
 if current().tid == TID.Identifier && current().value == "priority" {
  advance()
  priority = int(advance().value)
  skipNewlines()
 }
 // Disambiguate: if opening brace and first token is condition/enter/exit/on,
 // it's a full mode definition. Otherwise it's a simple mode block.
 if current().tid == TID.OpenBrace {
  savedPos = pos
  advance() // consume '{'
  skipNewlines()
  firstTok = current()
  pos = savedPos
  syncCur()
  isFullDefinition = (firstTok.tid == TID.Identifier && (firstTok.value == "condition" || firstTok.value == "enter" || firstTok.value == "exit" || firstTok.value == "on")) || firstTok.tid == TID.On
  if isFullDefinition {
   return parseModeFullDefinition(name, priority, l, c)
  }
 }
 // Simple mode block: mode name { statements }
 body = parseBlock()
 return ModeBlock(name, body, l, c)

 }
 fn parseModeFullDefinition(name, priority, l, c) {
 advance() // consume '{'
 skipNewlines()
 condition = null
 enterBlock = null
 exitBlock = null
 onEnterFrom = ""
 onExitTo = ""
 onEnterFromBlock = null
 onExitToBlock = null
 while current().tid != TID.CloseBrace && current().tid != TID.EOF {
  if current().tid == TID.Newline || current().tid == TID.Semicolon {
   advance()
   continue
  }
  curTid = current().tid
  if curTid != TID.Identifier && curTid != TID.On && curTid != TID.From {
   break
  }
  keyword = current().value
  advance()
if keyword == "condition" {
      if current().tid != TID.Assign && current().tid != TID.Colon {
        error("Expected '=' or ':' after 'condition'", current().line, current().col)
      }
      advance()
      condition = parseExpr(0)
  }
  else if keyword == "enter" {
   enterBlock = parseBlock()
  }
  else if keyword == "exit" {
   exitBlock = parseBlock()
  }
  else if keyword == "on" {
   if current().tid != TID.Identifier { break }
   eventType = current().value
   advance()
   if eventType == "enter" {
    if current().tid == TID.From || (current().tid == TID.Identifier && current().value == "from") {
     advance()
     onEnterFrom = current().value
     advance()
     onEnterFromBlock = parseBlock()
    }
    else {
     enterBlock = parseBlock()
    }
   }
   else if eventType == "exit" {
    if current().tid == TID.Identifier && current().value == "to" {
     advance()
     onExitTo = current().value
     advance()
     onExitToBlock = parseBlock()
    }
    else {
     exitBlock = parseBlock()
    }
   }
   else {
    // on close/minimize/maximize/open — skip for now
    parseBlock()
   }
  }
  skipNewlines()
 }
 if current().tid == TID.CloseBrace { advance() }
 modeDef = ModeDefinition(name, condition, enterBlock, exitBlock)
 modeDef.priority = priority
 modeDef.onEnterFrom = onEnterFrom
 modeDef.onExitTo = onExitTo
 modeDef.onEnterFromBlock = onEnterFromBlock
 modeDef.onExitToBlock = onExitToBlock
 return ModesBlock([modeDef])

 }
 fn parseModesBlockStatement() {
 l = current().line
 c = current().col
 advance() // consume 'modes'
 skipNewlines()
 if current().tid != TID.OpenBrace {
  return ConfigBlock("modes", parseBlock(), l, c)
 }
 advance() // consume '{'
 skipNewlines()
 modeDefs = []
 while current().tid != TID.CloseBrace && current().tid != TID.EOF {
  if current().tid == TID.Newline {
   advance()
   continue
  }
  if current().tid != TID.Identifier { break }
  modeName = current().value
  advance()
  skipNewlines()
  if current().tid != TID.OpenBrace { break }
  advance() // consume '{'
  skipNewlines()
  condition = null
  enterBlock = null
  exitBlock = null
  while current().tid != TID.CloseBrace && current().tid != TID.EOF {
   if current().tid == TID.Newline || current().tid == TID.Semicolon {
    advance()
    continue
   }
   if current().tid != TID.Identifier { break }
   keyword = current().value
   advance()
   if keyword == "condition" {
    if current().tid == TID.Assign || current().tid == TID.Colon {
     advance()
    }
    condition = parseExpr(0)
   }
   else if keyword == "enter" {
    enterBlock = parseBlock()
   }
   else if keyword == "exit" {
    exitBlock = parseBlock()
   }
   skipNewlines()
  }
  if current().tid == TID.CloseBrace { advance() }
  modeDefs.push(ModeDefinition(modeName, condition, enterBlock, exitBlock))
  skipNewlines()
 }
 if current().tid == TID.CloseBrace { advance() }
 return ModesBlock(modeDefs)

 }
// ===================================================================
 // STATEMENT: group
 // ===================================================================
    fn parseGroupStatement() {
        l = current().line
        c = current().col
        advance() // consume 'group'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("group:" + name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: signal
    // ===================================================================
    fn parseSignalStatement() {
        l = current().line
        c = current().col
        advance() // consume 'signal'
        skipNewlines()
        name = advance().value
        skipNewlines()
        value = null
        if current().tid == TID.Assign {
            advance()
            value = parseExpr(0)
        }
        node = LetDeclaration(name, value, l, c)
        node.isSignal = true
        node

    }
    // ===================================================================
    // STATEMENT: pool
    // ===================================================================
    fn parsePoolStatement() {
        l = current().line
        c = current().col
        advance() // consume 'pool'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("pool:" + name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: devices block
    // ===================================================================
    fn parseDevicesBlockStatement() {
        l = current().line
        c = current().col
        advance() // consume 'devices'
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("devices", body, l, c)

    }
    // ===================================================================
    // STATEMENT: thread/interval/timeout sugar
    // ===================================================================
    fn parseThreadStatement() {
        l = current().line
        c = current().col
        advance() // consume 'thread'
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__thread__", [], body, l, c, [])
        node.isThread = true
        node

    }
    fn parseIntervalStatement() {
        l = current().line
        c = current().col
        advance() // consume 'interval'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__interval__", [], body, l, c, [])
        node.isInterval = true
        node.intervalDuration = duration
        node

    }
    fn parseTimeoutStatement() {
        l = current().line
        c = current().col
        advance() // consume 'timeout'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__timeout__", [], body, l, c, [])
        node.isTimeout = true
node.timeoutDuration = duration
    node

}
// ===================================================================
// Type parameter list parser: (T) or (T: Bound) or (T: B1 & B2, E)
// Returns [] if no type parameters found (backtracks on failure)
// ===================================================================
fn parseTypeParameterList() {
    if current().tid != TID.OpenParen { return [] }
    nextTok = at(1)
    if nextTok.tid != TID.Identifier { return [] }
    savedPos = pos
    advance() // consume '('
    candidateParams = []
    isTypeParamList = true
    while current().tid == TID.Identifier && isTypeParamList {
        pname = advance().value
        bounds = []
        // Check for bound: T: Bound [& Bound2 ...]
        if current().tid == TID.Colon {
            advance() // consume ':'
            if current().tid == TID.Identifier {
                bounds.push(advance().value)
                while current().tid == TID.BitwiseAnd {
                    advance() // consume '&'
                    if current().tid == TID.Identifier {
                        bounds.push(advance().value)
                    } else {
                        isTypeParamList = false
                        break
                    }
                }
            } else {
                isTypeParamList = false
                break
            }
        }
        candidateParams.push(TypeParam(pname, bounds))
        if current().tid == TID.Comma {
            advance() // consume ','
        } else {
            break
        }
    }
  if isTypeParamList && current().tid == TID.CloseParen {
    advance() // consume ')'
    if !candidateParams.isEmpty() {
      // Only accept as type params if followed by another '(' for regular params
      // Otherwise this is just a regular parameter list — backtrack
      if current().tid == TID.OpenParen {
        return candidateParams
      }
      // Not followed by '(' — backtrack
      pos = savedPos
      syncCur()
      return []
    }
  }
  // Backtrack — not a type parameter list
  pos = savedPos
  syncCur()
  return []
  }

// ===================================================================
// STATEMENT: class declaration
// ===================================================================
fn parseClassDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'class'
    skipNewlines()
    name = current().value
    advance() // consume class name
    // Parse optional type parameters: class Calc(T: Number) { ... }
    typeParams = parseTypeParameterList()
    parentName = ""
    isColonBody = false
    // Check for inheritance: class X : ParentClass
    // vs colon body: class X :
    if current().tid == TID.Colon {
        nextTok = at(1)
        if nextTok.tid == TID.Identifier && nextTok.line == current().line {
            advance() // consume ':'
            parentName = current().value
            advance() // consume parent name
        } else {
            isColonBody = true
        }
    }
    // After inheritance, check for colon body
    if !isColonBody && current().tid == TID.Colon {
        isColonBody = true
    }
    fields = []
    methods = []
    if isColonBody {
        advance() // consume ':'
        skipNewlines()
        _parseClassMembers(methods, fields)
    } else if current().tid == TID.OpenBrace {
        advance() // consume '{'
        skipNewlines()
        _parseClassMembers(methods, fields)
        if current().tid == TID.CloseBrace {
            advance() // consume '}'
        }
    }
    return ClassDeclaration(name, parentName, fields, methods, l, c, typeParams)

}

fn _parseClassMembers(methods, fields) {
	while notEOF() && current().tid != TID.CloseBrace && current().tid != TID.EOF {
		skipNewlinesAndSemicolons()
		if !notEOF() || current().tid == TID.CloseBrace || current().tid == TID.EOF { break }
		tt = current().tid
		if tt == TID.Fn {
			m = _parseClassMethod()
			methods.push(m)
			continue
		}
		if tt == TID.Op {
			advance() // consume 'op'
			m = _parseClassOperatorMethod()
			methods.push(m)
			continue
		}
		// Field definition: name [: Type] [= default] or @@name [: Type] [= default]
		isClassField = false
		if tt == TID.AtAt {
			isClassField = true
			advance() // consume '@@'
		}
		fname = current().value
		fline = current().line
		fcol = current().col
		advance() // consume field name
		// Skip optional type annotation
		if current().tid == TID.Colon {
			advance() // consume ':'
			skipNewlines()
			if current().tid == TID.Identifier {
				advance() // consume type name
			}
		}
		// Optional default value
		defaultValue = null
		if current().tid == TID.Assign {
			advance() // consume '='
			defaultValue = parseExpr(0)
		}
		// Optional comma
		if current().tid == TID.Comma {
			advance()
		}
		fields.push({name: fname, isClassField: isClassField, defaultValue: defaultValue, line: fline, col: fcol})
	}

}

fn _parseClassMethod() {
	advance() // consume 'fn'
	mline = current().line
	mcol = current().col
	methodName = current().value
	// Handle constructor: fn @()
	if current().tid == TID.At {
		advance() // consume '@'
		methodName = "init"
	} else {
		advance() // consume method name
	}
	// Parse params
	params = []
	if current().tid == TID.OpenParen {
		advance() // consume '('
		while notEOF() && current().tid != TID.CloseParen {
			skipNewlines()
			if current().tid == TID.CloseParen { break }
			pname = current().value
 p = {name: pname}
 p.default = null
 advance() // consume param name
 // Optional default value
 if current().tid == TID.Assign {
 advance() // consume '='
 p.default = parseExpr(0)
 }
			params.push(p)
			skipNewlines()
			if current().tid == TID.Comma { advance() }
		}
		if current().tid == TID.CloseParen {
			advance() // consume ')'
		}
	}
	skipNewlines()
	// Parse body
	body = parseBlock()
	{name: methodName, params: params, body: body, line: mline, col: mcol}

}

fn _parseClassOperatorMethod() {
    mline = current().line
    mcol = current().col
    tv = current().value
    tt = current().tid

    OP_METHOD_MAP = {
        "+": "op_add", "-": "op_sub", "*": "op_mul", "/": "op_div",
        "==": "op_eq", "!=": "op_ne", "<": "op_lt", ">": "op_gt",
        "<=": "op_le", ">=": "op_ge", "[]": "op_index", "[]=": "op_index_set",
        "#": "op_length", "repr": "op_repr"
    }

    methodName = OP_METHOD_MAP[tv]
    if methodName == null && tt == TID.Not { methodName = "op_not" }
    if methodName == null && tt == TID.OpenBracket {
        advance() // consume '['
        if current().tid == TID.CloseBracket {
            advance() // consume ']'
            if current().tid == TID.Assign {
                advance() // consume '='
                methodName = "op_index_set"
            } else {
                methodName = "op_index"
            }
        }
    }
    else if methodName == null && tt == TID.OpenParen {
        methodName = "op_call"
    }
    if methodName == null { methodName = "op_" + tv }
	if methodName != "" && methodName.startsWith("op_") && current().tid != TID.OpenBracket && current().tid != TID.OpenParen {
		advance() // consume the operator token
	}
	// Parse params
	params = []
	if current().tid == TID.OpenParen {
		advance() // consume '('
		while notEOF() && current().tid != TID.CloseParen {
			skipNewlines()
			if current().tid == TID.CloseParen { break }
			pname = current().value
 p = {name: pname}
 p.default = null
 advance()
 if current().tid == TID.Assign {
 advance()
 p.default = parseExpr(0)
 }
			params.push(p)
			skipNewlines()
			if current().tid == TID.Comma { advance() }
		}
		if current().tid == TID.CloseParen {
			advance()
		}
	}
	skipNewlines()
	body = parseBlock()
	{name: methodName, params: params, body: body, line: mline, col: mcol}

}

// ===================================================================
// STATEMENT: struct declaration
// ===================================================================
fn parseStructDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'struct'
    skipNewlines()
    name = current().value
    advance() // consume struct name
    // Parse optional type parameters: struct Container(T: Number) { ... }
    typeParams = parseTypeParameterList()
    fields = []
    methods = []
    // struct Foo(field1, field2) or struct Foo { ... }
    if current().tid == TID.OpenParen {
        advance() // consume '('
        while notEOF() && current().tid != TID.CloseParen {
            skipNewlines()
            if current().tid == TID.CloseParen { break }
            fname = current().value
            f = {name: fname, isClassField: false, defaultValue: null, line: current().line, col: current().col}
            advance() // consume field name
            // Optional default value
            if current().tid == TID.Assign {
                advance()
                f.defaultValue = parseExpr(0)
            }
            fields.push(f)
            skipNewlines()
            if current().tid == TID.Comma { advance() }
        }
        if current().tid == TID.CloseParen {
            advance() // consume ')'
        }
    }
    skipNewlines()
 // Protocol conformance: struct Foo: ProtocolName [, Protocol2]
 // Disambiguate: ':' followed by identifier on same line = protocol conformance
 // ':' followed by newline (or non-identifier) = colon body
 protocolNames = []
 if current().tid == TID.Colon {
  nextTok = at(1)
  if nextTok.tid == TID.Identifier && nextTok.line == current().line {
   advance() // consume ':'
   protocolNames.push(advance().value)
   while current().tid == TID.Comma {
    advance() // consume ','
    if current().tid != TID.Identifier {
     return error("Expected protocol name after ','", l, c)
    }
    protocolNames.push(advance().value)
   }
  }
 }
    if current().tid == TID.OpenBrace {
        advance() // consume '{'
        skipNewlines()
        _parseClassMembers(methods, fields)
        if current().tid == TID.CloseBrace {
            advance() // consume '}'
        }
    } else if current().tid == TID.Colon {
        advance() // consume ':'
        skipNewlines()
        _parseClassMembers(methods, fields)
    }
    return StructDeclaration(name, fields, methods, protocolNames, l, c, typeParams)

}

// ===================================================================
// STATEMENT: enum declaration
// enum Name { Variant1, Variant2(Type), Variant3 }
// ===================================================================
fn parseEnumDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'enum'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected enum name after 'enum'", l, c)
    }
    name = advance().value
    // Parse optional type parameters: enum Result(T, E) { ... }
    typeParams = parseTypeParameterList()
    skipNewlines()
    if current().tid != TID.OpenBrace {
        return error("Expected '{' after enum name", l, c)
    }
    advance() // consume '{'
    variants = []
    while current().tid != TID.CloseBrace and notEOF() {
        skipNewlinesAndSemicolons()
        if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
        // Variant name
        if current().tid != TID.Identifier {
            return error("Expected variant name in enum", current().line, current().col)
        }
        vname = advance().value
        variant = {name: vname}
        // Optional payload type: Variant(Type)
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            payloadType = ""
            if current().tid == TID.Identifier {
                payloadType = advance().value
            }
            skipNewlines()
            if current().tid == TID.CloseParen {
                advance() // consume ')'
            }
            variant.payloadType = payloadType
        }
        variants.push(variant)
        // Optional comma
        if current().tid == TID.Comma { advance() }
        skipNewlines()
    }
    if current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return EnumDeclaration(name, variants, l, c, typeParams)
}

// ===================================================================
// STATEMENT: trait declaration
// trait Name { fn method(params); fn method2(params) { default_body } }
// ===================================================================
fn parseTraitDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'trait'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected trait name after 'trait'", l, c)
    }
    name = advance().value
    skipNewlines()
    if current().tid != TID.OpenBrace {
        return error("Expected '{' after trait name", l, c)
    }
    advance() // consume '{'
    methods = []
    while current().tid != TID.CloseBrace and notEOF() {
        skipNewlinesAndSemicolons()
        if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
        // Expect 'fn' keyword
        if current().tid != TID.Fn {
            return error("Expected 'fn' in trait body", current().line, current().col)
        }
        advance() // consume 'fn'
        skipNewlines()
        // Method name
        if current().tid != TID.Identifier {
            return error("Expected method name in trait", current().line, current().col)
        }
        methodName = advance().value
        // Parameters
        methodParams = []
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
                if current().tid != TID.Identifier {
                    return error("Expected parameter name in trait method", current().line, current().col)
                }
                methodParams.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma { advance() }
            }
            if current().tid == TID.CloseParen { advance() }
        }
        // Optional default body
        defaultBody = null
        if current().tid == TID.OpenBrace {
            defaultBody = parseBlock()
        }
        methods.push({name: methodName, params: methodParams, body: defaultBody})
        skipNewlines()
    }
    if current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return TraitDeclaration(name, methods, l, c)
}

// ===================================================================
// STATEMENT: protocol declaration
// prot Name { fn method(params); fn +(other) }
// ===================================================================
fn parseProtocolDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'prot'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected protocol name after 'prot'", l, c)
    }
    name = advance().value
    skipNewlines()
    // Colon or brace body
    isColonBody = false
    if current().tid == TID.Colon {
        isColonBody = true
        advance() // consume ':'
        skipNewlines()
    } else if current().tid == TID.OpenBrace {
        advance() // consume '{'
    } else {
        return error("Expected '{' or ':' after protocol name", l, c)
    }
    methods = []
    // End condition depends on body style
    while notEOF() {
        if !isColonBody && current().tid == TID.CloseBrace: break
        if isColonBody && current().col < c + 1: break
        skipNewlinesAndSemicolons()
        if !isColonBody && current().tid == TID.CloseBrace: break
        if isColonBody && (current().tid == TID.EOF || current().col < c + 1): break
        // Expect 'fn'
        if current().tid != TID.Fn {
            return error("Expected 'fn' in protocol body", current().line, current().col)
        }
        advance() // consume 'fn'
        skipNewlines()
        // Method name or operator
        methodName = ""
        pt = current().tid
        if pt == TID.Identifier {
            methodName = advance().value
        } else if pt == TID.Plus || pt == TID.Minus || pt == TID.Multiply || pt == TID.Divide || pt == TID.Equals || pt == TID.Less || pt == TID.Greater || pt == TID.OpenBracket {
            methodName = advance().value
        } else {
            return error("Expected method or operator name in protocol", current().line, current().col)
        }
        // Parameters
        methodParams = []
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
                if current().tid != TID.Identifier {
                    return error("Expected parameter name in protocol method", current().line, current().col)
                }
                methodParams.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma { advance() }
            }
            if current().tid == TID.CloseParen { advance() }
        }
        // Optional default body
        defaultBody = null
        if current().tid == TID.OpenBrace {
            defaultBody = parseBlock()
        }
        methods.push({name: methodName, params: methodParams, body: defaultBody})
        skipNewlines()
    }
    if !isColonBody && current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return ProtocolDeclaration(name, methods, l, c)
}

// ===================================================================
// STATEMENT: impl declaration
// impl TypeName { fn method() {} }
// impl TypeName for TraitName { fn method() {} }
// ===================================================================
fn parseImplDeclaration() {
  l = current().line
  c = current().col
  advance() // consume 'impl'
  skipNewlines()
  if current().tid != TID.Identifier {
    return error("Expected trait name after 'impl'", l, c)
  }
  traitName = advance().value
  skipNewlines()
  typeName = ""
  if current().tid == TID.For {
    advance() // consume 'for'
    skipNewlines()
    if current().tid != TID.Identifier {
      return error("Expected type name after 'for'", current().line, current().col)
    }
    typeName = advance().value
    skipNewlines()
  }
  if current().tid != TID.OpenBrace {
    return error("Expected '{' after impl declaration", l, c)
  }
  advance() // consume '{'
  funcs = []
  while current().tid != TID.CloseBrace and notEOF() {
    skipNewlinesAndSemicolons()
    if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
    // Each member should be a fn declaration
    if current().tid == TID.Fn {
      fnDecl = parseFnDeclaration()
      if fnDecl != null && fnDecl.kind != "ErrorNode" {
        funcs.push(fnDecl)
      }
      continue
    }
    // Skip unknown tokens
    advance()
  }
  if current().tid == TID.CloseBrace {
    advance() // consume '}'
  }
return ImplDeclaration(typeName, traitName, funcs, l, c)
}
// ===================================================================
// STATEMENT: when
// ===================================================================
fn parseWhenBlockStatement() {
  l = current().line
  c = current().col
  advance() // consume 'when'
  skipNewlines()
  prevSugar = allowBraceSugar
  allowBraceSugar = false
  condition = parseExpr(0)
  allowBraceSugar = prevSugar
  skipNewlines()
  if current().tid != TID.OpenBrace {
    error("Expected '{' after when condition", current().line, current().col)
  }
  advance() // consume '{'
  stmts = []
  skipNewlines()
  while current().tid != TID.CloseBrace && notEOF() {
    if current().tid == TID.NewLine || current().tid == TID.Semicolon {
      advance()
      continue
    }
    stmts.push(parseStatement())
    skipNewlines()
  }
  expect(TID.CloseBrace)
  return WhenBlock(condition, stmts, l, c)
}

// ===================================================================
// STATEMENT: with
// ===================================================================
fn parseWithStatement() {
  l = current().line
  c = current().col
  advance() // consume 'with'
  skipNewlines()
  prevSugar = allowBraceSugar
  allowBraceSugar = false
  obj = parseExpr(0)
  allowBraceSugar = prevSugar
  aliasNode = null
  if current().tid == TID.As {
    advance() // consume 'as'
    if current().tid != TID.Identifier {
      error("Expected identifier after 'as'", current().line, current().col)
    }
    aliasNode = Identifier(current().value, current().line, current().col)
    advance()
  }
  skipNewlines()
  if current().tid != TID.OpenBrace {
    error("Expected '{' after with expression", current().line, current().col)
  }
  advance() // consume '{'
  stmts = []
  skipNewlines()
  while current().tid != TID.CloseBrace && notEOF() {
    if current().tid == TID.NewLine {
      advance()
      continue
    }
    stmts.push(parseStatement())
    skipNewlines()
  }
  expect(TID.CloseBrace)
  return WithStatement(obj, aliasNode, stmts, l, c)
}

// ===================================================================
// STATEMENT: go
// ===================================================================
fn parseGoStatement() {
  l = current().line
  c = current().col
  advance() // consume 'go'
  if current().tid == TID.OpenBrace {
    // go { ... } → desugar to go (() => { ... })
    advance() // consume '{'
    stmts = []
    skipNewlines()
    while current().tid != TID.CloseBrace && notEOF() {
      if current().tid == TID.NewLine { advance(); continue }
      stmts.push(parseStatement())
      skipNewlines()
    }
    expect(TID.CloseBrace)
    block = BlockStatement(stmts, l, c)
    call = LambdaExpression([], block)
    return GoStatement(call, l, c)
  }
  call = parseExpr(0)
  return GoStatement(call, l, c)
}

// ===================================================================
// STATEMENT: wait
// ===================================================================
fn parseWaitStatement() {
  l = current().line
  c = current().col
  advance() // consume 'wait'
  expr = parseExpr(0)
  return WaitStatement(expr, l, c)
}

// ===================================================================
// STATEMENT: input (> prefix)
// ===================================================================
fn parseInputStatement() {
  l = current().line
  c = current().col
  advance() // consume '>'
  cmds = []
  while current().tid != TID.NewLine && current().tid != TID.Semicolon && current().tid != TID.EOF && current().tid != TID.CloseBrace {
    // :500 (sleep inline)
    if current().tid == TID.Colon {
      advance()
      dur = "0"
      if current().tid == TID.Number { dur = current().value; advance() }
      cmds.push(InputCommand("Sleep", null, null, null, null, dur))
      continue
    }
    // "text" (send text)
    if current().tid == TID.String || current().tid == TID.MultilineString {
      txt = current().value
      advance()
      cmds.push(InputCommand("SendText", txt, null, null, null, null))
      continue
    }
    // {Key} (send key)
    if current().tid == TID.OpenBrace {
      advance()
      if current().tid == TID.Identifier {
        k = current().value
        advance()
        cmds.push(InputCommand("SendKey", null, k, null, null, null))
      }
      if current().tid == TID.CloseBrace { advance() }
      continue
    }
    // identifier: lmb, rmb, m, r, w
    if current().tid == TID.Identifier {
      ident = current().value
      if ident == "lmb" {
        advance()
        cmds.push(InputCommand("MouseClick", "left", null, null, null, null))
        continue
      }
      if ident == "rmb" {
        advance()
        cmds.push(InputCommand("MouseClick", "right", null, null, null, null))
        continue
      }
      if ident == "m" || ident == "r" || ident == "w" {
        advance()
        if current().tid == TID.OpenParen {
          advance()
          xVal = null
          yVal = null
          if current().tid != TID.CloseParen {
            xVal = current().value
            advance()
          }
          if current().tid == TID.Comma {
            advance()
            if current().tid != TID.CloseParen {
              yVal = current().value
              advance()
            }
          }
          if current().tid == TID.CloseParen { advance() }
          itype = "MouseMove"
          if ident == "r" { itype = "MouseRelative" }
          if ident == "w" { itype = "MouseWheel" }
          cmds.push(InputCommand(itype, null, null, xVal, yVal, null))
        }
        continue
      }
    }
    // Unknown token, skip
    advance()
  }
  return InputStatement(cmds, l, c)
}

// ===================================================================
// STATEMENT: decorator ([deco] or @deco)
// ===================================================================
fn parseDecoratorStatement() {
  l = current().line
  c = current().col
  decorators = []
  // Parse [deco] or [deco(args)] syntax
  while current().tid == TID.OpenBracket {
    advance() // consume '['
    if current().tid != TID.Identifier {
      error("Expected decorator name after '['", current().line, current().col)
      break
    }
    decoName = Identifier(current().value, current().line, current().col)
    advance()
    decoExpr = decoName
    // Optional args
    if current().tid == TID.OpenParen {
      advance() // consume '('
      args = []
      while notEOF() && current().tid != TID.CloseParen {
        skipNewlines()
        if current().tid == TID.CloseParen { break }
        args.push(parseExpr(0))
        skipNewlines()
        if current().tid == TID.Comma { advance() }
      }
      if current().tid == TID.CloseParen { advance() }
      decoExpr = CallExpression(decoExpr, args, null, l, c)
    }
    if current().tid == TID.CloseBracket { advance() }
    decorators.push(decoExpr)
    skipNewlines()
  }
  target = parseStatement()
  if target == null {
    error("Expected declaration after decorator", current().line, current().col)
    return null
  }
  return DecoratorStatement(decorators, target, l, c)
}

// ===================================================================
// @decorator syntax
// ===================================================================
fn parseAtDecoratorStatement() {
  l = current().line
  c = current().col
  decorators = []
  while current().tid == TID.At && at(1).tid == TID.Identifier {
    advance() // consume '@'
    decoName = Identifier(current().value, current().line, current().col)
    advance() // consume decorator name
    decoExpr = decoName
    // Optional args: @decorator(arg1, arg2)
    if current().tid == TID.OpenParen {
      advance() // consume '('
      args = []
      while notEOF() && current().tid != TID.CloseParen {
        skipNewlines()
        if current().tid == TID.CloseParen { break }
        args.push(parseExpr(0))
        skipNewlines()
        if current().tid == TID.Comma { advance() }
      }
      if current().tid == TID.CloseParen { advance() }
      decoExpr = CallExpression(decoExpr, args, null, l, c)
    }
    decorators.push(decoExpr)
    skipNewlines()
  }
  target = parseStatement()
  if target == null {
    error("Expected declaration after @decorator", current().line, current().col)
    return null
  }
  return DecoratorStatement(decorators, target, l, c)
}
    // Return the parser interface
    {
    parseExpr: parseExpr,
    parseStatement: parseStatement,
    parseBlock: parseBlock,
    errors: errors,
    pos: pos,
    tokens: tokens,
    }
// ===================================================================
// PUBLIC API
// ===================================================================

// Parse entire source into a Program AST node
fn parseProgram(source) {
    tokenList = tokenize(source)
    p = Parser(tokenList)
    body = []
    while p.current().tid != TID.EOF {
        // Skip newlines and semicolons
        tt = p.current().tid
        if tt == TID.NewLine || tt == TID.Semicolon {
            p.advance()
            continue
        }
        stmt = p.parseStatement()
        if stmt != null {
            body.push(stmt)
        }
        // Error recovery
        if p.errors != null && #p.errors > 100 {
            break
        }
    }
    program = Program(body, 1, 1)
    return {ast: program, errors: p.errors, incomplete: p.incomplete}
}

// Parse entire source into a Program AST node (alias for parseProgram)
fn parse(source) {
  return parseProgram(source)
}
fn parseTokens(tokenList) {
  p = Parser(tokenList)
  body = []
  while p.current().tid != TID.EOF {
    tt = p.current().tid
    if tt == TID.NewLine || tt == TID.Semicolon {
      p.advance()
      continue
    }
    stmt = p.parseStatement()
    if stmt != null {
      body.push(stmt)
    }
    if p.errors != null && #p.errors > 100 {
      break
    }
  }
  program = Program(body, 1, 1)
  return {ast: program, errors: p.errors, incomplete: p.incomplete}
}