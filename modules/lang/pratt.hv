// Havel Pratt parser — pure Havel implementation
// Top-down operator precedence parser matching the C++ Parser.cpp architecture
// Consumes token list from "lexer".hv, produces AST nodes from "ast".hv

// Module-level parser state globals (must be before use statements for self-hosted bootstrap)
tokens = null
pos = 0
errors = []
incomplete = false
inMatchExpr = false
allowBraceSugar = true
_eof = null
_cur = null

use { tokenize, TOKEN_TYPES, KEYWORDS, TID, TID_NAME } from "lexer"
use { NODE_TYPES, BINARY_OPS, COMPOUND_ASSIGN_OPS, UNARY_OPS,
Program, BlockStatement, ExpressionStatement,
NumberLiteral, StringLiteral, BooleanLiteral, NullLiteral,
Identifier, BinaryExpression, UnaryExpression, UpdateExpression,
CallExpression, MemberExpression, IndexExpression,
AssignmentExpression, CompoundAssignment,
ArrayLiteral, ObjectLiteral, ObjectField, SpreadExpression,
IfStatement, WhileStatement, DoWhileStatement, ForStatement, ForExpression, LoopStatement,
RepeatStatement, BreakStatement, ContinueStatement,
FnDeclaration, LambdaExpression, ReturnStatement,
LetDeclaration, ValDeclaration, UseStatement, ImportStatement,
HotkeyBinding, BacktickExpression, ShellCommand,
RangeExpression, TernaryExpression, PipelineExpression,
ThrowStatement, TryStatement, MatchExpression, MatchCase,
InterpolatedString, RegexLiteral, AtExpression, AtAtExpression,
CastExpression, HotkeyExpression, HotkeyLiteral,
GoStatement, WhenBlock, WithStatement, DecoratorStatement,
OnModeStatement, OffModeStatement, OnReloadStatement, OnStartStatement,
OnTapStatement, OnComboStatement, OnKeyDownStatement, OnKeyUpStatement, OnMessageStatement,
ModesBlock, ModeBlock, ModeDefinition, ConfigSection, InputStatement, MultipleAssignment, QueryExpression,
ConfigBlock, SleepStatement, DeferStatement, WaitExpression, WaitGroupExpression, ErrorNode,
ClassDeclaration, StructDeclaration, EnumDeclaration, TraitDeclaration, ProtocolDeclaration, ImplDeclaration,
TypeParam, isNode, prettyPrint,
WildcardPattern, ArrayPattern, ObjectPattern, ConstructorPattern, OrPattern, RangePattern,
CharLiteral, ThisExpression, GoExpression, AsyncExpression, AwaitExpression, ChannelExpression,
YieldExpression, WaitStatement, InputCommand } from "ast"

// --- Binding power constants (matching C++ switch-based values) ---
BP_NONE = 0
BP_ASSIGN = 10
BP_NULLISH = 20
BP_QUESTION = 15
BP_OR = 30
BP_AND = 40
BP_EQUALITY = 50
BP_NOT_IN = 52
BP_IN = 55
BP_COMPARISON = 60
BP_RANGE = 70
BP_ADD = 70
BP_PIPE = 75
BP_BITWISE_OR = 80
BP_BITWISE_XOR = 90
BP_BITWISE_AND = 100
BP_SHIFT = 110
BP_MUL = 130
BP_POWER = 135
BP_POSTFIX = 150
BP_CALL_MEMBER = 170

// --- Binding power lookup tables (built programmatically for integer keys) ---
BP_TABLE = {}
BP_TABLE[TID.Assign] = 10; BP_TABLE[TID.PlusAssign] = 10; BP_TABLE[TID.MinusAssign] = 10
BP_TABLE[TID.MultiplyAssign] = 10; BP_TABLE[TID.DivideAssign] = 10; BP_TABLE[TID.ModuloAssign] = 10
BP_TABLE[TID.PowerAssign] = 10; BP_TABLE[TID.BackslashAssign] = 10; BP_TABLE[TID.DoubleModuloAssign] = 10
BP_TABLE[TID.BitwiseAndAssign] = 10; BP_TABLE[TID.BitwiseOrAssign] = 10; BP_TABLE[TID.BitwiseXorAssign] = 10
BP_TABLE[TID.ShiftLeftAssign] = 10; BP_TABLE[TID.ShiftRightAssign] = 10
BP_TABLE[TID.Arrow] = 10; BP_TABLE[TID.LeftArrow] = 10
BP_TABLE[TID.Nullish] = 20; BP_TABLE[TID.Question] = 15
BP_TABLE[TID.Or] = 30; BP_TABLE[TID.And] = 40
BP_TABLE[TID.Equals] = 50; BP_TABLE[TID.NotEquals] = 50; BP_TABLE[TID.Is] = 50
BP_TABLE[TID.Tilde] = 50; BP_TABLE[TID.Matches] = 50; BP_TABLE[TID.As] = 50; BP_TABLE[TID.In] = 55
BP_TABLE[TID.Less] = 60; BP_TABLE[TID.Greater] = 60; BP_TABLE[TID.LessEquals] = 60; BP_TABLE[TID.GreaterEquals] = 60
BP_TABLE[TID.DotDot] = 70; BP_TABLE[TID.DotDotEquals] = 70
BP_TABLE[TID.Plus] = 70; BP_TABLE[TID.Minus] = 70; BP_TABLE[TID.Pipe] = 75; BP_TABLE[TID.PipeRight] = 75
BP_TABLE[TID.BitwiseOr] = 80; BP_TABLE[TID.BitwiseXor] = 90; BP_TABLE[TID.BitwiseAnd] = 100
BP_TABLE[TID.ShiftLeft] = 110; BP_TABLE[TID.ShiftRight] = 110
BP_TABLE[TID.Multiply] = 130; BP_TABLE[TID.Divide] = 130; BP_TABLE[TID.Modulo] = 130; BP_TABLE[TID.Backslash] = 130
BP_TABLE[TID.DoubleBackslash] = 130; BP_TABLE[TID.DoubleModulo] = 130
BP_TABLE[TID.Power] = 135
BP_TABLE[TID.PlusPlus] = 150; BP_TABLE[TID.MinusMinus] = 150
BP_TABLE[TID.For] = 15
BP_TABLE[TID.Dot] = 170; BP_TABLE[TID.QuestionDot] = 170; BP_TABLE[TID.OpenParen] = 170; BP_TABLE[TID.OpenBracket] = 170

RBP_TABLE = {}
RBP_TABLE[TID.Assign] = 5; RBP_TABLE[TID.PlusAssign] = 5; RBP_TABLE[TID.MinusAssign] = 5
RBP_TABLE[TID.MultiplyAssign] = 5; RBP_TABLE[TID.DivideAssign] = 5; RBP_TABLE[TID.ModuloAssign] = 5
RBP_TABLE[TID.PowerAssign] = 5; RBP_TABLE[TID.BackslashAssign] = 5; RBP_TABLE[TID.DoubleModuloAssign] = 5
RBP_TABLE[TID.BitwiseAndAssign] = 5; RBP_TABLE[TID.BitwiseOrAssign] = 5; RBP_TABLE[TID.BitwiseXorAssign] = 5
RBP_TABLE[TID.ShiftLeftAssign] = 5; RBP_TABLE[TID.ShiftRightAssign] = 5
RBP_TABLE[TID.LeftArrow] = 5; RBP_TABLE[TID.Arrow] = 5
RBP_TABLE[TID.Power] = 130; RBP_TABLE[TID.Nullish] = 15; RBP_TABLE[TID.Question] = 10
RBP_TABLE[TID.For] = 15

fn getBindingPower(ttype) {
    if ttype == TID.Not {
        if at(1).tid == TID.In { return 52 }
        return BP_NONE
    }
    r = BP_TABLE[ttype]
    if r != null: return r
    return BP_NONE
}

// --- getRightBindingPower: lower rbp for right-associative operators ---
fn getRightBindingPower(ttype) {
    r = RBP_TABLE[ttype]
    if r != null: return r
    return getBindingPower(ttype)
}
// --- Compound assign token set (integer keys for fast lookup) ---
COMPOUND_ASSIGN_TOKENS = {}
COMPOUND_ASSIGN_TOKENS[TID.PlusAssign] = "+="
COMPOUND_ASSIGN_TOKENS[TID.MinusAssign] = "-="
COMPOUND_ASSIGN_TOKENS[TID.MultiplyAssign] = "*="
COMPOUND_ASSIGN_TOKENS[TID.DivideAssign] = "/="
COMPOUND_ASSIGN_TOKENS[TID.ModuloAssign] = "%="
COMPOUND_ASSIGN_TOKENS[TID.PowerAssign] = "**="
COMPOUND_ASSIGN_TOKENS[TID.BackslashAssign] = "\\="
COMPOUND_ASSIGN_TOKENS[TID.DoubleModuloAssign] = "%%="
COMPOUND_ASSIGN_TOKENS[TID.BitwiseAndAssign] = "&="
COMPOUND_ASSIGN_TOKENS[TID.BitwiseOrAssign] = "|="
COMPOUND_ASSIGN_TOKENS[TID.BitwiseXorAssign] = "^="
COMPOUND_ASSIGN_TOKENS[TID.ShiftLeftAssign] = "<<="
COMPOUND_ASSIGN_TOKENS[TID.ShiftRightAssign] = ">>="

// --- Check if identifier value is a hotkey key name ---
HOTKEY_IDENT_NAMES = {
	"space": true, "enter": true, "tab": true, "escape": true, "esc": true,
	"backspace": true, "delete": true, "insert": true, "home": true,
	"end": true, "pageup": true, "pagedown": true, "capslock": true,
	"numlock": true, "scrolllock": true, "lshift": true, "rshift": true,
	"lctrl": true, "rctrl": true, "lalt": true, "ralt": true,
	"lmeta": true, "rmeta": true, "super": true, "menu": true,
	"print": true, "pause": true, "up": true, "down": true,
	"left": true, "right": true, "wheelup": true, "wheeldown": true,
	"wheelleft": true, "wheelright": true,
	"numpad0": true, "numpad1": true, "numpad2": true, "numpad3": true,
	"numpad4": true, "numpad5": true, "numpad6": true, "numpad7": true,
	"numpad8": true, "numpad9": true, "btn0": true, "btn1": true,
	"btn2": true, "btn3": true, "btn4": true, "numpadmult": true,
	"numpadadd": true, "numpadsub": true, "numpaddiv": true,
	"numpadenter": true, "numpadsep": true,
}
fn isHotkeyIdentifier(value) {
	if value.len >= 2 && value[0] == "F" {
		rest = value.sub(1)
		isDigit = true
		i = 0
		while i < rest.len {
			ch = rest.sub(i, 1)
			if ch < "0" || ch > "9" { isDigit = false; break }
			i = i + 1
		}
		if isDigit { return true }
	}
	HOTKEY_IDENT_NAMES[value] != null
}

// parseHotkeyAttrs moved inside Parser()

// --- Token types that can start an expression (have nud) ---
NUD_TOKENS = {}
NUD_TOKENS[TID.Number] = true; NUD_TOKENS[TID.String] = true; NUD_TOKENS[TID.MultilineString] = true
NUD_TOKENS[TID.InterpolatedString] = true; NUD_TOKENS[TID.RegexString] = true; NUD_TOKENS[TID.RegexLiteral] = true
