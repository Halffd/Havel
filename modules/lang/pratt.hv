                    skipNewlines()
                    if current().tid == TID.CloseBrace: break
                    elements.push(parseExpr(0))
                    skipNewlines()
                    if current().tid == TID.Comma: advance()
                    else if current().tid != TID.CloseBrace {
                        skipNewlines()
                    }
