        couldBeSet = (nextTok.tid == TID.Identifier or nextTok.tid == TID.String or nextTok.tid == TID.MultilineString or nextTok.tid == TID.RegexString or nextTok.tid == TID.Number or nextTok.tid == TID.OpenBracket or nextTok.tid == TID.OpenParen or nextTok.tid == TID.OpenBrace or nextTok.tid == TID.Minus or nextTok.tid == TID.Not or nextTok.tid == TID.Plus or nextTok.tid == TID.Length or nextTok.tid == TID.True or nextTok.tid == TID.False or nextTok.tid == TID.Null)

        if couldBeSet {
            // Look ahead for comma
            setLook = lookahead + 1
            while setLook < tokens.len and at(setLook).tid != TID.Comma and at(setLook).tid != TID.Semicolon and at(setLook).tid != TID.CloseBrace and at(setLook).tid != TID.NewLine {
