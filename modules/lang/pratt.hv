LED_TOKENS[TID.ShiftLeftAssign] = true; LED_TOKENS[TID.ShiftRightAssign] = true
LED_TOKENS[TID.LeftArrow] = true; LED_TOKENS[TID.Nullish] = true; LED_TOKENS[TID.Question] = true
LED_TOKENS[TID.Or] = true; LED_TOKENS[TID.And] = true
LED_TOKENS[TID.Equals] = true; LED_TOKENS[TID.NotEquals] = true; LED_TOKENS[TID.Is] = true; LED_TOKENS[TID.Tilde] = true
LED_TOKENS[TID.Matches] = true; LED_TOKENS[TID.As] = true; LED_TOKENS[TID.In] = true; LED_TOKENS[TID.Not] = true
LED_TOKENS[TID.Less] = true; LED_TOKENS[TID.Greater] = true; LED_TOKENS[TID.LessEquals] = true; LED_TOKENS[TID.GreaterEquals] = true
LED_TOKENS[TID.DotDot] = true; LED_TOKENS[TID.DotDotEquals] = true
LED_TOKENS[TID.Plus] = true; LED_TOKENS[TID.Minus] = true; LED_TOKENS[TID.Pipe] = true; LED_TOKENS[TID.PipeRight] = true
LED_TOKENS[TID.BitwiseOr] = true; LED_TOKENS[TID.BitwiseXor] = true; LED_TOKENS[TID.BitwiseAnd] = true
LED_TOKENS[TID.ShiftLeft] = true; LED_TOKENS[TID.ShiftRight] = true
LED_TOKENS[TID.Multiply] = true; LED_TOKENS[TID.Divide] = true; LED_TOKENS[TID.Modulo] = true
LED_TOKENS[TID.Backslash] = true; LED_TOKENS[TID.DoubleBackslash] = true; LED_TOKENS[TID.DoubleModulo] = true
LED_TOKENS[TID.Power] = true; LED_TOKENS[TID.PlusPlus] = true; LED_TOKENS[TID.MinusMinus] = true
LED_TOKENS[TID.Dot] = true; LED_TOKENS[TID.QuestionDot] = true
LED_TOKENS[TID.OpenParen] = true; LED_TOKENS[TID.OpenBracket] = true
LED_TOKENS[TID.Arrow] = true

// --- Expression tokens (for implicit call sugar detection) ---
IMPLICIT_CALL_STARTERS = {}
IMPLICIT_CALL_STARTERS[TID.String] = true; IMPLICIT_CALL_STARTERS[TID.MultilineString] = true; IMPLICIT_CALL_STARTERS[TID.RegexString] = true
IMPLICIT_CALL_STARTERS[TID.Number] = true; IMPLICIT_CALL_STARTERS[TID.Identifier] = true; IMPLICIT_CALL_STARTERS[TID.InterpolatedString] = true
IMPLICIT_CALL_STARTERS[TID.InterpolatedBacktick] = true; IMPLICIT_CALL_STARTERS[TID.At] = true; IMPLICIT_CALL_STARTERS[TID.AtAt] = true
IMPLICIT_CALL_STARTERS[TID.Not] = true; IMPLICIT_CALL_STARTERS[TID.Length] = true

// ===================================================================
// Parser object — encapsulates parsing state
// ===================================================================
fn Parser(tokenList) {
  tokens = tokenList
  pos = 0
  errors = []
  inMatchExpr = false
  allowBraceSugar = true
  _eof = {type: "EOF", tid: TID.EOF, value: "", line: 0, col: 0}
  _cur = pos < tokens.len ? tokens[pos] : _eof

  fn at(offset) {
    i = pos + offset
    if i < 0: i = 0
    if i < tokens.len: return tokens[i]
    else: return _eof
  }
  fn current() {
    return _cur
  }
  fn advance() {
    if pos < tokens.len {
      t = tokens[pos]
      pos = pos + 1
      _cur = pos < tokens.len ? tokens[pos] : _eof
      return t
    }
    else {
      _cur = _eof
      return _eof
    }
  }
  fn syncCur() {
    _cur = pos < tokens.len ? tokens[pos] : _eof
  }
  fn notEOF() {
    return _cur.tid != TID.EOF
  }
 fn expect(ttype) {
 t = current()
 if t.tid == ttype {
 return advance()
 }
 else {
 tname = TID_NAME[ttype]
 if tname == null: tname = str(ttype)
 return error("Expected " + tname + " but got " + t.type, t.line, t.col)

 }
 }
 fn expectValue(ttype, expectedVal) {
 t = current()
 if t.tid == ttype and t.value == expectedVal {
 return advance()
 }
 else {
 tname = TID_NAME[ttype]
 if tname == null: tname = str(ttype)
 return error("Expected " + tname + " '" + expectedVal + "' but got " + t.type, t.line, t.col)

 }
 }
    // --- Newline skipping ---
    fn skipNewlines() {
        while current().tid == TID.NewLine {
            advance()

        }
    }
    fn skipNewlinesAndSemicolons() {
        while current().tid == TID.NewLine or current().tid == TID.Semicolon {
            advance()

        }
    }
    // --- Error handling ---
fn error(msg, line, col) {
    errors.push({msg: msg, line: line, col: col})
    return ErrorNode(msg, line, col)
}
  fn parseError(msg) {
    t = current()
    return error(msg, t.line, t.col)

  }
  // --- Token classification ---
  fn canStartExpr(ttype) {
    NUD_TOKENS[ttype] != null

  }
  fn isLed(ttype) {
    LED_TOKENS[ttype] != null

  }
// --- Check if 'not' is infix (followed by 'in') ---
fn isNotIn() {
  return current().tid == TID.Not and at(1).tid == TID.In

  }
    // ===================================================================
    // PRATT EXPRESSION PARSER
    // ===================================================================
fn parseExpr(rbp) {
  startToken = current()
  tok = advance()

  left = nud(tok)

  if left == null {
    return error("Unexpected token " + tok.type, startToken.line, startToken.col)

  }
  if left.kind == "ErrorNode" {
    return left

  }
 iterations = 0
 while true {
 iterations = iterations + 1
 if iterations > 10000 {
 return error("Pratt loop exceeded", startToken.line, startToken.col)

 }
  curType = current().tid
  bp = getBindingPower(curType)

  // Special: 'not' only acts as infix when followed by 'in'
  if curType == TID.Not and !isNotIn() {
 break

 }
 // Special: Arrow returns 0 in match context
 if curType == TID.Arrow and inMatchExpr {
                break

            }
  if bp == BP_NONE or rbp >= bp {
    break
  }
  opToken = advance()
  left = led(opToken, left)

            if left == null {
                return error("Failed to parse infix " + opToken.type, opToken.line, opToken.col)
            }
            if left.kind == "ErrorNode" {
                return left

            }
        }
 // Implicit call sugar: expr "string" -> expr("string")
 // Not across newlines — NewLine has bp=0 so the Pratt loop exits before we get here
 // and NewLine is not in IMPLICIT_CALL_STARTERS
 if allowBraceSugar and IMPLICIT_CALL_STARTERS[current().tid] != null {
            prevSugar = allowBraceSugar
            allowBraceSugar = false
            arg = parseExpr(0)
            allowBraceSugar = prevSugar

            if arg == null or arg.kind == "ErrorNode" {
                return arg

            }
            args = [arg]
            while current().tid == TID.Comma {
                advance()
                nextArg = parseExpr(0)
                if nextArg == null or nextArg.kind == "ErrorNode" {
                    return nextArg
                }
                args.push(nextArg)

            }
            left = CallExpression(left, args, [], startToken.line, startToken.col)

  }
  left

    }
    // ===================================================================
    // NULL DENOTATION (nud) — tokens that start expressions
    // ===================================================================
fn nud(tok) {
tt = tok.tid
l = tok.line
c = tok.col

if tt == TID.Number {
return NumberLiteral(tok.value, l, c)
}
else if tt == TID.String or tt == TID.MultilineString {
return StringLiteral(tok.value, l, c)
}
else if tt == TID.RegexString {
return StringLiteral(tok.value, l, c)
}
else if tt == TID.RegexLiteral {
parts = tok.value.split("/")
pattern = ""
flags = ""
if parts.len >= 2: pattern = parts[1]
if parts.len >= 3: flags = parts[2]
return RegexLiteral(pattern, flags, l, c)
}
else if tt == TID.Backtick {
if tok.value.has("{") or tok.value.has("$") {
return ShellCommand(tok.value, false, l, c)
}
else {
return BacktickExpression(tok.value, l, c)
}
}
else if tt == TID.InterpolatedBacktick {
return ShellCommand(tok.value, true, l, c)
}
else if tt == TID.ShellCommand {
return ShellCommand(tok.value, false, l, c)
}
else if tt == TID.ShellCommandCapture {
return ShellCommand(tok.value, true, l, c)
}
else if tt == TID.InterpolatedString {
return parseInterpolatedString(tok.value, l, c)
}
else if tt == TID.Identifier or (isKeywordIdent(tt) and tt != TID.True and tt != TID.False and tt != TID.Null and tt != TID.Fn and tt != TID.WaitGroup and tt != TID.Wait and tt != TID.Defer) {
return Identifier(tok.value, l, c)
}
else if tt == TID.True {
return BooleanLiteral(true, l, c)
}
else if tt == TID.False {
return BooleanLiteral(false, l, c)
}
else if tt == TID.Null {
return NullLiteral(l, c)
}
else if tt == TID.OpenParen {
return parseParenExpr(tok)
}
else if tt == TID.OpenBracket {
pos = pos - 1
syncCur()
return parseArrayLiteral()
}
else if tt == TID.OpenBrace {
pos = pos - 1
syncCur()
return disambiguateBrace()
}
else if tt == TID.BangOpenBrace {
return parseObjectLiteral(true)
}
else if tt == TID.Not {
if current().tid == TID.OpenBrace {
return parseObjectLiteral(true)
}
else {
operand = parseExpr(140)
return UnaryExpression(tok.value, operand, l, c)
}
}
else if tt == TID.Minus {
operand = parseExpr(140)
return UnaryExpression("-", operand, l, c)
}
else if tt == TID.Plus {
return parseExpr(140)
}
else if tt == TID.PlusPlus {
operand = parseExpr(140)
return UpdateExpression(operand, "++", true, l, c)
}
else if tt == TID.MinusMinus {
operand = parseExpr(140)
return UpdateExpression(operand, "--", true, l, c)
}
else if tt == TID.Length {
operand = parseExpr(140)
return UnaryExpression("#", operand, l, c)
}
else if tt == TID.Tilde {
if current().tid == TID.Identifier or current().tid == TID.Hotkey {
combo = "~" + current().value
advance()
if current().tid == TID.Colon {
advance()
if current().tid == TID.Number or current().tid == TID.Identifier {
combo = combo + ":" + current().value
advance()
}
}
return HotkeyExpression(combo, l, c)
}
operand = parseExpr(140)
return UnaryExpression("~", operand, l, c)
}
else if tt == TID.DoubleOpenParen {
inner = parseExpr(2)
if current().tid == TID.DoubleCloseParen {
advance()
}
return inner
}
else if tt == TID.At {
if current().tid == TID.Identifier {
field = advance()
return AtExpression(field.value, l, c)
}
else {
return error("Expected field name after '@'", l, c)
}
}
else if tt == TID.AtAt {
if current().tid == TID.Identifier {
field = advance()
return AtAtExpression(field.value, l, c)
}
else {
return error("Expected field name after '@@'", l, c)
}
}
else if tt == TID.ColonColon {
if current().tid == TID.Identifier {
ident = advance()
node = Identifier(ident.value, l, c)
node.globalScope = true
return node
}
else {
return error("Expected identifier after '::'", l, c)
}
}
else if tt == TID.Fn {
return parseLambdaExpr()
}
else if tt == TID.Match {
return parseMatchExpr()
}
else if tt == TID.If {
return parseIfExpr()
}
else if tt == TID.SuperArrow {
if current().tid == TID.Identifier {
methodName = advance().value
node = Identifier("__super__", l, c)
node.isSuperCall = true
node.superMethodName = methodName
if current().tid == TID.OpenParen {
advance()
args = []
skipNewlines()
while current().tid != TID.CloseParen and notEOF() {
skipNewlines()
if current().tid == TID.CloseParen: break
args.push(parseExpr(0))
skipNewlines()
if current().tid == TID.Comma: advance()
}
expect(TID.CloseParen)
return CallExpression(node, args, [], l, c)
}
else {
return node
}
}
else {
return error("Expected method name after '@->'", l, c)
}
}
else if tt == TID.WaitGroup {
if current().tid == TID.OpenParen {
advance()
if current().tid != TID.CloseParen {
return error("Expected '()' after waitgroup", l, c)
}
advance()
}
return WaitGroupExpression(l, c)
}
else if tt == TID.Wait {
target = parseExpr(140)
return WaitExpression(target, l, c)
}
else {
return error("Unexpected token in expression: " + tt, l, c)
}
}
    // ===================================================================
    // LEFT DENOTATION (led) — infix and postfix operators
    // ===================================================================
fn led(tok, left) {
tt = tok.tid
l = tok.line
c = tok.col

// Assignment operators
if tt == TID.Assign {
right = parseExpr(getRightBindingPower(TID.Assign))
if right == null: return error("Expected value after '='", l, c)
if right.kind == "ErrorNode": return right
return AssignmentExpression(left, right, l, c)
}
else if COMPOUND_ASSIGN_TOKENS[tt] != null {
right = parseExpr(getRightBindingPower(tt))
if right == null: return error("Expected value after compound assign", l, c)
if right.kind == "ErrorNode": return right
return CompoundAssignment(left, COMPOUND_ASSIGN_TOKENS[tt], right, l, c)
}
else if tt == TID.LeftArrow {
right = parseExpr(getRightBindingPower(TID.LeftArrow))
if right == null: return error("Expected value after '<-'", l, c)
if right.kind == "ErrorNode": return right
return AssignmentExpression(left, right, l, c)
}
// Binary operators
else if tt == TID.Plus {
right = parseExpr(getRightBindingPower(TID.Plus))
return BinaryExpression(left, "+", right, l, c)
}
else if tt == TID.Minus {
right = parseExpr(getRightBindingPower(TID.Minus))
return BinaryExpression(left, "-", right, l, c)
}
else if tt == TID.Multiply {
right = parseExpr(getRightBindingPower(TID.Multiply))
return BinaryExpression(left, "*", right, l, c)
}
else if tt == TID.Divide {
right = parseExpr(getRightBindingPower(TID.Divide))
return BinaryExpression(left, "/", right, l, c)
}
else if tt == TID.Modulo {
right = parseExpr(getRightBindingPower(TID.Modulo))
return BinaryExpression(left, "%", right, l, c)
}
else if tt == TID.Backslash {
right = parseExpr(getRightBindingPower(TID.Backslash))
return BinaryExpression(left, "\\", right, l, c)
}
else if tt == TID.DoubleBackslash {
right = parseExpr(getRightBindingPower(TID.DoubleBackslash))
return BinaryExpression(left, "\\\\", right, l, c)
}
else if tt == TID.DoubleModulo {
right = parseExpr(getRightBindingPower(TID.DoubleModulo))
return BinaryExpression(left, "%%", right, l, c)
}
else if tt == TID.Power {
right = parseExpr(getRightBindingPower(TID.Power))
return BinaryExpression(left, "**", right, l, c)
}
else if tt == TID.Equals {
right = parseExpr(getRightBindingPower(TID.Equals))
return BinaryExpression(left, "==", right, l, c)
}
else if tt == TID.NotEquals {
right = parseExpr(getRightBindingPower(TID.NotEquals))
return BinaryExpression(left, "!=", right, l, c)
}
else if tt == TID.Is {
right = parseExpr(getRightBindingPower(TID.Is))
return BinaryExpression(left, "is", right, l, c)
}
else if tt == TID.Tilde or tt == TID.Matches {
right = parseExpr(getRightBindingPower(tt))
return BinaryExpression(left, "matches", right, l, c)
}
else if tt == TID.In {
right = parseExpr(getRightBindingPower(TID.In))
return BinaryExpression(left, "in", right, l, c)
}
    else if tt == TID.Not {
        if current().tid == TID.In {
            advance()
            right = parseExpr(getRightBindingPower(TID.In))
            return BinaryExpression(left, "not in", right, l, c)
        }
        else {
            return left
        }
    }
    else if tt == TID.As {
        if current().tid == TID.Identifier {
            targetType = advance().value
            return CastExpression(left, targetType, l, c)
        }
        else {
            return error("Expected type name after 'as'", l, c)
        }
    }
else if tt == TID.Less {
right = parseExpr(getRightBindingPower(TID.Less))
return BinaryExpression(left, "<", right, l, c)
}
else if tt == TID.Greater {
right = parseExpr(getRightBindingPower(TID.Greater))
return BinaryExpression(left, ">", right, l, c)
}
else if tt == TID.LessEquals {
right = parseExpr(getRightBindingPower(TID.LessEquals))
return BinaryExpression(left, "<=", right, l, c)
}
else if tt == TID.GreaterEquals {
right = parseExpr(getRightBindingPower(TID.GreaterEquals))
return BinaryExpression(left, ">=", right, l, c)
}
else if tt == TID.And {
right = parseExpr(getRightBindingPower(TID.And))
return BinaryExpression(left, "&&", right, l, c)
}
else if tt == TID.Or {
right = parseExpr(getRightBindingPower(TID.Or))
return BinaryExpression(left, "||", right, l, c)
}
else if tt == TID.Nullish {
right = parseExpr(getRightBindingPower(TID.Nullish))
return BinaryExpression(left, "??", right, l, c)
}
// Bitwise
else if tt == TID.BitwiseOr {
right = parseExpr(getRightBindingPower(TID.BitwiseOr))
return BinaryExpression(left, "|", right, l, c)
}
else if tt == TID.BitwiseXor {
right = parseExpr(getRightBindingPower(TID.BitwiseXor))
return BinaryExpression(left, "^", right, l, c)
}
else if tt == TID.BitwiseAnd {
right = parseExpr(getRightBindingPower(TID.BitwiseAnd))
return BinaryExpression(left, "&", right, l, c)
}
else if tt == TID.ShiftLeft {
right = parseExpr(getRightBindingPower(TID.ShiftLeft))
return BinaryExpression(left, "<<", right, l, c)
}
else if tt == TID.ShiftRight {
right = parseExpr(getRightBindingPower(TID.ShiftRight))
return BinaryExpression(left, ">>", right, l, c)
}
// Ternary: cond ? true : false
else if tt == TID.Question {
trueExpr = parseExpr(0)
if current().tid != TID.Colon {
return error("Expected ':' after ternary true branch", l, c)
}
advance()
falseExpr = parseExpr(getRightBindingPower(TID.Question))
return TernaryExpression(left, trueExpr, falseExpr, l, c)
}
// Range
else if tt == TID.DotDot {
right = parseExpr(getRightBindingPower(TID.DotDot))
if current().tid == TID.DotDot {
advance()
step = parseExpr(getRightBindingPower(TID.DotDot))
node = RangeExpression(left, right, false, l, c)
node.step = step
return node
}
else {
return RangeExpression(left, right, false, l, c)
}
}
else if tt == TID.DotDotEquals {
right = parseExpr(getRightBindingPower(TID.DotDotEquals))
return RangeExpression(left, right, true, l, c)
}
// Pipeline
else if tt == TID.Pipe or tt == TID.PipeRight {
right = parseExpr(getRightBindingPower(tt))
if right != null and right.kind == "CallExpression" {
right.args.insert(0, left)
return PipelineExpression(left, right, l, c)
}
else {
return PipelineExpression(left, right, l, c)
}
}
// Member access: expr.field
else if tt == TID.Dot {
if current().tid == TID.Identifier or isDotAccessIdent(current().tid) {
prop = advance()
return MemberExpression(left, prop.value, l, c)
}
else {
return error("Expected identifier after '.'", l, c)
}
}
// Optional chaining: expr?.field
else if tt == TID.QuestionDot {
if current().tid == TID.Identifier or isDotAccessIdent(current().tid) {
prop = advance()
node = MemberExpression(left, prop.value, l, c)
node.optional = true
return node
}
else {
return error("Expected identifier after '?.'", l, c)
}
}
// Function call: expr(args)
else if tt == TID.OpenParen {
callResult = parseCallArgs()
return CallExpression(left, callResult.args, callResult.kwargs, l, c)
}
// Index: expr[index]
else if tt == TID.OpenBracket {
isSlice = detectSlice()
if isSlice {
return parseSliceExpr(left, l, c)
}
else {
idx = parseExpr(0)
skipNewlines()
if current().tid != TID.CloseBracket {
return error("Expected ']' after index", l, c)
}
else {
advance()
return IndexExpression(left, idx, l, c)
}
}
}
// Postfix increment/decrement
else if tt == TID.PlusPlus {
return UpdateExpression(left, "++", false, l, c)
}
else if tt == TID.MinusMinus {
return UpdateExpression(left, "--", false, l, c)
}
// Arrow function: param => body
else if tt == TID.Arrow {
if inMatchExpr {
return null
}
if left == null or left.kind != TID.Identifier {
return error("Arrow function requires identifier parameter", l, c)
}
paramName = left.name
params = [paramName]
body = null
if current().tid == TID.OpenBrace {
body = parseBlock()
}
else {
bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
}
return LambdaExpression(params, body, l, c)
}
  else {
    return error("Unexpected token in infix position: " + tt, l, c)
  }
}
    // ===================================================================
    // HELPER: Parse call arguments
    // ===================================================================
fn parseCallArgs() {
  args = []
  kwargs = []
  skipNewlines()
  while current().tid != TID.CloseParen and notEOF() {
    skipNewlines()
    if current().tid == TID.CloseParen: break
    if args.len > 0 or kwargs.len > 0 {
      if current().tid == TID.Comma {
        advance()
        skipNewlines()
      }
    }
    if current().tid == TID.CloseParen: break
    // Keyword argument: name=value
    if current().tid == TID.Identifier and at(1).tid == TID.Assign {
      name = advance().value
      advance() // consume '='
      value = parseExpr(0)
      kwargs.push({name: name, value: value})
    }
    // Spread
    else if current().tid == TID.Spread {
      advance()
      target = parseExpr(0)
      args.push(SpreadExpression(target, current().line, current().col))
    }
    else {
      args.push(parseExpr(0))
    }
    skipNewlines()
  }
  if current().tid == TID.CloseParen {
    advance()
  }
  else {
    error("Expected ')' after arguments", current().line, current().col)
  }
  {args: args, kwargs: kwargs}
}
    // ===================================================================
    // HELPER: Detect slice expression [...:...]
    // ===================================================================
    fn detectSlice() {
        lookahead = 0
        depth = 1
        while pos + lookahead < tokens.len {
            t = tokens[pos + lookahead]
            if t.tid == TID.OpenBracket: depth = depth + 1
            else if t.tid == TID.CloseBracket {
                depth = depth - 1
                if depth == 0: break
            }
            else if (t.tid == TID.Colon or t.tid == TID.ColonColon or t.tid == TID.DotDot or t.tid == TID.DotDotEquals) and depth == 1 {
                return true
            }
            else if t.tid == TID.EOF: break
            lookahead = lookahead + 1
        }
        false

    }
    // ===================================================================
    // HELPER: Parse slice expression
    // ===================================================================
    fn parseSliceExpr(obj, l, c) {
        start = null
        end = null
        step = null

        if current().tid != TID.Colon and current().tid != TID.ColonColon and current().tid != TID.DotDot and current().tid != TID.DotDotEquals {
            start = parseExpr(0)

        }
        if current().tid == TID.ColonColon {
            advance()
            if current().tid != TID.CloseBracket {
                step = parseExpr(0)
            }
        }
        else if current().tid == TID.Colon {
            advance()
            if current().tid != TID.Colon and current().tid != TID.CloseBracket {
                end = parseExpr(0)
            }
            if current().tid == TID.Colon {
                advance()
                if current().tid != TID.CloseBracket {
                    step = parseExpr(0)

                }
            }
        }
        else if current().tid == TID.DotDot {
         advance()
         if current().tid != TID.CloseBracket {
          end = parseExpr(0)
         }
        }
        else if current().tid == TID.DotDotEquals {
         advance()
         if current().tid != TID.CloseBracket {
          end = parseExpr(0)
         }
        }
        if current().tid == TID.CloseBracket {
            advance()
        }
        else {
            error("Expected ']' after slice", l, c)

        }
        // Desugar to obj.slice(start, end, step)
        args = []
        if start != null: args.push(start)
        else: args.push(NullLiteral(l, c))
        if end != null: args.push(end)
        else: args.push(NullLiteral(l, c))
        if step != null: args.push(step)
        else: args.push(NullLiteral(l, c))

  sliceMember = MemberExpression(obj, "slice", l, c)
  return CallExpression(sliceMember, args, [], l, c)

  }
    // ===================================================================
    // HELPER: Parse interpolated string into parts
    // ===================================================================
    fn parseInterpolatedString(value, l, c) {
        parts = []
        i = 0
        buf = ""

        while i < value.len {
            ch = value.sub(i, 1)

            // ${...} interpolation
            if ch == "$" and i + 1 < value.len and value.sub(i + 1, 1) == "{" {
                if buf.len > 0 {
                    parts.push(StringLiteral(buf, l, c))
                    buf = ""
                }
                i = i + 2
                depth = 1
                exprStr = ""
                while i < value.len and depth > 0 {
                    ch2 = value.sub(i, 1)
                    if ch2 == "{": depth = depth + 1
                    else if ch2 == "}": depth = depth - 1
                    if depth > 0: exprStr = exprStr + ch2
                    i = i + 1
                }
                // Parse the sub-expression by tokenizing and parsing
                subTokens = tokenize(exprStr)
                subParser = Parser(subTokens)
                subExpr = subParser.parseExpr(0)
                if subExpr != null: parts.push(subExpr)
                else: parts.push(Identifier(exprStr, l, c))

            }
            // {...} f-string interpolation
            else if ch == "{" and (i == 0 or value.sub(i - 1, 1) != "$") {
                if buf.len > 0 {
                    parts.push(StringLiteral(buf, l, c))
                    buf = ""
                }
                i = i + 1
                depth = 1
                exprStr = ""
                while i < value.len and depth > 0 {
                    ch2 = value.sub(i, 1)
                    if ch2 == "{": depth = depth + 1
                    else if ch2 == "}": depth = depth - 1
                    if depth > 0: exprStr = exprStr + ch2
                    i = i + 1
                }
                subTokens = tokenize(exprStr)
                subParser = Parser(subTokens)
                subExpr = subParser.parseExpr(0)
                if subExpr != null: parts.push(subExpr)
                else: parts.push(Identifier(exprStr, l, c))

            }
            else {
                buf = buf + ch
                i = i + 1

            }
        }
        if buf.len > 0 {
            parts.push(StringLiteral(buf, l, c))

  }
  return InterpolatedString(parts, l, c)

  }
    // ===================================================================
    // HELPER: Parenthesized expression or lambda
    // ===================================================================
    fn parseParenExpr(openTok) {
        l = openTok.line
        c = openTok.col

        // Empty lambda: () => body
        body = null
        if current().tid == TID.CloseParen and at(1).tid == TID.Arrow {
            advance() // )
            advance() // =>
            params = []
            if current().tid == TID.OpenBrace {
                body = parseBlock()
            }
            else {
                bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            }
            return LambdaExpression(params, body, l, c)

        }
        // Multi-param lambda detection: (a, b, c) => body
        savedPos = pos
        lambdaParams = []
        isLambda = false

        if current().tid == TID.Identifier {
            // Try collecting comma-separated identifiers
            while true {
                if current().tid == TID.Identifier {
                    lambdaParams.push(advance().value)
                    if current().tid == TID.Comma {
                        advance()
                    }
                    else {
                        break
                    }
                }
                else {
                    break

                }
            }
            if current().tid == TID.CloseParen {
                savedAfter = pos + 1
                // Peek past ) for =>
                if at(1).tid == TID.Arrow {
                    advance() // )
                    advance() // =>
                    isLambda = true

                }
            }
        }
        if isLambda {
            if current().tid == TID.OpenBrace {
                body = parseBlock()
            }
            else {
                bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            }
            return LambdaExpression(lambdaParams, body, l, c)

        }
        // Not a lambda — restore position and parse grouped expression
        pos = savedPos
    syncCur()
        skipNewlines()
        expr = parseExpr(0)
skipNewlines()
expect(TID.CloseParen)
return expr

}
    // ===================================================================
    // HELPER: Lambda expression (fn keyword form)
    // ===================================================================
    fn parseLambdaExpr() {
        l = current().line
        c = current().col

        // fn(params) => body  or  fn params => body
        params = []
        if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
            // Parse param name (allow keyword-idents as param names, but not Fn)
            lpt = current().tid
            if lpt == TID.Fn {
                return error("'fn' cannot be used as a parameter name (reserved for lambda syntax)", current().line, current().col)
            }
            if lpt != TID.Identifier && !isKeywordIdent(lpt) {
                return error("Expected parameter name, got " + lpt, current().line, current().col)
            }
            pname = advance().value
                p = {name: pname}
                // Type annotation
                if current().tid == TID.Colon {
                    advance()
                    p.typeAnn = advance().value
                }
		// Default value
		if current().tid == TID.Assign {
			advance()
			p.defval = parseExpr(0)
		}
                // Variadic
                if current().tid == TID.Spread {
                    advance()
                    p.variadic = true
                }
                params.push(p)
                skipNewlines()
                if current().tid == TID.Comma: advance()
            }
            expect(TID.CloseParen)
        }
        else if current().tid == TID.Identifier {
            params.push(advance().value)

        }
        // Optional => (fn(x) body and fn(x) => body both valid)
        if current().tid == TID.Arrow {
         advance()

        }
        body = null
        if current().tid == TID.OpenBrace {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

  }
  return LambdaExpression(params, body, l, c)

  }
    // ===================================================================
    // HELPER: Match expression
    // ===================================================================
    fn parseMatchExpr() {
        l = current().line
        c = current().col

        subject = parseExpr(0)
        skipNewlines()

        // Expect { or :
        if current().tid == TID.OpenBrace {
            advance()
        }
        else if current().tid == TID.Colon {
            advance()
        }
        else {
            return error("Expected '{' or ':' after match subject", l, c)

        }
        prevMatch = inMatchExpr
        inMatchExpr = true

 cases = []
 defaultCase = null
 skipNewlines()
 while current().tid != TID.CloseBrace and notEOF() and current().tid != TID.EOF {
 skipNewlines()
 if current().tid == TID.CloseBrace: break
 mc = parseMatchCase()
 if mc != null {
 if mc.isDefault {
 defaultCase = mc.body
 } else {
 cases.push(mc)
 }
 }
 // Skip optional comma between cases
 if current().tid == TID.Comma {
 advance()
 }
 // Skip newlines and semicolons (case separators)
 while current().tid == TID.NewLine or current().tid == TID.Semicolon {
 advance()
 }
 }
 inMatchExpr = prevMatch

 if current().tid == TID.CloseBrace {
 advance()

 }
 node = MatchExpression(subject, cases, l, c)
 node.defaultCase = defaultCase
 node

  }
fn parseMatchCase() {
 l = current().line
 c = current().col

 isDefault = false
 pattern = null

 // Check for wildcard pattern _
 if current().tid == TID.Identifier and current().value == "_" {
 advance()
 pattern = Identifier("_", l, c)
 isDefault = true
 skipNewlines()
 } else {
 // Parse pattern as expression
 prevSugar = allowBraceSugar
 allowBraceSugar = false
 pattern = parseExpr(0)
 allowBraceSugar = prevSugar
 skipNewlines()
 }

 // Optional guard: when expr or if expr
 guard = null
 if current().tid == TID.When or current().tid == TID.If {
 advance()
 guard = parseExpr(0)
 skipNewlines()

 }
 // Expect =>
 if current().tid == TID.Arrow {
 advance()
 } else {
 return error("Expected '=>' in match case", l, c)

 }
 skipNewlines()

 // Body
 body = null
 if current().tid == TID.OpenBrace {
 body = parseBlock()
 }
 else {
 bodyExpr = parseExpr(0)
 body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

 }
 mc = MatchCase(pattern, guard, body, l, c)
 mc.isDefault = isDefault
 mc

 }
    // ===================================================================
    // HELPER: If expression
    // ===================================================================
    fn parseIfExpr() {
        l = current().line
        c = current().col

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        condition = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

 thenBranch = null
 if current().tid == TID.OpenBrace {
  thenBranch = parseBlock()
 }
 else if current().tid == TID.Colon {
  thenBranch = parseBlock()
 }
 else {
  thenBranch = parseStatement()
  if thenBranch == null: thenBranch = BlockStatement([], l, c)
 }
 skipNewlines()

 elseBranch = null
 if current().tid == TID.Else {
            advance()
            skipNewlines()
            if current().tid == TID.If {
                elseBranch = parseIfExpr()
            }
            else if current().tid == TID.OpenBrace {
                elseBranch = parseBlock()
            }
 else if current().tid == TID.Colon {
  elseBranch = parseBlock()
 }
            else {
                elseBranch = parseStatement()
                if elseBranch == null: elseBranch = BlockStatement([], l, c)

}
}
return IfStatement(condition, thenBranch, elseBranch, l, c)

}
    // ===================================================================
    // HELPER: Array literal
    // ===================================================================
    fn parseArrayLiteral() {
        l = current().line
        c = current().col
        expect(TID.OpenBracket)
        skipNewlines()

        elements = []
        while current().tid != TID.CloseBracket and notEOF() {
            skipNewlines()
            if current().tid == TID.CloseBracket: break

            if current().tid == TID.Spread {
                advance()
                target = parseExpr(0)
                elements.push(SpreadExpression(target, current().line, current().col))
            }
            else {
                elements.push(parseExpr(0))

            }
            skipNewlines()
            if current().tid == TID.Comma {
                advance()
            }
            else if current().tid != TID.CloseBracket {
                // Allow missing comma (newline-separated)
                skipNewlines()

            }
        }
expect(TID.CloseBracket)
return ArrayLiteral(elements, l, c)

}
    // ===================================================================
    // HELPER: Object literal disambiguation
    // ===================================================================
fn disambiguateBrace() {
    l = current().line
    c = current().col

    // Lookahead to determine set vs object
    lookahead = 1
    while at(lookahead).tid == TID.NewLine {
        lookahead = lookahead + 1

    }
    nextTok = at(lookahead)

        // Empty braces = empty object
        if nextTok.tid == TID.CloseBrace {
            return parseObjectLiteral(false)

        }
// Check if object: identifier/string/number followed by colon or =
isObject = false
isObjKeyType = (nextTok.tid == TID.Identifier or nextTok.tid == TID.String or nextTok.tid == TID.MultilineString or nextTok.tid == TID.Number or isKeywordIdent(nextTok.tid))

if isObjKeyType {
    colonLook = lookahead + 1
    while at(colonLook).tid == TID.NewLine {
        colonLook = colonLook + 1
    }
    if at(colonLook).tid == TID.Colon or at(colonLook).tid == TID.Assign {
        isObject = true

    }
}
        if isObject {
            return parseObjectLiteral(false)

        }
        // Check for set literal: {expr, ...}
        couldBeSet = (nextTok.tid == TID.Identifier or nextTok.tid == TID.String or nextTok.tid == TID.MultilineString or nextTok.tid == TID.RegexString or nextTok.tid == TID.Number or nextTok.tid == TID.OpenBracket or nextTok.tid == TID.OpenParen or nextTok.tid == TID.OpenBrace or nextTok.tid == TID.Minus or nextTok.tid == TID.Not or nextTok.tid == TID.Plus or nextTok.tid == TID.Length or nextTok.tid == TID.True or nextTok.tid == TID.False or nextTok.tid == TID.Null)

        if couldBeSet {
            // Look ahead for comma
            setLook = lookahead + 1
            while setLook < tokens.len and at(setLook).tid != TID.Comma and at(setLook).tid != TID.Semicolon and at(setLook).tid != TID.CloseBrace and at(setLook).tid != TID.NewLine {
                setLook = setLook + 1

            }
            if at(setLook).tid == TID.Comma {
                // Parse as set literal
                advance()
                elements = []
                skipNewlines()
                while current().tid != TID.CloseBrace and notEOF() {
                    skipNewlines()
                    if current().tid == TID.CloseBrace: break
                    elements.push(parseExpr(0))
                    skipNewlines()
                    if current().tid == TID.Comma: advance()
                    else if current().tid != TID.CloseBrace {
                        skipNewlines()
                    }
                }
                expect(TID.CloseBrace)
                node = ArrayLiteral(elements, l, c)
                node.isSet = true
                return node

            }
}
// Default to object literal
return parseObjectLiteral(false)

}
    // ===================================================================
    // HELPER: Object literal
    // ===================================================================
    fn parseObjectLiteral(unsorted) {
        l = current().line
        c = current().col

        if current().tid == TID.BangOpenBrace {
            advance() // consume !{
        }
        else {
            expect(TID.OpenBrace)

        }
        skipNewlines()

    fields = []
    while current().tid != TID.CloseBrace and notEOF() {
        skipNewlines()
        if current().tid == TID.CloseBrace: break

        // Parse key — using separate if/return guards to avoid VM if/else fallthrough bug
        key = null
        if current().tid == TID.String or current().tid == TID.MultilineString {
            key = advance().value
        }
        if current().tid == TID.Number and key == null {
            key = advance().value
        }
        if (current().tid == TID.Identifier or isDotAccessIdent(current().tid)) and key == null {
            key = advance().value
        }
        if current().tid == TID.OpenBracket and key == null {
            // Computed key: [expr]
            advance()
            key = parseExpr(0)
            expect(TID.CloseBracket)
        }
        if key == null {
            return error("Expected object key", l, c)
        }
            skipNewlines()

    // Check for colon or = (key: value or key = value)
    value = null
    if current().tid == TID.Colon or current().tid == TID.Assign {
        advance()
        skipNewlines()
        value = parseExpr(0)
    }
            else {
                // Shorthand: {x} means {x: x}
                if type(key) == "string" {
                    value = Identifier(key, l, c)
                }
                else {
                    value = key
                }
                key = key

            }
            fields.push(ObjectField(key, value, l, c))

            skipNewlines()
            if current().tid == TID.Comma {
                advance()
            }
            else if current().tid != TID.CloseBrace {
                skipNewlines()

            }
        }
        expect(TID.CloseBrace)

        node = ObjectLiteral(fields, l, c)
        if unsorted: node.unsorted = true
        node

    }
    // ===================================================================
    // BLOCK PARSING
    // ===================================================================
fn parseBlock() {
  l = current().line
  c = current().col
  prevSugar = allowBraceSugar
  allowBraceSugar = false

  if current().tid == TID.OpenBrace {
    advance()
    skipNewlines()
    stmts = []
    while current().tid != TID.CloseBrace and notEOF() {
      skipNewlines()
      if current().tid == TID.CloseBrace: break
      s = parseStatement()
      if s != null and s.kind != "ErrorNode" {
        stmts.push(s)
      }
      if s != null and s.kind == "ErrorNode" {
        advance()
      }
      skipNewlinesAndSemicolons()
    }
    expect(TID.CloseBrace)
    allowBraceSugar = prevSugar
    return BlockStatement(stmts, l, c)
  }
 if current().tid == TID.Colon {
  // Find header indent by scanning backwards to first token on same line
  headerIndent = c
  scanPos = pos - 1
  while scanPos >= 0 {
   t = tokens[scanPos]
   if t.line == l {
    if t.tid != TID.NewLine and t.tid != TID.Semicolon:
     headerIndent = t.col
   }
   else { break }
   scanPos = scanPos - 1
  }
  advance()
  skipNewlines()
  stmts = []
  blockLine = l
  baseIndent = headerIndent + 1
  while notEOF() and current().tid != TID.EOF {
   skipNewlines()
   if current().tid == TID.EOF: break
   if current().col < baseIndent: break
   s = parseStatement()
   if s != null and s.kind != "ErrorNode" {
    stmts.push(s)
   }
   if s != null and s.kind == "ErrorNode" {
    advance()
   }
   skipNewlinesAndSemicolons()
 if current().tid == TID.EOF: break
 if current().col < baseIndent: break
 endTokens = {}
 endTokens[TID.Else] = true; endTokens[TID.Catch] = true; endTokens[TID.Finally] = true; endTokens[TID.Case] = true; endTokens[TID.Default] = true
 if endTokens[current().tid] != null: break
 }
 allowBraceSugar = prevSugar
  return BlockStatement(stmts, blockLine, c)
 }
  allowBraceSugar = prevSugar
  error("Expected '{' or ':' for block", l, c)

}
    // ===================================================================
    // STATEMENT PARSING
    // ===================================================================
fn parseStatement() {
  if !notEOF(): return null

  skipNewlines()
  if !notEOF(): return null

  tt = current().tid
  l = current().line
  c = current().col

        // Hotkey binding: Hotkey token or @token => block
        if tt == TID.Hotkey {
            return parseHotkeyStatement()

        }
        // @identifier => block (hotkey syntax)
        if tt == TID.At and at(1).tid == TID.Identifier {
            // Check if this is a hotkey: @id => ...
            // Look ahead past the @ident for =>
            savePos = pos
            advance() // @
            advance() // identifier
            if current().tid == TID.Arrow {
                pos = savePos
                syncCur()
                return parseHotkeyStatement()
            }
            pos = savePos
            syncCur()

        }
	// Identifier + When/If/Arrow at statement start => hotkey
	// e.g. F1 => { ... } or a when mode == "x" => { ... } or F1 mode="gaming" => { ... }
	if tt == TID.Identifier {
		nextTid = at(1).tid
		if nextTid == TID.When || nextTid == TID.If || nextTid == TID.Arrow {
			return parseHotkeyStatement()
		}
		// identifier mode="..." or policy="..." followed by => (hotkey with attrs)
		if nextTid == TID.Identifier && (at(1).value == "mode" || at(1).value == "policy") && isHotkeyIdentifier(current().value) {
			lookPos = 2
			while at(lookPos).tid == TID.Identifier && (at(lookPos).value == "mode" || at(lookPos).value == "policy") && at(lookPos + 1).tid == TID.Assign && at(lookPos + 2).tid == TID.String {
				lookPos = lookPos + 3
			}
			if at(lookPos).tid == TID.Arrow || at(lookPos).tid == TID.When || at(lookPos).tid == TID.If {
				return parseHotkeyStatement()
			}
		}
            // identifier = hotkey => action (e.g. dhk = d => { print @id })
            if nextTid == TID.Assign {
                at2 = at(2).tid
                if at2 == TID.Hotkey || (at2 == TID.Identifier && at(3).tid == TID.Arrow) {
                    return parseHotkeyAssignmentStatement()
                }
            }
        }
        // Variable declarations
        if tt == TID.Let {
            return parseLetDecl("Let")
        }
        if tt == TID.Val {
            return parseLetDecl("Val")
        }
        if tt == TID.Const {
            return parseLetDecl("Val") // const is alias for val

        }
        // Control flow
        if tt == TID.If {
            return parseIfStatement()
        }
    if tt == TID.While {
        return parseWhileStatement()
    }
    if tt == TID.Do {
        return parseDoWhileStatement()
    }
        if tt == TID.For {
            return parseForStatement()
        }
        if tt == TID.Loop {
            return parseLoopStatement()
        }
        if tt == TID.Repeat {
            return parseRepeatStatement()
        }
        if tt == TID.Break {
            advance()
            return BreakStatement(l, c)
        }
        if tt == TID.Continue {
            advance()
            return ContinueStatement(l, c)
        }
        if tt == TID.Return or tt == TID.Ret {
            return parseReturnStatement()
        }
        if tt == TID.Throw {
            return parseThrowStatement()
        }
        if tt == TID.Try {
            return parseTryStatement()
        }
        if tt == TID.Switch {
            return parseSwitchStatement()
        }
        if tt == TID.Del {
            return parseDelStatement()

        }
        // Function declaration
        if tt == TID.Fn {
            return parseFnDeclaration()

        }
        // Import / Use
        if tt == TID.Import {
            return parseImportStatement()
        }
        if tt == TID.Use {
            return parseUseStatement()

        }
        // Config block
        if tt == TID.Config {
            return parseConfigBlockStatement()

        }
// Sleep
if tt == TID.Sleep {
	advance()
	duration = parseExpr(0)
	return SleepStatement(duration, l, c)

}
// Defer
if tt == TID.Defer {
	advance()
	if current().tid == TID.OpenBrace {
		advance()
		stmts = []
		skipNewlines()
		while current().tid != TID.CloseBrace and notEOF() {
			if current().tid == TID.NewLine { advance(); continue }
			stmts.push(parseStatement())
			skipNewlines()
		}
		expect(TID.CloseBrace)
		block = BlockStatement(stmts, l, c)
		expr = LambdaExpression([], block, l, c)
		return DeferStatement(expr, l, c)
	}
	else {
		expr = parseExpr(0)
		return DeferStatement(expr, l, c)
	}
}
        // DSL statements
        if tt == TID.On: return parseOnStatement()
        if tt == TID.Mode: return parseModeBlockStatement()
        if tt == TID.Group: return parseGroupStatement()
        if tt == TID.Signal: return parseSignalStatement()
        if tt == TID.Pool: return parsePoolStatement()
        if tt == TID.Devices: return parseDevicesBlockStatement()

        // Thread/Interval/Timeout sugar
        if tt == TID.Thread: return parseThreadStatement()
        if tt == TID.Interval: return parseIntervalStatement()
        if tt == TID.Timeout: return parseTimeoutStatement()

 // Type declarations
 if tt == TID.Class { return parseClassDeclaration() }
 if tt == TID.Struct { return parseStructDeclaration() }
 if tt == TID.Enum { return parseEnumDeclaration() }
 if tt == TID.Trait { return parseTraitDeclaration() }
 if tt == TID.Prot { return parseProtocolDeclaration() }
 if tt == TID.Impl { return parseImplDeclaration() }
        // Expression statement
    expr = parseExpr(0)
    if expr == null: return null
    if expr.kind == "ErrorNode": return expr
    return ExpressionStatement(expr, l, c)
}
    // ===================================================================
    // STATEMENT: if
    // ===================================================================
fn parseIfStatement() {
 l = current().line
 c = current().col
 advance() // consume 'if'
 skipNewlines()

 prevSugar = allowBraceSugar
 allowBraceSugar = false
 condition = parseExpr(0)
 allowBraceSugar = prevSugar

 skipNewlines()

 thenBranch = null
 if current().tid == TID.OpenBrace {
 thenBranch = parseBlock()
 }
 if thenBranch == null && current().tid == TID.Colon {
 thenBranch = parseBlock()
 }
 if thenBranch == null {
 thenBranch = parseStatement()
 if thenBranch == null: thenBranch = BlockStatement([], l, c)
 }
 skipNewlines()

 elseBranch = null
 if current().tid == TID.Else {
 advance()
 skipNewlines()
 if current().tid == TID.If {
 elseBranch = parseIfStatement()
 }
 if elseBranch == null && current().tid == TID.OpenBrace {
 elseBranch = parseBlock()
 }
 if elseBranch == null && current().tid == TID.Colon {
  elseBranch = parseBlock()
 }
    if elseBranch == null {
      elseBranch = parseStatement()
      if elseBranch == null: elseBranch = BlockStatement([], l, c)
}
}
return IfStatement(condition, thenBranch, elseBranch, l, c)

}
    // ===================================================================
    // STATEMENT: while
    // ===================================================================
fn parseWhileStatement() {
    l = current().line
    c = current().col
    advance() // consume 'while'
    skipNewlines()

    prevSugar = allowBraceSugar
    allowBraceSugar = false
    condition = parseExpr(0)
    allowBraceSugar = prevSugar

    skipNewlines()

    body = null
    if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
    else {
        body = parseStatement()
        if body == null: body = BlockStatement([], l, c)

    }
    return WhileStatement(condition, body, l, c)

}
fn parseDoWhileStatement() {
    l = current().line
    c = current().col
    advance() // consume 'do'
    skipNewlines()

    body = null
    if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
    else {
        body = parseStatement()
        if body == null: body = BlockStatement([], l, c)
    }

    skipNewlines()
    if current().tid != TID.While {
        return error("Expected 'while' after 'do' block", current().line, current().col)
    }
    advance() // consume 'while'
    skipNewlines()

    prevSugar = allowBraceSugar
    allowBraceSugar = false
    condition = parseExpr(0)
    allowBraceSugar = prevSugar

    return DoWhileStatement(body, condition, l, c)

}
    // ===================================================================
    // STATEMENT: for
    // ===================================================================
    fn parseForStatement() {
        l = current().line
        c = current().col
        advance() // consume 'for'
        skipNewlines()

        // Parse iterator variable(s) — may be parenthesized
        names = []
        if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                names.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma: advance()
            }
            expect(TID.CloseParen)
        }
        else {
          names.push(advance().value)
          skipNewlines()
          while current().tid == TID.Comma {
            advance() // consume comma
            skipNewlines()
            names.push(advance().value)
            skipNewlines()
          }
        }
        skipNewlines()

        // Expect 'in'
        if current().tid == TID.In {
            advance()
        }
        else {
            return error("Expected 'in' in for statement", l, c)

        }
        skipNewlines()
        iterator = parseExpr(0)
        skipNewlines()

        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        }
        // If multiple names, use first as name and add keyVar
        name = names[0]
        node = ForStatement(name, iterator, body, l, c)
        if names.len > 1 {
            node.keyVar = names[0]
            node.name = names[1]
        }
        node

    }
    // ===================================================================
    // STATEMENT: loop
    // ===================================================================
    fn parseLoopStatement() {
        l = current().line
        c = current().col
        advance() // consume 'loop'
        skipNewlines()

        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        }
        return LoopStatement(body, l, c)

    }
    // ===================================================================
    // STATEMENT: repeat
    // ===================================================================
    fn parseRepeatStatement() {
        l = current().line
        c = current().col
        advance() // consume 'repeat'
        skipNewlines()

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        count = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        }
        return RepeatStatement(count, body, l, c)

    }
    // ===================================================================
    // STATEMENT: return
    // ===================================================================
    fn parseReturnStatement() {
        l = current().line
        c = current().col
        advance() // consume 'return' or 'ret'
        skipNewlines()

        // @ without following identifier -> return this
        if current().tid == TID.At and at(1).tid != TID.Identifier {
            advance()
            return ReturnStatement(Identifier("this", l, c), l, c)

        }
        value = null
        // Return value is optional — check if next token can start expression
        if canStartExpr(current().tid) or (current().tid == TID.Not and isNotIn()) or current().tid == TID.Minus or current().tid == TID.Plus {
            value = parseExpr(0)

        }
        return ReturnStatement(value, l, c)

    }
    // ===================================================================
    // STATEMENT: throw
    // ===================================================================
    fn parseThrowStatement() {
        l = current().line
        c = current().col
        advance() // consume 'throw'
        skipNewlines()
        value = parseExpr(0)
        return ThrowStatement(value, l, c)

    }
    // ===================================================================
    // STATEMENT: try/catch/finally
    // ===================================================================
    fn parseTryStatement() {
        l = current().line
        c = current().col
        advance() // consume 'try'
        skipNewlines()

        tryBlock = parseBlock()
        skipNewlines()

        catchParam = null
        catchBlock = null
        finallyBlock = null

if current().tid == TID.Catch {
advance()
skipNewlines()
if current().tid == TID.OpenParen {
advance() // consume (
skipNewlines()
if current().tid == TID.Identifier {
catchParam = advance().value
}
skipNewlines()
if current().tid == TID.CloseParen {
advance() // consume )
}
}
else if current().tid == TID.Identifier {
catchParam = advance().value
}
skipNewlines()
catchBlock = parseBlock()
skipNewlines()

}
        if current().tid == TID.Finally {
            advance()
            skipNewlines()
            finallyBlock = parseBlock()

        }
        return TryStatement(tryBlock, catchParam, catchBlock, finallyBlock, l, c)

    }
    // ===================================================================
    // STATEMENT: switch
    // ===================================================================
    fn parseSwitchStatement() {
        l = current().line
        c = current().col
        advance() // consume 'switch'
        skipNewlines()

        subject = parseExpr(0)
        skipNewlines()

        if current().tid == TID.OpenBrace {
            advance()
        }
        else if current().tid == TID.Colon {
            advance()
        }
        else {
            return error("Expected '{' or ':' after switch", l, c)

        }
        cases = []
        skipNewlines()
        while current().tid != TID.CloseBrace and notEOF() and current().tid != TID.EOF {
            skipNewlines()
            if current().tid == TID.CloseBrace: break

            if current().tid == TID.Case {
                advance()
                test = parseExpr(0)
            }
            else if current().tid == TID.Default {
                advance()
                test = null
            }
            else {
                // expression as case
                test = parseExpr(0)

            }
            skipNewlines()

            if current().tid == TID.Arrow {
                advance()
            }
            else if current().tid == TID.Colon {
                advance()
            }
            else {
                // Try to continue anyway
                pass

            }
            skipNewlines()
            body = parseBlock()
            cases.push({test: test, body: body})
            skipNewlines()

        }
        if current().tid == TID.CloseBrace {
            advance()

        }
        // Represent as MatchExpression (switch is syntactic sugar for match)
        matchCases = []
        for c in cases {
            matchCases.push(MatchCase(c.test, null, c.body, l, c))
        }
        return MatchExpression(subject, matchCases, l, c)

    }
    // ===================================================================
    // STATEMENT: del
    // ===================================================================
    fn parseDelStatement() {
        l = current().line
        c = current().col
        advance() // consume 'del'
        skipNewlines()

        // del(...) as function call or del expr
        if current().tid == TID.OpenParen {
            // Could be del(expr) — parse as call
            callee = Identifier("del", l, c)
            args = parseCallArgs()
            return ExpressionStatement(CallExpression(callee, args, [], l, c), l, c)

        }
        target = parseExpr(0)
        node = ExpressionStatement(target, l, c)
        node.isDel = true
        node

    }
    // ===================================================================
    // STATEMENT: fn declaration
    // ===================================================================
    fn parseFnDeclaration() {
        l = current().line
        c = current().col
        advance() // consume 'fn'
        skipNewlines()

        // Check if this is a lambda (fn followed by open paren)
        if current().tid == TID.OpenParen {
         lambda = parseLambdaExpr()
         return ExpressionStatement(lambda, l, c)
        
        }
  // Function name
  name = advance().value
  skipNewlines()

    // Parse optional type parameters: fn identity(T)(x: T): T { x }
    // or with bounds: fn calc(T: Number)(a: T, b: T): T { ... }
    typeParams = parseTypeParameterList()

  // Params
  params = []
  if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
      // Param name — must be Identifier or keyword-as-ident (not Fn, it's ambiguous with lambda)
      pt = current().tid
      if pt == TID.Fn {
        return error("'fn' cannot be used as a parameter name (reserved for lambda syntax)", current().line, current().col)
      }
      isVariadic = false
      if pt == TID.Spread {
        isVariadic = true
        advance()
        skipNewlines()
        pt = current().tid
      }
      if pt != TID.Identifier && !isKeywordIdent(pt) {
                return error("Expected parameter name, got " + pt, current().line, current().col)
            }
      pname = advance().value
      p = {name: pname}
      if isVariadic: p.isVariadic = true
      // Type annotation
      if current().tid == TID.Colon {
        advance()
        p.typeAnn = advance().value
        skipNewlines()
      }
      // Default value
      if current().tid == TID.Assign {
        advance()
        p.defval = parseExpr(0)
        skipNewlines()
      }
      params.push(p)
      if current().tid == TID.Comma: advance()
      }
      expect(TID.CloseParen)
      skipNewlines()

        }
        // Return type annotation
        if current().tid == TID.ReturnType {
            advance()
            advance() // consume type name
            skipNewlines()

        }
 // Body
 body = null
 if current().tid == TID.OpenBrace or current().tid == TID.Colon {
        body = parseBlock()
    }
 else if current().tid == TID.If or current().tid == TID.While or current().tid == TID.For or current().tid == TID.Loop or current().tid == TID.Return or current().tid == TID.Ret or current().tid == TID.Let or current().tid == TID.Val or current().tid == TID.Try or current().tid == TID.Switch or current().tid == TID.Break or current().tid == TID.Continue or current().tid == TID.Throw {
  // Statement body — parse multiple statements like colon block
  fnIndent = c
  baseIndent = fnIndent + 1
  stmts = []
  while notEOF() and current().tid != TID.EOF {
   skipNewlines()
   if current().tid == TID.EOF: break
 if current().col < baseIndent: break
 s = parseStatement()
 if s != null and s.kind != "ErrorNode" {
  stmts.push(s)
 }
 skipNewlinesAndSemicolons()
 if current().tid == TID.EOF: break
 if current().col < baseIndent: break
 endTokens = {}
 endTokens[TID.Else] = true; endTokens[TID.Catch] = true; endTokens[TID.Finally] = true; endTokens[TID.Case] = true; endTokens[TID.Default] = true
 if endTokens[current().tid] != null: break
 }
 body = BlockStatement(stmts, l, c)
 }
    else {
        // Expression body
        bodyExpr = parseExpr(0)
        body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

    }
    return FnDeclaration(name, params, body, l, c, typeParams)

    }
    // ===================================================================
    // STATEMENT: let / val declaration
    // ===================================================================
    fn parseLetDecl(keyword) {
        l = current().line
        c = current().col
        advance() // consume 'let'/'val'/'const'
        skipNewlines()

        // Parse name(s) — may be destructuring
        name = advance().value
        skipNewlines()

        value = null
        if current().tid == TID.Assign {
            advance()
            skipNewlines()
            value = parseExpr(0)
        }
        else if current().tid == TID.Colon {
            // Type annotation without assignment
            advance()
            advance() // type name
            skipNewlines()
            if current().tid == TID.Assign {
                advance()
                skipNewlines()
                value = parseExpr(0)

            }
        }
    if keyword == "Let" {
        return LetDeclaration(name, value, l, c)
    }
    else {
        return ValDeclaration(name, value, l, c)

        }
    }
    // ===================================================================
    // STATEMENT: import
    // ===================================================================
fn parseImportStatement() {
  l = current().line
  c = current().col
  advance()
  skipNewlines()

  iNames = []
  iAliases = []

  // import * from "module"
  if current().tid == TID.Multiply {
    advance()
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, ["*"], l, c, {isWildcard: true})
  }

  // import { names } from "module" or import a, b from "module"
  if current().tid == TID.OpenBrace {
    advance()
    skipNewlines()
    while current().tid != TID.CloseBrace and notEOF() {
      skipNewlines()
      if current().tid == TID.CloseBrace: break
      n = advance().value
      a = n
      if current().tid == TID.As {
        advance()
        skipNewlines()
        a = advance().value
      }
      iNames.push(n)
      iAliases.push(a)
      skipNewlines()
      if current().tid == TID.Comma: advance()
    }
    expect(TID.CloseBrace)
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, iNames, l, c, {importNames: iNames, importAliases: iAliases})
  }

  // import identifier[, identifier...] from "module"
  if current().tid == TID.Identifier {
    n = advance().value
    iNames.push(n)
    iAliases.push(n)
    skipNewlines()
    while current().tid == TID.Comma {
      advance()
      skipNewlines()
      n = advance().value
      iNames.push(n)
      iAliases.push(n)
      skipNewlines()
    }
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return ImportStatement(module, iNames, l, c, {importNames: iNames, importAliases: iAliases})
  }

  // bare: import "module"
  module = advance().value
  return ImportStatement(module, [], l, c, null)

}
    // ===================================================================
    // STATEMENT: use
    // ===================================================================
fn parseUseStatement() {
  l = current().line
  c = current().col
  advance()
  skipNewlines()

  // use { names } from "module" — named imports
  if current().tid == TID.OpenBrace {
    names = []
    iNames = []
    iAliases = []
    advance()
    skipNewlines()
    while current().tid != TID.CloseBrace and notEOF() {
      skipNewlines()
      if current().tid == TID.CloseBrace: break
      n = advance().value
      a = n
      if current().tid == TID.As {
        advance()
        skipNewlines()
        a = advance().value
      }
      names.push(n)
      iNames.push(n)
      iAliases.push(a)
      skipNewlines()
      if current().tid == TID.Comma: advance()
    }
    expect(TID.CloseBrace)
    skipNewlines()
    if current().tid != TID.From {
      return UseStatement(null, names, l, c, null)
    }
    advance()
    skipNewlines()
    module = advance().value
    return UseStatement(module, names, l, c, {isFileImport: true, isNamedImport: true,
      filePath: module, importNames: iNames, importAliases: iAliases})
  }

  // use * from "module" — wildcard
  if current().tid == TID.Multiply {
    advance()
    skipNewlines()
    if current().tid == TID.From {
      advance()
      skipNewlines()
    }
    module = advance().value
    return UseStatement(module, ["*"], l, c, {isFileImport: true, isWildcard: true,
      filePath: module})
  }

  // use "file.hv" or use "file.hv" as alias
  if current().tid == TID.String || current().tid == TID.InterpolatedString {
    fpath = advance().value
    skipNewlines()
    alias = null
    if current().tid == TID.As {
      advance()
      skipNewlines()
      alias = advance().value
    }
    if alias != null {
      return UseStatement(fpath, [], l, c, {isFileImport: true, filePath: fpath, alias: alias})
    }
    return UseStatement(fpath, ["*"], l, c, {isFileImport: true, filePath: fpath,
      isWildcard: true})
  }

  // use module or use module as alias or use module, module2
  firstMod = advance().value
  skipNewlines()

  // use module.* — wildcard via dot-star
  if current().tid == TID.Dot {
    advance()
    skipNewlines()
    if current().tid == TID.Multiply {
      advance()
      return UseStatement(firstMod, ["*"], l, c, {isWildcard: true, filePath: firstMod,
        moduleNames: [firstMod]})
    }
    return UseStatement(firstMod, [], l, c, null)
  }

  // use module as alias
  if current().tid == TID.As {
    advance()
    skipNewlines()
    alias = advance().value
    return UseStatement(firstMod, [], l, c, {alias: alias, moduleNames: [firstMod]})
  }

  // use module from "source"
  if current().tid == TID.From {
    advance()
    skipNewlines()
    source = advance().value
    return UseStatement(source, [], l, c, {isFileImport: true, filePath: source, alias: firstMod})
  }

  // use module, module2, ... — multiple bare module names
  mods = [firstMod]
  while current().tid == TID.Comma {
    advance()
    skipNewlines()
    if current().tid == TID.Identifier || current().tid == TID.Keyword {
      mods.push(advance().value)
      skipNewlines()
    }
  }
  return UseStatement(firstMod, [], l, c, {moduleNames: mods})

}
    // ===================================================================
    // STATEMENT: hotkey binding
    // ===================================================================
    fn parseHotkeyStatement() {
        l = current().line
        c = current().col

        // Collect the hotkey token(s)
        key = ""
        if current().tid == TID.Hotkey {
            key = advance().value
        }
        else if current().tid == TID.At {
            advance()
            if current().tid == TID.Identifier {
                key = "@" + advance().value
            }
            else {
                key = "@"

            }
        }
	else if current().tid == TID.Identifier {
		key = advance().value
	}
	skipNewlines()

	// Parse optional inline attributes: mode="name" policy="replace"
	attrs = parseHotkeyAttrs()
	modeAttr = attrs.mode
	policyAttr = attrs.policy
	skipNewlines()

	// Optional when/if prefix condition
        condition = null
        if current().tid == TID.When or current().tid == TID.If {
            advance()
            condition = parseExpr(BP_ASSIGN)

        }
        skipNewlines()

        // Expect => or {
        if current().tid == TID.Arrow {
            advance()
            skipNewlines()
        }
        else if current().tid != TID.OpenBrace and current().tid != TID.Colon {
            return error("Expected '=>' or '{' after hotkey", l, c)

        }
        // Parse body
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        }
	node = HotkeyBinding(key, body, l, c)
	if condition != null: node.condition = condition
	if modeAttr != "": node.mode = modeAttr
	if policyAttr != "": node.policy = policyAttr
	node

}
    // ===================================================================
    // STATEMENT: hotkey assignment (identifier = hotkey => action)
    // ===================================================================
fn parseHotkeyAssignmentStatement() {
	l = current().line
	c = current().col
	target = Identifier(advance().value, l, c)
	advance() // consume =
	hkToken = advance()
	key = hkToken.value
	if hkToken.tid == TID.Identifier { key = hkToken.value }
	skipNewlines()
	// Parse optional inline attributes: mode="name" policy="replace"
	attrs = parseHotkeyAttrs()
	modeAttr = attrs.mode
	policyAttr = attrs.policy
	condition = null
	if current().tid == TID.When or current().tid == TID.If {
            advance()
            condition = parseExpr(BP_ASSIGN)
        }
        skipNewlines()
        if current().tid == TID.Arrow {
            advance()
            skipNewlines()
        }
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
	binding = HotkeyBinding(key, body, l, c)
	if condition != null: binding.condition = condition
	if modeAttr != "": binding.mode = modeAttr
	if policyAttr != "": binding.policy = policyAttr
	hkExpr = HotkeyExpression(binding, l, c)
        assign = AssignmentExpression(target, hkExpr, "=", false, l, c)
        ExpressionStatement(assign, l, c)
    }
    // ===================================================================
    // STATEMENT: config block
    // ===================================================================
    fn parseConfigBlockStatement() {
        l = current().line
        c = current().col
        advance() // consume 'config'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock(name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: on
    // ===================================================================
    fn parseOnStatement() {
        l = current().line
        c = current().col
        advance() // consume 'on'
        skipNewlines()
        // on <event> => body or on <event> { body }
        event = advance().value
        skipNewlines()
        if current().tid == TID.Arrow {
            advance()
            skipNewlines()
        }
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = HotkeyBinding(event, body, l, c)
        node.isEvent = true
        node

    }
    // ===================================================================
    // STATEMENT: mode block
    // ===================================================================
    fn parseModeBlockStatement() {
        l = current().line
        c = current().col
        advance() // consume 'mode'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("mode:" + name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: group
    // ===================================================================
    fn parseGroupStatement() {
        l = current().line
        c = current().col
        advance() // consume 'group'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("group:" + name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: signal
    // ===================================================================
    fn parseSignalStatement() {
        l = current().line
        c = current().col
        advance() // consume 'signal'
        skipNewlines()
        name = advance().value
        skipNewlines()
        value = null
        if current().tid == TID.Assign {
            advance()
            value = parseExpr(0)
        }
        node = LetDeclaration(name, value, l, c)
        node.isSignal = true
        node

    }
    // ===================================================================
    // STATEMENT: pool
    // ===================================================================
    fn parsePoolStatement() {
        l = current().line
        c = current().col
        advance() // consume 'pool'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("pool:" + name, body, l, c)

    }
    // ===================================================================
    // STATEMENT: devices block
    // ===================================================================
    fn parseDevicesBlockStatement() {
        l = current().line
        c = current().col
        advance() // consume 'devices'
        skipNewlines()
        body = parseBlock()
        return ConfigBlock("devices", body, l, c)

    }
    // ===================================================================
    // STATEMENT: thread/interval/timeout sugar
    // ===================================================================
    fn parseThreadStatement() {
        l = current().line
        c = current().col
        advance() // consume 'thread'
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__thread__", [], body, l, c, [])
        node.isThread = true
        node

    }
    fn parseIntervalStatement() {
        l = current().line
        c = current().col
        advance() // consume 'interval'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__interval__", [], body, l, c, [])
        node.isInterval = true
        node.intervalDuration = duration
        node

    }
    fn parseTimeoutStatement() {
        l = current().line
        c = current().col
        advance() // consume 'timeout'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        body = null
        if current().tid == TID.OpenBrace or current().tid == TID.Colon {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        }
        node = FnDeclaration("__timeout__", [], body, l, c, [])
        node.isTimeout = true
node.timeoutDuration = duration
    node

}
// ===================================================================
// Type parameter list parser: (T) or (T: Bound) or (T: B1 & B2, E)
// Returns [] if no type parameters found (backtracks on failure)
// ===================================================================
fn parseTypeParameterList() {
    if current().tid != TID.OpenParen { return [] }
    nextTok = at(1)
    if nextTok.tid != TID.Identifier { return [] }
    savedPos = pos
    advance() // consume '('
    candidateParams = []
    isTypeParamList = true
    while current().tid == TID.Identifier && isTypeParamList {
        pname = advance().value
        bounds = []
        // Check for bound: T: Bound [& Bound2 ...]
        if current().tid == TID.Colon {
            advance() // consume ':'
            if current().tid == TID.Identifier {
                bounds.push(advance().value)
                while current().tid == TID.BitwiseAnd {
                    advance() // consume '&'
                    if current().tid == TID.Identifier {
                        bounds.push(advance().value)
                    } else {
                        isTypeParamList = false
                        break
                    }
                }
            } else {
                isTypeParamList = false
                break
            }
        }
        candidateParams.push(TypeParam(pname, bounds))
        if current().tid == TID.Comma {
            advance() // consume ','
        } else {
            break
        }
    }
  if isTypeParamList && current().tid == TID.CloseParen {
    advance() // consume ')'
    if !candidateParams.isEmpty() {
      // Only accept as type params if followed by another '(' for regular params
      // Otherwise this is just a regular parameter list — backtrack
      if current().tid == TID.OpenParen {
        return candidateParams
      }
      // Not followed by '(' — backtrack
      pos = savedPos
      syncCur()
      return []
    }
  }
  // Backtrack — not a type parameter list
  pos = savedPos
  syncCur()
  return []
  }

// ===================================================================
// STATEMENT: class declaration
// ===================================================================
fn parseClassDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'class'
    skipNewlines()
    name = current().value
    advance() // consume class name
    // Parse optional type parameters: class Calc(T: Number) { ... }
    typeParams = parseTypeParameterList()
    parentName = ""
    isColonBody = false
    // Check for inheritance: class X : ParentClass
    // vs colon body: class X :
    if current().tid == TID.Colon {
        nextTok = at(1)
        if nextTok.tid == TID.Identifier && nextTok.line == current().line {
            advance() // consume ':'
            parentName = current().value
            advance() // consume parent name
        } else {
            isColonBody = true
        }
    }
    // After inheritance, check for colon body
    if !isColonBody && current().tid == TID.Colon {
        isColonBody = true
    }
    fields = []
    methods = []
    if isColonBody {
        advance() // consume ':'
        skipNewlines()
        _parseClassMembers(methods, fields)
    } else if current().tid == TID.OpenBrace {
        advance() // consume '{'
        skipNewlines()
        _parseClassMembers(methods, fields)
        if current().tid == TID.CloseBrace {
            advance() // consume '}'
        }
    }
    return ClassDeclaration(name, parentName, fields, methods, l, c, typeParams)

}

fn _parseClassMembers(methods, fields) {
	while notEOF() && current().tid != TID.CloseBrace && current().tid != TID.EOF {
		skipNewlinesAndSemicolons()
		if !notEOF() || current().tid == TID.CloseBrace || current().tid == TID.EOF { break }
		tt = current().tid
		if tt == TID.Fn {
			m = _parseClassMethod()
			methods.push(m)
			continue
		}
		if tt == TID.Op {
			advance() // consume 'op'
			m = _parseClassOperatorMethod()
			methods.push(m)
			continue
		}
		// Field definition: name [: Type] [= default] or @@name [: Type] [= default]
		isClassField = false
		if tt == TID.AtAt {
			isClassField = true
			advance() // consume '@@'
		}
		fname = current().value
		fline = current().line
		fcol = current().col
		advance() // consume field name
		// Skip optional type annotation
		if current().tid == TID.Colon {
			advance() // consume ':'
			skipNewlines()
			if current().tid == TID.Identifier {
				advance() // consume type name
			}
		}
		// Optional default value
		defaultValue = null
		if current().tid == TID.Assign {
			advance() // consume '='
			defaultValue = parseExpr(0)
		}
		// Optional comma
		if current().tid == TID.Comma {
			advance()
		}
		fields.push({name: fname, isClassField: isClassField, defaultValue: defaultValue, line: fline, col: fcol})
	}

}

fn _parseClassMethod() {
	advance() // consume 'fn'
	mline = current().line
	mcol = current().col
	methodName = current().value
	// Handle constructor: fn @()
	if current().tid == TID.At {
		advance() // consume '@'
		methodName = "init"
	} else {
		advance() // consume method name
	}
	// Parse params
	params = []
	if current().tid == TID.OpenParen {
		advance() // consume '('
		while notEOF() && current().tid != TID.CloseParen {
			skipNewlines()
			if current().tid == TID.CloseParen { break }
			pname = current().value
 p = {name: pname}
 p.default = null
 advance() // consume param name
 // Optional default value
 if current().tid == TID.Assign {
 advance() // consume '='
 p.default = parseExpr(0)
 }
			params.push(p)
			skipNewlines()
			if current().tid == TID.Comma { advance() }
		}
		if current().tid == TID.CloseParen {
			advance() // consume ')'
		}
	}
	skipNewlines()
	// Parse body
	body = parseBlock()
	{name: methodName, params: params, body: body, line: mline, col: mcol}

}

fn _parseClassOperatorMethod() {
    mline = current().line
    mcol = current().col
    tv = current().value
    tt = current().tid

    OP_METHOD_MAP = {
        "+": "op_add", "-": "op_sub", "*": "op_mul", "/": "op_div",
        "==": "op_eq", "!=": "op_ne", "<": "op_lt", ">": "op_gt",
        "<=": "op_le", ">=": "op_ge", "[]": "op_index", "[]=": "op_index_set",
        "#": "op_length", "repr": "op_repr"
    }

    methodName = OP_METHOD_MAP[tv]
    if methodName == null && tt == TID.Not { methodName = "op_not" }
    if methodName == null && tt == TID.OpenBracket {
        advance() // consume '['
        if current().tid == TID.CloseBracket {
            advance() // consume ']'
            if current().tid == TID.Assign {
                advance() // consume '='
                methodName = "op_index_set"
            } else {
                methodName = "op_index"
            }
        }
    }
    else if methodName == null && tt == TID.OpenParen {
        methodName = "op_call"
    }
    if methodName == null { methodName = "op_" + tv }
	if methodName != "" && methodName.startsWith("op_") && current().tid != TID.OpenBracket && current().tid != TID.OpenParen {
		advance() // consume the operator token
	}
	// Parse params
	params = []
	if current().tid == TID.OpenParen {
		advance() // consume '('
		while notEOF() && current().tid != TID.CloseParen {
			skipNewlines()
			if current().tid == TID.CloseParen { break }
			pname = current().value
 p = {name: pname}
 p.default = null
 advance()
 if current().tid == TID.Assign {
 advance()
 p.default = parseExpr(0)
 }
			params.push(p)
			skipNewlines()
			if current().tid == TID.Comma { advance() }
		}
		if current().tid == TID.CloseParen {
			advance()
		}
	}
	skipNewlines()
	body = parseBlock()
	{name: methodName, params: params, body: body, line: mline, col: mcol}

}

// ===================================================================
// STATEMENT: struct declaration
// ===================================================================
fn parseStructDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'struct'
    skipNewlines()
    name = current().value
    advance() // consume struct name
    // Parse optional type parameters: struct Container(T: Number) { ... }
    typeParams = parseTypeParameterList()
    fields = []
    methods = []
    // struct Foo(field1, field2) or struct Foo { ... }
    if current().tid == TID.OpenParen {
        advance() // consume '('
        while notEOF() && current().tid != TID.CloseParen {
            skipNewlines()
            if current().tid == TID.CloseParen { break }
            fname = current().value
            f = {name: fname, isClassField: false, defaultValue: null, line: current().line, col: current().col}
            advance() // consume field name
            // Optional default value
            if current().tid == TID.Assign {
                advance()
                f.defaultValue = parseExpr(0)
            }
            fields.push(f)
            skipNewlines()
            if current().tid == TID.Comma { advance() }
        }
        if current().tid == TID.CloseParen {
            advance() // consume ')'
        }
    }
    skipNewlines()
    if current().tid == TID.OpenBrace {
        advance() // consume '{'
        skipNewlines()
        _parseClassMembers(methods, fields)
        if current().tid == TID.CloseBrace {
            advance() // consume '}'
        }
    } else if current().tid == TID.Colon {
        advance() // consume ':'
        skipNewlines()
        _parseClassMembers(methods, fields)
    }
    return StructDeclaration(name, fields, methods, null, l, c, typeParams)

}

// ===================================================================
// STATEMENT: enum declaration
// enum Name { Variant1, Variant2(Type), Variant3 }
// ===================================================================
fn parseEnumDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'enum'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected enum name after 'enum'", l, c)
    }
    name = advance().value
    // Parse optional type parameters: enum Result(T, E) { ... }
    typeParams = parseTypeParameterList()
    skipNewlines()
    if current().tid != TID.OpenBrace {
        return error("Expected '{' after enum name", l, c)
    }
    advance() // consume '{'
    variants = []
    while current().tid != TID.CloseBrace and notEOF() {
        skipNewlinesAndSemicolons()
        if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
        // Variant name
        if current().tid != TID.Identifier {
            return error("Expected variant name in enum", current().line, current().col)
        }
        vname = advance().value
        variant = {name: vname}
        // Optional payload type: Variant(Type)
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            payloadType = ""
            if current().tid == TID.Identifier {
                payloadType = advance().value
            }
            skipNewlines()
            if current().tid == TID.CloseParen {
                advance() // consume ')'
            }
            variant.payloadType = payloadType
        }
        variants.push(variant)
        // Optional comma
        if current().tid == TID.Comma { advance() }
        skipNewlines()
    }
    if current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return EnumDeclaration(name, variants, l, c, typeParams)
}

// ===================================================================
// STATEMENT: trait declaration
// trait Name { fn method(params); fn method2(params) { default_body } }
// ===================================================================
fn parseTraitDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'trait'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected trait name after 'trait'", l, c)
    }
    name = advance().value
    skipNewlines()
    if current().tid != TID.OpenBrace {
        return error("Expected '{' after trait name", l, c)
    }
    advance() // consume '{'
    methods = []
    while current().tid != TID.CloseBrace and notEOF() {
        skipNewlinesAndSemicolons()
        if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
        // Expect 'fn' keyword
        if current().tid != TID.Fn {
            return error("Expected 'fn' in trait body", current().line, current().col)
        }
        advance() // consume 'fn'
        skipNewlines()
        // Method name
        if current().tid != TID.Identifier {
            return error("Expected method name in trait", current().line, current().col)
        }
        methodName = advance().value
        // Parameters
        methodParams = []
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
                if current().tid != TID.Identifier {
                    return error("Expected parameter name in trait method", current().line, current().col)
                }
                methodParams.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma { advance() }
            }
            if current().tid == TID.CloseParen { advance() }
        }
        // Optional default body
        defaultBody = null
        if current().tid == TID.OpenBrace {
            defaultBody = parseBlock()
        }
        methods.push({name: methodName, params: methodParams, body: defaultBody})
        skipNewlines()
    }
    if current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return TraitDeclaration(name, methods, l, c)
}

// ===================================================================
// STATEMENT: protocol declaration
// prot Name { fn method(params); fn +(other) }
// ===================================================================
fn parseProtocolDeclaration() {
    l = current().line
    c = current().col
    advance() // consume 'prot'
    skipNewlines()
    if current().tid != TID.Identifier {
        return error("Expected protocol name after 'prot'", l, c)
    }
    name = advance().value
    skipNewlines()
    // Colon or brace body
    isColonBody = false
    if current().tid == TID.Colon {
        isColonBody = true
        advance() // consume ':'
        skipNewlines()
    } else if current().tid == TID.OpenBrace {
        advance() // consume '{'
    } else {
        return error("Expected '{' or ':' after protocol name", l, c)
    }
    methods = []
    // End condition depends on body style
    while notEOF() {
        if !isColonBody && current().tid == TID.CloseBrace: break
        if isColonBody && current().col < c + 1: break
        skipNewlinesAndSemicolons()
        if !isColonBody && current().tid == TID.CloseBrace: break
        if isColonBody && (current().tid == TID.EOF || current().col < c + 1): break
        // Expect 'fn'
        if current().tid != TID.Fn {
            return error("Expected 'fn' in protocol body", current().line, current().col)
        }
        advance() // consume 'fn'
        skipNewlines()
        // Method name or operator
        methodName = ""
        pt = current().tid
        if pt == TID.Identifier {
            methodName = advance().value
        } else if pt == TID.Plus || pt == TID.Minus || pt == TID.Multiply || pt == TID.Divide || pt == TID.Equals || pt == TID.Less || pt == TID.Greater || pt == TID.OpenBracket {
            methodName = advance().value
        } else {
            return error("Expected method or operator name in protocol", current().line, current().col)
        }
        // Parameters
        methodParams = []
        if current().tid == TID.OpenParen {
            advance() // consume '('
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
                if current().tid != TID.Identifier {
                    return error("Expected parameter name in protocol method", current().line, current().col)
                }
                methodParams.push(advance().value)
                skipNewlines()
                if current().tid == TID.Comma { advance() }
            }
            if current().tid == TID.CloseParen { advance() }
        }
        // Optional default body
        defaultBody = null
        if current().tid == TID.OpenBrace {
            defaultBody = parseBlock()
        }
        methods.push({name: methodName, params: methodParams, body: defaultBody})
        skipNewlines()
    }
    if !isColonBody && current().tid == TID.CloseBrace {
        advance() // consume '}'
    }
    return ProtocolDeclaration(name, methods, l, c)
}

// ===================================================================
// STATEMENT: impl declaration
// impl TypeName { fn method() {} }
// impl TypeName for TraitName { fn method() {} }
// ===================================================================
fn parseImplDeclaration() {
  l = current().line
  c = current().col
  advance() // consume 'impl'
  skipNewlines()
  if current().tid != TID.Identifier {
    return error("Expected trait name after 'impl'", l, c)
  }
  traitName = advance().value
  skipNewlines()
  typeName = ""
  if current().tid == TID.For {
    advance() // consume 'for'
    skipNewlines()
    if current().tid != TID.Identifier {
      return error("Expected type name after 'for'", current().line, current().col)
    }
    typeName = advance().value
    skipNewlines()
  }
  if current().tid != TID.OpenBrace {
    return error("Expected '{' after impl declaration", l, c)
  }
  advance() // consume '{'
  funcs = []
  while current().tid != TID.CloseBrace and notEOF() {
    skipNewlinesAndSemicolons()
    if current().tid == TID.CloseBrace || current().tid == TID.EOF: break
    // Each member should be a fn declaration
    if current().tid == TID.Fn {
      fnDecl = parseFnDeclaration()
      if fnDecl != null && fnDecl.kind != "ErrorNode" {
        funcs.push(fnDecl)
      }
      continue
    }
    // Skip unknown tokens
    advance()
  }
  if current().tid == TID.CloseBrace {
    advance() // consume '}'
  }
  return ImplDeclaration(typeName, traitName, funcs, l, c)
}
    // ===================================================================
    // PRODUCE AST — main entry point
    // ===================================================================
    fn produceAST() {
        skipNewlines()
        stmts = []

        while notEOF() and current().tid != TID.EOF {
            skipNewlinesAndSemicolons()
            if !notEOF() or current().tid == TID.EOF: break

            s = parseStatement()
            if s != null and s.kind != "ErrorNode" {
                stmts.push(s)
            }
            else if s != null and s.kind == "ErrorNode" {
                // Skip past error token and continue
                if pos < tokens.len: advance()
            }
            else {
                // Null statement — skip
                if pos < tokens.len: advance()

}
}
return Program(stmts, 1, 1)

}
    // Return the parser interface
    {
    parseExpr: parseExpr,
    parseStatement: parseStatement,
    parseBlock: parseBlock,
    produceAST: produceAST,
    errors: errors,
    pos: pos,
    tokens: tokens,
    }

}
// ===================================================================
// PUBLIC API
// ===================================================================

fn parse(source) {
  tokenList = tokenize(source)
  p = Parser(tokenList)
  ast = p.produceAST()
  return {ast: ast, errors: p.errors}

  }
  fn parseTokens(tokenList) {
  p = Parser(tokenList)
  ast = p.produceAST()
  return {ast: ast, errors: p.errors}

  }