                node.isSet = true
                return node

            }
}
// Block expression: { if/for/while/loop/val/let/fn/return/... }
isBlockStart = (nextTok.tid == TID.If || nextTok.tid == TID.For || nextTok.tid == TID.While || nextTok.tid == TID.Loop || nextTok.tid == TID.Repeat || nextTok.tid == TID.Let || nextTok.tid == TID.Val || nextTok.tid == TID.Fn || nextTok.tid == TID.Return || nextTok.tid == TID.Throw || nextTok.tid == TID.Try || nextTok.tid == TID.Match || nextTok.tid == TID.Break || nextTok.tid == TID.Continue || nextTok.tid == TID.Defer)
if isBlockStart {
 advance() // consume {
 skipNewlines()
 stmts = []
 while current().tid != TID.CloseBrace and notEOF() {
  skipNewlines()
  if current().tid == TID.CloseBrace: break
  s = parseStatement()
  if s != null { stmts.push(s) }
  skipNewlines()
 }
 expect(TID.CloseBrace)
 return BlockStatement(stmts, l, c)
}

// Default to object literal
return parseObjectLiteral(false)

}
