    // HELPER: Parenthesized expression or lambda
    // ===================================================================
    fn parseParenExpr(openTok) {
        l = openTok.line
        c = openTok.col

        // Empty lambda: () => body
        body = null
        if current().tid == TID.CloseParen and at(1).tid == TID.Arrow {
            advance() // )
            advance() // =>
            params = []
            if current().tid == TID.OpenBrace {
                body = parseBlock()
            }
            else {
                bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            }
            return LambdaExpression(parameters, body)
        }

        }
        // Multi-param lambda detection: (a, b, c) => body
        savedPos = pos
        lambdaParams = []
        isLambda = false

        if current().tid == TID.Identifier {
            // Try collecting comma-separated identifiers
            while true {
                if current().tid == TID.Identifier {
                    lambdaParams.push(advance().value)
                    if current().tid == TID.Comma {
                        advance()
                    }
                    else {
                        break
                    }
                }
                else {
                    break

                }
            }
            if current().tid == TID.CloseParen {
                savedAfter = pos + 1
                // Peek past ) for =>
                if at(1).tid == TID.Arrow {
                    advance() // )
                    advance() // =>
                    isLambda = true

                }
            }
        }
        if isLambda {
            if current().tid == TID.OpenBrace {
                body = parseBlock()
            }
            else {
                bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            }
            return LambdaExpression(lambdaParams, body)

        }
        // Not a lambda — restore position and parse grouped expression
        pos = savedPos
    syncCur()
        skipNewlines()
        expr = parseExpr(0)
skipNewlines()
skipNewlines()
// Check for tuple: (expr, expr, ...)
if current().tid == TID.Comma {
 elements = [expr]
 while current().tid == TID.Comma {
  advance() // consume comma
  if current().tid == TID.CloseParen { break }
  elements.push(parseExpr(0))
  skipNewlines()
 }
 expect(TID.CloseParen)
 // Return tuple as ArrayLiteral with isTuple flag
 node = ArrayLiteral(elements, l, c)
 node.isTuple = true
 return node
}
skipNewlines()
expect(TID.CloseParen)
return expr

}
    // ===================================================================
    // HELPER: Lambda expression (fn keyword form)
    // ===================================================================
    fn parseLambdaExpr() {
        l = current().line
        c = current().col

        name = null
        if current().tid == TID.Identifier {
            name = advance().value
        }

        // fn(params) => body  or  fn params => body
        params = []
        if current().tid == TID.OpenParen {
            advance()
            skipNewlines()
            while current().tid != TID.CloseParen and notEOF() {
                skipNewlines()
                if current().tid == TID.CloseParen: break
            // Parse param name (allow keyword-idents as param names, but not Fn)
            lpt = current().tid
            if lpt == TID.Fn {
                return error("'fn' cannot be used as a parameter name (reserved for lambda syntax)", current().line, current().col)
            }
            if lpt != TID.Identifier && !isKeywordIdent(lpt) {
                return error("Expected parameter name, got " + lpt, current().line, current().col)
            }
            pname = advance().value
                p = {name: pname}
                // Type annotation
                if current().tid == TID.Colon {
                    advance()
                    p.typeAnn = advance().value
                }
		// Default value
		if current().tid == TID.Assign {
			advance()
			p.defval = parseExpr(0)
		}
                // Variadic
                if current().tid == TID.Spread {
                    advance()
                    p.variadic = true
                }
                params.push(p)
                skipNewlines()
                if current().tid == TID.Comma: advance()
            }
            expect(TID.CloseParen)
        }
        else if current().tid == TID.Identifier {
            params.push({name: advance().value})

        }
        // Optional => (fn(x) body and fn(x) => body both valid)
        if current().tid == TID.Arrow {
         advance()

        }
        body = null
        if current().tid == TID.OpenBrace {
            body = parseBlock()
        }
        else {
            bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
    }

  print("DEBUG PARSER CALL: name=" + str(name) + " params=" + str(params) + " body=" + str(body) + " l=" + str(l) + " c=" + str(c))
  return LambdaExpression(params, body)

  }
    // ===================================================================
    // HELPER: Match expression
    // ===================================================================
// ===================================================================
// PATTERN PARSING — for match expressions
// ===================================================================
fn parsePattern() {
  alternatives = []
  first = parsePatternAtom()
  if first == null { return null }
  alternatives.push(first)
  while current().tid == TID.Pipe || current().tid == TID.Or {
    advance()
    next = parsePatternAtom()
    if next == null {
      error("Expected pattern after '|'", current().line, current().col)
      return alternatives[0]
    }
    alternatives.push(next)
  }
  if alternatives.length() == 1 { return alternatives[0] }
  return OrPattern(alternatives, current().line, current().col)
}

fn parsePatternAtom() {
  l = current().line
  c = current().col

  // Wildcard _
  if current().tid == TID.Underscore {
    advance()
    return WildcardPattern(l, c)
  }
  // Array pattern [x, y, ..rest]
  if current().tid == TID.OpenBracket {
    return parseArrayPatternForMatch()
  }
  // Object pattern {x, y: z}
  if current().tid == TID.OpenBrace {
    return parseObjectPatternForMatch()
  }
  // Boolean/Null/Number/String/Char/Regex literals
  if current().tid == TID.True { advance(); return BooleanLiteral(true, l, c) }
  if current().tid == TID.False { advance(); return BooleanLiteral(false, l, c) }
  if current().tid == TID.Null { advance(); return NullLiteral(l, c) }
  if current().tid == TID.Number { return NumberLiteral(advance().value, l, c) }
  if current().tid == TID.String || current().tid == TID.MultilineString { return StringLiteral(advance().value, l, c) }
  if current().tid == TID.CharLiteral { advance(); return CharLiteral(current().value, l, c) }
  if current().tid == TID.RegexLiteral { return StringLiteral(advance().value, l, c) }
  // Identifier — could be variable binding or Constructor pattern Name(args)
  if current().tid == TID.Identifier {
    name = current().value
    advance()
    // Constructor pattern: Name(p1, p2, ...)
    if current().tid == TID.OpenParen {
      advance() // consume '('
      args = []
      while current().tid != TID.CloseParen && notEOF() {
        skipNewlines()
        if current().tid == TID.CloseParen { break }
        arg = parsePattern()
        if arg != null { args.push(arg) }
        skipNewlines()
        if current().tid == TID.Comma { advance() }
      }
      if current().tid == TID.CloseParen { advance() }
      return ConstructorPattern(name, args, l, c)
    }
    pat = Identifier(name, l, c)
    // Range pattern: literal..=literal
    if current().tid == TID.DotDotEquals {
      advance()
      endPat = parsePatternAtom()
      if endPat == null {
        error("Expected pattern after '..='", current().line, current().col)
        return pat
      }
      return RangePattern(pat, endPat, l, c)
    }
    return pat
  }
  error("Expected pattern", l, c)
  return null
}

fn parseArrayPatternForMatch() {
  l = current().line
  c = current().col
  advance() // consume '['
  elements = []
  rest = null
  while notEOF() && current().tid != TID.CloseBracket {
    skipNewlines()
    if current().tid == TID.CloseBracket { break }
    // Rest pattern: ..rest or ..
    if current().tid == TID.DotDot {
      advance()
      if current().tid == TID.Identifier {
        rest = Identifier(advance().value, current().line, current().col)
      }
      else {
        rest = Identifier("_", l, c)
      }
      break
    }
    elements.push(parsePattern())
    skipNewlines()
    if current().tid == TID.Comma { advance() }
  }
  if current().tid == TID.CloseBracket { advance() }
  return ArrayPattern(elements, rest, l, c)
}

fn parseObjectPatternForMatch() {
  l = current().line
  c = current().col
  advance() // consume '{'
  properties = []
  rest = null
  while notEOF() && current().tid != TID.CloseBrace {
    skipNewlines()
    if current().tid == TID.CloseBrace { break }
    // Rest pattern: ...rest
    if current().tid == TID.Spread {
      advance()
      if current().tid == TID.Identifier {
        rest = Identifier(advance().value, current().line, current().col)
      }
      skipNewlines()
      if current().tid == TID.Comma { advance() }
      break
    }
    if current().tid != TID.Identifier {
      error("Expected identifier in object pattern", current().line, current().col)
      break
    }
    key = advance().value
    pat = null
    if current().tid == TID.Colon {
      advance() // consume ':'
      pat = parsePattern()
    }
    else {
      // Shorthand: {x} binds x to x
      pat = Identifier(key, l, c)
    }
    properties.push({key: key, value: pat})
    skipNewlines()
    if current().tid == TID.Comma { advance() }
  }
  if current().tid == TID.CloseBrace { advance() }
  return ObjectPattern(properties, rest, l, c)
}

fn parseMatchCase() {
  l = current().line
  c = current().col

  isDefault = false
  patterns = []

  // Parse first pattern using pattern parser
  firstPat = parsePattern()
  if firstPat != null && firstPat.kind == "WildcardPattern" {
    isDefault = true
  }
  patterns.push(firstPat)

  // Multi-discriminant: comma-separated patterns
  while current().tid == TID.Comma {
    // Look ahead: if comma followed by 'if', it's a guard not another pattern
    if at(1).tid == TID.If { break }
    advance()
    pat = parsePattern()
    if pat != null && pat.kind != "WildcardPattern" { isDefault = false }
    patterns.push(pat)
  }

  // Optional guard: if expr
  guard = null
  if current().tid == TID.When || current().tid == TID.If {
    advance()
    guard = parseExpr(0)
    skipNewlines()
  }

  // Expect =>
  if current().tid == TID.Arrow {
    advance()
  } else {
    return error("Expected '=>' in match case", l, c)

  }
  skipNewlines()

  // Body
  body = null
  if current().tid == TID.OpenBrace {
    body = parseBlock()
  }
  else {
    bodyExpr = parseExpr(0)
    body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

  }
  // For single pattern, unwrap
  if #patterns == 1 {
    mc = MatchCase(patterns[0], guard, body, l, c)
  }
  else {
    mc = MatchCase(patterns, guard, body, l, c)
  }
  mc.isDefault = isDefault
  mc

}


fn parseMatchExpr() {
  l = current().line
  c = current().col

  // Parse discriminants (comma-separated before { or :)
  prevSugar = allowBraceSugar
  allowBraceSugar = false
  discriminants = [parseExpr(0)]
  while current().tid == TID.Comma {
    // Look ahead: if comma followed by { or :, these are case delimiters not more discriminants
    if at(1).tid == TID.OpenBrace || at(1).tid == TID.Colon { break }
    advance()
    discriminants.push(parseExpr(0))
  }
  allowBraceSugar = prevSugar
  skipNewlines()

  // Expect { or :
  if current().tid == TID.OpenBrace {
    advance()
  }
  else if current().tid == TID.Colon {
    advance()
  }
  else {
    return error("Expected '{' or ':' after match subject", l, c)

  }
  prevMatch = inMatchExpr
  inMatchExpr = true

  cases = []
  defaultCase = null
  skipNewlines()
  while current().tid != TID.CloseBrace and notEOF() and current().tid != TID.EOF {
    skipNewlines()
    if current().tid == TID.CloseBrace: break
    mc = parseMatchCase()
    if mc != null {
      if mc.isDefault {
        defaultCase = mc.body
      } else {
        cases.push(mc)
      }
    }
    // Skip optional comma between cases
    if current().tid == TID.Comma {
      advance()
    }
    // Skip newlines and semicolons (case separators)
    while current().tid == TID.NewLine or current().tid == TID.Semicolon {
      advance()
    }
  }
  inMatchExpr = prevMatch

  if current().tid == TID.CloseBrace {
    advance()

  }
  node = MatchExpression(discriminants, cases, l, c)
  node.defaultCase = defaultCase
  node
}
