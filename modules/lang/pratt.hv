NUD_TOKENS[TID.Class] = true; NUD_TOKENS[TID.Struct] = true; NUD_TOKENS[TID.Enum] = true; NUD_TOKENS[TID.Mode] = true
NUD_TOKENS[TID.Val] = true; NUD_TOKENS[TID.Const] = true; NUD_TOKENS[TID.Let] = true
NUD_TOKENS[TID.Config] = true; NUD_TOKENS[TID.Devices] = true
NUD_TOKENS[TID.ShellCommand] = true; NUD_TOKENS[TID.ShellCommandCapture] = true
NUD_TOKENS[TID.SuperArrow] = true
NUD_TOKENS[TID.Spread] = true; NUD_TOKENS[TID.Hash] = true; NUD_TOKENS[TID.DoubleOpenParen] = true
NUD_TOKENS[TID.Tilde] = true; NUD_TOKENS[TID.Hotkey] = true
NUD_TOKENS[TID.Thread] = true; NUD_TOKENS[TID.Interval] = true; NUD_TOKENS[TID.Timeout] = true
NUD_TOKENS[TID.Async] = true; NUD_TOKENS[TID.LeftArrow] = true; NUD_TOKENS[TID.CharLiteral] = true
NUD_TOKENS[TID.Yield] = true; NUD_TOKENS[TID.Channel] = true; NUD_TOKENS[TID.Go] = true
NUD_TOKENS[TID.WaitGroup] = true; NUD_TOKENS[TID.Wait] = true; NUD_TOKENS[TID.From] = true

// --- Keywords allowed as identifiers in expression context ---
KEYWORD_IDENTS = {}
KEYWORD_IDENTS[TID.Class] = true; KEYWORD_IDENTS[TID.Struct] = true; KEYWORD_IDENTS[TID.Enum] = true; KEYWORD_IDENTS[TID.Mode] = true
KEYWORD_IDENTS[TID.Val] = true; KEYWORD_IDENTS[TID.Const] = true; KEYWORD_IDENTS[TID.Let] = true
KEYWORD_IDENTS[TID.Config] = true; KEYWORD_IDENTS[TID.Devices] = true; KEYWORD_IDENTS[TID.On] = true; KEYWORD_IDENTS[TID.Off] = true; KEYWORD_IDENTS[TID.When] = true
KEYWORD_IDENTS[TID.Timeout] = true; KEYWORD_IDENTS[TID.Thread] = true; KEYWORD_IDENTS[TID.Interval] = true; KEYWORD_IDENTS[TID.Channel] = true
KEYWORD_IDENTS[TID.Co] = true; KEYWORD_IDENTS[TID.Go] = true; KEYWORD_IDENTS[TID.Fn] = true; KEYWORD_IDENTS[TID.Op] = true
KEYWORD_IDENTS[TID.Return] = true; KEYWORD_IDENTS[TID.Ret] = true; KEYWORD_IDENTS[TID.Break] = true; KEYWORD_IDENTS[TID.Continue] = true
KEYWORD_IDENTS[TID.Try] = true; KEYWORD_IDENTS[TID.Catch] = true; KEYWORD_IDENTS[TID.Finally] = true; KEYWORD_IDENTS[TID.Throw] = true; KEYWORD_IDENTS[TID.Del] = true
KEYWORD_IDENTS[TID.True] = true; KEYWORD_IDENTS[TID.False] = true; KEYWORD_IDENTS[TID.Null] = true; KEYWORD_IDENTS[TID.This] = true; KEYWORD_IDENTS[TID.Repeat] = true
KEYWORD_IDENTS[TID.Use] = true; KEYWORD_IDENTS[TID.Import] = true; KEYWORD_IDENTS[TID.From] = true; KEYWORD_IDENTS[TID.As] = true; KEYWORD_IDENTS[TID.With] = true
KEYWORD_IDENTS[TID.Dsl] = true
KEYWORD_IDENTS[TID.Pool] = true; KEYWORD_IDENTS[TID.Signal] = true; KEYWORD_IDENTS[TID.Group] = true; KEYWORD_IDENTS[TID.Modes] = true
KEYWORD_IDENTS[TID.Sleep] = true; KEYWORD_IDENTS[TID.Yield] = true; KEYWORD_IDENTS[TID.WaitGroup] = true; KEYWORD_IDENTS[TID.Wait] = true; KEYWORD_IDENTS[TID.Defer] = true

DOT_ACCESS_KEYWORDS = {}
DOT_ACCESS_KEYWORDS[TID.If] = true; DOT_ACCESS_KEYWORDS[TID.Else] = true; DOT_ACCESS_KEYWORDS[TID.For] = true; DOT_ACCESS_KEYWORDS[TID.In] = true; DOT_ACCESS_KEYWORDS[TID.While] = true
DOT_ACCESS_KEYWORDS[TID.Loop] = true; DOT_ACCESS_KEYWORDS[TID.Switch] = true; DOT_ACCESS_KEYWORDS[TID.Do] = true; DOT_ACCESS_KEYWORDS[TID.Match] = true; DOT_ACCESS_KEYWORDS[TID.Case] = true
DOT_ACCESS_KEYWORDS[TID.Default] = true; DOT_ACCESS_KEYWORDS[TID.Not] = true; DOT_ACCESS_KEYWORDS[TID.And] = true; DOT_ACCESS_KEYWORDS[TID.Or] = true; DOT_ACCESS_KEYWORDS[TID.Is] = true
DOT_ACCESS_KEYWORDS[TID.Matches] = true; DOT_ACCESS_KEYWORDS[TID.Where] = true; DOT_ACCESS_KEYWORDS[TID.Select] = true
DOT_ACCESS_KEYWORDS[TID.Async] = true; DOT_ACCESS_KEYWORDS[TID.Sync] = true
DOT_ACCESS_KEYWORDS[TID.Trait] = true; DOT_ACCESS_KEYWORDS[TID.Prot] = true; DOT_ACCESS_KEYWORDS[TID.Impl] = true

fn isKeywordIdent(ttype) {
  if ttype == null { return false }
  KEYWORD_IDENTS[ttype] != null
}

fn isDotAccessIdent(ttype) {
  KEYWORD_IDENTS[ttype] != null or DOT_ACCESS_KEYWORDS[ttype] != null
}

// --- Token types that are infix/postfix operators (have led) ---
LED_TOKENS = {}
LED_TOKENS[TID.Assign] = true; LED_TOKENS[TID.PlusAssign] = true; LED_TOKENS[TID.MinusAssign] = true
LED_TOKENS[TID.MultiplyAssign] = true; LED_TOKENS[TID.DivideAssign] = true; LED_TOKENS[TID.ModuloAssign] = true
LED_TOKENS[TID.PowerAssign] = true; LED_TOKENS[TID.BackslashAssign] = true; LED_TOKENS[TID.DoubleModuloAssign] = true
