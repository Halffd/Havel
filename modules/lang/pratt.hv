LED_TOKENS[TID.LeftArrow] = true; LED_TOKENS[TID.Nullish] = true; LED_TOKENS[TID.Question] = true
LED_TOKENS[TID.Or] = true; LED_TOKENS[TID.And] = true
LED_TOKENS[TID.Equals] = true; LED_TOKENS[TID.NotEquals] = true; LED_TOKENS[TID.Is] = true; LED_TOKENS[TID.Tilde] = true
LED_TOKENS[TID.Matches] = true; LED_TOKENS[TID.As] = true; LED_TOKENS[TID.In] = true; LED_TOKENS[TID.Not] = true
LED_TOKENS[TID.Less] = true; LED_TOKENS[TID.Greater] = true; LED_TOKENS[TID.LessEquals] = true; LED_TOKENS[TID.GreaterEquals] = true
LED_TOKENS[TID.DotDot] = true; LED_TOKENS[TID.DotDotEquals] = true
LED_TOKENS[TID.Plus] = true; LED_TOKENS[TID.Minus] = true; LED_TOKENS[TID.Pipe] = true; LED_TOKENS[TID.PipeRight] = true
LED_TOKENS[TID.BitwiseOr] = true; LED_TOKENS[TID.BitwiseXor] = true; LED_TOKENS[TID.BitwiseAnd] = true
LED_TOKENS[TID.ShiftLeft] = true; LED_TOKENS[TID.ShiftRight] = true
LED_TOKENS[TID.Multiply] = true; LED_TOKENS[TID.Divide] = true; LED_TOKENS[TID.Modulo] = true
LED_TOKENS[TID.Backslash] = true; LED_TOKENS[TID.DoubleBackslash] = true; LED_TOKENS[TID.DoubleModulo] = true
LED_TOKENS[TID.Power] = true; LED_TOKENS[TID.PlusPlus] = true; LED_TOKENS[TID.MinusMinus] = true
LED_TOKENS[TID.Dot] = true; LED_TOKENS[TID.QuestionDot] = true
LED_TOKENS[TID.OpenParen] = true; LED_TOKENS[TID.OpenBracket] = true
LED_TOKENS[TID.Arrow] = true; LED_TOKENS[TID.For] = true

// --- Expression tokens (for implicit call sugar detection) ---
IMPLICIT_CALL_STARTERS = {}
IMPLICIT_CALL_STARTERS[TID.String] = true; IMPLICIT_CALL_STARTERS[TID.MultilineString] = true; IMPLICIT_CALL_STARTERS[TID.RegexString] = true
IMPLICIT_CALL_STARTERS[TID.Number] = true; IMPLICIT_CALL_STARTERS[TID.Identifier] = true; IMPLICIT_CALL_STARTERS[TID.InterpolatedString] = true
IMPLICIT_CALL_STARTERS[TID.InterpolatedBacktick] = true; IMPLICIT_CALL_STARTERS[TID.At] = true; IMPLICIT_CALL_STARTERS[TID.AtAt] = true
IMPLICIT_CALL_STARTERS[TID.Not] = true; IMPLICIT_CALL_STARTERS[TID.Length] = true

// ===================================================================
// Parser object — encapsulates parsing state
// ===================================================================
fn Parser(tokenList) {
  ::tokens = tokenList
  ::pos = 0
  ::errors = []
  ::incomplete = false
  ::inMatchExpr = false
  ::allowBraceSugar = true
  ::_eof = {type: "EOF", tid: TID.EOF, value: "", line: 0, col: 0}
  ::_cur = pos < tokens.len ? tokens[pos] : _eof

  fn at(offset) {
    i = pos + offset
    if i < 0: i = 0
    if i < tokens.len: return tokens[i]
    else: return _eof
  }
  fn current() {
    return _cur
  }
  fn advance() {
    if pos < tokens.len {
      t = tokens[pos]
      pos = pos + 1
      _cur = pos < tokens.len ? tokens[pos] : _eof
      return t
    }
    else {
      _cur = _eof
      return _eof
    }
  }
  fn syncCur() {
    _cur = pos < tokens.len ? tokens[pos] : _eof
  }
  fn synchronize() {
    while notEOF() and current().tid != TID.EOF {
      tt = current().tid
      if tt == TID.Semicolon { advance(); return }
      if tt == TID.CloseBrace { return }
      if tt == TID.NewLine { return }
      if tt == TID.Fn { return }
      if tt == TID.If { return }
      if tt == TID.While { return }
      if tt == TID.For { return }
      if tt == TID.Switch { return }
      if tt == TID.Match { return }
      if tt == TID.Try { return }
      if tt == TID.Return { return }
      if tt == TID.Break { return }
      if tt == TID.Continue { return }
      if tt == TID.Struct { return }
      if tt == TID.Class { return }
      if tt == TID.Enum { return }
      if tt == TID.Import { return }
      if tt == TID.Use { return }
      if tt == TID.Throw { return }
      if tt == TID.Async { return }
      if tt == TID.Config { return }
      if tt == TID.Do { return }
      if tt == TID.Defer { return }
      if tt == TID.Hotkey { return }
      advance()
    }
  }
  fn notEOF() {
    return _cur.tid != TID.EOF
  }
 fn expect(ttype) {
 t = current()
 if t.tid == ttype {
 return advance()
 }
 else {
 tname = TID_NAME[ttype]
 if tname == null: tname = str(ttype)
 return error("Expected " + tname + " but got " + t.type, t.line, t.col)

 }
 }
 fn expectValue(ttype, expectedVal) {
 t = current()
 if t.tid == ttype and t.value == expectedVal {
 return advance()
 }
 else {
 tname = TID_NAME[ttype]
 if tname == null: tname = str(ttype)
 return error("Expected " + tname + " '" + expectedVal + "' but got " + t.type, t.line, t.col)

 }
 }
    // --- Newline skipping ---
    fn skipNewlines() {
        while current().tid == TID.NewLine {
            advance()

        }
    }
    fn skipNewlinesAndSemicolons() {
        while current().tid == TID.NewLine or current().tid == TID.Semicolon {
            advance()

        }
    }
    // --- Error handling ---
fn error(msg, line, col) {
    if current().tid == TID.EOF: incomplete = true
    errors.push({msg: msg, line: line, col: col})
    return ErrorNode(msg, line, col)
}
  fn parseError(msg) {
    t = current()
    return error(msg, t.line, t.col)

  }
  // --- Token classification ---
  fn canStartExpr(ttype) {
    NUD_TOKENS[ttype] != null

  }
  fn isLed(ttype) {
    LED_TOKENS[ttype] != null

  }
// --- Check if 'not' is infix (followed by 'in') ---
fn isNotIn() {
  return current().tid == TID.Not and at(1).tid == TID.In

  }
    // ===================================================================
    // PRATT EXPRESSION PARSER
    // ===================================================================
fn parseExpr(rbp) {
  startToken = current()
  tok = advance()

  left = nud(tok)

  if left == null {
    return error("Unexpected token " + tok.type, startToken.line, startToken.col)

  }
  if left.kind == "ErrorNode" {
    return left

  }
 iterations = 0
 while true {
 iterations = iterations + 1
 if iterations > 10000 {
 return error("Pratt loop exceeded", startToken.line, startToken.col)

 }
  curType = current().tid
  bp = getBindingPower(curType)

  // Special: 'not' only acts as infix when followed by 'in'
  if curType == TID.Not and !isNotIn() {
 break

 }
 // Special: Arrow returns 0 in match context
 if curType == TID.Arrow and inMatchExpr {
                break

            }
  if bp == BP_NONE or rbp >= bp {
    break
  }
  opToken = advance()
  left = led(opToken, left)

            if left == null {
                return error("Failed to parse infix " + opToken.type, opToken.line, opToken.col)
            }
            if left.kind == "ErrorNode" {
                return left

            }
        }
 // Implicit call sugar: expr "string" -> expr("string")
 // Not across newlines — NewLine has bp=0 so the Pratt loop exits before we get here
 // and NewLine is not in IMPLICIT_CALL_STARTERS
 if allowBraceSugar and IMPLICIT_CALL_STARTERS[current().tid] != null {
            prevSugar = allowBraceSugar
            allowBraceSugar = false
            arg = parseExpr(0)
            allowBraceSugar = prevSugar

            if arg == null or arg.kind == "ErrorNode" {
                return arg

            }
            args = [arg]
            while current().tid == TID.Comma {
                advance()
                nextArg = parseExpr(0)
                if nextArg == null or nextArg.kind == "ErrorNode" {
                    return nextArg
                }
                args.push(nextArg)

            }
            left = CallExpression(left, args, [], startToken.line, startToken.col)

  }
  left

    }
    // ===================================================================
    // NULL DENOTATION (nud) — tokens that start expressions
    // ===================================================================
fn nud(tok) {
tt = tok.tid
l = tok.line
c = tok.col

if tt == TID.Number {
  return NumberLiteral(tok.value, l, c)
}
else if tt == TID.String or tt == TID.MultilineString {
  return StringLiteral(tok.value, l, c)
}
else if tt == TID.CharLiteral {
  return CharLiteral(tok.value, l, c)
}
else if tt == TID.This {
  return ThisExpression(l, c)
}
else if tt == TID.RegexString {
return StringLiteral(tok.value, l, c)
}
else if tt == TID.RegexLiteral {
parts = tok.value.split("/")
pattern = ""
flags = ""
if parts.len >= 2: pattern = parts[1]
if parts.len >= 3: flags = parts[2]
return RegexLiteral(pattern, flags, l, c)
}
else if tt == TID.Backtick {
if tok.value.has("{") or tok.value.has("$") {
return ShellCommand(tok.value, false, l, c)
}
else {
return BacktickExpression(tok.value, l, c)
}
}
else if tt == TID.InterpolatedBacktick {
return ShellCommand(tok.value, true, l, c)
}
else if tt == TID.ShellCommand {
return ShellCommand(tok.value, false, l, c)
}
else if tt == TID.ShellCommandCapture {
return ShellCommand(tok.value, true, l, c)
}
else if tt == TID.Hotkey {
 return HotkeyExpression(tok.value, l, c)
}
else if tt == TID.InterpolatedString {
return parseInterpolatedString(tok.value, l, c)
}
 else if tt == TID.From {
  // from x in source where pred select f -> PipelineExpression chain
  if current().tid == TID.Identifier {
   varName = advance().value
   if current().tid == TID.In {
    advance() // consume 'in'
    source = parseExpr(getRightBindingPower(TID.From))
    pipeline = source
while current().tid == TID.Where {
      advance() // consume 'where'
condition = parseExpr(getRightBindingPower(TID.Where))
      filterIdent = Identifier("filter", l, c)
      param = varName
      body = ExpressionStatement(condition, l, c)
      lambda = LambdaExpression([param], body)
      filterCall = CallExpression(filterIdent, [lambda], [], l, c)
      pipeline = PipelineExpression(pipeline, filterCall, l, c)
     }
     if current().tid == TID.Select {
      advance() // consume 'select'
      transform = parseExpr(getRightBindingPower(TID.Select))
      mapIdent = Identifier("map", l, c)
      param = varName
      body = ExpressionStatement(transform, l, c)
      lambda = LambdaExpression([param], body)
      mapCall = CallExpression(mapIdent, [lambda], [], l, c)
      pipeline = PipelineExpression(pipeline, mapCall, l, c)
     }
     return pipeline
    }
  }
  return Identifier(tok.value, l, c)
 }
else if tt == TID.Identifier or (isKeywordIdent(tt) and tt != TID.True and tt != TID.False and tt != TID.Null and tt != TID.Fn and tt != TID.WaitGroup and tt != TID.Wait and tt != TID.Defer and tt != TID.From) {
return Identifier(tok.value, l, c)
}
else if tt == TID.True {
return BooleanLiteral(true, l, c)
}
else if tt == TID.False {
return BooleanLiteral(false, l, c)
}
else if tt == TID.Null {
return NullLiteral(l, c)
}
else if tt == TID.OpenParen {
return parseParenExpr(tok)
}
else if tt == TID.OpenBracket {
pos = pos - 1
syncCur()
return parseArrayLiteral()
}
else if tt == TID.OpenBrace {
pos = pos - 1
syncCur()
return disambiguateBrace()
}
else if tt == TID.BangOpenBrace {
return parseObjectLiteral(true, true)
}
else if tt == TID.Not {
if current().tid == TID.OpenBrace {
return parseObjectLiteral(true, true)
}
else {
operand = parseExpr(140)
return UnaryExpression(tok.value, operand, l, c)
}
}
else if tt == TID.Minus {
operand = parseExpr(140)
return UnaryExpression("-", operand, l, c)
}
else if tt == TID.Plus {
return parseExpr(140)
}
else if tt == TID.PlusPlus {
operand = parseExpr(140)
return UpdateExpression(operand, "++", true, l, c)
}
else if tt == TID.MinusMinus {
operand = parseExpr(140)
return UpdateExpression(operand, "--", true, l, c)
}
else if tt == TID.Length {
operand = parseExpr(140)
return UnaryExpression("#", operand, l, c)
}
else if tt == TID.Tilde {
if current().tid == TID.Identifier or current().tid == TID.Hotkey {
combo = "~" + current().value
advance()
if current().tid == TID.Colon {
advance()
if current().tid == TID.Number or current().tid == TID.Identifier {
combo = combo + ":" + current().value
advance()
}
}
return HotkeyExpression(combo, l, c)
}
operand = parseExpr(140)
return UnaryExpression("~", operand, l, c)
}
else if tt == TID.DoubleOpenParen {
inner = parseExpr(2)
if current().tid == TID.DoubleCloseParen {
advance()
}
return inner
}
else if tt == TID.At {
if current().tid == TID.Identifier {
field = advance()
return AtExpression(field.value, l, c)
}
else {
return error("Expected field name after '@'", l, c)
}
}
else if tt == TID.AtAt {
if current().tid == TID.Identifier {
field = advance()
return AtAtExpression(field.value, l, c)
}
else {
return error("Expected field name after '@@'", l, c)
}
}
else if tt == TID.ColonColon {
if current().tid == TID.Identifier {
ident = advance()
node = Identifier(ident.value, l, c)
node.globalScope = true
return node
}
else {
return error("Expected identifier after '::'", l, c)
}
}
else if tt == TID.Fn {
return parseLambdaExpr()
}
else if tt == TID.Match {
return parseMatchExpr()
}
else if tt == TID.If {
return parseIfExpr()
}
else if tt == TID.SuperArrow {
if current().tid == TID.Identifier {
methodName = advance().value
node = Identifier("__super__", l, c)
node.isSuperCall = true
node.superMethodName = methodName
if current().tid == TID.OpenParen {
advance()
args = []
skipNewlines()
while current().tid != TID.CloseParen and notEOF() {
skipNewlines()
if current().tid == TID.CloseParen: break
args.push(parseExpr(0))
skipNewlines()
if current().tid == TID.Comma: advance()
}
expect(TID.CloseParen)
return CallExpression(node, args, [], l, c)
}
else {
return node
}
}
else {
return error("Expected method name after '@->'", l, c)
}
}
else if tt == TID.WaitGroup {
if current().tid == TID.OpenParen {
advance()
if current().tid != TID.CloseParen {
return error("Expected '()' after waitgroup", l, c)
}
advance()
}
return WaitGroupExpression(l, c)
}
else if tt == TID.Wait {
  target = parseExpr(140)
  return WaitExpression(target, l, c)
}
else if tt == TID.Yield {
  value = null
  ct = current().tid
  if ct != TID.Semicolon && ct != TID.NewLine && ct != TID.CloseBrace && ct != TID.CloseParen && ct != TID.EOF {
    value = parseExpr(0)
  }
  return YieldExpression(value, l, c)
}
else if tt == TID.Go {
  // go expression: go fn() or go { ... }
  if current().tid == TID.OpenBrace {
    advance()
    stmts = []
    skipNewlines()
    while current().tid != TID.CloseBrace && notEOF() {
      if current().tid == TID.NewLine { advance(); continue }
      stmts.push(parseStatement())
      skipNewlines()
    }
    expect(TID.CloseBrace)
    block = BlockStatement(stmts, l, c)
    call = LambdaExpression([], block)
    return GoExpression(call, l, c)
  }
  call = parseExpr(0)
  return GoExpression(call, l, c)
}
else if tt == TID.Channel {
  if current().tid == TID.OpenParen {
    advance()
    if current().tid != TID.CloseParen {
      return error("Expected '()' after channel", l, c)
    }
    advance()
  }
  return ChannelExpression(l, c)
}
else if tt == TID.Async {
  // async { ... } or async fn
  if current().tid == TID.OpenBrace {
    advance()
    stmts = []
    skipNewlines()
    while current().tid != TID.CloseBrace && notEOF() {
      if current().tid == TID.NewLine { advance(); continue }
      stmts.push(parseStatement())
      skipNewlines()
    }
    expect(TID.CloseBrace)
    block = BlockStatement(stmts, l, c)
    return AsyncExpression(block, l, c)
  }
  // async fn ... — parse as function, wrap
  if current().tid == TID.Fn {
    fnDecl = parseFnDeclaration()
    return AsyncExpression(fnDecl, l, c)
  }
  return error("Expected '{' or 'fn' after 'async'", l, c)
}
else if tt == TID.Await {
  arg = parseExpr(140)
  return AwaitExpression(arg, l, c)
}
else {
return error("Unexpected token in expression: " + tt, l, c)
}
}
    // ===================================================================
    // LEFT DENOTATION (led) — infix and postfix operators
    // ===================================================================
fn led(tok, left) {
tt = tok.tid
l = tok.line
c = tok.col

// Assignment operators
if tt == TID.Assign {
right = parseExpr(getRightBindingPower(TID.Assign))
if right == null: return error("Expected value after '='", l, c)
if right.kind == "ErrorNode": return right
return AssignmentExpression(left, right, l, c)
}
else if COMPOUND_ASSIGN_TOKENS[tt] != null {
right = parseExpr(getRightBindingPower(tt))
if right == null: return error("Expected value after compound assign", l, c)
if right.kind == "ErrorNode": return right
return CompoundAssignment(left, COMPOUND_ASSIGN_TOKENS[tt], right, l, c)
}
else if tt == TID.LeftArrow {
right = parseExpr(getRightBindingPower(TID.LeftArrow))
if right == null: return error("Expected value after '<-'", l, c)
if right.kind == "ErrorNode": return right
return AssignmentExpression(left, right, l, c)
}
// Binary operators
else if tt == TID.Plus {
right = parseExpr(getRightBindingPower(TID.Plus))
return BinaryExpression(left, "+", right, l, c)
}
else if tt == TID.Minus {
right = parseExpr(getRightBindingPower(TID.Minus))
return BinaryExpression(left, "-", right, l, c)
}
else if tt == TID.Multiply {
right = parseExpr(getRightBindingPower(TID.Multiply))
return BinaryExpression(left, "*", right, l, c)
}
else if tt == TID.Divide {
right = parseExpr(getRightBindingPower(TID.Divide))
return BinaryExpression(left, "/", right, l, c)
}
else if tt == TID.Modulo {
right = parseExpr(getRightBindingPower(TID.Modulo))
return BinaryExpression(left, "%", right, l, c)
}
else if tt == TID.Backslash {
right = parseExpr(getRightBindingPower(TID.Backslash))
return BinaryExpression(left, "\\", right, l, c)
}
else if tt == TID.DoubleBackslash {
right = parseExpr(getRightBindingPower(TID.DoubleBackslash))
return BinaryExpression(left, "\\\\", right, l, c)
}
else if tt == TID.DoubleModulo {
right = parseExpr(getRightBindingPower(TID.DoubleModulo))
return BinaryExpression(left, "%%", right, l, c)
}
else if tt == TID.Power {
right = parseExpr(getRightBindingPower(TID.Power))
return BinaryExpression(left, "**", right, l, c)
}
else if tt == TID.Equals {
right = parseExpr(getRightBindingPower(TID.Equals))
return BinaryExpression(left, "==", right, l, c)
}
else if tt == TID.NotEquals {
right = parseExpr(getRightBindingPower(TID.NotEquals))
return BinaryExpression(left, "!=", right, l, c)
}
else if tt == TID.Is {
right = parseExpr(getRightBindingPower(TID.Is))
return BinaryExpression(left, "is", right, l, c)
}
else if tt == TID.Tilde or tt == TID.Matches {
right = parseExpr(getRightBindingPower(tt))
return BinaryExpression(left, "matches", right, l, c)
}
else if tt == TID.In {
right = parseExpr(getRightBindingPower(TID.In))
return BinaryExpression(left, "in", right, l, c)
}
    else if tt == TID.Not {
        if current().tid == TID.In {
            advance()
            right = parseExpr(getRightBindingPower(TID.In))
            return BinaryExpression(left, "not in", right, l, c)
        }
        else {
            return left
        }
    }
    else if tt == TID.As {
        if current().tid == TID.Identifier {
            targetType = advance().value
            return CastExpression(left, targetType, l, c)
        }
        else {
            return error("Expected type name after 'as'", l, c)
        }
    }
else if tt == TID.Less {
right = parseExpr(getRightBindingPower(TID.Less))
return BinaryExpression(left, "<", right, l, c)
}
else if tt == TID.Greater {
right = parseExpr(getRightBindingPower(TID.Greater))
return BinaryExpression(left, ">", right, l, c)
}
else if tt == TID.LessEquals {
right = parseExpr(getRightBindingPower(TID.LessEquals))
return BinaryExpression(left, "<=", right, l, c)
}
else if tt == TID.GreaterEquals {
right = parseExpr(getRightBindingPower(TID.GreaterEquals))
return BinaryExpression(left, ">=", right, l, c)
}
else if tt == TID.And {
right = parseExpr(getRightBindingPower(TID.And))
return BinaryExpression(left, "&&", right, l, c)
}
else if tt == TID.Or {
right = parseExpr(getRightBindingPower(TID.Or))
return BinaryExpression(left, "||", right, l, c)
}
else if tt == TID.Nullish {
right = parseExpr(getRightBindingPower(TID.Nullish))
return BinaryExpression(left, "??", right, l, c)
}
// Bitwise
else if tt == TID.BitwiseOr {
right = parseExpr(getRightBindingPower(TID.BitwiseOr))
return BinaryExpression(left, "|", right, l, c)
}
else if tt == TID.BitwiseXor {
right = parseExpr(getRightBindingPower(TID.BitwiseXor))
return BinaryExpression(left, "^", right, l, c)
}
else if tt == TID.BitwiseAnd {
right = parseExpr(getRightBindingPower(TID.BitwiseAnd))
return BinaryExpression(left, "&", right, l, c)
}
else if tt == TID.ShiftLeft {
right = parseExpr(getRightBindingPower(TID.ShiftLeft))
return BinaryExpression(left, "<<", right, l, c)
}
else if tt == TID.ShiftRight {
right = parseExpr(getRightBindingPower(TID.ShiftRight))
return BinaryExpression(left, ">>", right, l, c)
}
// Ternary: cond ? true : false
else if tt == TID.Question {
trueExpr = parseExpr(0)
if current().tid != TID.Colon {
return error("Expected ':' after ternary true branch", l, c)
}
advance()
falseExpr = parseExpr(getRightBindingPower(TID.Question))
return TernaryExpression(left, trueExpr, falseExpr, l, c)
}
// Range
else if tt == TID.DotDot {
right = parseExpr(getRightBindingPower(TID.DotDot))
if current().tid == TID.DotDot {
advance()
step = parseExpr(getRightBindingPower(TID.DotDot))
node = RangeExpression(left, right, false, l, c)
node.step = step
return node
}
else {
return RangeExpression(left, right, false, l, c)
}
}
else if tt == TID.DotDotEquals {
right = parseExpr(getRightBindingPower(TID.DotDotEquals))
return RangeExpression(left, right, true, l, c)
}
// Pipeline
else if tt == TID.Pipe or tt == TID.PipeRight {
right = parseExpr(getRightBindingPower(tt))
if right != null and right.kind == "CallExpression" {
right.args.insert(0, left)
return PipelineExpression(left, right, l, c)
}
else {
return PipelineExpression(left, right, l, c)
}
}
// Member access: expr.field
else if tt == TID.Dot {
if current().tid == TID.Identifier or isDotAccessIdent(current().tid) {
prop = advance()
return MemberExpression(left, prop.value, l, c)
}
else {
return error("Expected identifier after '.'", l, c)
}
}
// Optional chaining: expr?.field
else if tt == TID.QuestionDot {
if current().tid == TID.Identifier or isDotAccessIdent(current().tid) {
prop = advance()
node = MemberExpression(left, prop.value, l, c)
node.optional = true
return node
}
else {
return error("Expected identifier after '?.'", l, c)
}
}
// Function call: expr(args)
else if tt == TID.OpenParen {
callResult = parseCallArgs()
return CallExpression(left, callResult.args, callResult.kwargs, l, c)
}
// Index: expr[index]
else if tt == TID.OpenBracket {
isSlice = detectSlice()
if isSlice {
return parseSliceExpr(left, l, c)
}
else {
idx = parseExpr(0)
skipNewlines()
if current().tid != TID.CloseBracket {
return error("Expected ']' after index", l, c)
}
else {
advance()
return IndexExpression(left, idx, l, c)
}
}
}
// Postfix increment/decrement
else if tt == TID.PlusPlus {
return UpdateExpression(left, "++", false, l, c)
}
else if tt == TID.MinusMinus {
return UpdateExpression(left, "--", false, l, c)
}
// For-expression: expr for binding in/: iterable
else if tt == TID.For {
if current().tid != TID.Identifier {
return error("Expected iterator variable after 'for'", l, c)
}
binding = advance().value
if current().tid == TID.Colon or current().tid == TID.In {
advance()
} else {
return error("Expected ':' or 'in' after iterator variable in for-expression", l, c)
}
iterable = parseExpr(getRightBindingPower(TID.For))
if iterable == null: return error("Expected iterable after 'for' binding", l, c)
if iterable.kind == "ErrorNode": return iterable
return ForExpression(left, binding, iterable, l, c)
}
// Arrow function: param => body
else if tt == TID.Arrow {
 if inMatchExpr {
  return null
 }
 // Check if left is a tuple (hotkey binding): (F1, F2) => { ... }
 if left.kind == "ArrayLiteral" && left.isTuple != null {
  binding = HotkeyBinding([], null, l, c)
  for el in left.elements {
   if el.kind == "HotkeyExpression" {
    binding.hotkeys.push(HotkeyLiteral(el.key, l, c))
   }
   else if el.kind == "Identifier" {
    binding.hotkeys.push(HotkeyLiteral(el.name, l, c))
   }
  }
  if current().tid == TID.OpenBrace {
   binding.action = parseBlock()
  }
  else {
   bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
   binding.action = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
  }
  return HotkeyExpression(binding, l, c)
 }
 // Check if left is a HotkeyExpression: F1 => { ... }
 if left.kind == "HotkeyExpression" {
  binding = HotkeyBinding([], null, l, c)
  binding.hotkeys.push(HotkeyLiteral(left.key, l, c))
  if current().tid == TID.OpenBrace {
   binding.action = parseBlock()
  }
  else {
   bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
   binding.action = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
  }
  return HotkeyExpression(binding, l, c)
 }
 // Single-parameter lambda: x => body
 if left == null || left.kind != "Identifier" {
  return error("Arrow function requires identifier parameter", l, c)
 }
 paramName = left.name
 params = [paramName]
 body = null
 if current().tid == TID.OpenBrace {
  body = parseBlock()
}
  else {
    bodyExpr = parseExpr(getRightBindingPower(TID.Arrow))
    body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
  }
  return LambdaExpression(params, body)
}
  else {
    return error("Unexpected token in infix position: " + tt, l, c)
  }
}
    // ===================================================================
    // HELPER: Parse call arguments
    // ===================================================================
fn parseCallArgs() {
  args = []
  kwargs = []
  skipNewlines()
  while current().tid != TID.CloseParen and notEOF() {
    skipNewlines()
    if current().tid == TID.CloseParen: break
    if args.len > 0 or kwargs.len > 0 {
      if current().tid == TID.Comma {
        advance()
        skipNewlines()
      }
    }
    if current().tid == TID.CloseParen: break
    // Keyword argument: name=value
    if current().tid == TID.Identifier and at(1).tid == TID.Assign {
      name = advance().value
      advance() // consume '='
      value = parseExpr(0)
      kwargs.push({name: name, value: value})
    }
    // Spread
    else if current().tid == TID.Spread {
      advance()
      target = parseExpr(0)
      args.push(SpreadExpression(target, current().line, current().col))
    }
    else {
      args.push(parseExpr(0))
    }
    skipNewlines()
  }
  if current().tid == TID.CloseParen {
    advance()
  }
  else {
    error("Expected ')' after arguments", current().line, current().col)
  }
  {args: args, kwargs: kwargs}
}
    // ===================================================================
    // HELPER: Detect slice expression [...:...]
    // ===================================================================
    fn detectSlice() {
        lookahead = 0
        depth = 1
        while pos + lookahead < tokens.len {
            t = tokens[pos + lookahead]
            if t.tid == TID.OpenBracket: depth = depth + 1
            else if t.tid == TID.CloseBracket {
                depth = depth - 1
                if depth == 0: break
            }
            else if (t.tid == TID.Colon or t.tid == TID.ColonColon or t.tid == TID.DotDot or t.tid == TID.DotDotEquals) and depth == 1 {
                return true
            }
            else if t.tid == TID.EOF: break
            lookahead = lookahead + 1
        }
        false

    }
    // ===================================================================
    // HELPER: Parse slice expression
    // ===================================================================
    fn parseSliceExpr(obj, l, c) {
        start = null
        end = null
        step = null

        if current().tid != TID.Colon and current().tid != TID.ColonColon and current().tid != TID.DotDot and current().tid != TID.DotDotEquals {
            start = parseExpr(0)

        }
        if current().tid == TID.ColonColon {
            advance()
            if current().tid != TID.CloseBracket {
                step = parseExpr(0)
            }
        }
        else if current().tid == TID.Colon {
            advance()
            if current().tid != TID.Colon and current().tid != TID.CloseBracket {
                end = parseExpr(0)
            }
            if current().tid == TID.Colon {
                advance()
                if current().tid != TID.CloseBracket {
                    step = parseExpr(0)

                }
            }
        }
        else if current().tid == TID.DotDot {
         advance()
         if current().tid != TID.CloseBracket {
          end = parseExpr(0)
         }
        }
        else if current().tid == TID.DotDotEquals {
         advance()
         if current().tid != TID.CloseBracket {
          end = parseExpr(0)
         }
        }
        if current().tid == TID.CloseBracket {
            advance()
        }
        else {
            error("Expected ']' after slice", l, c)

        }
        // Desugar to obj.slice(start, end, step)
        args = []
        if start != null: args.push(start)
        else: args.push(NullLiteral(l, c))
        if end != null: args.push(end)
        else: args.push(NullLiteral(l, c))
        if step != null: args.push(step)
        else: args.push(NullLiteral(l, c))

  sliceMember = MemberExpression(obj, "slice", l, c)
  return CallExpression(sliceMember, args, [], l, c)

  }
    // ===================================================================
    // HELPER: Parse interpolated string into parts
    // ===================================================================
    fn parseInterpolatedString(value, l, c) {
        parts = []
        i = 0
        buf = ""

        while i < value.len {
            ch = value.sub(i, 1)

            // {...} interpolation (works in all strings, not just f-strings)
            if ch == "{" {
                if buf.len > 0 {
                    parts.push(StringLiteral(buf, l, c))
                    buf = ""
                }
                i = i + 1
                depth = 1
                exprStr = ""
                while i < value.len and depth > 0 {
                    ch2 = value.sub(i, 1)
                    if ch2 == "{": depth = depth + 1
                    else if ch2 == "}": depth = depth - 1
                    if depth > 0: exprStr = exprStr + ch2
                    i = i + 1
                }
                subTokens = tokenize(exprStr)
                subParser = Parser(subTokens)
                subExpr = subParser.parseExpr(0)
                if subExpr != null: parts.push(subExpr)
                else: parts.push(Identifier(exprStr, l, c))

            }
            else {
                buf = buf + ch
                i = i + 1

            }
        }
        if buf.len > 0 {
            parts.push(StringLiteral(buf, l, c))

