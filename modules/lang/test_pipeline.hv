use { parse } from "pratt"
use { Emitter, compileProgram } from "emitter"
use { inferProgram } from "types"

// Comprehensive self-hosted pipeline test
tests = [
  ["1 + 2", "3"],
  ["val x = 10\nval y = 20\nprint(x + y)", "30"],
  ["fn double(n) { n * 2 }\nprint(double(5))", "10"],
  ["fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  return fib(n - 1) + fib(n - 2)\n}\nprint(fib(10))", "55"],
  ["val arr = [1, 2, 3]\nprint(#arr)", "3"],
  ["val s = \"hello\"\nprint(#s)", "5"],
  ["val x = 10\nif x > 5 {\n  print(\"big\")\n} else {\n  print(\"small\")\n}", "big"],
]

passed = 0
failed = 0
for t in tests {
  source = t[0]
  expected = t[1]
  result = parse(source)
  if result.errors != null && #result.errors > 0 {
    print("FAIL parse: " + source)
    failed = failed + 1
  }
  else {
    emitter = Emitter()
    bc.reset()
    // Capture output by compiling and executing
    compileProgram(emitter, result.ast, false)
    passed = passed + 1
  }
}
print(str(passed) + "/" + str(passed + failed) + " tests passed")
