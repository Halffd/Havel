use { tokenize } from "lang/lexer"
use { parseTokens } from "lang/pratt"
use { compileProgram } from "lang/emitter"

source = fs.read("/tmp/test_fib2.hv")
tokens = tokenize(source)
print("tokens: " + str(#tokens))
ast = parseTokens(tokens)
print("ast body: " + str(#ast.body))
result = compileProgram(ast, "test_fib2", true)
print("result: " + str(result))
print("result type: " + type(result))
