// protocols.hv — EWMH/NET_WM atom constants and protocol helpers
// Provides: atom constants, state operation codes, helper functions
// for EWMH-compliant window manager communication

use x11

// EWMH state operations
STATE_ADD = 1
STATE_REMOVE = 0
STATE_TOGGLE = 2

// Source indication for _NET_ACTIVE_WINDOW
SOURCE_UNKNOWN = 0
SOURCE_APPLICATION = 1
SOURCE_PAGER = 2

// Cached display and atoms (lazily initialized)
_dpy = 0
_atoms_cache = {}

fn _ensureDpy() {
    if _dpy == 0 {
        _dpy = x11.open(null)
    }
    _dpy
}

fn _atom(name) {
    if _atoms_cache.has(name) { return _atoms_cache.get(name) }
    _d = _ensureDpy()
    _a = x11.internAtom(_d, name, 1)
    _atoms_cache.set(name, _a)
    _a
}

// ============================================================
// Root window atoms
// ============================================================

fn netSupported() { _atom("_NET_SUPPORTED") }
fn netClientList() { _atom("_NET_CLIENT_LIST") }
fn netClientListStacking() { _atom("_NET_CLIENT_LIST_STACKING") }
fn netNumberOfDesktops() { _atom("_NET_NUMBER_OF_DESKTOPS") }
fn netCurrentDesktop() { _atom("_NET_CURRENT_DESKTOP") }
fn netDesktopNames() { _atom("_NET_DESKTOP_NAMES") }
fn netActiveWindow() { _atom("_NET_ACTIVE_WINDOW") }
fn netWorkarea() { _atom("_NET_WORKAREA") }
fn netShowingDesktop() { _atom("_NET_SHOWING_DESKTOP") }
fn netDesktopViewport() { _atom("_NET_DESKTOP_VIEWPORT") }
fn netDesktopGeometry() { _atom("_NET_DESKTOP_GEOMETRY") }

