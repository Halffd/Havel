// WM protocol atoms
// ============================================================

fn wmProtocols() { _atom("WM_PROTOCOLS") }
fn wmDeleteWindow() { _atom("WM_DELETE_WINDOW") }
fn wmTakeFocus() { _atom("WM_TAKE_FOCUS") }
fn wmName() { _atom("WM_NAME") }
fn wmClass() { _atom("WM_CLASS") }

// ============================================================
// Helper: send EWMH client message to root window
// ============================================================

fn sendRootMessage(dpy, win, messageType, d0, d1, d2, d3, d4) {
    _ev = x11.makeClientMessage(win, messageType, 32, d0, d1, d2, d3, d4)
    _root = x11.rootWindow(dpy)
    _m1 = x11.SubstructureRedirectMask
    _m2 = x11.SubstructureNotifyMask
    _mask = _m1 | _m2
    x11.sendEvent(dpy, _root, x11.XFalse, _mask, _ev)
    x11.flush(dpy)
    x11.freeClientMessage(_ev)
}

// Helper: send EWMH state change
fn sendStateMessage(dpy, win, action, atom1, atom2) {
    sendRootMessage(dpy, win, netWmState(), action, atom1, atom2, 0, 0)
}

// Helper: activate window
fn sendActiveMessage(dpy, win, source) {
    sendRootMessage(dpy, win, netActiveWindow(), source, x11.CurrentTime, 0, 0, 0)
}

// Helper: close window via WM_DELETE_WINDOW
fn sendCloseMessage(dpy, win) {
    _ev = x11.makeClientMessage(win, wmProtocols(), 32, wmDeleteWindow(), x11.CurrentTime, 0, 0, 0)
    x11.sendEvent(dpy, win, x11.XFalse, x11.NoEventMask, _ev)
    x11.flush(dpy)
    x11.freeClientMessage(_ev)
}

// Helper: move/resize via _NET_MOVERESIZE_WINDOW
fn sendMoveResizeMessage(dpy, win, x, y, w, h) {
    // flags: x(1<<8) | y(1<<9) | w(1<<10) | h(1<<11)
    _f1 = 1 << 8
    _f2 = 1 << 9
    _f3 = 1 << 10
    _f4 = 1 << 11
    _flags = _f1 | _f2 | _f3 | _f4
    sendRootMessage(dpy, win, netWmMoveResize(), _flags, x, y, w, h)
}

// Helper: change desktop
fn sendDesktopMessage(dpy, desktop) {
    _root = x11.rootWindow(dpy)
    _ev = x11.makeClientMessage(_root, netCurrentDesktop(), 32, desktop, x11.CurrentTime, 0, 0, 0)
    _m1 = x11.SubstructureRedirectMask
    _m2 = x11.SubstructureNotifyMask
    _mask = _m1 | _m2
    x11.sendEvent(dpy, _root, x11.XFalse, _mask, _ev)
    x11.flush(dpy)
    x11.freeClientMessage(_ev)
}

// Helper: read cardinal property from a window
fn getCardinalProp(dpy, win, atom) {
    _r = x11.getWindowProperty(dpy, win, atom, 0, 1, 0, x11.XA_CARDINAL)
    _val = 0
    if _r.rcode == 0 && _r.nitems > 0 && _r.prop != 0 {
        _val = ffi.get_i32(_r.prop)
        x11.free(_r.prop)
    }
    _val
}

// Helper: read window property (returns a single window ID)
fn getWindowProp(dpy, win, atom) {
    _r = x11.getWindowProperty(dpy, win, atom, 0, 1, 0, x11.XA_WINDOW)
    _val = 0
    if _r.rcode == 0 && _r.nitems > 0 && _r.prop != 0 {
        _val = ffi.get_u64(_r.prop)
        x11.free(_r.prop)
    }
    _val
}

// Helper: read atom array property
fn getAtomProp(dpy, win, atom) {
    _r = x11.getWindowProperty(dpy, win, atom, 0, 1024, 0, x11.XA_ATOM)
    _atoms = []
    if _r.rcode == 0 && _r.nitems > 0 && _r.prop != 0 {
        _i = 0
        while _i < _r.nitems {
            _a = ffi.get_u64(ffi.ptr_add(_r.prop, _i * 8))
            _atoms.push(_a)
            _i = _i + 1
        }
        x11.free(_r.prop)
    }
    _atoms
}

// Helper: read string property
fn getStringProp(dpy, win, atom) {
    _r = x11.getWindowProperty(dpy, win, atom, 0, 1024, 0, 0)
    _val = ""
    if _r.rcode == 0 && _r.nitems > 0 && _r.prop != 0 {
        _val = ffi.string(_r.prop)
        x11.free(_r.prop)
    }
    _val
}

// Helper: check if a window has a specific state atom
fn hasState(dpy, win, stateAtom) {
    _states = getAtomProp(dpy, win, netWmState())
    _found = false
    _i = 0
    while _i < #_states {
        if _states[_i] == stateAtom { _found = true }
        _i = _i + 1
    }
    _found
}

// Cleanup display
fn cleanup() {
    if _dpy != 0 {
        x11.close(_dpy)
        _dpy = 0
        _atoms_cache = {}
    }
}
