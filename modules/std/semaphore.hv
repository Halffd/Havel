// Error codes
// ============================================

const SEM_VALUE_MAX = 2147483647
const SEM_FAILED = null
const EINVAL = "EINVAL"
const ENOSPC = "ENOSPC"
const EAGAIN = "EAGAIN"
const ETIMEDOUT = "ETIMEDOUT"
const EINTR = "EINTR"
const ENOSYS = "ENOSYS"
const EPERM = "EPERM"
const EACCES = "EACCES"
const ENOENT = "ENOENT"
const ENOTSUP = "ENOTSUP"
const ECANCELED = "ECANCELED"
const EOWNERDEAD = "EOWNERDEAD"
const ENOTRECOVERABLE = "ENOTRECOVERABLE"
const EPROTO = "EPROTO"
const EDEADLK = "EDEADLK"
const PTHREAD_BARRIER_SERIAL_THREAD = "PTHREAD_BARRIER_SERIAL_THREAD"