// modules/string.hv
// Pure Havel string module using FFI when needed, pure Havel otherwise

// ============================================================
// Core string operations (pure Havel, no FFI)
// ============================================================

fn upper(s) {
    result = ""
    i = 0
    len = #s
    while i < len {
        ch = s[i:i+1]
        if ch >= "a" && ch <= "z" {
            result = result + char(ord(ch) - 32)
        } else {
            result = result + ch
        }
        i = i + 1
    }
    return result
}

fn lower(s) {
    result = ""
    i = 0
    len = #s
    while i < len {
        ch = s[i:i+1]
        if ch >= "A" && ch <= "Z" {
            result = result + char(ord(ch) + 32)
        } else {
            result = result + ch
        }
        i = i + 1
    }
    return result
}

fn trim(s) {
    start = 0
    end = #s - 1
    while start <= end {
        ch = s[start:start+1]
        if ch != " " && ch != "\t" && ch != "\n" && ch != "\r" {
            break
        }
        start = start + 1
    }
    while end >= start {
        ch = s[end:end+1]
        if ch != " " && ch != "\t" && ch != "\n" && ch != "\r" {
            break
        }
        end = end - 1
    }
    if start > end {
        return ""
    }
    return s[start:end+1]
}

fn split(s, delim) {
    result = []
    if delim == null {
        delim = ","
    }
    pos = 0
    dlen = #delim
    slen = #s
    while pos <= slen {
        found = s.find(delim, pos)
        if found == null || found < 0 {
            result.push(s[pos:])
            break
        }
        result.push(s[pos:found])
        pos = found + dlen
    }
    return result
}

fn join(arr, delim) {
    if delim == null {
        delim = ""
    }
    result = ""
    i = 0
    len = #arr
    while i < len {
        if i > 0 {
            result = result + delim
        }
        result = result + arr[i]
        i = i + 1
    }
    return result
}

fn replace(s, old, new) {
    if old == null || old == "" {
        return s
    }
    result = ""
    pos = 0
    slen = #s
    olen = #old
    while true {
        idx = s.find(old, pos)
        if idx == null || idx < 0 {
            result = result + s[pos:]
            break
        }
        result = result + s[pos:idx] + new
        pos = idx + olen
    }
    return result
}

fn startsWith(s, prefix) {
    if #prefix > #s {
        return false
    }
    return s[0:#prefix] == prefix
}

fn endsWith(s, suffix) {
    if #suffix > #s {
        return false
    }
    return s[#s - #suffix:] == suffix
}

fn contains(s, sub) {
    return s.find(sub) != null && s.find(sub) >= 0
}

fn count(s, sub) {
    if sub == null || sub == "" {
        return 0
    }
    cnt = 0
    pos = 0
    slen = #s
    olen = #sub
    while pos <= slen {
        idx = s.find(sub, pos)
        if idx == null || idx < 0 {
            break
        }
        cnt = cnt + 1
        pos = idx + olen
    }
    return cnt
}

fn repeat(s, n) {
    if n <= 0 {
        return ""
    }
    result = ""
    i = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    return result
}

fn padStart(s, width, pad) {
    if pad == null {
        pad = " "
    }
    if #s >= width {
        return s
    }
    needed = width - #s
    padLen = #pad
    prefix = ""
    i = 0
    while i < needed {
        prefix = prefix + pad[i % padLen:i % padLen + 1]
        i = i + 1
    }
    return prefix + s
}

fn padEnd(s, width, pad) {
    if pad == null {
        pad = " "
    }
    if #s >= width {
        return s
    }
    needed = width - #s
    padLen = #pad
    suffix = ""
    i = 0
    while i < needed {
        suffix = suffix + pad[i % padLen:i % padLen + 1]
        i = i + 1
    }
    return s + suffix
}

fn left(s, n) {
    if n <= 0 {
        return ""
    }
    if n >= #s {
        return s
    }
    return s[0:n]
}

fn right(s, n) {
    if n <= 0 {
        return ""
    }
    if n >= #s {
        return s
    }
    return s[#s - n:]
}

fn chars(s) {
    result = []
    i = 0
    len = #s
    while i < len {
        result.push(s[i:i+1])
        i = i + 1
    }
    return result
}

fn bytes(s) {
    // Returns array of byte values (0-255)
    result = []
    i = 0
    len = #s
    while i < len {
        result.push(ord(s[i:i+1]))
        i = i + 1
    }
    return result
}

// ============================================================
// FFI-based operations (if libc available)
// ============================================================

_libc = null
_toupper = null
_tolower = null
_strlen = null

fn _initLibc() {
    if _libc != null {
        return
    }
    _libc = ffi.open("libc.so.6")
    if _libc != null {
        _toupper = ffi.sym(_libc, "toupper")
        _tolower = ffi.sym(_libc, "tolower")
        _strlen = ffi.sym(_libc, "strlen")
    }
}

fn upperFast(s) {
    _initLibc()
    if _toupper == null {
        return upper(s)
    }
    // Implementation would need to iterate over bytes
    // For now, fall back to pure Havel
    return upper(s)
}

fn lowerFast(s) {
    _initLibc()
    if _tolower == null {
        return lower(s)
    }
    return lower(s)
}

// ord() and char() are provided by the host runtime

// ============================================================
// Utility functions
// ============================================================

fn ord(ch) {
    // Returns Unicode code point of first character
    // Simplified: only ASCII for now
    if ch == null || ch == "" {
        return 0
    }
    // This is a limitation — real implementation needs UTF-8 decode
    return ch[0]  // This won't work, need actual byte value
}

fn char(code) {
    // Convert code point to string
    // Simplified: only ASCII
    if code < 0 || code > 127 {
        return ""
    }
    // Need way to create string from code
    return str(code)  // This is wrong, need actual char
}

// ============================================================
// Utility functions
// ============================================================

fn isUpper(ch) {
    if #ch != 1 {
        return false
    }
    return ch >= "A" && ch <= "Z"
}

fn isLower(ch) {
    if #ch != 1 {
        return false
    }
    return ch >= "a" && ch <= "z"
}

fn isDigit(ch) {
    if #ch != 1 {
        return false
    }
    return ch >= "0" && ch <= "9"
}

fn isLetter(ch) {
    if #ch != 1 {
        return false
    }
    return (ch >= "A" && ch <= "Z") || (ch >= "a" && ch <= "z")
}

fn isAlphaNum(ch) {
    return isLetter(ch) || isDigit(ch)
}

fn isSpace(ch) {
    if #ch != 1 {
        return false
    }
    return ch == " " || ch == "\t" || ch == "\n" || ch == "\r"
}

// ============================================================
// Reverse (by code units, not graphemes)
// ============================================================

fn reverse(s) {
    result = ""
    i = #s - 1
    while i >= 0 {
        result = result + s[i:i+1]
        i = i - 1
    }
    return result
}

