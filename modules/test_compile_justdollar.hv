use fs
use { tokenize } from "lexer"
use { parseTokens } from "pratt"
use { Emitter, compileProgram } from "emitter"

fn run_source(src) {
  tokens = tokenize(src)
  result = parseTokens(tokens)
  emitter = Emitter()
  compileProgram(emitter, result.ast, true)
  bc.execute()
}

x = 10
run_source('print("$x")')
name = "world"
run_source('name = "world"\nprint("hello $name!")')
run_source('print("no interp here")')
run_source('print(3 + 4)')
run_source('fn add(a, b) { return a + b }\nprint(add(10, 20))')
