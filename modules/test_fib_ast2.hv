use { tokenize } from "lexer"
use { parseTokens } from "pratt"

source = "fn fib(n)\n    if n <= 1\n        return n\n    return fib(n - 1) + fib(n - 2)"
tokens = tokenize(source)
result = parseTokens(tokens)
ast = result.ast
body = ast.body[0].body
for j in 0..(#body.body - 1) {
    inner = body.body[j]
    print("[" + str(j) + "] kind=" + inner.kind)
    if inner.kind == "IfStatement" {
        print("  test kind=" + str(inner.test.kind))
        print("  consequent kind=" + str(inner.consequent.kind))
        cons = inner.consequent
        if cons != null && cons.kind == "BlockStatement" {
            for k in 0..(#cons.body - 1) {
                print("    cons[" + str(k) + "] kind=" + cons.body[k].kind)
            }
        }
        alt = inner["else"]
        if alt != null {
            print("  alternate kind=" + str(alt.kind))
        }
    }
    if inner.kind == "ReturnStatement" {
        print("  value kind=" + str(inner.value.kind))
    }
}
