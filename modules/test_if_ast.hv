use { tokenize } from "lexer"
use { parseTokens } from "pratt"

source = "if n <= 1\n    return n"
tokens = tokenize(source)
print("tokens: " + str(#tokens))
for i in 0..(#tokens - 1) {
    print("  " + str(i) + ": " + tokens[i].type + " " + str(tokens[i].value))
}
result = parseTokens(tokens)
ast = result.ast
print("ast body count: " + str(#ast.body))
if #ast.body > 0 {
    stmt = ast.body[0]
    print("stmt kind=" + stmt.kind)
    if stmt.kind == "IfStatement" {
        print("  test kind=" + str(stmt.test.kind))
        print("  cons kind=" + str(stmt.consequent.kind))
    }
}
