use { tokenize } from "lexer"
use { parseTokens } from "pratt"

source = "if n <= 1\n    return n"
tokens = tokenize(source)
result = parseTokens(tokens)
ast = result.ast
if #ast.body > 0 {
    stmt = ast.body[0]
    print("kind=" + stmt.kind)
    print("condition=" + str(stmt.condition))
    print("then=" + str(stmt.then))
    print("then.kind=" + str(stmt.then.kind))
    alt = stmt["else"]
    print("else=" + str(alt))
}
