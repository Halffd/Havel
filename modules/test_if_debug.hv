use { tokenize } from "lexer"
use { parseTokens } from "pratt"

source = "if n <= 1\n    return n"
tokens = tokenize(source)
print("tokens: " + str(#tokens))
for i in 0..(#tokens - 1) {
    print("  " + str(i) + ": type=" + tokens[i].type + " value=" + str(tokens[i].value))
}
result = parseTokens(tokens)
if result.errors != null && #result.errors > 0 {
    for i in 0..(#result.errors - 1) {
        print("ERROR: " + str(result.errors[i]))
    }
}
ast = result.ast
print("body count=" + str(#ast.body))
if #ast.body > 0 {
    stmt = ast.body[0]
    print("kind=" + stmt.kind)
    print("test=" + str(stmt.test))
    print("consequent=" + str(stmt.consequent))
}
