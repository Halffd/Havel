use { tokenize } from "lexer"
use { parseTokens } from "pratt"

// Test: does parseExpr(0) work when called from within parseIfStatement?
source = "if x + 1\n    return 0"
tokens = tokenize(source)
result = parseTokens(tokens)
ast = result.ast
if #ast.body > 0 {
    stmt = ast.body[0]
    print("kind=" + stmt.kind + " test=" + str(stmt.test) + " cons=" + str(stmt.consequent))
}
