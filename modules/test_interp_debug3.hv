use fs
use { tokenize } from "lexer"
use { parseTokens } from "pratt"
use { Emitter, compileProgram } from "emitter"
source = fs.read("/tmp/test_bare_interp.txt")
tokens = tokenize(source)
result = parseTokens(tokens)
if result.errors != null && #result.errors > 0 {
  for err in result.errors { print("ERR: " + str(err)) }
  exit(1)
}
emitter = Emitter()
compileProgram(emitter, result.ast, true)
// Check chunk state before executing
funcCount = bc.func_count()
print("func_count=" + str(funcCount))
strCount = bc.str_count()
print("str_count=" + str(strCount))
// Try a non-interpolation test first
bc.execute()
