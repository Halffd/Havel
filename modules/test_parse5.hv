use { tokenize } from "lang/lexer"
use { parseTokens } from "lang/pratt"
source = "arr[1] = 99"
tokens = tokenize(source)
result = parseTokens(tokens)
ast = result.ast
stmt = ast.body[0]
print("stmt kind=" + str(stmt.kind))
if stmt.kind == "ExpressionStatement" {
    expr = stmt.expr
    print("expr kind=" + str(expr.kind))
    if expr.kind == "AssignmentExpression" {
        target = expr.target
        print("target kind=" + str(target.kind))
        if target.kind == "IndexExpression" {
            print("target.obj kind=" + str(target.obj.kind))
            print("target.obj.name=" + str(target.obj.name))
            print("target.index.kind=" + str(target.index.kind))
            print("target.index.value=" + str(target.index.value))
        }
        print("value.kind=" + str(expr.value.kind))
        print("value.value=" + str(expr.value.value))
    }
}
