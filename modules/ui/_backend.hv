    @fnTrayNotify = self.sym("havel_ui_shim_tray_notify")
    @fnTrayShow = self.sym("havel_ui_shim_tray_show")
    @fnTrayHide = self.sym("havel_ui_shim_tray_hide")
    @fnTrayIsVisible = self.sym("havel_ui_shim_tray_is_visible")
