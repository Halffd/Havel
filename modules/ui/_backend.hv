fn _callV(fn_ptr, retType, params) {
 ffi.call(fn_ptr, retType, params)
}

fn _call0(fn_ptr, retType, params) {
 ffi.call(fn_ptr, retType, params)
}

class Backend {
  uiBackend

  fn @(toolkitName) {
        _resolveShimSyms()
        _toolkitHandle = ffi.open(_toolkitPath(toolkitName))
        if _toolkitHandle == null {
            print("ui._backend: failed to load toolkit: " + toolkitName)
            return null
        }
        infoFn = ffi.sym(_toolkitHandle, "havel_toolkit_info")
        if infoFn == null {
            print("ui._backend: no havel_toolkit_info in " + toolkitName)
            return null
        }
        _abiPtr = ffi.call(infoFn, "pointer", [])
        if _abiPtr == null {
            print("ui._backend: havel_toolkit_info returned null")
            return null
        }
        createFnPtr = ffi.get_ptr(ffi.ptr_add(_abiPtr, 32))
        if createFnPtr == null {
            print("ui._backend: no create_ui_backend in ABI struct")
            return null
        }
        @uiBackend = ffi.call(createFnPtr, "pointer", [])
        if @uiBackend == null {
            print("ui._backend: create_ui_backend returned null")
            return null
        }
        ffi.call(_fn_init, "int32", ["pointer"], @uiBackend)
  _initialized = true
    self
  }

