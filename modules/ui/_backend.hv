  fn destroy() {
  self.shutdown()
        if _toolkitHandle != null {
            ffi.close(_toolkitHandle)
            _toolkitHandle = null
        }
        if _shimHandle != null {
            ffi.close(_shimHandle)
            _shimHandle = null
        }
        @uiBackend = null
        _initialized = false
    }
}

fn detectToolkit() {
    names = ["qt", "gtk", "imgui"]
    for name in names {
        path = _toolkitPath(name)
        handle = ffi.open(path)
        if handle != null {
            ffi.close(handle)
            return name
        }
    }
    ""
}
