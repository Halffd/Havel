// _backend.hv - FFI bridge to havel_toolkit_*.so and havel_ui_shim.so
// Pure Havel. Uses ffi to dlopen toolkit .so, create backend, and call all UIBackend methods.
// All mutable state in Backend class instance to avoid module-level state bug.

use "ffi" as ffi
use "env" as env

class ShimState {
  handle, fnInit, fnShutdown, fnWindow, fnPanel, fnModal,
  fnText, fnLabel, fnImage, fnIcon, fnDivider, fnSpacer,
  fnProgress, fnSpinner, fnBtn, fnInput, fnTextarea,
  fnCheckbox, fnToggle, fnSlider, fnDropdown,
  fnRow, fnCol, fnGrid, fnTable, fnFlex, fnScroll, fnCanvas,
  fnMenu, fnMenuItem, fnMenuSeparator,
  fnShow, fnHide, fnClose, fnRealize, fnAddChild,
  fnSetTitle, fnSetSize, fnSetPos, fnSetStyle,
  fnGetValue, fnSetValue,
  fnCanvasFlush, fnCanvasClear, fnCanvasDrawLine,
  fnCanvasDrawRect, fnCanvasDrawCircle,
  fnCanvasSetPen, fnCanvasFill,
  fnRunLoop, fnQuitLoop, fnPumpEvents,
  fnAlert, fnConfirm, fnFilePicker, fnDirPicker, fnNotify,
  fnTrayIcon, fnTrayMenu, fnTrayNotify,
  fnTrayShow, fnTrayHide, fnTrayIsVisible,
  fnTimerCreate, fnTimerStart, fnTimerStop, fnTimerDestroy,
  fnSettingsCreate, fnSettingsDestroy,
  fnSettingsSetValue, fnSettingsValue,
  fnSettingsContains, fnSettingsRemove, fnSettingsSync,
  fnColorPicker, fnFontPicker,
  fnInputText, fnInputInt,
  fnHasActiveWindows, fnIsAvailable,
  fnGetApiName, fnSetAppMetadata, fnLastError,
  toolkitHandle, initialized
  fn @() {
    @handle = null
    @toolkitHandle = null
    @initialized = false
    @fnInit = null
    @fnShutdown = null
    @fnWindow = null
    @fnPanel = null
    @fnModal = null
    @fnText = null
    @fnLabel = null
    @fnImage = null
    @fnIcon = null
    @fnDivider = null
    @fnSpacer = null
    @fnProgress = null
    @fnSpinner = null
    @fnBtn = null
    @fnInput = null
    @fnTextarea = null
    @fnCheckbox = null
    @fnToggle = null
    @fnSlider = null
    @fnDropdown = null
    @fnRow = null
    @fnCol = null
    @fnGrid = null
    @fnTable = null
    @fnFlex = null
    @fnScroll = null
    @fnCanvas = null
    @fnMenu = null
    @fnMenuItem = null
    @fnMenuSeparator = null
    @fnShow = null
    @fnHide = null
    @fnClose = null
    @fnRealize = null
    @fnAddChild = null
    @fnSetTitle = null
    @fnSetSize = null
    @fnSetPos = null
    @fnSetStyle = null
    @fnGetValue = null
    @fnSetValue = null
    @fnCanvasFlush = null
    @fnCanvasClear = null
    @fnCanvasDrawLine = null
    @fnCanvasDrawRect = null
    @fnCanvasDrawCircle = null
    @fnCanvasSetPen = null
    @fnCanvasFill = null
    @fnRunLoop = null
    @fnQuitLoop = null
    @fnPumpEvents = null
    @fnAlert = null
    @fnConfirm = null
    @fnFilePicker = null
    @fnDirPicker = null
    @fnNotify = null
    @fnTrayIcon = null
    @fnTrayMenu = null
    @fnTrayNotify = null
    @fnTrayShow = null
    @fnTrayHide = null
    @fnTrayIsVisible = null
    @fnTimerCreate = null
    @fnTimerStart = null
    @fnTimerStop = null
    @fnTimerDestroy = null
    @fnSettingsCreate = null
    @fnSettingsDestroy = null
    @fnSettingsSetValue = null
    @fnSettingsValue = null
    @fnSettingsContains = null
    @fnSettingsRemove = null
    @fnSettingsSync = null
    @fnColorPicker = null
    @fnFontPicker = null
    @fnInputText = null
    @fnInputInt = null
    @fnHasActiveWindows = null
    @fnIsAvailable = null
    @fnGetApiName = null
    @fnSetAppMetadata = null
    @fnLastError = null
    @
  }

  fn shimPath() {
    dir = env.get("HAVEL_SHIM_DIR")
    if dir != null { return dir + "/havel_ui_shim.so" }
    build = env.get("HAVEL_BUILD_DIR")
    if build != null { return build + "/shims/havel_ui_shim.so" }
    "havel_ui_shim.so"
  }

  fn toolkitPath(name) {
    dir = env.get("HAVEL_TOOLKIT_DIR")
    if dir != null { return dir + "/havel_toolkit_" + name + ".so" }
    build = env.get("HAVEL_BUILD_DIR")
    if build != null { return build + "/toolkits/havel_toolkit_" + name + ".so" }
    "havel_toolkit_" + name + ".so"
  }

  fn loadShim() {
    if @handle != null { return }
    @handle = ffi.open(self.shimPath())
    if @handle == null {
      print("ui._backend: failed to load shim: " + ffi.lastError())
    }
  }

  fn sym(name) {
    self.loadShim()
    ffi.sym(@handle, name)
  }

  fn resolveShimSyms() {
    @fnInit = self.sym("havel_ui_shim_init")
    @fnShutdown = self.sym("havel_ui_shim_shutdown")
    @fnWindow = self.sym("havel_ui_shim_window")
    @fnPanel = self.sym("havel_ui_shim_panel")
    @fnModal = self.sym("havel_ui_shim_modal")
    @fnText = self.sym("havel_ui_shim_text")
    @fnLabel = self.sym("havel_ui_shim_label")
    @fnImage = self.sym("havel_ui_shim_image")
    @fnIcon = self.sym("havel_ui_shim_icon")
    @fnDivider = self.sym("havel_ui_shim_divider")
    @fnSpacer = self.sym("havel_ui_shim_spacer")
    @fnProgress = self.sym("havel_ui_shim_progress")
    @fnSpinner = self.sym("havel_ui_shim_spinner")
    @fnBtn = self.sym("havel_ui_shim_btn")
    @fnInput = self.sym("havel_ui_shim_input")
    @fnTextarea = self.sym("havel_ui_shim_textarea")
    @fnCheckbox = self.sym("havel_ui_shim_checkbox")
    @fnToggle = self.sym("havel_ui_shim_toggle")
    @fnSlider = self.sym("havel_ui_shim_slider")
    @fnDropdown = self.sym("havel_ui_shim_dropdown")
    @fnRow = self.sym("havel_ui_shim_row")
    @fnCol = self.sym("havel_ui_shim_col")
    @fnGrid = self.sym("havel_ui_shim_grid")
    @fnTable = self.sym("havel_ui_shim_table")
    @fnFlex = self.sym("havel_ui_shim_flex")
    @fnScroll = self.sym("havel_ui_shim_scroll")
    @fnCanvas = self.sym("havel_ui_shim_canvas")
    @fnMenu = self.sym("havel_ui_shim_menu")
    @fnMenuItem = self.sym("havel_ui_shim_menu_item")
    @fnMenuSeparator = self.sym("havel_ui_shim_menu_separator")
    @fnShow = self.sym("havel_ui_shim_show")
    @fnHide = self.sym("havel_ui_shim_hide")
    @fnClose = self.sym("havel_ui_shim_close")
    @fnRealize = self.sym("havel_ui_shim_realize")
    @fnAddChild = self.sym("havel_ui_shim_add_child")
    @fnSetTitle = self.sym("havel_ui_shim_set_title")
    @fnSetSize = self.sym("havel_ui_shim_set_size")
    @fnSetPos = self.sym("havel_ui_shim_set_pos")
    @fnSetStyle = self.sym("havel_ui_shim_set_style")
    @fnGetValue = self.sym("havel_ui_shim_get_value")
    @fnSetValue = self.sym("havel_ui_shim_set_value")
    @fnCanvasFlush = self.sym("havel_ui_shim_canvas_flush")
    @fnCanvasClear = self.sym("havel_ui_shim_canvas_clear")
    @fnCanvasDrawLine = self.sym("havel_ui_shim_canvas_draw_line")
    @fnCanvasDrawRect = self.sym("havel_ui_shim_canvas_draw_rect")
    @fnCanvasDrawCircle = self.sym("havel_ui_shim_canvas_draw_circle")
    @fnCanvasSetPen = self.sym("havel_ui_shim_canvas_set_pen")
    @fnCanvasFill = self.sym("havel_ui_shim_canvas_fill")
    @fnRunLoop = self.sym("havel_ui_shim_run_loop")
    @fnQuitLoop = self.sym("havel_ui_shim_quit_loop")
    @fnPumpEvents = self.sym("havel_ui_shim_pump_events")
    @fnAlert = self.sym("havel_ui_shim_alert")
    @fnConfirm = self.sym("havel_ui_shim_confirm")
    @fnFilePicker = self.sym("havel_ui_shim_file_picker")
    @fnDirPicker = self.sym("havel_ui_shim_dir_picker")
    @fnNotify = self.sym("havel_ui_shim_notify")
    @fnTrayIcon = self.sym("havel_ui_shim_tray_icon")
