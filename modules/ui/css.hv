// css.hv - CSS parser and selector matching for Havel UI
use "ui/markup" as markup

class Selector {
  parts, specificity, text
  fn @(parts, text) {
    @parts = parts
    @text = text
    @specificity = computeSpecificity(parts)
  }
}

class Declaration {
  property, value, important
  fn @(property, value, important) {
    @property = property
    @value = value
    @important = important
  }
}

class Rule {
  selectors, declarations
  fn @(selectors, declarations) {
    @selectors = selectors
    @declarations = declarations
  }
}

class Parser {
  src, pos, len
  fn @(src) {
    @src = src
    @pos = 0
    @len = #src
  }

  fn at() {
    p = @pos
    l = @len
    if p < l {
      e = p + 1
      s = @src
      s[p:e]
    } else { null }
  }

  fn peek(offset) {
    p = @pos
    i = p + offset
    l = @len
    if i < l {
      e = i + 1
      s = @src
      s[i:e]
    } else { null }
  }

  fn advance() {
    ch = @at()
    @pos = @pos + 1
    ch
  }

  fn skipWS() {
    p = @pos
    l = @len
    while p < l {
      ch = @at()
      if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" || ch == "\f" {
        @pos = @pos + 1
        p = @pos
      } else { return }
    }
  }

  fn skipComment() {
    p = @pos
    l = @len
    while p < l {
      ch = @at()
      pk = @peek(1)
      if ch == "/" && pk == "*" {
        @pos = @pos + 2
        p = @pos
        while p < l {
          ch2 = @at()
          pk2 = @peek(1)
          if ch2 == "*" && pk2 == "/" {
            @pos = @pos + 2
            p = @pos
            return
          }
          @pos = @pos + 1
          p = @pos
        }
      } else { return }
      @skipWS()
      p = @pos
    }
  }

  fn skipWSAndComments() {
    p = @pos
    l = @len
    while p < l {
      @skipWS()
      ch = @at()
      pk = @peek(1)
      if ch == "/" && pk == "*" {
        @skipComment()
        p = @pos
      } else { return }
    }
  }

  fn isIdentStart(ch) {
    if ch == null { return false }
    (ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") || ch == "_" || ch == "-"
  }

  fn isIdent(ch) {
    if ch == null { return false }
    started = @isIdentStart(ch)
    started || (ch >= "0" && ch <= "9")
  }

  fn readIdent() {
    result = ""
    ch = @at()
    if ch == "-" { result = "-"; @advance() }
    p = @pos
    l = @len
    while p < l {
      ch = @at()
      if !@isIdent(ch) { break }
      result = result + @advance()
      p = @pos
    }
    result
  }

  fn readString(quote) {
    @advance()
    result = ""
    p = @pos
    l = @len
    ch = @at()
    while p < l && ch != quote {
      if ch == "\\" {
        @advance()
        result = result + @advance()
      } else {
        result = result + @advance()
      }
      p = @pos
      ch = @at()
    }
    if p < l { @advance() }
    result
  }

  fn parseSelector() {
    parts = []
    @skipWSAndComments()
    p = @pos
    l = @len
    cur = @at()
    while p < l && cur != "{" && cur != "," {
      @skipWSAndComments()
      ch = @at()
      if ch == null || ch == "{" || ch == "," { break }
      if ch == "." {
        @advance()
        name = @readIdent()
        parts.push({type: "class", value: name})
      } else if ch == "#" {
        @advance()
        name = @readIdent()
        parts.push({type: "id", value: name})
      } else if ch == "[" {
        @advance()
        attrName = @readIdent()
        @skipWS()
        oper = ""
        nxt = @at()
        if nxt == "=" { oper = "="; @advance() }
        else if nxt == "~" {
          pk1 = @peek(1)
          if pk1 == "=" { oper = "~="; @pos = @pos + 2 }
        } else if nxt == "|" {
          pk1 = @peek(1)
          if pk1 == "=" { oper = "|="; @pos = @pos + 2 }
        } else if nxt == "^" {
          pk1 = @peek(1)
          if pk1 == "=" { oper = "^="; @pos = @pos + 2 }
        } else if nxt == "$" {
          pk1 = @peek(1)
          if pk1 == "=" { oper = "$="; @pos = @pos + 2 }
        } else if nxt == "*" {
          pk1 = @peek(1)
          if pk1 == "=" { oper = "*="; @pos = @pos + 2 }
        }
        attrValue = ""
        if oper != "" {
          @skipWS()
          q = @at()
          if q == "\"" || q == "'" {
            attrValue = @readString(q)
          } else {
            p2 = @pos
            while p2 < l {
              c = @at()
              if c == "]" || c == " " { break }
              attrValue = attrValue + @advance()
              p2 = @pos
            }
          }
        }
        @skipWS()
        if @at() == "]" { @advance() }
        parts.push({type: "attr", name: attrName, "op": oper, value: attrValue})
      } else if ch == ":" {
        @advance()
        nxt = @at()
        if nxt == ":" {
          @advance()
          name = @readIdent()
          parts.push({type: "pseudo_element", value: name})
        } else {
          name = @readIdent()
          args = ""
          nxt2 = @at()
          if nxt2 == "(" {
            @advance()
            depth = 1
            p3 = @pos
            while p3 < l && depth > 0 {
              c = @advance()
              if c == "(" { depth = depth + 1 }
              else if c == ")" { depth = depth - 1 }
              if depth > 0 { args = args + c }
              p3 = @pos
            }
          }
          parts.push({type: "pseudo", value: name, args: args})
        }
      } else if ch == "*" {
        @advance()
        parts.push({type: "universal", value: "*"})
      } else if ch == ">" {
        @advance()
        @skipWSAndComments()
        parts.push({type: "combinator", value: ">"})
      } else if ch == "+" {
        @advance()
        @skipWSAndComments()
        parts.push({type: "combinator", value: "+"})
      } else if ch == "~" {
        @advance()
        @skipWSAndComments()
        parts.push({type: "combinator", value: "~"})
      } else {
        pk1 = @peek(1)
        if @isIdentStart(ch) {
          name = @readIdent()
          parts.push({type: "type", value: name})
        } else if ch == "-" && @isIdentStart(pk1) {
          name = @readIdent()
          parts.push({type: "type", value: name})
        } else {
          @advance()
        }
      }
      p = @pos
      cur = @at()
    }
    start = 0
    n = #parts
    while start < n {
      pt = parts[start]
      if pt.type != "combinator" { break }
      start = start + 1
    }
    if start > 0 { parts = parts[start:] }
    parts
  }

  fn parseSelectorList() {
    selectors = []
    @skipWSAndComments()
    p = @pos
    l = @len
    cur = @at()
    while p < l && cur != "{" {
      parts = @parseSelector()
      if #parts > 0 {
        text = selectorPartsToText(parts)
        sel = Selector.new(parts, text)
        selectors.push(sel)
      }
      @skipWSAndComments()
      cur = @at()
      if cur == "," {
        @advance()
        @skipWSAndComments()
        cur = @at()
      } else { break }
      p = @pos
    }
    selectors
  }

  fn parseDeclarations() {
    decls = []
    p = @pos
    l = @len
    cur = @at()
    while p < l && cur != "}" {
      @skipWSAndComments()
      cur = @at()
      if cur == "}" { break }
      prop = @readIdent()
      if prop == "" {
        if p < l { @advance() }
        p = @pos
        continue
      }
      @skipWSAndComments()
      cur2 = @at()
      if cur2 != ":" {
        p = @pos
        continue
      }
      @advance()
      @skipWS()
      value = ""
      p2 = @pos
      while p2 < l {
        c = @at()
        if c == ";" || c == "}" { break }
        if c == "\"" || c == "'" {
          value = value + @readString(c)
        } else {
          value = value + @advance()
        }
        p2 = @pos
      }
      value = value.trim()
      important = false
      vl = #value
      if vl > 10 {
        tail = value[vl - 10:]
        if tail == "!important" {
          important = true
          e = vl - 10
          value = value[:e].trim()
        }
      }
      if !important && vl > 9 {
        tail = value[vl - 9:]
        if tail == "!important" {
          important = true
          e = vl - 9
          value = value[:e].trim()
        }
      }
      if @at() == ";" { @advance() }
      if prop != "" && value != "" {
        decls.push(Declaration.new(prop, value, important))
      }
      p = @pos
    }
    decls
  }

  fn parseRule() {
    selectors = @parseSelectorList()
    @skipWSAndComments()
    cur = @at()
    if cur != "{" { return null }
    @advance()
    decls = @parseDeclarations()
    cur2 = @at()
    if cur2 == "}" { @advance() }
    if #selectors > 0 { Rule.new(selectors, decls) }
    else { null }
  }

  fn parseAll() {
    rules = []
    p = @pos
    l = @len
    while p < l {
      @skipWSAndComments()
      p = @pos
      if p >= l { break }
      cur = @at()
      if cur == "}" { @advance(); p = @pos; continue }
      rule = @parseRule()
      if rule != null { rules.push(rule) }
      p = @pos
    }
    rules
  }
}

fn computeSpecificity(parts) {
  a = 0
  b = 0
  c = 0
  for p in parts {
    t = p.type
    if t == "id" { a = a + 1 }
    else if t == "class" { b = b + 1 }
    else if t == "attr" { b = b + 1 }
    else if t == "pseudo" { b = b + 1 }
    else if t == "type" { c = c + 1 }
  }
  [a, b, c]
}

fn selectorPartsToText(parts) {
  result = ""
  i = 0
  for p in parts {
    if i > 0 && p.type != "combinator" {
      prev = parts[i - 1]
      if prev.type != "combinator" { result = result + " " }
    }
    t = p.type
    if t == "type" { result = result + p.value }
    else if t == "class" { result = result + "." + p.value }
    else if t == "id" { result = result + "#" + p.value }
    else if t == "universal" { result = result + "*" }
    else if t == "attr" {
      result = result + "[" + p.name
      o = p.op
      if o != "" { result = result + o + p.value }
      result = result + "]"
    }
    else if t == "pseudo" {
      result = result + ":" + p.value
      a = p.args
      if a != "" { result = result + "(" + a + ")" }
    }
    else if t == "pseudo_element" { result = result + "::" + p.value }
    else if t == "combinator" { result = result + " " + p.value + " " }
    i += 1
  }
  result
}

fn parse(cssText) {
  p = Parser.new(cssText)
  p.parseAll()
}

fn parseFile(path) {
  content = fs.read(path)
  if content == null { return [] }
  parse(content)
}

fn _matchPart(part, node) {
  t = part.type
  if t == "universal" { return true }
  if t == "type" { return node.tag == part.value }
  if t == "class" {
    cls = node.props["class"]
    if cls == null { return false }
    classes = str(cls).split(" ")
    for c in classes {
      if c == part.value { return true }
    }
    return false
  }
  if t == "id" {
    return node.props["id"] == part.value
  }
  if t == "attr" {
    attrVal = node.props[part.name]
    if attrVal == null { return false }
    sval = str(attrVal)
    o = part.op
    if o == "" { return true }
    if o == "=" { return sval == part.value }
    if o == "~=" {
      for w in sval.split(" ") {
        if w == part.value { return true }
      }
      return false
    }
    if o == "^=" {
      vl = #part.value
      return #sval >= vl && sval[:vl] == part.value
    }
    if o == "$=" {
      vl = #part.value
      el = #sval - vl
      return #sval >= vl && sval[el:] == part.value
    }
    if o == "*=" { return sval.includes(part.value) }
    true
  }
  if t == "pseudo" {
    if part.value == "first-child" { return true }
    if part.value == "last-child" { return true }
    if part.value == "nth-child" {
      n = int(part.args)
      return n > 0
    }
    true
  }
  if t == "pseudo_element" { return false }
  if t == "combinator" { return true }
  false
}

fn matchSelector(selector, node) {
  if node == null { return false }
  if !markup.isVNode(node) { return false }
  parts = selector.parts
  if #parts == 0 { return false }
  hasCombinator = false
  for p in parts {
    if p.type == "combinator" { hasCombinator = true }
  }
  if !hasCombinator {
    for p in parts {
      if !_matchPart(p, node) { return false }
    }
    return true
  }
  _matchWithCombinators(parts, #parts - 1, node)
}

fn _matchWithCombinators(parts, partIdx, node) {
  if partIdx < 0 { return true }
  p = parts[partIdx]
  if p.type == "combinator" { return _matchWithCombinators(parts, partIdx - 1, node) }
  if !_matchPart(p, node) { return false }
  if partIdx == 0 { return true }
  if partIdx >= 2 {
    prev = parts[partIdx - 1]
    if prev.type == "combinator" {
      parent = node._parent
      return _matchWithCombinators(parts, partIdx - 2, parent)
    }
  }
  _matchWithCombinators(parts, partIdx - 1, node)
}

fn matchAny(rules, node) {
  matched = []
  for rule in rules {
    for sel in rule.selectors {
      if matchSelector(sel, node) {
        matched.push({rule: rule, selector: sel})
      }
    }
  }
  _sortBySpecificity(matched)
  matched
}

fn _sortBySpecificity(matched) {
  n = #matched
  i = 0
  while i < n - 1 {
    j = 0
    while j < n - i - 1 {
      a = matched[j].selector.specificity
      b = matched[j + 1].selector.specificity
      if a[0] < b[0] || (a[0] == b[0] && a[1] < b[1]) || (a[0] == b[0] && a[1] == b[1] && a[2] < b[2]) {
        tmp = matched[j]
        matched[j] = matched[j + 1]
        matched[j + 1] = tmp
      }
      j += 1
    }
    i += 1
  }
  matched
}

fn specificity(selector) {
  selector.specificity
}
