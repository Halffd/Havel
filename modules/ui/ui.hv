class Slider : Element {
  fn @(min, max, value) {
    b = _requireBackend()
    mn = min != null ? min : 0
    mx = max != null ? max : 100
    v = value != null ? value : 0
    id = b != null ? b.slider(mn, mx, v) : -1
    super(id, "slider")
    self
  }
}

class Dropdown : Element {
  fn @(options) {
    b = _requireBackend()
    csv = ""
    if options != null {
      first = true
      i = 0
      n = #options
      while i < n {
        if !first { csv = csv + "," }
        csv = csv + str(options[i])
        first = false
        i += 1
      }
    }
    id = b != null ? b.dropdown(csv) : -1
    super(id, "dropdown")
    self
  }
}

