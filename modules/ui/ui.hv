class Slider : Element {
    fn @(min, max, value) {
        b = _requireBackend()
        mn = min != null ? min : 0
        mx = max != null ? max : 100
        v = value != null ? value : 0
        id = b != null ? b.slider(mn, mx, v) : -1
        super(id, "slider")
        @
    }
}

class Dropdown : Element {
    fn @(options) {
        b = _requireBackend()
        csv = ""
        if options != null {
            first = true
            for o in options {
                if !first { csv = csv + "," }
                csv = csv + str(o)
                first = false
            }
        }
        id = b != null ? b.dropdown(csv) : -1
        super(id, "dropdown")
        @
    }
}

