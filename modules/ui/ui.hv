// ui.hv - Widget library + backward-compat ui.* functions
// Replaces C++ UIModule.cpp with pure Havel via FFI shim
// All mutable state in UIState class instance to avoid module-level state bug

use "ui/_backend" as _backend_mod
use "ui/markup" as markup
use "ui/css" as css
use "ui/style" as style

class UIState {
  backend, rules, styles, pendingEvents
  fn @() {
    @backend = null
    @rules = []
    @styles = {}
    @pendingEvents = []
  }
}

_state = UIState.new()

fn init(toolkitName) {
  name = toolkitName != null ? toolkitName : _backend_mod.detectToolkit()
  if name == "" { return false }
  _state.backend = _backend_mod.Backend.new(name)
  _state.backend != null
}

fn _requireBackend() {
  if _state.backend == null { init(null) }
  _state.backend
}

class Element {
  id, _type, _children, _parent, _eventHandlers
  fn @(id, elementType) {
    @id = id
    @_type = elementType
    @_children = []
    @_parent = null
    @_eventHandlers = {}
  }

  fn add(child) {
    b = _requireBackend()
    if b == null { return self }
    if type(child) == "Element" {
      b.addChild(@id, child.id)
      @_children.push(child)
      child._parent = self
    }
    self
  }

  fn show() {
    b = _requireBackend()
    if b != null { b.show(@id) }
    self
  }

  fn hide() {
    b = _requireBackend()
    if b != null { b.hide(@id) }
    self
  }

  fn close() {
    b = _requireBackend()
    if b != null { b.close(@id) }
    self
  }

  fn setTitle(title) {
    b = _requireBackend()
    if b != null { b.setTitle(@id, title) }
    self
  }

  fn setSize(w, h) {
    b = _requireBackend()
    if b != null { b.setSize(@id, w, h) }
    self
  }

  fn setPos(x, y) {
    b = _requireBackend()
    if b != null { b.setPos(@id, x, y) }
    self
  }

  fn listen(eventType, handler) {
    @_eventHandlers[eventType] = handler
    self
  }

  fn unlisten(eventType) {
    @_eventHandlers.delete(eventType)
    self
  }

  fn style(key, value) {
    b = _requireBackend()
    if b != null { b.setStyle(@id, key, value) }
    self
  }

  fn value(newVal) {
    b = _requireBackend()
    if b == null { return "" }
    if newVal != null {
      b.setValue(@id, str(newVal))
      self
    } else {
      b.getValue(@id)
    }
  }
}

class Window : Element {
  fn @(title, opts) {
    b = _requireBackend()
    id = b != null ? b.window(title != null ? title : "Window") : -1
    super(id, "window")
    if opts != null {
      if opts.has("width") && opts.has("height") {
        self.setSize(opts.width, opts.height)
      }
    }
    self
  }
}

