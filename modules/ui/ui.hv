fn window(title, opts) { Window.new(title, opts) }
fn panel(side) { Panel.new(side) }
fn modal(title) { Modal.new(title) }
fn btn(label) { Btn.new(label) }
fn text(content) { Text.new(content) }
fn label(content) { Label.new(content) }
fn input(placeholder) { Input.new(placeholder) }
fn textarea(placeholder) { Textarea.new(placeholder) }
fn checkbox(label, checked) { Checkbox.new(label, checked) }
fn toggle(label, value) { Toggle.new(label, value) }
fn slider(min, max, value) { Slider.new(min, max, value) }
fn dropdown(options) { Dropdown.new(options) }
fn image(path) { Image.new(path) }
fn divider() { Divider.new() }
fn spacer(size) { Spacer.new(size) }
fn progress(value, max) { Progress.new(value, max) }
fn spinner() { Spinner.new() }
fn row() { Row.new() }
fn col() { Col.new() }
fn grid(cols) { Grid.new(cols) }
fn table(rows, cols) { Table.new(rows, cols) }
fn flex(direction) { Flex.new(direction) }
fn scroll() { Scroll.new() }
fn canvas(width, height) { Canvas.new(width, height) }
fn menu(title) { Menu.new(title) }
fn menuItem(label, shortcut) { MenuItem.new(label, shortcut) }
fn menuSeparator() { MenuSeparator.new() }

fn alert(msg) {
  b = _requireBackend()
  if b != null { b.alert(msg) }
}

fn confirm(msg) {
  b = _requireBackend()
  if b != null { b.confirm(msg) != 0 } else { false }
}

fn filePicker(title) {
  b = _requireBackend()
  if b != null { b.filePicker(title) } else { "" }
}

fn dirPicker(title) {
  b = _requireBackend()
  if b != null { b.dirPicker(title) } else { "" }
}

fn notify(msg, type) {
  b = _requireBackend()
  if b != null { b.notify(msg, type != null ? type : "info") }
}

fn trayIcon(iconPath, tooltip) {
  b = _requireBackend()
  if b != null { b.trayIcon(iconPath, tooltip) }
}

fn trayMenu(menuId) {
  b = _requireBackend()
  if b != null { b.trayMenu(menuId) }
}

fn trayNotify(title, msg, iconType) {
  b = _requireBackend()
  if b != null { b.trayNotify(title, msg, iconType) }
}

fn trayShow() {
  b = _requireBackend()
  if b != null { b.trayShow() }
}

fn trayHide() {
  b = _requireBackend()
  if b != null { b.trayHide() }
}

fn setApi(name) {
  init(name)
}

fn getApi() {
  b = _requireBackend()
  if b != null { b.getApiName() } else { "" }
}

fn isAvailable() {
  b = _requireBackend()
  if b != null { b.isAvailable() != 0 } else { false }
}

fn run() {
  b = _requireBackend()
  if b != null { b.runLoop() }
}

fn quit(code) {
  b = _requireBackend()
  if b != null { b.quitLoop(code != null ? code : 0) }
}

fn pump(timeoutMs) {
  b = _requireBackend()
  if b != null { b.pumpEvents(timeoutMs != null ? timeoutMs : 16) }
}

fn shutdown() {
  if _state.backend != null {
    _state.backend.destroy()
    _state.backend = null
  }
}

fn addStylesheet(cssText) {
  newRules = css.parse(cssText)
  i = 0
  n = #newRules
  while i < n {
    _state.rules.push(newRules[i])
    i += 1
  }
}

fn addStylesheetFile(path) {
  newRules = css.parseFile(path)
  i = 0
  n = #newRules
  while i < n {
    _state.rules.push(newRules[i])
    i += 1
  }
}

fn resolveStyles(element) {
  style.compute(element, _state.rules)
}

fn render(vdom) {
  root = vdom
  if markup.isVNode(root) {
    _renderNode(root, null)
  }
  root
}

fn _renderNode(node, parentId) {
  if node == null { return }
  if !markup.isVNode(node) { return }
  el = _createElementFromVNode(node)
  if el == null { return }
  node._element = el
  if parentId != null && _state.backend != null {
    _state.backend.addChild(parentId, el.id)
  }
  i = 0
  n = #node.children
  while i < n {
    child = node.children[i]
    if markup.isVNode(child) {
      child._parent = node
      _renderNode(child, el.id)
    }
    i += 1
  }
  el
}

fn _createElementFromVNode(node) {
  b = _requireBackend()
  if b == null { return null }
  tag = node.tag
  if tag == "window" { Window.new(node.props.has("title") ? node.props.title : "Window", node.props) }
  else if tag == "panel" { Panel.new(node.props.has("side") ? node.props.side : "left") }
  else if tag == "modal" { Modal.new(node.props.has("title") ? node.props.title : "Dialog") }
  else if tag == "button" || tag == "btn" { Btn.new(node.props.has("label") ? node.props.label : "") }
  else if tag == "text" { Text.new(node.children.join("")) }
  else if tag == "label" { Label.new(node.props.has("content") ? node.props.content : "") }
  else if tag == "input" { Input.new(node.props.has("placeholder") ? node.props.placeholder : "") }
  else if tag == "textarea" { Textarea.new(node.props.has("placeholder") ? node.props.placeholder : "") }
  else if tag == "checkbox" { Checkbox.new(node.props.has("label") ? node.props.label : "", node.props.has("checked") ? node.props.checked : false) }
  else if tag == "toggle" { Toggle.new(node.props.has("label") ? node.props.label : "", node.props.has("value") ? node.props.value : false) }
  else if tag == "slider" { Slider.new(node.props.has("min") ? node.props.min : 0, node.props.has("max") ? node.props.max : 100, node.props.has("value") ? node.props.value : 0) }
  else if tag == "dropdown" { Dropdown.new(node.props.has("options") ? node.props.options : []) }
  else if tag == "image" || tag == "img" { Image.new(node.props.has("src") ? node.props.src : "") }
  else if tag == "icon" { Icon.new(node.props.has("name") ? node.props.name : "") }
  else if tag == "divider" || tag == "hr" { Divider.new() }
  else if tag == "spacer" { Spacer.new(node.props.has("size") ? node.props.size : 10) }
  else if tag == "progress" { Progress.new(node.props.has("value") ? node.props.value : 0, node.props.has("max") ? node.props.max : 100) }
  else if tag == "spinner" { Spinner.new() }
  else if tag == "row" { Row.new() }
  else if tag == "col" { Col.new() }
  else if tag == "grid" { Grid.new(node.props.has("cols") ? node.props.cols : 2) }
  else if tag == "table" { Table.new(node.props.has("rows") ? node.props.rows : 0, node.props.has("cols") ? node.props.cols : 0) }
  else if tag == "flex" { Flex.new(node.props.has("direction") ? node.props.direction : "row") }
  else if tag == "scroll" { Scroll.new() }
  else if tag == "canvas" { Canvas.new(node.props.has("width") ? node.props.width : 400, node.props.has("height") ? node.props.height : 300) }
  else if tag == "menu" { Menu.new(node.props.has("title") ? node.props.title : "Menu") }
  else if tag == "menuitem" { MenuItem.new(node.props.has("label") ? node.props.label : "", node.props.has("shortcut") ? node.props.shortcut : "") }
  else if tag == "menuseparator" { MenuSeparator.new() }
  else { null }
}
