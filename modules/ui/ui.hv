    fn circle(cx, cy, r) {
        b = _requireBackend()
        if b != null { b.canvasDrawCircle(@id, cx, cy, r) }
        @
    }

    fn setPen(r, g, b, width) {
        bk = _requireBackend()
        if bk != null { bk.canvasSetPen(@id, r, g, b, width != null ? width : 1) }
        @
    }

    fn fill(x, y) {
