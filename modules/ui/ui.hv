// ui.hv - Widget library + backward-compat ui.* functions
// Replaces C++ UIModule.cpp with pure Havel via FFI shim

_backend = null
_rules = []
_styles = {}
_pendingEvents = []

fn init(toolkitName) {
    name = toolkitName != null ? toolkitName : _backend_mod.detectToolkit()
    if name == "" { return false }
    _backend = _backend_mod.Backend.new(name)
    _backend != null
}

fn _requireBackend() {
    if _backend == null { init(null) }
    _backend
}

class Element {
    var id = -1
    var _type = ""
    var _children = []
    var _parent = null
    var _eventHandlers = {}

    fn @(id, elementType) {
        @id = id
        @_type = elementType
        @
    }

    fn add(child) {
        b = _requireBackend()
        if b == null { return @ }
        if type(child) == "Element" {
            b.addChild(@id, child.id)
            @_children.push(child)
            child._parent = @
        }
        @
    }

    fn show() {
        b = _requireBackend()
        if b != null { b.show(@id) }
        @
    }

    fn hide() {
        b = _requireBackend()
        if b != null { b.hide(@id) }
        @
    }

    fn close() {
        b = _requireBackend()
        if b != null { b.close(@id) }
        @
    }

    fn setTitle(title) {
        b = _requireBackend()
        if b != null { b.setTitle(@id, title) }
        @
    }

    fn setSize(w, h) {
        b = _requireBackend()
        if b != null { b.setSize(@id, w, h) }
        @
    }

    fn setPos(x, y) {
        b = _requireBackend()
        if b != null { b.setPos(@id, x, y) }
        @
    }

    fn listen(eventType, handler) {
        @_eventHandlers[eventType] = handler
        @
    }

    fn style(key, value) {
        b = _requireBackend()
        if b != null { b.setStyle(@id, key, value) }
        @
    }

    fn value(newVal) {
        b = _requireBackend()
        if b == null { return "" }
        if newVal != null {
            b.setValue(@id, str(newVal))
            @
        } else {
            b.getValue(@id)
        }
    }
}

class Window : Element {
    fn @(title, opts) {
        b = _requireBackend()
        id = b != null ? b.window(title != null ? title : "Window") : -1
        super(id, "window")
        if opts != null {
            if opts.has("width") && opts.has("height") {
                self.setSize(opts.width, opts.height)
            }
        }
        @
    }
}

