class Canvas : Element {
  fn @(width, height) {
    b = _requireBackend()
    id = b != null ? b.canvas(width != null ? width : 400, height != null ? height : 300) : -1
    super(id, "canvas")
    self
  }

  fn line(x1, y1, x2, y2) {
    b = _requireBackend()
    if b != null { b.canvasDrawLine(@id, x1, y1, x2, y2) }
    self
  }

  fn rect(x, y, w, h) {
    b = _requireBackend()
    if b != null { b.canvasDrawRect(@id, x, y, w, h) }
    self
  }

  fn circle(cx, cy, r) {
    b = _requireBackend()
    if b != null { b.canvasDrawCircle(@id, cx, cy, r) }
    self
  }

  fn setPen(r, g, b, width) {
    bk = _requireBackend()
    if bk != null { bk.canvasSetPen(@id, r, g, b, width != null ? width : 1) }
    self
  }

  fn fill(x, y) {
    b = _requireBackend()
    if b != null { b.canvasFill(@id, x, y) }
    self
  }

  fn flush() {
    b = _requireBackend()
    if b != null { b.canvasFlush(@id) }
    self
  }

  fn clear() {
    b = _requireBackend()
    if b != null { b.canvasClear(@id) }
    self
  }
}

