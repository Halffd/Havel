build_one = fn(input, output) {
  ok = compiler.build(input, output)
  if ok { return true }
  print("compile failed")
  print(input)
  return false
}

main = fn(args) {
  if len(args) < 2 {
    print("usage: compiler_driver.hv <in.hv> <out.hvc>")
    return 2
  }
  ok = build_one(args[0], args[1])
  if ok { return 0 }
  return 1
}
