use { tokenize } from "lexer"
lines = []
lines.push("// comment line")
lines.push("fn foo() {")
lines.push("  x = 1 + 2")
lines.push("  print(x)")
lines.push("}")
lines.push("")
lines.push("fn bar(a, b) {")
lines.push("  if a > b {")
lines.push("    a")
lines.push("  }")
lines.push("  else {")
lines.push("    b")
lines.push("  }")
lines.push("}")
src = lines.join("\n")
print("length: " + str(#src))
tokens = tokenize(src)
print("tokens: " + str(#tokens))
