// Bootstrap test: can lexer.hv tokenize itself?
use { tokenize, printTokens } from "lexer"

src = fs.read("modules/lang/lexer.hv")
if src == null {
    print("FAIL: could not read modules/lang/lexer.hv")
    1
}
else {
    tokens = tokenize(src)
    print("tokens: " + str(#tokens))
    if #tokens == 0 {
        print("FAIL: lexer returned 0 tokens")
        1
    }
    else {
        print("first 5:")
        i = 0
        while i < 5 && i < #tokens {
            t = tokens[i]
            print("  " + t.type + " " + t.value)
            i = i + 1
        }
        print("last 5:")
        i = #tokens - 5
        if i < 0 { i = 0 }
        while i < #tokens {
            t = tokens[i]
            print("  " + t.type + " " + t.value)
            i = i + 1
        }
        0
    }
}
