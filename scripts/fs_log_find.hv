use *
fs.write("/tmp/test.log", "[ERROR] Failed\n[ERROR] Crash!\n[INFO] Exited")
let files = fs.readDir("/tmp")
let filtered = files.filter(f => f.endsWith(".log"))

for i, f in filtered {
  let content = fs.read(f)
  print("{i}: {f}")
  if (content.includes("ERROR")) {
    io.send("Found error in {f}: {content.find("ERROR")}")
  }
}
app.quit(0)