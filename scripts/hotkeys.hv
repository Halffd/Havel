print("mode terminal")
mode terminal {
    condition = exe == "kitty" || exe == "alacritty" || exe == "wezterm" || exe == "gnome-terminal" || exe == "tilix" || exe == "xterm" || exe == "urxvt" || exe == "st" || exe == "yakuake" || exe == "tmux"
    enter { 
      print("entered terminal mode")
      hotkey.disable("!x")
    }
    exit {
        print("exited terminal mode")
        hotkey.enable("!x")
    }
}
print("mode typing")
let keysToDisable = ["Menu", "Alt", "!Tab", "Ctrl", "Super", "Shift", "Esc", "Insert"]
mode typing {
  condition = title ~ "keybr" || title ~ "typing" || title ~ "monkeytype"
  enter {
    print("entered typing mode")
    General.CapsLoxkOnTyping >> doMap
    if doMap {
      io.unmap("CapsLock")
    }
    for key in keysToDisable {
      hotkey.register(key, () => nop)
    }
  }
  exit {
    print("exited typing mode")
    for key in keysToDisable {
      hotkey.remove(key)
    }
  }
}
print("mode vm")
mode vm {
  condition = class ~ "VirtualBox" || class ~ "QEMU" || class ~ "VMware" || class ~ "Virtual Machine" || class ~ "gnome-boxes"
  enter {
    print("entered VM mode")
    hotkey.disable("lwin")
  }
  exit {
    print("exited VM mode")
    hotkey.enable("lwin")
  }
}
