[cpu, gpu, ram, motherboard, storage] = [hardware.cpu, hardware.gpu, hardware.ram, hardware.motherboard, hardware.storage]
storageCount = #storage
totalStorage = storage.reduce((acc, s) => acc + s.size, 0)
