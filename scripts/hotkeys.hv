windows = mac = bsd = linux = unknownOS = false
match sys.os {
  "Windows" => windows = true,
  "MacOS" => mac = true,
  "BSD" => bsd = true,
  "Linux" => linux = true,
  "Unknown" => unknownOS = true,
  _ => {}
}
wl = match sys.os {
  "Linux" => sys.displayProtocol == "Wayland",
  _ => false
}
displayName = ""
shell = sys.shell
user = sys.user
home = sys.home

if linux {
  wl = sys.displayProtocol == "Wayland"
  displayName = sys.display ?? ":0"
  print("wl: $wl")
  print("displayName: $displayName")
}
wm = sys.windowManager.lower()
print("wm: $wm")

if wm == "Unknown" || wm == "unknown" {
  print("wm is unknown, checking for compiz")
  if process.exists("compiz") {
    wm = "compiz"
    print("wm is now: $wm")
  }
}
hypr = kde = i3 = compiz = cinnamon = gnome = wf = xfce = false
match wm {
    "hyprland" => hypr = true,
    "kde plasma" => kde = true,
    "i3" => i3 = true,
    "compiz" => compiz = true,
    "cinnamon" => cinnamon = true,
    "gnome" || "gnome on x11" || "gnome on wayland" => gnome = true,
    "wayfire" => wf = true,
    "xfce" => xfce = true,
    _ => {}
}

kdewl = kde && wl
if !xfce {
  if len(process.find("xfce4-session")) > 0 {
    xfce = true
  }
}
xfcewl = xfce && wl
other = !any([hypr, kde, kdewl, i3, compiz, cinnamon, gnome, wf, xfce, xfcewl])
