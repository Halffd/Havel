class AutoBase {
  running: bool = false
  timer = null
  winId: int = null
  delay: int = 100
  
  fn init() {
    @running = false
  }
  
  fn run?() {
    // Override in subclass
    false
  }
  
  fn start() {
    if run?() { stop() }
    running = true
    winId = window.active().id
    timer = interval delay {
      if !(run?()) || window.active().id != winId {
        stop()
        return
      }
      sendKey()  // Abstract method
    }
    end()
  }
  
  fn stop() {
    if timer { timer.stop() }
    running = false
    timer = null
    winId = null
  }
  
  fn sendKey() {
    // Override in subclass
  }

  fn end(){
    // Override in subclass
  }
}

class AutoF : AutoBase {
  fn run?() {
    return io.getKey("lctrl") || running
  }
  
  fn sendKey() {
    send("f")
  }

  fn end(){
    timeout 10000 {
      stop()
    }
  }
}

class AutoSpace : AutoBase {
  enabled: bool = false
  hk: int = null
  
  fn init(hk) {
    @->init()
    @enabled = true
    @hk = hk
  }
  
  fn run?() {
    return enabled && running && !io.getKey("space")
  }
  
  fn sendKey() {
    send("{space}")
  }
  fn onDown() {
    if run?() { return }
    send("{space:up}")
    sleep(100)
    enabled = false
  }
  fn onUp() {
    toggle()
    send("{space:up}")
    hotkey.enable(hk)
  }
  
  fn toggle() {
    enabled = !enabled
    if !enabled { stop() }
  }
}
