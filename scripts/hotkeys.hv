print("mpv")
// MPV media player hotkeys
let mpvHotkeys = {
  "[": () => mpv.volumeUp(),
  "]": () => mpv.volumeDown(),
  "backspace": () => mpv.toggleMute(),
  "@|rctrl": () => play(),
  "+Esc": () => mpv.stop(),
  "+PgUp": () => mpv.next(),
  "+PgDn": () => mpv.previous(),
  "o": () => mpv.seek("-3"),
  "p": () => mpv.seek("3"),
  "+o": () => mpv.addSpeed("-0.1"),
  "+p": () => mpv.addSpeed("0.1"),
  "@|n": () => mpv.cycle("sub-visibility"),
  "+@|n": () => mpv.cycle("secondary-sub-visibility"),
  "7": () => mpv.addSubScale("-0.1"),
  "8": () => mpv.addSubScale("0.1"),
  "+z": () => mpv.addSubDelay("-0.1"),
  "+x": () => mpv.addSubDelay("0.1"),
  ";": () => mpv.cycle("sub"),
  "9": () => mpv.seek("-1"),
  "0": () => mpv.subSeek("0"),
  "\\": () => mpv.copySubtitle(),
  "minus": () => mpv.subSeek("-1"),
  "equal": () => mpv.subSeek("1"),
  "+v": () => mpv.screenshot(),
  "+i": () => mpv.ipcSet("/tmp/mpvsocket2"),
  "+^r": () => mpv.ipcReset(),
  "y": () => {
    if wd {
      send("{w down}")
    } else {
      send("{w up}")
    }
  },
  "u": () => {
    mouse.up(1)
    mouse.down(1)
  }
}
