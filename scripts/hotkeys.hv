print("applyBr")
fn applyBr () {
  if temperature < 0 {
    temperature = 0
  }
  if temperature > 10000 {
    temperature = 10000
  }
  if brightness < 0.0 {
    brightness = 0.0
  }
  if brightness > 100.0 {
    brightness = 100.0
  }
  let cmd = "~/scripts/lux-hypr.sh $brightness $temperature"
  run(cmd)
}
print("kwinZoom")
fn kwinZoom (cmd) {
  runDetached("qdbus $cmd")
  let out = qdbus("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.getZoomLevelDBus")
  zoomLevel = out
}
let inc = 0.25
fn zoom (level) {
  if level < 0 {
    level = 0
  } else if level > 4 {
    level = 4
  }
  if hypr {
    if level == 0 {
      zoomLevel -= inc
    }
    if level == 1 {
      zoomLevel += inc
    }
    if level == 2 {
      zoomLevel = 1.0
    }
    if level == 3 {
      zoomLevel = 1.7
    }
    if level == 4 {
      zoomLevel = 2.0
    }
    if zoomLevel < 1.0 {
      zoomLevel = 1.0
    }
    if zoomLevel > 8.0 {
      zoomLevel = 8.0
    }
    let cmd = "hyprctl keyword cursor:zoom_factor $zoomLevel"
    run(cmd)
  } else {
    if level == 0 {
      if kde {
        kwinZoom("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.zoomOutDBus")
      }
      if zoomLevel <= 0 || !kde {
        send("@^{Down}")
        zoomLevel -= 0.1
      }
    } else if level == 1 {
      if kde {
        kwinZoom("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.zoomInDBus")
      }
      if zoomLevel <= 0 || !kde {
        send("@^{Up}")
        zoomLevel += 0.1
      }
    } else if level == 2 {
      if kde {
        kwinZoom("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.resetZoomDBus")
      }
      if zoomLevel <= 0 || !kde {
        send("@^/")
        zoomLevel = 1.0
      }
    } else if level == 3 {
      if kde {
        kwinZoom("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.zoomToValueDBus " + zoom3Value)
      }
      if zoomLevel <= 0 || !kde {
        send("@^+/")
        zoomLevel = 1.5
      }
    } else if level == 4 {
      if kde {
        kwinZoom("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.zoomTo140DBus")
      }
      if zoomLevel <= 0 || !kde {
        send("@^+/")
        send("@^Up")
        send("@^Up")
      }
    }

    if zoomLevel < 1.0 {
      zoomLevel = 1.0
    }
  }
}
print("zoomToggle")
fn zoomToggle () {
  if kde {
    zoomLevel = qdbus("org.kde.KWin /Zoom org.kde.KWin.Effect.Zoom.getZoomLevelDBus")
  }
  if zoomLevel <= 1.0 {
    zoom(3)
  } else {
    zoom(2)
  }
}
