let defaultLanguage = "ja"
fn transcribe(
    w,
    h,
    x = mouse.pos().x,
    y = mouse.pos().y,
    lang = defaultLanguage
){
  let text = ocr.read(pixel.region(x,y,w,h), lang)
  text | join("\n") | print | clipboard.set
}
fn transcribe(mon, lang = defaultLanguage) {
  transcribe(mon.x, mon.y, mon.width, mon.height, lang)
}
