// Click automation for Enter key
class AutoClicker : AutoBase {
  delay = 5
  val iClickMax = 50
  fn run?() {
    return @running  // always run when started
  }
  
  fn sendKey() {
    click()
    sleep(math.randint(5, iClickMax))
  }
  
  fn end() {
    // optional: add timeout or cleanup
  }
}

// E + Q rotation for Slash
class AutoRotation : AutoBase {
  eTimer = null
  qTimer = null
  val iE = 5000
  val iQ = 60000
  
  fn sendKey() {
    // This gets called every 100ms by base timer
    // But for rotation, we want separate timers
    // So maybe override start() instead
  }
  
  fn start() {
    if @run?() @stop()
    @running = true
    @winId = window.active().id
    
    @eTimer = interval iE {  // iE = 5000 from your code
      if !@running || window.active().id != @winId { return }
      send("e")
    }
    
    @qTimer = interval iQ {  // iQ = 60000
      if !@running || window.active().id != @winId { return }
      send("q")
    }
  }
  
  fn stop() {
    if @eTimer { @eTimer.stop() }
    if @qTimer { @qTimer.stop() }
    @running = false
  }
}

// Autorunner for Shift+S (+s)
class AutoRunner : AutoBase {
  fn run?() {
    return @running
  }
  
  fn start() {
    if @run?() @stop()
    @running = true
    @winId = window.active().id
    
    send("{LShift:down}")
    send("{w:down}")
    
    // Random interval for LShift taps
    @timer = interval math.randint(1000, 5000) {
      if !@running || window.active().id != @winId {
        @stop()
        return
      }
      send("{LShift}")
      send("{LShift:down}")
    }
  }
  
  fn stop() {
    if @timer { @timer.stop() }
    send("{LShift:up}")
    send("{w:up}")
    @running = false
  }
}

// Instantiate
clicker = AutoClicker()
rotation = AutoRotation()
runner = AutoRunner()
genshinAutomationActive = false

// Bind to hotkeys
enter if mode == "genshin" => {
  genshinAutomationActive = !genshinAutomationActive
  if genshinAutomationActive {
    clicker.start()
    rotation.start()
  } else {
    clicker.stop()
    rotation.stop()
  }
}

/ if mode == "genshin" => {  // Slash key
  if runner.running?() {
    runner.stop()
  } else {
    runner.start()
  }
}

+s if mode == "genshin" => {  // Shift+S
  winid = window.active().id
  interval 100 {
    if winid != window.active().id || io.getKey("f") { return }
    send("{enter}")
    sleep(100)
    send("f")
    move(1600, 900)
    click()
  }
}

!#g => {
  if genshinAutomationActive {
    genshinAutomationActive = false
    clicker.stop()
    rotation.stop()
    gui.notify("Genshin Automation", "Automation sequence stopped")
  } else {
    gui.notify("Genshin Automation", "No active automation to stop")
  }
}

