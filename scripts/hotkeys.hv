let freezeGaming = true
let freezeBrowser = fn(modeFrom = ""){
  if modeFrom == "gaming" && not freezeGaming {
    print("Freeze browser skipped - gaming mode is frozen")
    return
  } 
  print("Freezing browser from mode: " + modeFrom)
  $ ["~/scripts/freeze.sh", b]
}

fn qdbus (cmd) {
  let res = runDetached("qdbus $cmd")
  return res.stdout
}
