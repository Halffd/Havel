print("!f handler")
!f => {
  let pid = window.getPid()
  let state = process.getState(pid)
  let sig = state == "RUNNING" ? process.SIGSTOP : process.SIGCONT
  process.sendSignal(pid, sig)
}

print("kill handler")
!^k => {
  let pid = window.getPid()
  process.sendSignal(pid, process.SIGKILL)
}

print("zoom toggle handler")
@|kc89 => {
  zoomToggle()
}

