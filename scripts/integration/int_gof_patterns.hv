testStrategy()

// --- Template Method ---
class TemplateDecoder {
  fn decode(msg) {
    result = @doDecode(msg)
    @process(result)
    result
  }
  fn doDecode(msg) { {id: "0"} }
  fn process(r) {}
}

class XMLTemplate : TemplateDecoder {
  fn doDecode(msg) {
    id = "1"
    n = ""
    nPos = msg.find('name="')
    if nPos {
      rest = msg.sub(nPos + 6)
      n = rest.sub(0, rest.find('"'))
    }
    {id: id, name: n}
  }
  fn process(r) {
    // simulate processing
  }
}
    {id: id, name: n}
  }
  fn process(r) {
    // simulate processing
  }
}

fn testTemplateMethod() {
  d = XMLTemplate()
  r = d.decode('<person name="Charlie"/>')
  check("Template", r.name, "Charlie")
}
testTemplateMethod()

// --- Visitor ---
struct IntNode {
  n: int
}

struct AddNode {
  left, right
}

struct MulNode {
  left, right
}

fn calcInt(n) { n.n }

fn calcAdd(n) {
  calcExpr(n.left) + calcExpr(n.right)
}

fn calcMul(n) {
  calcExpr(n.left) * calcExpr(n.right)
}

fn calcExpr(e) {
  if e.n != null { calcInt(e) }
  else if e.left && e.right {
    if e.left.n != null { calcMul(e) } else { calcAdd(e) }
  }
  else { 0 }
}

fn printInt(n) { f"{n.n}" }

fn printAdd(n) {
  f"({printExpr(n.left)}+{printExpr(n.right)})"
}

fn printMul(n) {
  f"({printExpr(n.left)}*{printExpr(n.right)})"
}

fn printExpr(e) {
  if e.n != null { printInt(e) }
  else if e.left {
    if e.left.n != null { printMul(e) } else { printAdd(e) }
  }
  else { "?" }
}

fn testVisitor() {
  expr = AddNode(IntNode(5), MulNode(IntNode(3), IntNode(4)))
  check("Visitor-calc", calcExpr(expr), 17)
  checkTrue("Visitor-print", printExpr(expr) != "")
}
testVisitor()

