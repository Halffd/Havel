// integration: GoF creational, structural, behavioral + GRASP design patterns
// Each pattern has a self-contained demo with assert-style checks

pass = 0
fail = 0

fn check(n, a, e) {
  if a == e {
    pass += 1
  } else {
    fail += 1
    print(f"FAIL {n}: got {a}, expected {e}")
  }
}

fn checkTrue(n, a) {
  if a {
    pass += 1
  } else {
    fail += 1
    print(f"FAIL {n}: expected true, got {a}")
  }
}

// ======================== CREATIONAL ========================

// --- Abstract Factory ---
struct CustData { id, name, email }

fn parseCSV(msg) {
  // manual split since .split() has VM bug in class methods
  parts = []
  acc = ""
  for c in msg {
    if c == ";" { parts.push(acc); acc = "" }
    else { acc = acc + c }
  }
  parts.push(acc)
  if parts.len < 3 { CustData("0", "", "") }
  else { CustData(parts[0], parts[1], parts[2]) }
}

fn testAbstractFactory() {
  r1 = parseCSV("1;Alice;alice_at_x.com")
  check("AF-csv-id", r1.id, "1")
  check("AF-csv-name", r1.name, "Alice")
}
testAbstractFactory()

// --- Factory Method ---
class PaymentResult {
  approved: bool
  txId: str
  method: str
  amount: num
}

fn makePaymentResult(approved, txId, method, amount) {
  r = PaymentResult()
  r.approved = approved
  r.txId = txId
  r.method = method
  r.amount = amount
  r
}

class PixPayment {
  key: str
  fn @(k) { @key = k }
  fn pay(amount) {
    makePaymentResult(true, "PIX-1", "PIX", amount)
  }
}

class CardPayment {
  number: str
  holder: str
  fn @(n, h) { @number = n; @holder = h }
  fn pay(amount) {
    makePaymentResult(true, "CARD-1", "CARD", amount)
  }
}

class PaymentService {
  strategy
  fn @() {}
  fn setStrategy(s) { @strategy = s }
  fn pay(amount) { @strategy.pay(amount) }
}

fn testFactoryMethod() {
  svc = PaymentService()
  svc.setStrategy(PixPayment("alice_at_x"))
  r = svc.pay(100)
  check("FM-pix-approve", r.approved, true)
  check("FM-pix-method", r.method, "PIX")
  svc.setStrategy(CardPayment("4111", "Alice"))
  r2 = svc.pay(200)
  check("FM-card-approve", r2.approved, true)
  check("FM-card-method", r2.method, "CARD")
}
testFactoryMethod()

// --- Builder ---
class Building {
  type: str
  desc: str
  area: int
}

class TowerBuilder {
  b
  fn @() { @b = Building() }
  fn withType(t) { @b.type = t; @b }
  fn withDesc(d) { @b.desc = d; @b }
  fn withArea(a) { @b.area = a; @b }
  fn build() { r = @b; @b = Building(); r }
}

class Tower {
  floors
  fn @() { @floors = [] }
  fn add(fl) { @floors.push(fl) }
  fn count() { @floors.len }
}

fn testBuilder() {
  tower = Tower()
  builder = TowerBuilder()
  b1 = builder.withType("Lobby")
  b1 = b1.withDesc("Main Lobby")
  b1 = b1.withArea(100)
  tower.add(b1.build())
  b2 = builder.withType("Office")
  b2 = b2.withDesc("Open Office")
  b2 = b2.withArea(200)
  tower.add(b2.build())
  check("Builder-count", tower.count(), 2)
}
testBuilder()

// --- Prototype ---
class Document {
  title: str
  content: str
  fmt: str
  fn @(t, c, fmt) { @title = t; @content = c; @fmt = fmt }
  fn clone() { Document(@title, @content, @fmt) }
}

fn testPrototype() {
  d1 = Document("Report", "data", "PDF")
  d2 = d1.clone()
  check("Proto-title", d2.title, "Report")
  check("Proto-fmt", d2.fmt, "PDF")
}
testPrototype()

// --- Singleton ---
// Note: constructor from class method has VM bug, use manual lazy init
_configInstance = null

fn getConfig() {
  if _configInstance == null {
    _configInstance = {}
    _configInstance["items"] = {}
  }
  _configInstance
}

fn testSingleton() {
  c1 = getConfig()
  c2 = getConfig()
  c1["items"]["key"] = "val"
  check("Single-get", c2["items"]["key"], "val")
  checkTrue("Single-instance", c1["items"]["key"] == c2["items"]["key"])
}
testSingleton()

// ======================== STRUCTURAL ========================

// --- Adapter ---
class PayXPTO {
  fn pay(card, amount) {
    f"XPTO: {card} paid {amount}"
  }
}

class ABCService {
  fn process(card, amount) {
    f"ABC: paid {amount}"
  }
}

class XPTOAdapter {
  xpto
  fn @(x) { @xpto = x }
  fn pay(card, amount) { @xpto.pay(card, amount) }
}

class PaymentProcessor {
  adapter
  fn @(a) { @adapter = a }
  fn pay(card, amount) { @adapter.pay(card, amount) }
}

fn testAdapter() {
  p = PaymentProcessor(XPTOAdapter(PayXPTO()))
  r = p.pay("4111", 100)
  checkTrue("Adapter", r != "")
}
testAdapter()

// --- Bridge ---
class TextRenderer {
  fn render(t) { t }
}

class WidgetRenderer {
  fn render(t) { f"[WIDGET] {t}" }
}

class TextArea {
  text
  renderer
  fn @(t, r) { @text = t; @renderer = r }
  fn render() { @renderer.render(@text) }
}

fn testBridge() {
  t1 = TextArea("Hello", TextRenderer())
  t2 = TextArea("Hello", WidgetRenderer())
  check("Bridge-plain", t1.render(), "Hello")
  check("Bridge-widget", t2.render(), "[WIDGET] Hello")
}
testBridge()

// --- Composite ---
class File {
  name: str
  fn @(n) { @name = n }
  fn delete() { f"Deleting {@name}" }
  fn encrypt() {
    // simple caesar shift
    result = ""
    for c in @name
      result += str.char(str.ord(c) + 1)
    result
  }
}

class Folder {
  name: str
  children
  fn @(n) { @name = n; @children = [] }
  fn add(e) { @children.push(e) }
  fn delete() {
    @children.map(fn(f){ f.delete() }).join(",")
  }
  fn encrypt() {
    @children.map(fn(f){ f.encrypt() }).join(",")
  }
}

fn testComposite() {
  root = Folder("root")
  root.add(File("secret"))
  root.add(File("data"))
  e = root.encrypt()
  checkTrue("Composite", e.len > 0)
}
testComposite()

// --- Decorator ---
fn testDecorator() {
  // Simple writer chain: compress then encrypt
  parts = []
  fn write(s) { parts.push(s) }

  // encryptor
  fn enc(s) {
    result = ""
    for c in s { result = result + str.char(str.ord(c) + 1) }
    result
  }

  // compression simulation
  data = "Hello World"
  encrypted = enc(data)
  parts.push(encrypted)
  checkTrue("Decorator", parts.len > 0)
}
testDecorator()

// --- Facade ---
class Castle {
  fn lightsOn() { "Lights on" }
  fn lightsOff() { "Lights off" }
  fn fireOn() { "Fireplace lit" }
  fn fireOff() { "Fireplace out" }
  fn arm() { "Security armed" }
  fn disarm() { "Security disarmed" }
}

class CastleFacade {
  castle
  fn @() { @castle = Castle() }
  fn goodNight() {
    f"Disarmed, { @castle.disarm() } -> Lights: { @castle.lightsOff() } -> Fire: { @castle.fireOff() } -> Armed: { @castle.arm() }"
  }
}

fn testFacade() {
  cf = CastleFacade()
  r = cf.goodNight()
  checkTrue("Facade", r.len > 10)
}
testFacade()

// --- Flyweight ---
class Element {
  symbol
  name
  num
  mass
  fn @(s, n, num, m) { @symbol = s; @name = n; @num = num; @mass = m }
}

elementData = [
  ["H", "Hydrogen", 1, 1.008], ["He", "Helium", 2, 4.003],
  ["C", "Carbon", 6, 12.011], ["O", "Oxygen", 8, 15.999],
  ["Fe", "Iron", 26, 55.845], ["Au", "Gold", 79, 196.967]
]

fn getElement(sym) {
  for row in elementData {
    if row[0] == sym { return Element(row[0], row[1], row[2], row[3]) }
  }
}

fn testFlyweight() {
  h1 = getElement("H")
  h2 = getElement("H")
  check("Flyweight-name", h1.name, "Hydrogen")
  checkTrue("Flyweight-same", h1.num == h2.num)
}
testFlyweight()

// --- Proxy ---
fn testProxy() {
  cache = {}
  cache["key"] = null
  fn readPath(p, cache, real) {
    if cache[p] != null { f"[CACHE] {cache[p]}" }
    else {
      v = f"Content of {p}"
      cache[p] = v
      v
    }
  }
  r1 = readPath("/doc.txt", cache, null)
  r2 = readPath("/doc.txt", cache, null)
  checkTrue("Proxy", r1 != "")
  checkTrue("Proxy-cache", r2.find("[CACHE]") != null)
}
testProxy()

// ======================== BEHAVIORAL ========================

// --- Chain of Responsibility ---
class PhoneCall {
  typ: str
  duration: int
  fn @(t, d) { @typ = t; @duration = d }
}

class CallRater {
  next
  fn setNext(n) { @next = n }
  fn rate(call) { @next ? @next.rate(call) : -1 }
}

class InternalRater : CallRater {
  fn rate(call) {
    if call.typ == "internal" { 0 }
    else { @next ? @next.rate(call) : -1 }
  }
}

class LocalRater : CallRater {
  fn rate(call) {
    if call.typ == "local" { call.duration * 0.1 }
    else { @next ? @next.rate(call) : -1 }
  }
}

class NationalRater : CallRater {
  fn rate(call) {
    if call.typ == "national" { call.duration * 0.5 }
    else { @next ? @next.rate(call) : -1 }
  }
}

fn testChain() {
  c1 = InternalRater()
  c1.setNext(LocalRater())
  c2 = c1.next
  c2.setNext(NationalRater())

  r1 = c1.rate(PhoneCall("internal", 10))
  r2 = c1.rate(PhoneCall("national", 10))
  check("Chain-internal", r1, 0)
  check("Chain-national", r2, 5)
}
testChain()

// --- Command --- class Macro
class Adventurer {
  hp
  fn @() { @hp = 100 }
  fn attack() { f"Attack! HP={@hp}" }
  fn heal() { @hp = @hp + 20; if @hp > 100 { @hp = 100 }; f"Heal! HP={@hp}" }
}

class AttackCmd {
  a
  fn @(a) { @a = a }
  fn exec() { @a.attack() }
  fn undo() { "Undo attack" }
}

class HealCmd {
  a
  fn @(a) { @a = a }
  fn exec() { @a.heal() }
  fn undo() { "Undo heal" }
}

class Macro {
  cmds
  fn @() { @cmds = [] }
  fn add(c) { @cmds.push(c) }
  fn exec() {
    // manual accumulation due to push bug in class methods
    r = ""
    for c in @cmds {
      if r != "" { r = r + "; " }
      r = r + c.exec()
    }
    r
  }
  fn undo() {
    r = ""
    i = @cmds.len - 1
    while i >= 0 {
      if r != "" { r = r + "; " }
      r = r + @cmds[i].undo()
      i -= 1
    }
    r
  }
}

fn testCommand() {
  a = Adventurer()
  macro = Macro()
  macro.add(AttackCmd(a))
  macro.add(HealCmd(a))
  r = macro.exec()
  checkTrue("Command", r.len > 0)
  u = macro.undo()
  checkTrue("Command-undo", u.len > 0)
}
testCommand()

