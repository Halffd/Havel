testInfoExpert()

// --- Polymorphism ---
class AlphaBroker {
  fn pay(card, amount) { f"Alpha:{card}:{amount}" }
}

class BetaBroker {
  fn pay(card, amount) { f"Beta:{card}:{amount}" }
}

class PaymentClient {
  broker
  fn @(b) { @broker = b }
  fn pay(card, amount) { @broker.pay(card, amount) }
}

fn testPolymorphism() {
  alpha = PaymentClient(AlphaBroker())
  r1 = alpha.pay("4111", 100)
  checkTrue("Poly-alpha", r1 != "")
  beta = PaymentClient(BetaBroker())
  r2 = beta.pay("4111", 100)
  checkTrue("Poly-beta", r2.find("Beta") != null)
}
testPolymorphism()

// --- Repository ---
class ProductRepo {
  data
  fn @() { @data = {} }
  fn save(p) { @data[p.code] = p }
  fn find(code) { @data[code] }
  fn remove(code) { @data[code] = nil }
}

fn testRepository() {
  repo = ProductRepo()
  prod = {code: "P1", name: "Sword", price: 100}
  repo.save(prod)
  found = repo.find("P1")
  check("Repo-name", found.name, "Sword")
  check("Repo-price", found.price, 100)
}
testRepository()

// --- Protected Variation ---
class StdFreight {
  fn calc(order) { 25 }
}

class ExpressFreight {
  fn calc(order) { 45 }
}

class OrderCloser {
  freight
  fn @(f) { @freight = f }
  fn close(order) {
    // Freight calculation is protected from changes
    @freight.calc(order)
  }
}

fn testProtectedVariation() {
  order = SimpleOrder(3)
  closer = OrderCloser(StdFreight())
  check("ProtVar-std", closer.close(order), 25)
  closer2 = OrderCloser(ExpressFreight())
  check("ProtVar-express", closer2.close(order), 45)
}
testProtectedVariation()

