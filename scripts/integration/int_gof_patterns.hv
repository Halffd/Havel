  check("Interpreter", expr, 17)
}
testInterpreter()

// --- Iterator (built-in iteration) ---
fn testIterator() {
  items = ["Sword", "Potion", "Shield"]
  names = items.join(",")
  check("Iterator", names, "Sword,Potion,Shield")
  count = 0
  for i in items
    count += 1
  check("Iterator-count", count, 3)
}
testIterator()

// --- Memento ---
struct OrderState {
  number, status
}

class Order {
  number
  status
  items
  fn @(num) { @number = num; @items = []; @status = "OPEN" }
  fn addItem(item) { @items.push(item) }
  fn save() { OrderState(@number, @status) }
  fn restore(s) { @number = s.number; @status = s.status }
}

fn testMemento() {
  ord = Order(1)
  ord.addItem("Sword")
  saved = ord.save()
  ord.status = "CLOSED"
  ord.restore(saved)
  check("Memento", ord.status, "OPEN")
}
testMemento()

// --- Observer ---
class Observable {
  observers
  changed
  fn @() { @observers = []; @changed = false }
  fn add(o) { @observers.push(o) }
  fn setChanged() { @changed = true }
  fn notify(data) {
    if @changed {
      for o in @observers
        o.update(data)
      @changed = false
    }
  }
}

class Point : Observable {
  x: int
  y: int
  fn @(x, y) { @x = x; @y = y; @observers = [] }
  fn move(x, y) { @x = x; @y = y; @changed = true; for o in @observers { o.update(@x) } }
  fn getX() { @x }
}

class PrinterObserver {
  lastX
  fn @() { @lastX = 0 }
  fn update(x) { @lastX = x }
}

fn testObserver() {
  p = Point(0, 0)
  obs = PrinterObserver()
  p.add(obs)
  p.move(10, 20)
  check("Observer-x", obs.lastX, 10)
}
testObserver()

// --- State ---
class State {
  fn startWithdrawal() {
    "starting withdrawal"
  }
}

class POS {
  state
  fn @() { @state = State() }
  fn changeState(s) { @state = s }
  fn startWithdrawal() { @state.startWithdrawal() }
}

class WithdrawState : State {
  fn startWithdrawal() {
    "already in withdrawal"
  }
}

fn testState() {
  pos = POS()
  r1 = pos.startWithdrawal()
  pos.changeState(WithdrawState())
  r2 = pos.startWithdrawal()
  checkTrue("State", r1 != "")
  checkTrue("State-2", r2 != "")
}
testState()

