// --- Creator ---
class OrderItem {
  product: str
  qty: int
  price: int
  fn @(p, q, pr) { @product = p; @qty = q; @price = pr }
  fn getTotal() { @qty * @price }
}

class SimpleOrder {
  number: int
  items
  fn @(num) { @number = num; @items = [] }
  fn add(product, qty, price) { @items.push(OrderItem(product, qty, price)) }
  fn getTotal() {
    t = 0
    for i in @items { t += i.getTotal() }
    t
  }
}

fn testCreator() {
  o = SimpleOrder(1)
  o.add("Sword", 2, 100)
  check("Creator", o.getTotal(), 200)
}
testCreator()

// --- Indirection ---
class OrderRepo {
  data
  fn @() { @data = {} }
  fn save(o) { @data[o.number] = o }
  fn find(num) { @data[num] }
  fn count() { @data.len }
}

fn testIndirection() {
  repo = OrderRepo()
  order = SimpleOrder(1)
  order.add("Shield", 1, 50)
  repo.save(order)
  found = repo.find(1)
  check("Indirection", found.number, 1)
  check("Indirection-count", repo.count(), 1)
}
testIndirection()

