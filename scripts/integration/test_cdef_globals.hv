use ffi

let libc = ffi.open("libc.so.6")

let defs = ffi.cdef("#define EINTR 4\n#define EINVAL 22\n#define ENOENT 2\n#define EXIT_SUCCESS 0\n#define EXIT_FAILURE 1\n#define PATH_MAX 4096\n#define O_RDONLY 0\n#define O_CREAT 64\nint getpid(void);\nint close(int fd);\nextern int errno;", libc)

print("EINTR = " + EINTR)
print("EINVAL = " + EINVAL)
print("ENOENT = " + ENOENT)
print("EXIT_SUCCESS = " + EXIT_SUCCESS)
print("EXIT_FAILURE = " + EXIT_FAILURE)
print("PATH_MAX = " + PATH_MAX)
print("O_RDONLY = " + O_RDONLY)
print("O_CREAT = " + O_CREAT)

ffi.close(libc)
