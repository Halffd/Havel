// Test 2: Decorator factory — @deco(args) fn f()
// A decorator factory is a function that takes args and returns a decorator

// Factory: takes a multiplier, returns a decorator
fn multiply_result(factor) {
    fn wrapper(func) {
        // We can't wrap the call since we don't have *args spread,
        // so just return the original function for now (identity factory)
        print("multiply_result factory called with factor=" + str(factor))
        return func
    }
    return wrapper
}

@multiply_result(2)
fn add(a, b) {
    return a + b
}

print(add(3, 4))
