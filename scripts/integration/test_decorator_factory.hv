// Decorator factory test — [bracket] syntax
// Use [bracket] syntax instead

pass = 0
fail = 0

fn check(n, a, e) {
  if a == e {
    pass += 1
  } else {
    fail += 1
    print(f"FAIL {n}: got {a}, expected {e}")
  }
}

// Factory: takes a multiplier, returns identity decorator
fn multiply_result(factor) {
  fn wrapper(func) {
    return func
  }
  return wrapper
}

[multiply_result(2)]
fn add(a, b) {
  return a + b
}

check("factory-add", add(3, 4), 7)

// Factory with string arg
fn make_tagged(tag) {
  fn tagger(func) {
    return func
  }
  return tagger
}

[make_tagged("v2")]
fn getNumber() {
  return 99
}

check("factory-tag", getNumber(), 99)

// Factory with no args (paren-less not supported, use parens)
fn just_wrap(func) {
  return func
}

[just_wrap]
fn echo(x) {
  return x
}

check("no-arg-factory", echo("hello"), "hello")

print(f"int-decorator-factory: {pass} passed, {fail} failed")
exit(fail)
