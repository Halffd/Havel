class Builder {
    value: int = 0

    fn init() {
        @value = 0
    }

    fn put(x) {
        @value = x
        return @
    }

    fn plus(x) {
        @value = @value + x
        return @
    }

    fn times(x) {
        @value = @value * x
        return @
    }

    fn read() {
        return @value
    }
}

let result = Builder().put(5).plus(3).times(2).read()
print("chained result: " + result)
assert(result == 16, "Builder chain should produce 16")
print("builder pattern test passed")
