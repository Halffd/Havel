// Test thread, interval, and timeout features

print "=== Testing Thread ==="
let counter = 0

// Create a simple thread
let t = thread(fn(){
  for i in range(5) {
    print("Thread iteration: " + i)
    sleep_ms(100)
  }
})

print "Thread created, checking status..."
print "Thread running: " + thread.running(t)

print "\n=== Testing Timeout ==="
// Create a timeout
let to = timeout(500, fn(){
  print("Timeout fired after 500ms!")
})

print "Timeout created, waiting..."
sleep_ms(200)
print "Still waiting..."
sleep_ms(400)
print "Timeout should have fired"

print "\n=== Testing Interval ==="
// Create an interval  
let count = 0
let iv = interval(200, fn(){
  count = count + 1
  print("Interval tick: " + count)
  if count >= 3 {
    print("Stopping interval after 3 ticks")
    interval.stop(iv)
  }
})

print "Interval created, waiting for ticks..."
sleep_ms(1000)
print "Interval test complete"

print "\n=== All Concurrency Tests Passed! ==="
