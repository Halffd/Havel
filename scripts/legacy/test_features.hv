// Test new features (without interpolation which needs scope fix)

print("=== Testing New Features ===\n")

// 1. Test array printing
print("1. Array printing:")
let arr = [1, 2, 3]
print(arr)
print("")

// 2. Test string interpolation with explicit syntax
print("2. String interpolation (explicit):")
let x = 42
print("Double: x = ")
print(x)
print('Single quotes: literal $x')
print("")

// 3. Test keyword arguments
print("3. Keyword arguments:")
print("a", "b", "c", delim="-", end="!\n")
print("")

// 4. Test print with no args (just newline)
print("4. Print with no args:")
print()
print("After empty print")
print("")

// 5. Test fmt() function
print("5. fmt() function:")
let name = "World"
let num = 123
print(fmt("Hello, {}!", name))
print(fmt("{} + {} = {}", 1, 2, 3))
print("")

// 6. Test for-in with arrays
print("6. For-in with arrays:")
for i in [10, 20, 30] {
  print("  ")
  print(i)
}
print("")

// 7. Test for-in with strings
print("7. For-in with strings:")
for c in "abc" {
  print("  '")
  print(c)
  print("'")
}
print("")

print("=== All Tests Complete ===")
