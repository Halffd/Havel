// Test struct field assignment
struct Point { x: int y: int }
p := Point.new(0, 0)
p.x = 100
p.y = 200
print("Point: " + p.x + ", " + p.y)

// Test type checking
print("type.of(p) = " + type.of(p))
print("type.is(p, 'object') = " + type.is(p, "object"))

// Test with array
arr := [1, 2, 3]
print("type.of(arr) = " + type.of(arr))

// Test with string
s := "hello"
print("type.of(s) = " + type.of(s))
