// gaming.hv - Gaming mode module
// This script will be imported

// Exported functions
export fn start() {
    print("🎮 Gaming mode started")
    brightness(50)
    volume(80)
}

export fn stop() {
    print("🎮 Gaming mode stopped")
    brightness(100)
    volume(50)
}

export let active = false

export fn toggle() {
    active = !active
    if active {
        start()
    } else {
        stop()
    }
}

// Mode definition
mode gaming priority 10 {
    condition = active.exe == "steam.exe" || active.class == "steam"
    enter {
        start()
    }
    exit {
        stop()
    }
}
