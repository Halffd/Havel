let nums = [1, 2, 3, 4, 5]
let double = fn(x) { return x * 2 }

print("Testing map(double):")
let doubled = nums.map(double)
print(doubled)

print("Testing map(lambda):")
let tripled = nums.map(fn(x) { return x * 3 })
print(tripled)

print("Testing filter:")
let even = nums.filter(fn(x) { return x % 2 == 0 })
print(even)

print("Testing method chaining:")
let result = nums.map(fn(x) { return x + 1 }).filter(fn(x) { return x > 3 })
print(result)

print("Testing nested functions:")
fn outer(x) {
  fn inner(y) {
    return x + y
  }
  return inner(10)
}
print(outer(5)) # Expected 15

print("Testing lambda inside function call:")
fn apply(f, x) {
  return f(x)
}
print(apply(fn(x) { return x * x }, 6)) # Expected 36
