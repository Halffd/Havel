// Test the user's script pattern

print("=== Testing User Script Pattern ===\n")

let sys = detectSystem()
print("System detected:")
print("  Display Protocol:", sys.displayProtocol)
print("  Window Manager:", sys.windowManager)

let wl = sys.displayProtocol == "Wayland"
let wm = lower(sys.windowManager)
print("\nNormalized WM:", wm)
print("Is Wayland:", wl)

if wm == "unknown" {
  if process.find("compiz").length > 0 {
    wm = "compiz"
    print("Detected Compiz via process")
  }
}

let hypr = wm == "hyprland"
let kde = wm == "kde plasma"
let kdewl = kde
if !wl {
  kdewl = false
}
let i3 = wm == "i3"
let compiz = wm == "compiz"
let cinnamon = wm == "cinnamon"
let gnome = wm == "gnome" || wm == "gnome on x11" || wm == "gnome on wayland"
let wf = wm == "wayfire"
let xfce = wm == "xfce"
if !xfce {
  if process.find("xfce4-session").length > 0 {
    xfce = true
    print("Detected XFCE via process")
  }
}

print("\nDesktop Environment Detection:")
print("  Hyprland:", hypr)
print("  KDE:", kde)
print("  KDE on Wayland:", kdewl)
print("  i3:", i3)
print("  Compiz:", compiz)
print("  Cinnamon:", cinnamon)
print("  GNOME:", gnome)
print("  Wayfire:", wf)
print("  XFCE:", xfce)

print("\n=== Test Complete ===\n")
