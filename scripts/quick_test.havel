// Quick test of recent fixes
fn main() {
    // Test 1: Closure variable capture (no :: needed)
    display = "test"
    let b = fn() {
        if !(display ~ ".") {
            display = display + "."
        }
    }
    b()
    if display == "test." {
        print("PASS: Closure capture works")
    } else {
        print("FAIL: Closure capture broken")
    }

    // Test 2: Tilde operator (substring search)
    if ("hello" ~ "ell") {
        print("PASS: Tilde substring search works")
    } else {
        print("FAIL: Tilde broken")
    }

    // Test 3: Dot is literal, not regex
    if ("12.3" ~ ".") {
        print("PASS: Dot treated as literal")
    } else {
        print("FAIL: Dot not literal")
    }
}

main()
