// smoke: closure-upvalue-reassign = 99
fn makeSetter():
  x = 10
  fn set(v):
    x = v
  fn get():
    return x
  return [set, get]

pair = makeSetter()
pair[0](99)
val __result = pair[1]()
if __result != 99:
  print("FAIL closure-upvalue-reassign: expected 99, got " + str(__result))
  process.exit(1)
return __result
