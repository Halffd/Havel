// smoke: index-compound-single-eval = 15
fn run() {
    hits = 0
    arr = [1, 2]
    fn getArr() {
        hits += 1
        return arr
    }

    getArr()[1] += 3
    return arr[1] + hits * 10
}
val __result = run()
if __result != 15 {
 print("FAIL index-compound-single-eval: expected 15, got " + str(__result))
 process.exit(1)
}
return __result
