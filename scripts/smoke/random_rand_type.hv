// smoke: random-rand-type = 1
// rand() returns a double in [0, 1)
v = rand()
// If it returns a double, comparing with 0 should work
ok = 1
if v < 0 { ok = 0 }
if v >= 1 { ok = 0 }
val __result = ok
if __result != 1 {
 print("FAIL random-rand-type: expected 1, got " + str(__result))
 process.exit(1)
}
return __result
