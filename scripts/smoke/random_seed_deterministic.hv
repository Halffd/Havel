// smoke: random-seed-deterministic = 1
// Setting seed should make subsequent calls deterministic
random.seed(42)
a = randint(1, 1000)
random.seed(42)
b = randint(1, 1000)
// Same seed must produce same sequence
val __result = a == b ? 1 : 0
if __result != 1 {
 print("FAIL random-seed-deterministic: expected 1, got " + str(__result))
 process.exit(1)
}
return __result
