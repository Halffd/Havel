// Comprehensive test for method call standardization
// Tests all three syntaxes: method, module, pipe

print("=== String Tests ===")
s := "hello world"
result1 := s.upper()
result2 := string.upper(s)
result3 := s | upper
print("Method: " + result1)
print("Module: " + result2)
print("Pipe: " + result3)
assert result1 == result2 && result2 == result3

print("=== Array Tests ===")
arr := [1, 2, 3, 4, 5]
len1 := arr.len()
len2 := array.len(arr)
len3 := arr | len
print("Method len: " + len1)
print("Module len: " + len2)
print("Pipe len: " + len3)
assert len1 == len2 && len2 == len3

print("=== Object Tests ===")
obj := {name: "test", value: 42, active: true}
len1 := obj.len()
len2 := object.len(obj)
len3 := obj | len
print("Method len: " + len1)
print("Module len: " + len2)
print("Pipe len: " + len3)
assert len1 == len2 && len2 == len3

print("=== ALL TESTS PASSED ===")
