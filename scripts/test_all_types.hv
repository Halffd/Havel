// Test standardization across ALL types
// All three syntaxes should work for: string, array, object, struct

print("=== String Tests ===")
s := "hello"
print("Method: " + s.upper())
print("Module: " + string.upper(s))
print("Pipe: " + (s | upper))

print("=== Array Tests ===")
arr := [1, 2, 3]
print("Method len: " + arr.len())
print("Module len: " + array.len(arr))
print("Pipe len: " + (arr | len))

print("=== Object Tests ===")
obj := {name: "test", value: 42}
print("Method len: " + obj.len())
print("Module len: " + object.len(obj))
print("Pipe len: " + (obj | len))

print("=== All Types Standardized ===")
