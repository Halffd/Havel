// Test any() function

print("=== any() Function Tests ===\n")

// Helper function for testing
fn isEven(x) {
  return x % 2 == 0
}

fn isNegative(x) {
  return x < 0
}

// Test 1: any() with array
print("1. any() with array:")
let arr = [1, 2, 3, 4, 5]
print("  any(arr, isEven): ")
print(any(arr, isEven))
print("  any(arr, isNegative): ")
print(any(arr, isNegative))
print("")

// Test 2: any() with range
print("2. any() with range:")
print("  any(1..10, isEven): ")
print(any(1..10, isEven))
print("  any(1..5, isNegative): ")
print(any(1..5, isNegative))
print("")

print("=== Tests Complete ===")
