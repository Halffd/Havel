// Test Async Module - Basic functionality

print("=== Testing Async Module ===\n")

// Test 1: await function exists
print("Test 1: await function\n")
try {
    print("await exists:", await)
} catch e {
    print("await NOT loaded:", e)
}

// Test 2: spawn function
print("\nTest 2: spawn function\n")
try {
    print("spawn exists:", spawn)
} catch e {
    print("spawn NOT loaded:", e)
}

// Test 3: channel function
print("\nTest 3: channel function\n")
try {
    let ch = channel()
    print("channel() works:", ch)
} catch e {
    print("channel NOT loaded:", e)
}

// Test 4: yield function
print("\nTest 4: yield function\n")
try {
    yield()
    print("yield() works")
} catch e {
    print("yield NOT loaded:", e)
}

// Test 5: CancellationTokenSource
print("\nTest 5: CancellationTokenSource\n")
try {
    let cts = CancellationTokenSource()
    print("Initial state:", cts.token.isCancellationRequested())
    
    cts.cancel()
    print("After cancel:", cts.token.isCancellationRequested())
    print("✓ CancellationTokenSource works")
} catch e {
    print("✗ CancellationTokenSource NOT loaded:", e)
}

// Test 6: throwIfCancellationRequested
print("\nTest 6: throwIfCancellationRequested\n")
try {
    let cts2 = CancellationTokenSource()
    throwIfCancellationRequested(cts2.token)
    print("No cancellation - OK")
    
    cts2.cancel()
    try {
        throwIfCancellationRequested(cts2.token)
    } catch cancelErr {
        print("Correctly caught:", cancelErr)
    }
    print("✓ throwIfCancellationRequested works")
} catch e {
    print("✗ Error:", e)
}

// Test 7: withTimeout
print("\nTest 7: withTimeout\n")
try {
    let result = withTimeout(1000, () => {
        return "Completed"
    })
    print("withTimeout result:", result)
    print("✓ withTimeout works")
} catch e {
    print("✗ withTimeout NOT loaded:", e)
}

// Test 8: withCancellation
print("\nTest 8: withCancellation\n")
try {
    let cts3 = CancellationTokenSource()
    let result = withCancellation(cts3.token, () => {
        return "Success"
    })
    print("withCancellation result:", result)
    print("✓ withCancellation works")
} catch e {
    print("✗ withCancellation NOT loaded:", e)
}

// Test 9: sleep
print("\nTest 9: sleep (100ms)\n")
try {
    let start = time()
    sleep(100)
    let end = time()
    print("Slept for approximately:", (end - start) * 1000, "ms")
    print("✓ sleep works")
} catch e {
    print("✗ sleep NOT loaded:", e)
}

print("\n=== Async Module Tests Complete ===\n")
