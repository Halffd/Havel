use ffi

_c = ffi.open("libc.so.6")
if _c == 0 { _c = ffi.open("libc.so") }

_popen = ffi.sym(_c, "popen")
_pclose = ffi.sym(_c, "pclose")
_fgets = ffi.sym(_c, "fgets")

_cs = ffi.cstring("pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null")
_mode = ffi.cstring("r")
_fp = ffi.call(_popen, "pointer", ["pointer", "pointer"], _cs, _mode)
ffi.free(_cs)
ffi.free(_mode)
print("fp: " + str(_fp))

if _fp != 0 {
  _buf = ffi.allocBytes(4096)
  _ret = ffi.call(_fgets, "pointer", ["pointer", "int32", "pointer"], _buf, 4096, _fp)
  if _ret != 0 {
    _s = ffi.string(_buf)
    print("line: " + _s)
  }
  ffi.call(_pclose, "int32", ["pointer"], _fp)
  ffi.free(_buf)
}
