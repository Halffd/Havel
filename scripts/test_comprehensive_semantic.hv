// Comprehensive Semantic Analysis Test

print("=== Comprehensive Semantic Analysis Test ===\n")

// Test 1: Valid declarations
print("Test 1: Valid Declarations\n")
let a = 1
let b = 2
let c = a + b
print("a + b =", c)

// Test 2: Function definition and call
print("\nTest 2: Functions\n")
fn greet(name) {
    print("Hello,", name)
}
greet("World")

// Test 3: Nested scopes
print("\nTest 3: Nested Scopes\n")
let outer = 100
{
    let inner = 200
    print("outer =", outer, "inner =", inner)
}
print("outer still =", outer)

// Test 4: Function with multiple parameters
print("\nTest 4: Multiple Parameters\n")
fn calc(x, y, z) {
    return x * y + z
}
print("calc(2, 3, 4) =", calc(2, 3, 4))

// Test 5: Built-in functions
print("\nTest 5: Built-in Functions\n")
print("math.sqrt(16) =", math.sqrt(16))
print("math.abs(-5) =", math.abs(-5))
print("math.PI =", math.PI)

// Test 6: Conditional execution
print("\nTest 6: Conditionals\n")
let value = 50
if value > 25 {
    print("value is greater than 25")
} else {
    print("value is 25 or less")
}

// Test 7: Loop
print("\nTest 7: Loops\n")
let counter = 0
while counter < 3 {
    print("counter =", counter)
    counter = counter + 1
}

print("\n=== All Tests Passed ===\n")
