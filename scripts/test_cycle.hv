// Test cycle detection

print("=== Cycle Detection Test ===\n")

// Test 1: Normal nested array (should NOT show <cycle>)
print("1. Normal nested array:")
let nested = [[1, 2], [3, 4], [5, 6]]
print("  nested: ")
print(nested)
print("")

// Test 2: Object.entries (creates nested arrays)
print("2. Object entries:")
let obj = {a: 1, b: 2}
let entries = object.entries(obj)
print("  entries: ")
print(entries)
print("")

// Test 3: Self-referential array (SHOULD show <cycle>)
print("3. Self-referential array:")
let selfRef = [1, 2]
selfRef.push(selfRef)
print("  selfRef: ")
print(selfRef)
print("")

// Test 4: Mutual reference (SHOULD show <cycle>)
print("4. Mutual reference:")
let a = [1]
let b = [2]
a.push(b)
b.push(a)
print("  a: ")
print(a)
print("")

print("=== Tests Complete ===")
