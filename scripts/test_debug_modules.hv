// Debug module registration

print("=== Debug Module Loading ===\n")

// Check standard library modules that should always be loaded
print("Checking standard library modules:\n")

// These are loaded directly in loadHostModules
try {
    let arr = [1,2,3]
    arr.sort()
    print("✓ Array module loaded (arr.sort works)")
} catch e {
    print("✗ Array module NOT loaded:", e)
}

try {
    let result = math.sqrt(16)
    print("✓ Math module loaded, sqrt(16)=", result)
} catch e {
    print("✗ Math module NOT loaded:", e)
}

try {
    let upper = "hello".upper()
    print("✓ String module loaded, upper()=", upper)
} catch e {
    print("✗ String module NOT loaded:", e)
}

try {
    let exists = file.exists("/tmp")
    print("✓ File module loaded, /tmp exists=", exists)
} catch e {
    print("✗ File module NOT loaded:", e)
}

print("\n=== Debug Complete ===\n")
