// Test enum runtime support

print("=== Enum Runtime Tests ===\n")

// Test 1: Simple enum variant (no payload)
print("1. Testing simple enum variant:")
let red = newEnum("Color", "Red")
let variant = getVariant(red)
print("  Color.Red variant: ")
print(variant)
print("")

// Test 2: Enum variant with payload
print("2. Testing enum with payload:")
let okResult = newEnum("Result", "Ok", 42)
let okVariant = getVariant(okResult)
print("  Result.Ok variant: ")
print(okVariant)
let payload0 = getPayload(okResult, 0)
print("  Payload[0]: ")
print(payload0)
print("")

// Test 3: Error variant with string payload
print("3. Testing error variant:")
let errResult = newEnum("Result", "Err", "Something went wrong")
let errVariant = getVariant(errResult)
print("  Result.Err variant: ")
print(errVariant)
let errPayload = getPayload(errResult, 0)
print("  Error message: ")
print(errPayload)
print("")

print("=== Enum Tests Complete ===")
