// Test basic generator variable assignment - with debug
fn make_gen() {
  print("[make_gen] Creating generator")
  yield 1
  yield 2
  return 3
}

print("[main] Starting")

fn caller() {
  print("[caller START]")
  let g = make_gen()
  print("[caller] Got generator")
  return g
}

print("[main] Calling caller...")
caller()
print("[main] Done")
