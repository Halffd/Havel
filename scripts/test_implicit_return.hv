// Test Rust-like implicit return

fn add(a, b) {
  a + b
}

fn double(x) {
  x * 2
}

fn greet(name) {
  "Hello, " + name
}

fn nothing() {
  print("Side effect")
}

print("add(2, 3) = ")
print(add(2, 3))

print("double(5) = ")
print(double(5))

print("greet('World') = ")
print(greet("World"))

print("nothing() = ")
print(nothing())
