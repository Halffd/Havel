// Test 'in' and 'not in' operators

print("=== 'in' and 'not in' Tests ===\n")

// Test 1: Array membership
print("1. Array membership:")
let arr = [1, 2, 3]
print("  2 in arr: ")
print(2 in arr)
print("  5 in arr: ")
print(5 in arr)
print("  5 not in arr: ")
print(5 not in arr)
print("")

// Test 2: String membership
print("2. String membership:")
let str = "hello"
print("  'ell' in str: ")
print("ell" in str)
print("  'x' in str: ")
print("x" in str)
print("")

// Test 3: Object key membership
print("3. Object key membership:")
let obj = {"a": 1, "b": 2}
print("  'a' in obj: ")
print("a" in obj)
print("  'c' in obj: ")
print("c" in obj)
print("")

// Test 4: Range membership
print("4. Range membership:")
print("  3 in 1..5: ")
print(3 in 1..5)
print("  6 in 1..5: ")
print(6 in 1..5)
print("  3 in 1..10..2: ")
print(3 in 1..10..2)
print("  4 in 1..10..2: ")
print(4 in 1..10..2)
print("")

print("=== Tests Complete ===")
