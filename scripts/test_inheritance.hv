// Test struct and class basic functionality
struct Point {
  x: int = 0
  y: int = 0
}

// Standalone function for distance calculation
// (struct methods are not supported yet)
fn distance(p1, p2) {
  let dx = p1.x - p2.x
  let dy = p1.y - p2.y
  math.sqrt(dx*dx + dy*dy)
}

p1 = Point(0, 0)
p2 = Point(3, 4)
print("Point 1: " + p1.x + ", " + p1.y)
print("Point 2: " + p2.x + ", " + p2.y)
print("Distance: " + distance(p1, p2))
