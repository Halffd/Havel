// Test 1: Module-level generator (should work)
print("[Test 1] Module-level generator")

fn gen1() {
  yield 1
  yield 2
  return 3
}

let g1 = gen1()
print("Result 1: " + str(g1()))
print("Result 2: " + str(g1()))
print("Result 3: " + str(g1()))

// Test 2: Function that creates a generator (does this work?)
print("\n[Test 2] Generator inside function call")

fn make_gen2() {
  print("[make_gen2] Called")
  return fn() {
    yield "a"
    yield "b"
    return "c"
  }
}

print("[test 2a] Calling make_gen2...")
let gfunc = make_gen2()
print("[test 2b] Got result: " + str(type(gfunc)))

// Now try to invoke it
print("[test 2c] Creating generator...")
let g2 = gfunc()
print("[test 2d] Got generator, calling it...")
print("Result 1: " + str(g2()))
