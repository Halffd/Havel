// Test what modules are actually loaded

print("=== Checking Loaded Modules ===\n")

// Try different module name patterns
let tests = [
    ["window", "Window module"],
    ["Window", "Window module (capital)"],
    ["io", "IO module"],
    ["IO", "IO module (capital)"],
    ["file", "File module"],
    ["File", "File module (capital)"],
    ["string", "String module"],
    ["String", "String module (capital)"],
    ["math", "Math module"],
    ["Math", "Math module (capital)"],
    ["array", "Array module"],
    ["Array", "Array module (capital)"],
    ["process", "Process module"],
    ["Process", "Process module (capital)"],
    ["system", "System module"],
    ["System", "System module (capital)"]
]

for test in tests {
    let name = test[0]
    let desc = test[1]
    try {
        let val = eval(name)
        print("✓", desc, "-", name, "exists")
    } catch e {
        print("-", desc, "-", name, "NOT found")
    }
}

print("\n=== Test Complete ===\n")
