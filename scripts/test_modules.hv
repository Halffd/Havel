    let activeWindow = window.active()
    print("✓ Window module loaded")
} catch e {
    print("✗ Window module not available:", e)
}

// IO module
try {
    print("✓ IO module loaded")
    // Don't actually send keys, just check module exists
} catch e {
    print("✗ IO module not available:", e)
}

// Media module
try {
    print("✓ Media module loaded")
} catch e {
    print("✗ Media module not available:", e)
