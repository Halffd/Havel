// Test new modules: display, config, mode, audio

print("=== Testing New Modules ===\n")

// Test 1: Display module
print("1. Display module:")
let monitorCount = display.getCount()
print("  Monitor count: ")
print(monitorCount)

let monitors = display.getMonitors()
print("  Monitors: ")
print(monitors)

let primary = display.getPrimary()
print("  Primary: ")
print(primary)
print("")

// Test 2: Config module
print("2. Config module:")
let brightness = config.get("General.Brightness", 1.0)
print("  Brightness: ")
print(brightness)

config.set("General.TestValue", "hello", false)
let testVal = config.get("General.TestValue", "default")
print("  Test value: ")
print(testVal)

config.save()
print("  Config saved")
print("")

// Test 3: Mode module
print("3. Mode module:")
let currentMode = mode.current()
print("  Current mode: ")
print(currentMode)

let prevMode = mode.previous()
print("  Previous mode: ")
print(prevMode)
print("")

// Test 4: Audio module
print("4. Audio module:")
let volume = audio.getVolume()
print("  Volume: ")
print(volume)

let muted = audio.isMuted()
print("  Muted: ")
print(muted)
print("")

print("=== Tests Complete ===")
