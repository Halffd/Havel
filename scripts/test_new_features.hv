// Test all new features

print("=== Testing New Features ===\n")

// Test 1: Object methods
print("1. Testing object methods:")
let obj = {}
object.add(obj, "a", 1)
object.add(obj, "b", 2)
object.add(obj, "c", 3)
print("  Object keys: ")
print(object.keys(obj))
print("  Object values: ")
print(object.values(obj))
print("  Object items: ")
print(object.items(obj))

// Remove a key
object.remove(obj, "b")
print("  After removing 'b':")
print("  Keys: ")
print(object.keys(obj))
print("")

// Test 2: type() alias and num type
print("2. Testing type() and num type:")
print("  type(42): ")
print(type(42))
print("  type(3.14): ")
print(type(3.14))
print("  type.is(3.14, 'num'): ")
print(type.is(3.14, "num"))
print("  type.is(3.14, 'float'): ")
print(type.is(3.14, "float"))
print("")

// Test 3: type.of() returns num
print("3. Testing type.of() returns 'num':")
print("  type.of(3.14): ")
print(type.of(3.14))
print("")

print("=== All Tests Complete ===")
