// Test multi-variable iteration with debug

print("=== Object Iteration Debug ===\n")

// Create object
let obj = {"a": 1, "b": 2}
print("Object created")

// Iterate with single variable first
print("\nSingle variable iteration:")
for item in obj {
  print("  item: ")
  print(item)
}

// Iterate with key, value
print("\nMulti-variable iteration:")
for (key, val) in obj {
  print("  key=")
  print(key)
  print(", val=")
  print(val)
}

print("\n=== Done ===")
