#!/usr/bin/env havel
// ============================================================================
// Phase 3 Integration Tests: Coroutines and Yield/Resume
//
// Tests the complete Phase 3 concurrent execution system:
// - Fiber creation and scheduling
// - Yield/resume mechanism
// - State preservation across suspension
// - Generator functions
// - Concurrent generator execution
//
// WARNING: Tests are fake if they don't:
// 1. Call the same generator multiple times
// 2. Verify different values returned each time
// 3. Verify state persists (counter increments)
// 4. Verify dead fiber returns null
//
// ============================================================================

fn test_simple_yield_and_resume() {
    print("Test 1: Simple yield and resume");
    
    // Generator that yields 1, 2, 3, then returns 42
    fn gen() {
        yield 1;
        yield 2;
        yield 3;
        return 42;
    }
    
    // Call generator - returns generator object
    let g = gen();
    
    // Resume generator multiple times
    let v1 = g();  // Should yield 1
    let v2 = g();  // Should yield 2
    let v3 = g();  // Should yield 3
    let v4 = g();  // Should return 42
    let v5 = g();  // Should return null (done)
    
    assert v1 == 1, "First yield should be 1";
    assert v2 == 2, "Second yield should be 2";
    assert v3 == 3, "Third yield should be 3";
    assert v4 == 42, "Return should be 42";
    assert v5 == null, "Dead generator should return null";
    
    print("✓ Test 1 passed");
}

fn test_state_preservation() {
    print("\nTest 2: State preservation across yields");
    
    // Generator that maintains counter state
    fn counter() {
        let count = 0;
        yield count;  // Yield 0
        count = count + 1;
        yield count;  // Yield 1
        count = count + 1;
        yield count;  // Yield 2
        count = count + 1;
        return count;  // Return 3
    }
    
    let g = counter();
    
    // Each call preserves and increments count
    let v1 = g();  // 0
    let v2 = g();  // 1
    let v3 = g();  // 2
    let v4 = g();  // 3
    
    assert v1 == 0, "First value should be 0";
    assert v2 == 1, "Counter should be 1";
    assert v3 == 2, "Counter should be 2";
    assert v4 == 3, "Return should be 3";
    
    print("✓ Test 2 passed");
}

fn test_yield_in_loop() {
    print("\nTest 3: Yield in loop");
    
    // Generator that yields values in a loop
    fn loop_gen() {
        let i = 0;
        while i < 5 {
            yield i;
            i = i + 1;
        }
        return "done";
    }
    
    let g = loop_gen();
    
    // Collect all yields
    let v1 = g();  // 0
    let v2 = g();  // 1
    let v3 = g();  // 2
    let v4 = g();  // 3
    let v5 = g();  // 4
    let v6 = g();  // "done"
    let v7 = g();  // null (dead)
    
    assert v1 == 0, "First loop value should be 0";
    assert v2 == 1, "Second loop value should be 1";
    assert v3 == 2, "Third loop value should be 2";
    assert v4 == 3, "Fourth loop value should be 3";
    assert v5 == 4, "Fifth loop value should be 4";
    assert v6 == "done", "Should return done";
    assert v7 == null, "Dead generator should return null";
    
    print("✓ Test 3 passed");
}

fn test_nested_function_calls() {
    print("\nTest 4: Generator with nested function calls");
    
    fn helper() {
        return 100;
    }
    
    // Generator that calls helper between yields
    fn nested_gen() {
        yield 1;
        let h = helper();
        yield h;
        yield 3;
        return 4;
    }
    
    let g = nested_gen();
    
    let v1 = g();  // 1
    let v2 = g();  // 100 (from helper)
    let v3 = g();  // 3
    let v4 = g();  // 4
    
    assert v1 == 1, "First yield should be 1";
    assert v2 == 100, "Second yield should be 100";
    assert v3 == 3, "Third yield should be 3";
    assert v4 == 4, "Return should be 4";
    
    print("✓ Test 4 passed");
}

fn test_multiple_generators_concurrent() {
    print("\nTest 5: Multiple concurrent generators");
    
    fn gen_a() {
        yield "a1";
        yield "a2";
        return "a_done";
    }
    
    fn gen_b() {
        yield "b1";
        yield "b2";
        yield "b3";
        return "b_done";
    }
    
    let g1 = gen_a();
    let g2 = gen_b();
    
    // Interleave calls to both generators
    let a1 = g1();  // "a1"
    let b1 = g2();  // "b1"
    let a2 = g1();  // "a2"
    let b2 = g2();  // "b2"
    let b3 = g2();  // "b3"
    let a3 = g1();  // "a_done"
    let b4 = g2();  // "b_done"
    let a4 = g1();  // null
    let b5 = g2();  // null
    
    assert a1 == "a1", "Gen A first yield";
    assert b1 == "b1", "Gen B first yield";
    assert a2 == "a2", "Gen A second yield";
    assert b2 == "b2", "Gen B second yield";
    assert b3 == "b3", "Gen B third yield";
    assert a3 == "a_done", "Gen A done";
    assert b4 == "b_done", "Gen B done";
    assert a4 == null, "Gen A dead";
    assert b5 == null, "Gen B dead";
    
    print("✓ Test 5 passed");
}

fn test_dead_fiber_returns_null() {
    print("\nTest 6: Dead fiber returns null");
    
    fn simple_gen() {
        yield 1;
        return 2;
    }
    
    let g = simple_gen();
    
    let v1 = g();  // 1
    let v2 = g();  // 2
    let v3 = g();  // null (dead)
    let v4 = g();  // null (dead)
    let v5 = g();  // null (dead)
    
    assert v1 == 1, "First call should yield";
    assert v2 == 2, "Second call should return";
    assert v3 == null, "Third call should return null";
    assert v4 == null, "Fourth call should return null";
    assert v5 == null, "Fifth call should return null";
    
    print("✓ Test 6 passed");
}

fn test_exception_in_generator() {
    print("\nTest 7: Exception handling in generators");
    
    fn error_gen() {
        yield 1;
        // This should raise an error
        let x = 1 / 0;
        yield 2;
        return 3;
    }
    
    let g = error_gen();
    
    let v1 = g();  // 1 (ok)
    let v2 = g();  // error (1/0)
    
    assert v1 == 1, "First yield should succeed";
    
    // v2 should be an error or null depending on error handling
    // For now, just verify the generator can be called again
    let v3 = g();  // Should handle error gracefully
    
    print("✓ Test 7 passed");
}

fn test_deep_call_stack() {
    print("\nTest 8: Generator with deep call stack");
    
    fn level3() {
        yield 3;
    }
    
    fn level2() {
        yield 2;
        level3();
    }
    
    fn level1() {
        yield 1;
        level2();
        yield 1.5;
    }
    
    fn deep_gen() {
        yield 0;
        level1();
        return "done";
    }
    
    let g = deep_gen();
    
    let v1 = g();  // 0
    let v2 = g();  // 1
    let v3 = g();  // 2
    let v4 = g();  // 3
    let v5 = g();  // Will depend on call chain
    
    assert v1 == 0, "Should yield 0";
    assert v2 == 1, "Should yield 1";
    assert v3 == 2, "Should yield 2";
    assert v4 == 3, "Should yield 3";
    
    print("✓ Test 8 passed");
}

// ============================================================================
// MAIN: Run all tests
// ============================================================================

fn main() {
    print("=== Phase 3 Integration Tests: Coroutines and Yield/Resume ===\n");
    
    test_simple_yield_and_resume();
    test_state_preservation();
    test_yield_in_loop();
    test_nested_function_calls();
    test_multiple_generators_concurrent();
    test_dead_fiber_returns_null();
    test_exception_in_generator();
    test_deep_call_stack();
    
    print("\n=== All Phase 3 tests passed! ===");
}

main();
