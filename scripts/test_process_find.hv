// Test process.find() function

print("=== Testing process.find() ===\n")

// Test 1: Find bash processes
print("Test 1: Find 'bash' processes\n")
let bashProcs = process.find("bash")
print("Found", bashProcs.length, "bash process(es)")
for proc in bashProcs {
    print("  PID:", proc.pid, "Name:", proc.name)
}

// Test 2: Find init/systemd
print("\nTest 2: Find 'systemd' or 'init'\n")
let initProcs = process.find("systemd")
if initProcs.length == 0 {
    initProcs = process.find("init")
}
print("Found", initProcs.length, "init process(es)")
for proc in initProcs {
    print("  PID:", proc.pid, "Name:", proc.name)
}

// Test 3: List all processes (first 5)
print("\nTest 3: List all processes\n")
let allProcs = process.list()
print("Total processes:", allProcs.length)

// Test 4: Find non-existent process
print("\nTest 4: Find non-existent process\n")
let fakeProcs = process.find("this_process_does_not_exist_xyz123")
print("Found", fakeProcs.length, "processes (should be 0)")

print("\n=== Test Complete ===\n")
