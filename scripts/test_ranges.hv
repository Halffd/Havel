// Test range creation and iteration

print("=== Range Tests ===\n")

// Test 1: Simple range 1..5
print("1. Range 1..5:")
for i in 1..5 {
  print("  ")
  print(i)
}
print("")

// Test 2: Range with step 1..10..2
print("2. Range 1..10..2 (step 2):")
for i in 1..10..2 {
  print("  ")
  print(i)
}
print("")

// Test 3: Range in for loop
print("3. Sum of 1..10:")
let sum = 0
for i in 1..10 {
  sum = sum + i
}
print("  Sum = ")
print(sum)
print("")

print("=== Tests Complete ===")
