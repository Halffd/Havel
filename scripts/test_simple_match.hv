// Simple test for multi-value match
fn test_simple() {
    let a = 0
    let b = 0
    
    // Test multi-value match with simple values
    let result = match a, b {
        0, 0 => "both zero"
        0, _ => "first zero"
        _, 0 => "second zero"
        _ => "neither zero"
    }
    
    print("Result: " + result)
}

// Test with single value (backward compatibility)
fn test_single() {
    let x = 5
    let result = match x {
        1 => "one"
        5 => "five"
        _ => "other"
    }
    print("Single match result: " + result)
}

print("Starting tests...")
test_simple()
test_single()
print("Done!")
