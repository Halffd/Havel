# Test sorted objects implementation
# This tests:
# 1. Sorted objects by default ({})
# 2. Unsorted objects (!{})
# 3. Numeric indexing on objects (obj[0], obj[-1])

# Test 1: Sorted object (keys should be sorted alphabetically)
let sorted_obj = {z: 1, a: 2, m: 3}
print("Sorted object keys:")
for k, v in sorted_obj {
  print("  " + k + " = " + v)
}

# Test 2: Unsorted object (keys should maintain insertion order)
let unsorted_obj = !{z: 1, a: 2, m: 3}
print("\nUnsorted object keys (insertion order):")
for k, v in unsorted_obj {
  print("  " + k + " = " + v)
}

# Test 3: Numeric indexing on sorted object
print("\nNumeric indexing on sorted object:")
print("sorted_obj[0] = " + sorted_obj[0])
print("sorted_obj[1] = " + sorted_obj[1])
print("sorted_obj[2] = " + sorted_obj[2])
print("sorted_obj[-1] = " + sorted_obj[-1])  # Last element
print("sorted_obj[-2] = " + sorted_obj[-2])  # Second to last

# Test 4: Numeric indexing on unsorted object
print("\nNumeric indexing on unsorted object:")
print("unsorted_obj[0] = " + unsorted_obj[0])
print("unsorted_obj[1] = " + unsorted_obj[1])
print("unsorted_obj[2] = " + unsorted_obj[2])
print("unsorted_obj[-1] = " + unsorted_obj[-1])

# Test 5: Empty objects
let empty_sorted = {}
let empty_unsorted = !{}
print("\nEmpty objects created successfully")

print("\nAll tests completed!")
