// Test standardization: all three syntaxes should work identically
s := "hello world"

// Method syntax: s.upper()
result1 := s.upper()
print("Method syntax: " + result1)

// Module syntax: string.upper(s)
// This should also route through any.* dispatch now
result2 := string.upper(s)
print("Module syntax: " + result2)

// Pipe syntax: s | upper
result3 := s | upper
print("Pipe syntax: " + result3)

// All three should produce "HELLO WORLD"
if result1 == result2 && result2 == result3 then
    print("SUCCESS: All three syntaxes produce identical results")
else
    print("FAILURE: Results differ")
end
