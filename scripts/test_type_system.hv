// Test Type System Features

print("=== Testing Type System ===\n")

// Test 1: Type declarations (type aliases)
print("Test 1: Type Aliases\n")
type Point = {x: 0, y: 0}
print("Type aliases defined")

// Test 2: Type annotations
print("\nTest 2: Type Annotations\n")
let x = 42
let name = "Alice"
let active = true
print("x:", x, "name:", name, "active:", active)

// Test 3: Function with type annotations
print("\nTest 3: Typed Functions\n")
fn add(a, b) {
    return a + b
}
print("add(3, 5) =", add(3, 5))

// Test 4: Record types
print("\nTest 4: Record Types\n")
let person = {name: "Bob", age: 30}
print("Person:", person.name, person.age)

// Test 5: Union types (basic)
print("\nTest 5: Union Types\n")
// Union types are parsed but currently treated as Any
type Maybe = Nothing | Just(Num)
print("Union type defined")

// Test 6: Function types
print("\nTest 6: Function Types\n")
// Function type annotations work internally
let multiply = fn(a, b) { return a * b }
print("multiply(4, 5) =", multiply(4, 5))

// Test 7: Type references
print("\nTest 7: Type References\n")
// Using previously defined types
let p = {x: 10, y: 20}
print("Point:", p.x, p.y)

// Test 8: Struct vs Type
print("\nTest 8: Struct vs Type Declaration\n")
struct Vec2 {
    x: Num
    y: Num
}
let v = Vec2 { x: 1, y: 2 }
print("Vec2 struct:", v.x, v.y)

// Test 9: Trait declaration
print("\nTest 9: Trait Declaration\n")
trait Drawable {
    fn draw()
}
print("Trait Drawable defined")

// Test 10: Complex type
print("\nTest 10: Complex Type\n")
type Complex = {real: Num, imag: Num}
fn makeComplex(r, i) {
    return {real: r, imag: i}
}
let c = makeComplex(3, 4)
print("Complex:", c.real, c.imag)

print("\n=== Type System Tests Complete ===\n")
