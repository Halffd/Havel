// Test type system and type declarations

print("=== Type System Tests ===\n")

// Test 1: type.of()
print("1. Testing type.of():")
print("  type.of(42): ")
print(type.of(42))
print("  type.of(3.14): ")
print(type.of(3.14))
print("  type.of('hello'): ")
print(type.of("hello"))
let arr = [1,2,3]
print("  type.of(array): ")
print(type.of(arr))
print("")

// Test 2: type.is()
print("2. Testing type.is():")
print("  type.is(42, 'int'): ")
print(type.is(42, "int"))
print("  type.is(3.14, 'float'): ")
print(type.is(3.14, "float"))
print("  type.is('hello', 'string'): ")
print(type.is("hello", "string"))
print("")

// Test 3: Struct declaration
print("3. Testing struct declaration:")
struct Vec2 {
  x: Num
  y: Num
}
print("  Struct Vec2 declared successfully")
print("")

// Test 4: Enum declaration
print("4. Testing enum declaration:")
enum Color {
  Red
  Green
  Blue
}
print("  Enum Color declared successfully")
print("")

// Test 5: Trait declaration
print("5. Testing trait declaration:")
trait Drawable {
  fn draw()
}
print("  Trait Drawable declared successfully")
print("")

// Test 6: implements()
print("6. Testing implements():")
print("  implements(42, 'Drawable'): ")
print(implements(42, "Drawable"))
print("")

print("=== Type Tests Complete ===")
