print("  Complex operations completed in:", end_perf - start_perf, "ms");

// Test 5: Memory Safety Validation
print("Test 5: Memory Safety Validation");
print("  Multiple operations without leaks:");
for_test = 0;
while (for_test < 3) {
    test_arr = [for_test, for_test+1, for_test+2];
    test_result = array.reverse(test_arr);
    test_joined = array.join(test_result, ",");
    for_test = for_test + 1;
}
