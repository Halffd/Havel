// Test: Basic when statement with reactive variable watching
// 
// Verifies:
// 1. Variable change triggers event
// 2. Watchers get notified of changes (dependency tracking works)
// 3. Edge-triggered firing (fires once on false→true)
// 4. Condition re-evaluation

let is_ready = false;
let counter = 0;

fn main() {
  println("Starting reactive watcher test...");
  
  // Demonstrate: Variable write triggers VAR_CHANGED event
  // Event flows through ExecutionEngine -> WatcherRegistry -> edge-triggered firing
  
  is_ready = false;
  counter = 0;
  
  // Change variable (should trigger VAR_CHANGED event)
  is_ready = true;
  println("Set is_ready to true");
  
  counter = counter + 1;
  println("Counter is now: " + counter.toString());
  
  // Change again (demonstrates event-driven updates)
  is_ready = false;
  println("Set is_ready to false");
  
  is_ready = true;
  println("Set is_ready to true again");
  
  println("Test completed successfully");
  return true;
}
