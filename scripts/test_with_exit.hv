// Test array and string VM intrinsics

print("=== Array/String VM Intrinsics Tests ===\n")

// Test 1: Array methods
print("1. Testing array methods:")
let arr = [1, 2, 3]
print("  arr.len(): ")
print(arr.len())
arr.push(4)
print("  After push(4): ")
print(arr)
let popped = arr.pop()
print("  pop() returned: ")
print(popped)
print("  arr.has(2): ")
print(arr.has(2))
print("  arr.find(3): ")
print(arr.find(3))
print("")

// Test 2: String methods
print("2. Testing string methods:")
let str = "  Hello World  "
print("  str.trim(): '")
print(str.trim())
print("'")
print("  str.upper(): '")
print(str.upper())
print("'")
print("  str.lower(): '")
print(str.lower())
print("'")
print("  str.includes('World'): ")
print(str.includes("World"))
print("  str.startswith('  Hello'): ")
print(str.startswith("  Hello"))
print("  str.endswith('World  '): ")
print(str.endswith("World  "))
print("")

print("=== Tests Complete ===")
exit
