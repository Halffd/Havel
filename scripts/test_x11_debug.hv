use ffi
_dpy = ffi.call(ffi.sym(ffi.open("libX11.so.6"), "XOpenDisplay"), "pointer", ["pointer"], 0)
print(_dpy)
if _dpy != 0 {
  _root_fn = ffi.sym(ffi.open("libX11.so.6"), "XDefaultRootWindow")
  _root = ffi.call(_root_fn, "uint64", ["pointer"], _dpy)
  print(_root)
  _focus_ptr = ffi.allocBytes(8)
  _revert_ptr = ffi.allocBytes(4)
  _focus_fn = ffi.sym(ffi.open("libX11.so.6"), "XGetInputFocus")
  ffi.call(_focus_fn, "int32", ["pointer", "pointer", "pointer"], _dpy, _focus_ptr, _revert_ptr)
  _focus = ffi.get_u64(_focus_ptr)
  print(_focus)
  ffi.free(_focus_ptr)
  ffi.free(_revert_ptr)
  ffi.call(ffi.sym(ffi.open("libX11.so.6"), "XCloseDisplay"), "int32", ["pointer"], _dpy)
}
