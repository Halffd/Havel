Mode = mode
mode = lmode = "default"
title_ = ltitle = ""
lclass = class_ = ""
wid = lwid = 0
wpid = lwpid = 0
win = lastWin = null
cmd = lcmd = ""

timeout 35000 {
    print("35 seconds passed, exiting")
    exit(0)
}

Enter if title_ ~ "onsole" => print("Enter pressed in konsole")
when title_ ~ "onsole" {
  print("Konsole is active")
}
when class_ ~ "mpv" {
  print("MPV class is active")
}
when title_ ~ "mpv" {
  print("MPV title is active")
}
when title_ ~ "hatterino" {
  print("Chatterino is active")
}
p if title_ ~ "mpv" => play()
^v if title_ ~ "hatterino" => print("Ctrl+V pressed in chatterino")
+s if mode == "gaming" => {  // Shift+S
  winid = window.active().id
  interval 100 {
    if winid != window.active().id || io.getKey("f") { return }
    send("{enter}")
    sleep(100)
    send("f")
    move(1600, 900)
    click()
  }
}
if cfg?.General == null {
  cfg.General = {}
}
cfg.General.Apps = "steam,lutris,mpv,konsole,hatterino"
fn modeEval (win) {
  titlelower = win.title.lower().trim()
  classlower = win.class.lower().trim()
  cmdlower = win.cmdline.lower().trim()
  apps = cfg.General.Apps.lower().trim().split(",")
  // print("apps: " + apps.join(","))
  if (classlower in apps || titlelower in apps) && !(classlower in cfg.General.GamingExcludeClasses.lower().split(",") || titlelower in cfg.General.GamingExcludeTitles.lower().split(",")) && mode != "gaming" {
    print(f"Gaming mode activated for window: $title_ (class: $class_)")
    mode = "gaming"
  } else if mode != "default" {
    mode = "default"
    print("Leaving mode to default")
  }
}
hotkeyTest = hotkey.register_conditional("a", () => { print "Gaming/mpv mode active" }, () => { res = mode == "gaming" || title_ ~ "mpv"; print("CONDITIONAL mode gaming or mpv:" + res); return res })
hotkeyTest2 = hotkey.register_conditional("b", () => { print "On terminal" }, () => { res = title_ ~ "onsole"; print("CONDITIONAL title onsole:" + res); return res })
dbgWin = 0
hks = null
tickGo = 0
tickOut = 0
print("STARTING GOROUTINE")
go fn update() {
  loop {
    tickGo++
    print("[IN GOROUTINE] tick=$tickGo")
    if(tickGo > 5 && tickOut < 5){
        print("[ERROR] ONLY GOROUTINE RUNNING $tickGo > $tickOut")
        if(tickOut == 0){
            print("[ERROR] OUTSIDE LOOP NEVER RAN $tickOut")
        }
    }
    win = window.active()
    [title_, class_, cmd, wid, wpid] = [win.title, win.class, win.cmdline, win.id, win.pid]
    if wid != lwid {
      [ltitle, lclass, lcmd, lwid, lwpid] = [title_, class_, cmd, wid, wpid]
      modeEval(win)
      if dbgWin {
         print("Active window changed: $title_ class: $class_ mode: $mode cmd: $cmd pid: $wpid id: $wid last: ${lastWin ? lastWin.title_ : "none"}")
      }
      print("hotkeyTest: ", hotkeyTest)
      print("hotkeyTest2: ", hotkeyTest2)
      print("Hotkeys:")
      print(hotkey.list())
      print("Scheduler: ", scheduler.info(), scheduler.goroutines())
    }
    sleep(1000)
  }
}
print("LINE93: STARTING OUTSIDE LOOP")
loop {
    tickOut++
    println("[OUTSIDE GOROUTINE] tick=$tickOut")
    if(tickOut > 20 && tickGo <= 20){
        print("[ERROR] GOROUTINE HANG $tickGo < $tickOut")
    }
    sleep(1000)
}
