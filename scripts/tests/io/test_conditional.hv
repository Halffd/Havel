Mode = mode
mode = lmode = "default"
title_ = ltitle = ""
lclass = class_ = ""
wid = lwid = 0
wpid = lwpid = 0
win = lastWin = null
cmd = lcmd = ""

timeout 35000 {
    print("35 seconds passed, exiting")
    exit(0)
}

enterHk = Enter if title_ ~ "onsole" => print("Enter pressed in konsole")
enter2Hk = ~Enter if !(title_ ~ "onsole") => print("Enter pressed OU8TSIDE konsole")
tHk = #t if true => print("Meta+t pressed")
fHk = +f if false => print("Error")
nHk = !n if 1 + 2 == 4 - 1 => print("Alt+n pressed")
oHk = ~!o if {} == {} => print("Alt+o non-grab pressed")
xHk = |x if #"x" == 1 => print("X non repeat pressed")
assert(tHk.grab == true, "true FAIL")
assert(fHk.grab == false, "false FAIL")
assert(nHk.grab == true, "Arithmetic FAIL")
assert(oHk.grab == true, "Equality FAIL")
assert(xHk.grab == true, "Length FAIL")
when title_ ~ "onsole" {
  print("Konsole is active")
}
when class_ ~ "mpv" {
  print("MPV class is active")
}
when title_ ~ "mpv" {
  print("MPV title is active")
}
when title_ ~ "hatterino" {
  print("Chatterino is active")
}
pHk = p if title_ ~ "mpv" => print("P pressed in mpv")
vHk = ^v if title_ ~ "hatterino" => print("Ctrl+V pressed in chatterino")
+s if mode == "gaming" => {  // Shift+S
  winid = window.active().id
  interval 100 {
    if winid != window.active().id || io.getKey("f") { return }
    send("{enter}")
    sleep(100)
    send("f")
    move(1600, 900)
    click()
  }
}
if cfg?.General == null {
  cfg.General = {}
}
cfg.General.Apps = "steam,lutris,mpv,konsole,hatterino"
fn modeEval (win) {
  titlelower = win.title.lower().trim()
  classlower = win.class.lower().trim()
  cmdlower = win.cmdline.lower().trim()
  apps = cfg.General.Apps.lower().trim().split(",")
  // print("apps: " + apps.join(","))
  if (classlower in apps || titlelower in apps) && !(classlower in cfg.General.GamingExcludeClasses.lower().split(",") || titlelower in cfg.General.GamingExcludeTitles.lower().split(",")) && mode != "gaming" {
    print(f"Gaming mode activated for window: $title_ (class: $class_)")
    mode = "gaming"
  } else if mode != "default" {
    mode = "default"
    print("Leaving mode to default")
  }
}
condGaming = () => { res = mode == "gaming" || title_ ~ "mpv"; print("CONDITIONAL mode gaming or mpv:" + res); return res }
condConsole = () => { res = title_ ~ "onsole"; print("CONDITIONAL title onsole:" + res); return res }
hotkeyTest = hotkey.register_conditional("a", () => { print "Gaming/mpv mode active" }, condGaming)
hotkeyTest2 = hotkey.register_conditional("b", () => { print "On terminal" }, condConsole)
fn test() {
    print("title: $title_")
    print("UNCONDITIONAL P PRRESSED, CONDITIONAL P STATUS: ", pHk)
    print("hotkeyTest: ", hotkeyTest)
    print("hotkeyTest2: ", hotkeyTest2)
    print("enterHk: ", enterHk)
    print("enter2Hk: ", enter2Hk)
    if title_ ~ "hatterino" && (!vHk.enabled || !vHk.grab) {
        print("ERROR [^v] - IN WINDOW BUT ^v NOT ENABLED")
    }
    if title_ ~ "onsole" && (!enterHk.enabled || !enterHk.grab) {
        print("ERROR [Enter] - IN WINDOW BUT ENTER NOT ENABLED")
    }

    if !(title_ ~ "onsole") && (!enter2Hk.enabled || !enter2Hk.grab) {
        print("ERROR [Enter] - OUTSIDE WINDOW BUT ~ENTER NOT ACTIVE")
    }
    if title_ ~ "onsole" && enter2Hk.grab {
        print("ERROR [Enter] - IN WINDOW BUT ~ENTER IS GRABBING")
    }
    if title_ ~ "mpv" && (!pHk.enabled || !pHk.grab) {
        print("ERROR [p] - IN MPV BUT P HOTKEY NOT ENABLED")
    }
    if condGaming() && (!hotkeyTest.enabled || !hotkeyTest.grab) {
        print("ERROR [a] CONDITION hotkeyTest NOT WORKING")
    }
    if condConsole() && (!hotkeyTest2.enabled || !hotkeyTest2.grab) {
        print("ERROR [b] CONDITION hotkeyTest2 NOT WORKING")
    }

    print("")
}
o => test()
dbgWin = 0
hks = null
tick = 0
fn onTick() {
    print("[UPDATE] tick=$tick")
    win = window.active()
    [title_, class_, cmd, wid, wpid] = [win.title, win.class, win.cmdline, win.id, win.pid]
    if wid != lwid {
      [ltitle, lclass, lcmd, lwid, lwpid] = [title_, class_, cmd, wid, wpid]
      modeEval(win)
      if dbgWin {
         print("Active window changed: $title_ class: $class_ mode: $mode cmd: $cmd pid: $wpid id: $wid last: ${lastWin ? lastWin.title_ : "none"}")
      }
      print("Hotkeys:")
      print(hotkey.list())
      test()
    }
}
print("STARTING MAIN LOOP")
loop {
    tick++
    println("[LOOP] tick=$tick")
    onTick()
    sleep(1000)
}
