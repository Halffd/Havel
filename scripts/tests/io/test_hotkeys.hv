hotkey.register("p", fn() {
    print("pressed P")
    interval 1000 {
        print(time.now())
    }
})
a => {
    print "hello"
    print(go fn(){
        i = 0
        loop {
            print(i)
            i += 1
            if i > 100 {
                return i
            }
        }
    })
}
b => {
  try {
      print(rand())
      print 1/0
  } catch e {
    if type e == 'string'
       return
    print e
  }
  interval 500 {
    print("hello", z)
  }
}
z = 0
c => {
    if 1 > 0 {
       print 1 > 0
    } else  {
       print 0
    }
    loop {
      z++
      print z
      sleep(100)
    }
}
!d => io.send("#d")
RShift => {
  print 'zoom'
  while z > 0 {
    z -= 3
    print "-$z"
    sleep(80)
  }
}
// dhk  assigned below
dhk=d => {
  print @id
  print @alias
  print @key
  @disable()
  print "hotkey disabled"
}
