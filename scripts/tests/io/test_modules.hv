print("IO getKey Ctrl: " + io.getKey("Ctrl"))
print("IO getKey Alt: " + io.getKey("Alt"))
print("IO getKey E: " + io.getKey("E"))
io.sendKey("E", "up")
io.sendKey("Alt", "up")
io.sendKey("Ctrl", "up")
io.setLock("CapsLock", false)
print("IO locks after unsetting CapsLock: " + io.locks())
print("IO getKey Ctrl: " + io.getKey("Ctrl"))
print("IO getKey Alt: " + io.getKey("Alt"))
print("IO getKey E: " + io.getKey("E"))
io.sendKey("Shift", "down")
io.sendKey("A", "down")
print("IO state after sending Shift+A: " + io.state())
io.reset()
print("IO state after reset: " + io.state())
io.send("Hello, world!")
