mouseAcc = 1
mouseStep = 10
fn moveMouse (dx, dy) {
  print(time.now())
  print(f"moveMouse called with dx: $dx, dy: $dy, current mouseAcc: $mouseAcc")
  print("Mouse position before move: " + mouse.pos())
  mouse.moveRel(dx * mouseStep * mouseAcc, dy * mouseStep * mouseAcc)
  mouseAcc = mouseAcc + 1
  if mouseAcc > 10 { mouseAcc = 10 }
  print("Mouse moved to " + mouse.pos() + " with acceleration " + mouseAcc)
  print(time.now())
  print("moveMouse finished " + mouse.pos())
}
moveMouse(10, 0)
moveMouse(0, 10)
moveMouse(-10, 0)
moveMouse(0, -10)
moveMouse(5000, 5)
print("left click down")
mouse.down(1)
print("Mouse state: " + io.getKey("LButton"))

print("left click up")
mouse.up(1)
print("Mouse state: " + io.getKey("LButton"))
print("Mouse position: " + mouse.pos())
print("Scrolling, type(mouse.scroll) is " + type(mouse.scroll))
mouse.scroll(0, 1)
mouse.scroll(0, -1)
mouse.scroll(1, 0)
mouse.scroll(-1, 0)

print("Brightness and color temperature control")
b = "1.0"
sl = "0.0"
gr = "1.0"
gg = "1.0"
gb = "1.0"
temp = "6500"
print("Resetting brightness to defaults: " + b + " " + sl + " " + gr + " " + gg + " " + gb + " " + temp)
brightness.set(num(b))
brightness.setShadowLift(num(sl))
brightness.setGammaRGB(num(gr), num(gg), num(gb))
brightness.setTemperature(int(temp))

print("Current brightness: " + brightness.get() + " ShadowLift: " + brightness.getShadowLift() + " GammaR: " + brightness.getGammaR() + " GammaG: " + brightness.getGammaG() + " GammaB: " + brightness.getGammaB() + " Temperature: " + brightness.getTemperature())

print("Brightness increase requested")
print("Brightness before change: ")
print(brightness.get())
brightness.increase(0.05)
print("Brightness after change: ")
print(brightness.get())
print("Brightness decrease requested")
brightness.decrease(0.05)
print("Brightness after decrease: ")
print(brightness.get())
print("type of brightness: " + type(brightness) + ", type of brightness.get: " + type(brightness.get) + ", type of brightness.increase: " + type(brightness.increase) + ", type of brightness.decrease: " + type(brightness.decrease) + ", type of brightness.set: " + type(brightness.set) + ", type of brightness.getShadowLift: " + type(brightness.getShadowLift) + ", type of brightness.setShadowLift: " + type(brightness.setShadowLift) + ", type of brightness.getGammaR: " + type(brightness.getGammaR) + ", type of brightness.setGammaRGB: " + type(brightness.setGammaRGB) + ", type of brightness.getTemperature: " + type(brightness.getTemperature) + ", type of brightness.setTemperature: " + type(brightness.setTemperature))
print(brightness)

sl = brightness.getShadowLift()
print("Current ShadowLift: " + sl)
print("ShadowLift increase requested")
brightness.increaseShadowLift(0.05)
print("ShadowLift after increase: " + brightness.getShadowLift())
print("ShadowLift decrease requested")
brightness.decreaseShadowLift(0.05)
print("ShadowLift after decrease: " + brightness.getShadowLift())
sl = brightness.getShadowLift()
brightness.setShadowLift(sl - 0.05)
print("ShadowLift after decrease: " + brightness.getShadowLift())
// temperature
temp = brightness.getTemperature()
print("Current color temperature: " + temp)
print("Color temperature increase requested")
brightness.increaseTemperature(500)
print("Color temperature after increase: " + brightness.getTemperature())
print("Color temperature decrease requested")
brightness.decreaseTemperature(500)
print("Color temperature after decrease: " + brightness.getTemperature())
temp = brightness.getTemperature()
brightness.setTemperature(temp - 500)
print("Color temperature after decrease: " + brightness.getTemperature())
// get brightness and set it directly
b = brightness.get()
print("Current brightness: " + b)
brightness.set(b - 0.05)
print("Brightness after decrease: " + brightness.get())

