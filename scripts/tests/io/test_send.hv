fn msH(ms) {
    ms / 3600000.0
}
fn hMs(h) { h * 3600000.0 }

delayH = 0.0
delayM = 0.0
delayS = 1.0
delayMs = 0.0
delay = (delayH * 3600000) + (delayM * 60000) + (delayS * 1000) + delayMs
print("delay: ", delay )

pr = [
1,
2,
"abc{Enter}${"abcd".len()}",
"""fn f($delay)
      print ${2 * 5 / 2}""",
3
]
it = #pr - 1
print(it)
totH = 12
limH = totH / msH(delay)
print(it, limH, delay)
if it > limH {
    print("Too many, limiting to ", limH)
    it = limH
}
for i in 0..it {
    print(i, ": ", pr[i])
}
prmap = {
    "1": "continue",
    "2": "build",
    "3": "test"
}
fn xx(h, p){
    sc = h
 sleep(sc)
// sleep(9000)
 send("{enter}")
 if clipboard == null {
    run("echo \"$p\" | xargs -0 printf '%q' | xclip -selection clipboard")
 } else {
    clipboard.set(p)
 }
 send("^+v")
// send("!{left}")
// sleep(1000)
// send("{enter}")
}
for i in 0..it {
    p = pr[i]
    if type(p) == "number" {
        if p > 0 && p < 11 {
           p = prmap[p]
        }
    }
    print(i, " : ", p)
    xx(delay, p)
}
send("end{enter}")
send("{lalt:down}{left}{lalt:up}")
send("^{a}")
send("!{Backspace}")
