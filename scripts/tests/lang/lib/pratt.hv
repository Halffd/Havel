// Havel Pratt parser — pure Havel implementation
// Top-down operator precedence parser matching the C++ Parser.cpp architecture
// Consumes token list from lexer.hv, produces AST nodes from ast.hv

use { tokenize, TOKEN_TYPES, KEYWORDS } from "lexer"
use { NODE_TYPES, BINARY_OPS, COMPOUND_ASSIGN_OPS, UNARY_OPS,
      Program, BlockStatement, ExpressionStatement,
      NumberLiteral, StringLiteral, BooleanLiteral, NullLiteral,
      Identifier, BinaryExpression, UnaryExpression, UpdateExpression,
      CallExpression, MemberExpression, IndexExpression,
      AssignmentExpression, CompoundAssignment,
      ArrayLiteral, ObjectLiteral, ObjectField, SpreadExpression,
      IfStatement, WhileStatement, ForStatement, LoopStatement,
      RepeatStatement, BreakStatement, ContinueStatement,
      FnDeclaration, LambdaExpression, ReturnStatement,
      LetDeclaration, ValDeclaration, UseStatement, ImportStatement,
      HotkeyBinding, BacktickExpression, ShellCommand,
      RangeExpression, TernaryExpression, PipelineExpression,
      ThrowStatement, TryStatement, MatchExpression, MatchCase,
      InterpolatedString, RegexLiteral, AtExpression, AtAtExpression,
      ConfigBlock, SleepStatement, ErrorNode,
      isNode, prettyPrint } from "ast"

// --- Binding power constants (matching C++ switch-based values) ---
BP_NONE = 0
BP_ASSIGN = 10
BP_NULLISH = 20
BP_QUESTION = 15
BP_OR = 30
BP_AND = 40
BP_EQUALITY = 50
BP_NOT_IN = 52
BP_IN = 55
BP_COMPARISON = 60
BP_RANGE = 70
BP_ADD = 70
BP_PIPE = 75
BP_BITWISE_OR = 80
BP_BITWISE_XOR = 90
BP_BITWISE_AND = 100
BP_SHIFT = 110
BP_MUL = 130
BP_POWER = 135
BP_POSTFIX = 150
BP_CALL_MEMBER = 170

// --- getBindingPower: left binding power for each token type ---
fn getBindingPower(ttype):
    if ttype == "Assign": BP_ASSIGN
    else if ttype == "PlusAssign": BP_ASSIGN
    else if ttype == "MinusAssign": BP_ASSIGN
    else if ttype == "MultiplyAssign": BP_ASSIGN
    else if ttype == "DivideAssign": BP_ASSIGN
    else if ttype == "ModuloAssign": BP_ASSIGN
    else if ttype == "PowerAssign": BP_ASSIGN
    else if ttype == "BackslashAssign": BP_ASSIGN
    else if ttype == "DoubleModuloAssign": BP_ASSIGN
    else if ttype == "BitwiseAndAssign": BP_ASSIGN
    else if ttype == "BitwiseOrAssign": BP_ASSIGN
    else if ttype == "BitwiseXorAssign": BP_ASSIGN
    else if ttype == "ShiftLeftAssign": BP_ASSIGN
    else if ttype == "ShiftRightAssign": BP_ASSIGN
    else if ttype == "Nullish": BP_NULLISH
    else if ttype == "Question": BP_QUESTION
    else if ttype == "Or": BP_OR
    else if ttype == "And": BP_AND
    else if ttype == "Equals": BP_EQUALITY
    else if ttype == "NotEquals": BP_EQUALITY
    else if ttype == "Is": BP_EQUALITY
    else if ttype == "Tilde": BP_EQUALITY
    else if ttype == "Matches": BP_EQUALITY
    else if ttype == "In": BP_IN
    else if ttype == "Less": BP_COMPARISON
    else if ttype == "Greater": BP_COMPARISON
    else if ttype == "LessEquals": BP_COMPARISON
    else if ttype == "GreaterEquals": BP_COMPARISON
    else if ttype == "DotDot": BP_RANGE
    else if ttype == "Plus": BP_ADD
    else if ttype == "Minus": BP_ADD
    else if ttype == "Pipe": BP_PIPE
    else if ttype == "PipeRight": BP_PIPE
    else if ttype == "BitwiseOr": BP_BITWISE_OR
    else if ttype == "BitwiseXor": BP_BITWISE_XOR
    else if ttype == "BitwiseAnd": BP_BITWISE_AND
    else if ttype == "ShiftLeft": BP_SHIFT
    else if ttype == "ShiftRight": BP_SHIFT
    else if ttype == "Multiply": BP_MUL
    else if ttype == "Divide": BP_MUL
    else if ttype == "Modulo": BP_MUL
    else if ttype == "Backslash": BP_MUL
    else if ttype == "DoubleBackslash": BP_MUL
    else if ttype == "DoubleModulo": BP_MUL
    else if ttype == "Power": BP_POWER
    else if ttype == "PlusPlus": BP_POSTFIX
    else if ttype == "MinusMinus": BP_POSTFIX
    else if ttype == "Dot": BP_CALL_MEMBER
    else if ttype == "QuestionDot": BP_CALL_MEMBER
    else if ttype == "OpenParen": BP_CALL_MEMBER
    else if ttype == "OpenBracket": BP_CALL_MEMBER
    else if ttype == "Arrow": BP_ASSIGN
    else if ttype == "LeftArrow": BP_ASSIGN
    else if ttype == "Not":
        // infix 'not in' — only when followed by 'in'
        52
    else: BP_NONE

// --- getRightBindingPower: lower rbp for right-associative operators ---
fn getRightBindingPower(ttype):
    if ttype == "Assign": 5
    else if ttype == "PlusAssign": 5
    else if ttype == "MinusAssign": 5
    else if ttype == "MultiplyAssign": 5
    else if ttype == "DivideAssign": 5
    else if ttype == "ModuloAssign": 5
    else if ttype == "PowerAssign": 5
    else if ttype == "BackslashAssign": 5
    else if ttype == "DoubleModuloAssign": 5
    else if ttype == "BitwiseAndAssign": 5
    else if ttype == "BitwiseOrAssign": 5
    else if ttype == "BitwiseXorAssign": 5
    else if ttype == "ShiftLeftAssign": 5
    else if ttype == "ShiftRightAssign": 5
    else if ttype == "LeftArrow": 5
    else if ttype == "Arrow": 5
    else if ttype == "Power": 130
    else if ttype == "Nullish": 15
    else if ttype == "Question": 10
    else: getBindingPower(ttype)

// --- Compound assign token set ---
COMPOUND_ASSIGN_TOKENS = {
    "PlusAssign": "+=",
    "MinusAssign": "-=",
    "MultiplyAssign": "*=",
    "DivideAssign": "/=",
    "ModuloAssign": "%=",
    "PowerAssign": "**=",
    "BackslashAssign": "\\=",
    "DoubleModuloAssign": "%%=",
    "BitwiseAndAssign": "&=",
    "BitwiseOrAssign": "|=",
    "BitwiseXorAssign": "^=",
    "ShiftLeftAssign": "<<=",
    "ShiftRightAssign": ">>=",
}

// --- Token types that can start an expression (have nud) ---
NUD_TOKENS = {
    "Number": true,
    "String": true,
    "MultilineString": true,
    "InterpolatedString": true,
    "RegexString": true,
    "RegexLiteral": true,
    "Backtick": true,
    "InterpolatedBacktick": true,
    "Identifier": true,
    "True": true,
    "False": true,
    "Null": true,
    "OpenParen": true,
    "OpenBracket": true,
    "OpenBrace": true,
    "BangOpenBrace": true,
    "Not": true,
    "Minus": true,
    "Plus": true,
    "PlusPlus": true,
    "MinusMinus": true,
    "Length": true,
    "At": true,
    "AtAt": true,
    "ColonColon": true,
    "Fn": true,
    "Match": true,
    "If": true,
    "Class": true,
    "Struct": true,
    "Enum": true,
    "Mode": true,
    "Val": true,
    "Const": true,
    "Let": true,
    "Config": true,
    "Devices": true,
    "ShellCommand": true,
    "ShellCommandCapture": true,
    "SuperArrow": true,
}

// --- Keywords allowed as identifiers in expression context ---
KEYWORD_IDENTS = {
    "Class": true,
    "Struct": true,
    "Enum": true,
    "Mode": true,
    "Val": true,
    "Const": true,
    "Let": true,
    "Config": true,
    "Devices": true,
    "On": true,
    "Off": true,
    "When": true,
    "Timeout": true,
    "Thread": true,
    "Interval": true,
    "Channel": true,
    "Co": true,
    "Go": true,
    "Fn": true,
    "If": true,
    "For": true,
    "Loop": true,
    "While": true,
    "Switch": true,
    "Do": true,
    "Return": true,
    "Ret": true,
    "Break": true,
    "Continue": true,
    "Try": true,
    "Catch": true,
    "Finally": true,
    "Throw": true,
    "Del": true,
    "True": true,
    "False": true,
    "Null": true,
    "Repeat": true,
}

// --- Token types that are infix/postfix operators (have led) ---
LED_TOKENS = {
    "Assign": true,
    "PlusAssign": true,
    "MinusAssign": true,
    "MultiplyAssign": true,
    "DivideAssign": true,
    "ModuloAssign": true,
    "PowerAssign": true,
    "BackslashAssign": true,
    "DoubleModuloAssign": true,
    "BitwiseAndAssign": true,
    "BitwiseOrAssign": true,
    "BitwiseXorAssign": true,
    "ShiftLeftAssign": true,
    "ShiftRightAssign": true,
    "LeftArrow": true,
    "Nullish": true,
    "Question": true,
    "Or": true,
    "And": true,
    "Equals": true,
    "NotEquals": true,
    "Is": true,
    "Tilde": true,
    "Matches": true,
    "In": true,
    "Not": true,
    "Less": true,
    "Greater": true,
    "LessEquals": true,
    "GreaterEquals": true,
    "DotDot": true,
    "DotDotEquals": true,
    "Plus": true,
    "Minus": true,
    "Pipe": true,
    "PipeRight": true,
    "BitwiseOr": true,
    "BitwiseXor": true,
    "BitwiseAnd": true,
    "ShiftLeft": true,
    "ShiftRight": true,
    "Multiply": true,
    "Divide": true,
    "Modulo": true,
    "Backslash": true,
    "DoubleBackslash": true,
    "DoubleModulo": true,
    "Power": true,
    "PlusPlus": true,
    "MinusMinus": true,
    "Dot": true,
    "QuestionDot": true,
    "OpenParen": true,
    "OpenBracket": true,
    "Arrow": true,
}

// --- Expression tokens (for implicit call sugar detection) ---
IMPLICIT_CALL_STARTERS = {
    "String": true,
    "MultilineString": true,
    "RegexString": true,
    "Number": true,
    "Identifier": true,
    "InterpolatedString": true,
    "InterpolatedBacktick": true,
    "At": true,
    "AtAt": true,
    "Not": true,
    "Length": true,
}

// ===================================================================
// Parser object — encapsulates parsing state
// ===================================================================
fn Parser(tokenList):
    tokens = tokenList
    pos = 0
    errors = []
    inMatchExpr = false
    allowBraceSugar = true

    // --- Token access ---
    fn at(offset):
        i = pos + offset
        if i < 0: i = 0
        if i < tokens.len: tokens[i]
        else: {type: "EOF", value: "", line: 0, col: 0}

    fn current():
        at(0)

    fn advance():
        if pos < tokens.len:
            t = tokens[pos]
            pos = pos + 1
            t
        else:
            {type: "EOF", value: "", line: 0, col: 0}

    fn notEOF():
        pos < tokens.len and current().type != "EOF"

    fn expect(ttype):
        t = current()
        if t.type == ttype:
            advance()
        else:
            error("Expected " + ttype + " but got " + t.type, t.line, t.col)

    fn expectValue(ttype, expectedVal):
        t = current()
        if t.type == ttype and t.value == expectedVal:
            advance()
        else:
            error("Expected " + ttype + " '" + expectedVal + "' but got " + t.type, t.line, t.col)

    // --- Newline skipping ---
    fn skipNewlines():
        while current().type == "NewLine":
            advance()

    fn skipNewlinesAndSemicolons():
        while current().type == "NewLine" or current().type == "Semicolon":
            advance()

    // --- Error handling ---
    fn error(msg, line, col):
        errors.push({msg: msg, line: line, col: col})
        ErrorNode(msg, line, col)

    fn parseError(msg):
        t = current()
        error(msg, t.line, t.col)

    // --- Token classification ---
    fn canStartExpr(ttype):
        NUD_TOKENS.has(ttype)

    fn isLed(ttype):
        LED_TOKENS.has(ttype)

    fn isKeywordIdent(ttype):
        KEYWORD_IDENTS.has(ttype)

    // --- Check if 'not' is infix (followed by 'in') ---
    fn isNotIn():
        current().type == "Not" and at(1).type == "In"

    // ===================================================================
    // PRATT EXPRESSION PARSER
    // ===================================================================
    fn parseExpr(rbp):
        startToken = current()
        tok = advance()

        left = nud(tok)

        if left == null:
            return error("Unexpected token " + tok.type, startToken.line, startToken.col)

        if left.kind == "ErrorNode":
            return left

        iterations = 0
        while true:
            iterations = iterations + 1
            if iterations > 10000:
                return error("Pratt loop exceeded", startToken.line, startToken.col)

            curType = current().type
            bp = getBindingPower(curType)

            // Special: 'not' only acts as infix when followed by 'in'
            if curType == "Not" and !isNotIn():
                break

            // Special: Arrow returns 0 in match context
            if curType == "Arrow" and inMatchExpr:
                break

            if bp == BP_NONE or rbp >= bp:
                break

            opToken = advance()
            left = led(opToken, left)

            if left == null:
                return error("Failed to parse infix " + opToken.type, opToken.line, opToken.col)
            if left.kind == "ErrorNode":
                return left

        // Implicit call sugar: expr "string" -> expr("string")
        if allowBraceSugar and IMPLICIT_CALL_STARTERS.has(current().type):
            prevSugar = allowBraceSugar
            allowBraceSugar = false
            arg = parseExpr(0)
            allowBraceSugar = prevSugar

            if arg == null or arg.kind == "ErrorNode":
                return arg

            args = [arg]
            while current().type == "Comma":
                advance()
                nextArg = parseExpr(0)
                if nextArg == null or nextArg.kind == "ErrorNode":
                    return nextArg
                args.push(nextArg)

            left = CallExpression(left, args, startToken.line, startToken.col)

        left

    // ===================================================================
    // NULL DENOTATION (nud) — tokens that start expressions
    // ===================================================================
    fn nud(tok):
        tt = tok.type
        l = tok.line
        c = tok.col

        if tt == "Number":
            numVal = tok.value
            if numVal.has(".") or numVal.has("e") or numVal.has("E"):
                NumberLiteral(num(numVal), l, c)
            else:
                NumberLiteral(int(numVal), l, c)

        else if tt == "String" or tt == "MultilineString":
            StringLiteral(tok.value, l, c)

        else if tt == "RegexString":
            StringLiteral(tok.value, l, c)

        else if tt == "RegexLiteral":
            // value contains pattern + flags after the closing /
            parts = tok.value.split("/")
            // parts[0] is empty (before first /), parts[1] is pattern, parts[2] is flags
            pattern = ""
            flags = ""
            if parts.len >= 2: pattern = parts[1]
            if parts.len >= 3: flags = parts[2]
            RegexLiteral(pattern, flags, l, c)

        else if tt == "Backtick":
            if tok.value.has("{") or tok.value.has("$"):
                ShellCommand(tok.value, false, l, c)
            else:
                BacktickExpression(tok.value, l, c)

        else if tt == "InterpolatedBacktick":
            ShellCommand(tok.value, true, l, c)

        else if tt == "ShellCommand":
            ShellCommand(tok.value, false, l, c)

        else if tt == "ShellCommandCapture":
            ShellCommand(tok.value, true, l, c)

        else if tt == "InterpolatedString":
            parseInterpolatedString(tok.value, l, c)

        else if tt == "Identifier" or isKeywordIdent(tt):
            Identifier(tok.value, l, c)

        else if tt == "True":
            BooleanLiteral(true, l, c)

        else if tt == "False":
            BooleanLiteral(false, l, c)

        else if tt == "Null":
            NullLiteral(l, c)

        else if tt == "OpenParen":
            parseParenExpr(tok)

        else if tt == "OpenBracket":
            // Pratt already consumed '[', but parseArrayLiteral expects to consume it
            pos = pos - 1
            parseArrayLiteral()

        else if tt == "OpenBrace":
            // Pratt already consumed '{', but parseObjectLiteral expects to consume it
            pos = pos - 1
            disambiguateBrace()

        else if tt == "BangOpenBrace":
            // !{key: value} unsorted object literal
            parseObjectLiteral(true)

        else if tt == "Not":
            // Check for !{} unsorted object
            if current().type == "OpenBrace":
                parseObjectLiteral(true)
            else:
                operand = parseExpr(140)
                UnaryExpression("not", operand, l, c)

        else if tt == "Minus":
            operand = parseExpr(140)
            UnaryExpression("-", operand, l, c)

        else if tt == "Plus":
            parseExpr(140)

        else if tt == "PlusPlus":
            operand = parseExpr(140)
            UpdateExpression(operand, "++", true, l, c)

        else if tt == "MinusMinus":
            operand = parseExpr(140)
            UpdateExpression(operand, "--", true, l, c)

        else if tt == "Length":
            operand = parseExpr(140)
            UnaryExpression("#", operand, l, c)

        else if tt == "At":
            if current().type == "Identifier":
                field = advance()
                AtExpression(field.value, l, c)
            else:
                error("Expected field name after '@'", l, c)

        else if tt == "AtAt":
            if current().type == "Identifier":
                field = advance()
                AtAtExpression(field.value, l, c)
            else:
                error("Expected field name after '@@'", l, c)

        else if tt == "ColonColon":
            // :: global scope identifier
            if current().type == "Identifier":
                ident = advance()
                node = Identifier(ident.value, l, c)
                node.globalScope = true
                node
            else:
                error("Expected identifier after '::'", l, c)

        else if tt == "Fn":
            parseLambdaExpr()

        else if tt == "Match":
            parseMatchExpr()

        else if tt == "If":
            parseIfExpr()

        else if tt == "SuperArrow":
            // @->method — super call
            if current().type == "Identifier":
                methodName = advance().value
                node = Identifier("__super__", l, c)
                node.isSuperCall = true
                node.superMethodName = methodName
                // Parse arguments if present
                if current().type == "OpenParen":
                    advance()
                    args = []
                    skipNewlines()
                    while current().type != "CloseParen" and notEOF():
                        skipNewlines()
                        if current().type == "CloseParen": break
                        args.push(parseExpr(0))
                        skipNewlines()
                        if current().type == "Comma": advance()
                    expect("CloseParen")
                    CallExpression(node, args, l, c)
                else:
                    node
            else:
                error("Expected method name after '@->'", l, c)

        else:
            error("Unexpected token in expression: " + tt, l, c)

    // ===================================================================
    // LEFT DENOTATION (led) — infix and postfix operators
    // ===================================================================
    fn led(tok, left):
        tt = tok.type
        l = tok.line
        c = tok.col

        // Assignment operators
        if tt == "Assign":
            right = parseExpr(getRightBindingPower("Assign"))
            if right == null: return error("Expected value after '='", l, c)
            if right.kind == "ErrorNode": return right
            AssignmentExpression(left, right, l, c)

        else if COMPOUND_ASSIGN_TOKENS.has(tt):
            right = parseExpr(getRightBindingPower(tt))
            if right == null: return error("Expected value after compound assign", l, c)
            if right.kind == "ErrorNode": return right
            CompoundAssignment(left, COMPOUND_ASSIGN_TOKENS[tt], right, l, c)

        else if tt == "LeftArrow":
            // await-assign: x <- expr
            right = parseExpr(getRightBindingPower("LeftArrow"))
            if right == null: return error("Expected value after '<-'", l, c)
            if right.kind == "ErrorNode": return right
            AssignmentExpression(left, right, l, c)

        // Binary operators
        else if tt == "Plus":
            right = parseExpr(getRightBindingPower("Plus"))
            BinaryExpression(left, "+", right, l, c)

        else if tt == "Minus":
            right = parseExpr(getRightBindingPower("Minus"))
            BinaryExpression(left, "-", right, l, c)

        else if tt == "Multiply":
            right = parseExpr(getRightBindingPower("Multiply"))
            BinaryExpression(left, "*", right, l, c)

        else if tt == "Divide":
            right = parseExpr(getRightBindingPower("Divide"))
            BinaryExpression(left, "/", right, l, c)

        else if tt == "Modulo":
            right = parseExpr(getRightBindingPower("Modulo"))
            BinaryExpression(left, "%", right, l, c)

        else if tt == "Backslash":
            right = parseExpr(getRightBindingPower("Backslash"))
            BinaryExpression(left, "\\", right, l, c)

        else if tt == "DoubleBackslash":
            right = parseExpr(getRightBindingPower("DoubleBackslash"))
            BinaryExpression(left, "\\\\", right, l, c)

        else if tt == "DoubleModulo":
            right = parseExpr(getRightBindingPower("DoubleModulo"))
            BinaryExpression(left, "%%", right, l, c)

        else if tt == "Power":
            right = parseExpr(getRightBindingPower("Power"))
            BinaryExpression(left, "**", right, l, c)

        else if tt == "Equals":
            right = parseExpr(getRightBindingPower("Equals"))
            BinaryExpression(left, "==", right, l, c)

        else if tt == "NotEquals":
            right = parseExpr(getRightBindingPower("NotEquals"))
            BinaryExpression(left, "!=", right, l, c)

        else if tt == "Is":
            right = parseExpr(getRightBindingPower("Is"))
            BinaryExpression(left, "is", right, l, c)

        else if tt == "Tilde" or tt == "Matches":
            right = parseExpr(getRightBindingPower(tt))
            BinaryExpression(left, "matches", right, l, c)

        else if tt == "In":
            right = parseExpr(getRightBindingPower("In"))
            BinaryExpression(left, "in", right, l, c)

        else if tt == "Not":
            // 'not in' compound infix
            if current().type == "In":
                advance()
                right = parseExpr(getRightBindingPower("In"))
                BinaryExpression(left, "not in", right, l, c)
            else:
                left

        else if tt == "Less":
            right = parseExpr(getRightBindingPower("Less"))
            BinaryExpression(left, "<", right, l, c)

        else if tt == "Greater":
            right = parseExpr(getRightBindingPower("Greater"))
            BinaryExpression(left, ">", right, l, c)

        else if tt == "LessEquals":
            right = parseExpr(getRightBindingPower("LessEquals"))
            BinaryExpression(left, "<=", right, l, c)

        else if tt == "GreaterEquals":
            right = parseExpr(getRightBindingPower("GreaterEquals"))
            BinaryExpression(left, ">=", right, l, c)

        else if tt == "And":
            right = parseExpr(getRightBindingPower("And"))
            BinaryExpression(left, "&&", right, l, c)

        else if tt == "Or":
            right = parseExpr(getRightBindingPower("Or"))
            BinaryExpression(left, "||", right, l, c)

        else if tt == "Nullish":
            right = parseExpr(getRightBindingPower("Nullish"))
            BinaryExpression(left, "??", right, l, c)

        // Bitwise
        else if tt == "BitwiseOr":
            right = parseExpr(getRightBindingPower("BitwiseOr"))
            BinaryExpression(left, "|", right, l, c)

        else if tt == "BitwiseXor":
            right = parseExpr(getRightBindingPower("BitwiseXor"))
            BinaryExpression(left, "^", right, l, c)

        else if tt == "BitwiseAnd":
            right = parseExpr(getRightBindingPower("BitwiseAnd"))
            BinaryExpression(left, "&", right, l, c)

        else if tt == "ShiftLeft":
            right = parseExpr(getRightBindingPower("ShiftLeft"))
            BinaryExpression(left, "<<", right, l, c)

        else if tt == "ShiftRight":
            right = parseExpr(getRightBindingPower("ShiftRight"))
            BinaryExpression(left, ">>", right, l, c)

        // Ternary: cond ? true : false
        else if tt == "Question":
            trueExpr = parseExpr(0)
            if current().type != "Colon":
                return error("Expected ':' after ternary true branch", l, c)
            advance()
            falseExpr = parseExpr(getRightBindingPower("Question"))
            TernaryExpression(left, trueExpr, falseExpr, l, c)

        // Range
        else if tt == "DotDot":
            right = parseExpr(getRightBindingPower("DotDot"))
            // Check for step: a..b..step
            if current().type == "DotDot":
                advance()
                step = parseExpr(getRightBindingPower("DotDot"))
                node = RangeExpression(left, right, false, l, c)
                node.step = step
                node
            else:
                RangeExpression(left, right, false, l, c)

        else if tt == "DotDotEquals":
            right = parseExpr(getRightBindingPower("DotDotEquals"))
            RangeExpression(left, right, true, l, c)

        // Pipeline
        else if tt == "Pipe" or tt == "PipeRight":
            right = parseExpr(getRightBindingPower(tt))
            // If right is a CallExpression, prepend left as first arg
            if right != null and right.kind == "CallExpression":
                right.args.insert(0, left)
                right
            else:
                PipelineExpression(left, right, l, c)

        // Member access: expr.field
        else if tt == "Dot":
            if current().type == "Identifier" or isKeywordIdent(current().type):
                prop = advance()
                MemberExpression(left, prop.value, l, c)
            else
                error("Expected identifier after '.'", l, c)

        // Optional chaining: expr?.field
        else if tt == "QuestionDot":
            if current().type == "Identifier" or isKeywordIdent(current().type):
                prop = advance()
                node = MemberExpression(left, prop.value, l, c)
                node.optional = true
                node
            else
                error("Expected identifier after '?.'", l, c)

        // Function call: expr(args)
        else if tt == "OpenParen":
            args = parseCallArgs()
            CallExpression(left, args, l, c)

        // Index: expr[index]
        else if tt == "OpenBracket":
            // Check for slice: look ahead for colon at bracket depth 1
            isSlice = detectSlice()

            if isSlice:
                parseSliceExpr(left, l, c)
            else:
                idx = parseExpr(0)
                skipNewlines()
                if current().type != "CloseBracket":
                    error("Expected ']' after index", l, c)
                else:
                    advance()
                    IndexExpression(left, idx, l, c)

        // Postfix increment/decrement
        else if tt == "PlusPlus":
            UpdateExpression(left, "++", false, l, c)

        else if tt == "MinusMinus":
            UpdateExpression(left, "--", false, l, c)

        // Arrow function: param => body
        else if tt == "Arrow":
            if inMatchExpr:
                return null
            if left == null or left.kind != "Identifier":
                return error("Arrow function requires identifier parameter", l, c)
            paramName = left.name
            params = [paramName]
            // Parse body
            if current().type == "OpenBrace":
                body = parseBlock()
            else
                bodyExpr = parseExpr(getRightBindingPower("Arrow"))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            LambdaExpression(params, body, l, c)

        else
            error("Unexpected token in infix position: " + tt, l, c)

    // ===================================================================
    // HELPER: Parse call arguments
    // ===================================================================
    fn parseCallArgs():
        args = []
        skipNewlines()
        while current().type != "CloseParen" and notEOF():
            skipNewlines()
            if current().type == "CloseParen": break
            if args.len > 0:
                if current().type == "Comma":
                    advance()
                    skipNewlines()
            if current().type == "CloseParen": break
            // Spread
            if current().type == "Spread":
                advance()
                target = parseExpr(0)
                args.push(SpreadExpression(target, current().line, current().col))
            else
                args.push(parseExpr(0))
            skipNewlines()
        if current().type == "CloseParen":
            advance()
        else
            error("Expected ')' after arguments", current().line, current().col)
        args

    // ===================================================================
    // HELPER: Detect slice expression [...:...]
    // ===================================================================
    fn detectSlice():
        lookahead = 0
        depth = 1
        while pos + lookahead < tokens.len:
            t = tokens[pos + lookahead]
            if t.type == "OpenBracket": depth = depth + 1
            else if t.type == "CloseBracket":
                depth = depth - 1
                if depth == 0: break
            else if (t.type == "Colon" or t.type == "ColonColon") and depth == 1:
                return true
            else if t.type == "EOF": break
            lookahead = lookahead + 1
        false

    // ===================================================================
    // HELPER: Parse slice expression
    // ===================================================================
    fn parseSliceExpr(obj, l, c):
        start = null
        end = null
        step = null

        if current().type != "Colon" and current().type != "ColonColon":
            start = parseExpr(0)

        if current().type == "ColonColon":
            advance()
            if current().type != "CloseBracket":
                step = parseExpr(0)
        else if current().type == "Colon":
            advance()
            if current().type != "Colon" and current().type != "CloseBracket":
                end = parseExpr(0)
            if current().type == "Colon":
                advance()
                if current().type != "CloseBracket":
                    step = parseExpr(0)

        if current().type == "CloseBracket":
            advance()
        else:
            error("Expected ']' after slice", l, c)

        // Desugar to obj.slice(start, end, step)
        args = []
        if start != null: args.push(start)
        else: args.push(NullLiteral(l, c))
        if end != null: args.push(end)
        else: args.push(NullLiteral(l, c))
        if step != null: args.push(step)
        else: args.push(NullLiteral(l, c))

        sliceMember = MemberExpression(obj, "slice", l, c)
        CallExpression(sliceMember, args, l, c)

    // ===================================================================
    // HELPER: Parse interpolated string into parts
    // ===================================================================
    fn parseInterpolatedString(value, l, c):
        parts = []
        i = 0
        current = ""

        while i < value.len:
            ch = value.sub(i, 1)

            // ${...} interpolation
            if ch == "$" and i + 1 < value.len and value.sub(i + 1, 1) == "{":
                if current.len > 0:
                    parts.push(StringLiteral(current, l, c))
                    current = ""
                i = i + 2
                depth = 1
                exprStr = ""
                while i < value.len and depth > 0:
                    ch2 = value.sub(i, 1)
                    if ch2 == "{": depth = depth + 1
                    else if ch2 == "}": depth = depth - 1
                    if depth > 0: exprStr = exprStr + ch2
                    i = i + 1
                // Parse the sub-expression by tokenizing and parsing
                subTokens = tokenize(exprStr)
                subParser = Parser(subTokens)
                subExpr = subParser.parseExpr(0)
                if subExpr != null: parts.push(subExpr)
                else: parts.push(Identifier(exprStr, l, c))

            // {...} f-string interpolation
            else if ch == "{" and (i == 0 or value.sub(i - 1, 1) != "$"):
                if current.len > 0:
                    parts.push(StringLiteral(current, l, c))
                    current = ""
                i = i + 1
                depth = 1
                exprStr = ""
                while i < value.len and depth > 0:
                    ch2 = value.sub(i, 1)
                    if ch2 == "{": depth = depth + 1
                    else if ch2 == "}": depth = depth - 1
                    if depth > 0: exprStr = exprStr + ch2
                    i = i + 1
                subTokens = tokenize(exprStr)
                subParser = Parser(subTokens)
                subExpr = subParser.parseExpr(0)
                if subExpr != null: parts.push(subExpr)
                else: parts.push(Identifier(exprStr, l, c))

            else:
                current = current + ch
                i = i + 1

        if current.len > 0:
            parts.push(StringLiteral(current, l, c))

        InterpolatedString(parts, l, c)

    // ===================================================================
    // HELPER: Parenthesized expression or lambda
    // ===================================================================
    fn parseParenExpr(openTok):
        l = openTok.line
        c = openTok.col

        // Empty lambda: () => body
        if current().type == "CloseParen" and at(1).type == "Arrow":
            advance() // )
            advance() // =>
            params = []
            if current().type == "OpenBrace":
                body = parseBlock()
            else
                bodyExpr = parseExpr(getRightBindingPower("Arrow"))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            return LambdaExpression(params, body, l, c)

        // Multi-param lambda detection: (a, b, c) => body
        savedPos = pos
        lambdaParams = []
        isLambda = false

        if current().type == "Identifier":
            // Try collecting comma-separated identifiers
            while true:
                if current().type == "Identifier":
                    lambdaParams.push(advance().value)
                    if current().type == "Comma":
                        advance()
                    else:
                        break
                else:
                    break

            if current().type == "CloseParen":
                savedAfter = pos + 1
                // Peek past ) for =>
                if at(1).type == "Arrow":
                    advance() // )
                    advance() // =>
                    isLambda = true

        if isLambda:
            if current().type == "OpenBrace":
                body = parseBlock()
            else
                bodyExpr = parseExpr(getRightBindingPower("Arrow"))
                body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
            return LambdaExpression(lambdaParams, body, l, c)

        // Not a lambda — restore position and parse grouped expression
        pos = savedPos
        skipNewlines()
        expr = parseExpr(0)
        skipNewlines()
        expect("CloseParen")
        expr

    // ===================================================================
    // HELPER: Lambda expression (fn keyword form)
    // ===================================================================
    fn parseLambdaExpr():
        l = current().line
        c = current().col

        // fn(params) => body  or  fn params => body
        params = []
        if current().type == "OpenParen":
            advance()
            skipNewlines()
            while current().type != "CloseParen" and notEOF():
                skipNewlines()
                if current().type == "CloseParen": break
                // Parse param name (allow keywords as param names)
                pname = advance().value
                p = {name: pname}
                // Type annotation
                if current().type == "Colon":
                    advance()
                    p.typeAnn = advance().value
                // Default value
                if current().type == "Assign":
                    advance()
                    p.default = parseExpr(0)
                // Variadic
                if current().type == "Spread":
                    advance()
                    p.variadic = true
                params.push(p.name)
                skipNewlines()
                if current().type == "Comma": advance()
            expect("CloseParen")
        else if current().type == "Identifier":
            params.push(advance().value)

        // Expect =>
        if current().type == "Arrow":
            advance()
        else
            return error("Expected '=>' in lambda", l, c)

        if current().type == "OpenBrace":
            body = parseBlock()
        else
            bodyExpr = parseExpr(getRightBindingPower("Arrow"))
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        LambdaExpression(params, body, l, c)

    // ===================================================================
    // HELPER: Match expression
    // ===================================================================
    fn parseMatchExpr():
        l = current().line
        c = current().col

        subject = parseExpr(0)
        skipNewlines()

        // Expect { or :
        if current().type == "OpenBrace":
            advance()
        else if current().type == "Colon":
            advance()
        else
            return error("Expected '{' or ':' after match subject", l, c)

        prevMatch = inMatchExpr
        inMatchExpr = true

        cases = []
        skipNewlines()
        while current().type != "CloseBrace" and notEOF() and current().type != "EOF":
            skipNewlines()
            if current().type == "CloseBrace": break
            cases.push(parseMatchCase())
            skipNewlines()

        inMatchExpr = prevMatch

        if current().type == "CloseBrace":
            advance()

        MatchExpression(subject, cases, l, c)

    fn parseMatchCase():
        l = current().line
        c = current().col

        // Parse pattern
        pattern = parseExpr(0)
        skipNewlines()

        // Optional guard: when expr
        guard = null
        if current().type == "When":
            advance()
            guard = parseExpr(0)
            skipNewlines()

        // Expect =>
        if current().type == "Arrow":
            advance()
        else
            return error("Expected '=>' in match case", l, c)

        skipNewlines()

        // Body
        if current().type == "OpenBrace":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        MatchCase(pattern, guard, body, l, c)

    // ===================================================================
    // HELPER: If expression
    // ===================================================================
    fn parseIfExpr():
        l = current().line
        c = current().col

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        condition = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        if current().type == "OpenBrace":
            thenBranch = parseBlock()
        else if current().type == "Colon":
            advance()
            skipNewlines()
            thenBranch = parseBlock()
        else
            thenBranch = parseStatement()
            if thenBranch == null: thenBranch = BlockStatement([], l, c)

        skipNewlines()

        elseBranch = null
        if current().type == "Else":
            advance()
            skipNewlines()
            if current().type == "If":
                elseBranch = parseIfExpr()
            else if current().type == "OpenBrace":
                elseBranch = parseBlock()
            else if current().type == "Colon":
                advance()
                skipNewlines()
                elseBranch = parseBlock()
            else
                elseBranch = parseStatement()
                if elseBranch == null: elseBranch = BlockStatement([], l, c)

        IfStatement(condition, thenBranch, elseBranch, l, c)

    // ===================================================================
    // HELPER: Array literal
    // ===================================================================
    fn parseArrayLiteral():
        l = current().line
        c = current().col
        expect("OpenBracket")
        skipNewlines()

        elements = []
        while current().type != "CloseBracket" and notEOF():
            skipNewlines()
            if current().type == "CloseBracket": break

            if current().type == "Spread":
                advance()
                target = parseExpr(0)
                elements.push(SpreadExpression(target, current().line, current().col))
            else
                elements.push(parseExpr(0))

            skipNewlines()
            if current().type == "Comma":
                advance()
            else if current().type != "CloseBracket":
                // Allow missing comma (newline-separated)
                skipNewlines()

        expect("CloseBracket")
        ArrayLiteral(elements, l, c)

    // ===================================================================
    // HELPER: Object literal disambiguation
    // ===================================================================
    fn disambiguateBrace():
        l = current().line
        c = current().col

        // Lookahead to determine set vs object
        lookahead = 1
        while at(lookahead).type == "NewLine":
            lookahead = lookahead + 1

        nextTok = at(lookahead)

        // Empty braces = empty object
        if nextTok.type == "CloseBrace":
            return parseObjectLiteral(false)

        // Check if object: identifier/string/number followed by colon
        isObject = false
        isObjKeyType = (nextTok.type == "Identifier" or nextTok.type == "String" or nextTok.type == "MultilineString" or nextTok.type == "Number" or isKeywordIdent(nextTok.type))

        if isObjKeyType:
            colonLook = lookahead + 1
            while at(colonLook).type == "NewLine":
                colonLook = colonLook + 1
            if at(colonLook).type == "Colon":
                isObject = true

        if isObject:
            return parseObjectLiteral(false)

        // Check for set literal: {expr, ...}
        couldBeSet = (nextTok.type == "Identifier" or nextTok.type == "String" or nextTok.type == "MultilineString" or nextTok.type == "RegexString" or nextTok.type == "Number" or nextTok.type == "OpenBracket" or nextTok.type == "OpenParen" or nextTok.type == "OpenBrace" or nextTok.type == "Minus" or nextTok.type == "Not" or nextTok.type == "Plus" or nextTok.type == "Length" or nextTok.type == "True" or nextTok.type == "False" or nextTok.type == "Null")

        if couldBeSet:
            // Look ahead for comma
            setLook = lookahead + 1
        while setLook < tokens.len and at(setLook).type != "Comma" and at(setLook).type != "Semicolon" and at(setLook).type != "CloseBrace" and at(setLook).type != "NewLine":
                setLook = setLook + 1

            if at(setLook).type == "Comma":
                // Parse as set literal
                advance() // consume {
                elements = []
                skipNewlines()
                while current().type != "CloseBrace" and notEOF():
                    skipNewlines()
                    if current().type == "CloseBrace": break
                    elements.push(parseExpr(0))
                    skipNewlines()
                    if current().type == "Comma": advance()
                    else if current().type != "CloseBrace":
                        // Allow newline-separated
                        skipNewlines()
                expect("CloseBrace")
                // Represent set as ArrayLiteral with isSet flag
                node = ArrayLiteral(elements, l, c)
                node.isSet = true
                return node

        // Default to object literal
        parseObjectLiteral(false)

    // ===================================================================
    // HELPER: Object literal
    // ===================================================================
    fn parseObjectLiteral(unsorted):
        l = current().line
        c = current().col

        if current().type == "BangOpenBrace":
            advance() // consume !{
        else
            expect("OpenBrace")

        skipNewlines()

        fields = []
        while current().type != "CloseBrace" and notEOF():
            skipNewlines()
            if current().type == "CloseBrace": break

            // Parse key
            key = null
            if current().type == "String" or current().type == "MultilineString":
                key = advance().value
            else if current().type == "Number":
                key = advance().value
            else if current().type == "Identifier" or isKeywordIdent(current().type):
                key = advance().value
            else if current().type == "OpenBracket":
                // Computed key: [expr]
                advance()
                key = parseExpr(0)
                expect("CloseBracket")
            else
                // Try to advance past error
                return error("Expected object key", l, c)

            skipNewlines()

            // Check for colon (key: value)
            if current().type == "Colon":
                advance()
                skipNewlines()
                value = parseExpr(0)
            else
                // Shorthand: {x} means {x: x}
                if type(key) == "string":
                    value = Identifier(key, l, c)
                else
                    value = key
                key = key

            fields.push(ObjectField(key, value, l, c))

            skipNewlines()
            if current().type == "Comma":
                advance()
            else if current().type != "CloseBrace":
                skipNewlines()

        expect("CloseBrace")

        node = ObjectLiteral(fields, l, c)
        if unsorted: node.unsorted = true
        node

    // ===================================================================
    // BLOCK PARSING
    // ===================================================================
    fn parseBlock():
        l = current().line
        c = current().col

        if current().type == "OpenBrace":
            advance()
            skipNewlines()
            stmts = []
            while current().type != "CloseBrace" and notEOF():
                skipNewlines()
                if current().type == "CloseBrace": break
                s = parseStatement()
                if s != null and s.kind != "ErrorNode":
                    stmts.push(s)
                else if s != null and s.kind == "ErrorNode":
                    // Skip error tokens and continue
                    advance()
                skipNewlinesAndSemicolons()
            expect("CloseBrace")
            BlockStatement(stmts, l, c)
        else if current().type == "Colon":
            advance()
            skipNewlines()
            stmts = []
            // Parse indented block — consume until we see dedent-like pattern
            // In Havel, blocks after : end at the next token at same or lower indent
            blockLine = l
            while notEOF() and current().type != "EOF":
                skipNewlines()
                if current().type == "EOF": break
                s = parseStatement()
                if s != null and s.kind != "ErrorNode":
                    stmts.push(s)
                else if s != null and s.kind == "ErrorNode":
                    advance()
                // Check for continuation
                skipNewlines()
                if current().type == "EOF": break
                // A block ends when we see certain tokens that can't be in the block
                endTokens = {"Else": true, "Catch": true, "Finally": true, "Case": true, "Default": true}
                if endTokens.has(current().type): break
            BlockStatement(stmts, blockLine, c)
        else
            error("Expected '{' or ':' for block", l, c)

    // ===================================================================
    // STATEMENT PARSING
    // ===================================================================
    fn parseStatement():
        if !notEOF(): return null

        skipNewlines()
        if !notEOF(): return null

        tt = current().type
        l = current().line
        c = current().col

        // Hotkey binding: Hotkey token or @token => block
        if tt == "Hotkey":
            return parseHotkeyStatement()

        // @identifier => block (hotkey syntax)
        if tt == "At" and at(1).type == "Identifier":
            // Check if this is a hotkey: @id => ...
            // Look ahead past the @ident for =>
            savePos = pos
            advance() // @
            advance() // identifier
            if current().type == "Arrow":
                pos = savePos
                return parseHotkeyStatement()
            pos = savePos

        // Variable declarations
        if tt == "Let":
            return parseLetDecl("Let")
        if tt == "Val":
            return parseLetDecl("Val")
        if tt == "Const":
            return parseLetDecl("Val") // const is alias for val

        // Control flow
        if tt == "If":
            return parseIfStatement()
        if tt == "While":
            return parseWhileStatement()
        if tt == "For":
            return parseForStatement()
        if tt == "Loop":
            return parseLoopStatement()
        if tt == "Repeat":
            return parseRepeatStatement()
        if tt == "Break":
            advance()
            return BreakStatement(l, c)
        if tt == "Continue":
            advance()
            return ContinueStatement(l, c)
        if tt == "Return" or tt == "Ret":
            return parseReturnStatement()
        if tt == "Throw":
            return parseThrowStatement()
        if tt == "Try":
            return parseTryStatement()
        if tt == "Switch":
            return parseSwitchStatement()
        if tt == "Del":
            return parseDelStatement()

        // Function declaration
        if tt == "Fn":
            return parseFnDeclaration()

        // Import / Use
        if tt == "Import":
            return parseImportStatement()
        if tt == "Use":
            return parseUseStatement()

        // Config block
        if tt == "Config":
            return parseConfigBlockStatement()

        // Sleep
        if tt == "Sleep":
            advance()
            duration = parseExpr(0)
            return SleepStatement(duration, l, c)

        // DSL statements
        if tt == "On": return parseOnStatement()
        if tt == "Mode": return parseModeBlockStatement()
        if tt == "Group": return parseGroupStatement()
        if tt == "Signal": return parseSignalStatement()
        if tt == "Pool": return parsePoolStatement()
        if tt == "Devices": return parseDevicesBlockStatement()

        // Thread/Interval/Timeout sugar
        if tt == "Thread": return parseThreadStatement()
        if tt == "Interval": return parseIntervalStatement()
        if tt == "Timeout": return parseTimeoutStatement()

        // Type declarations
        if tt == "Struct" or tt == "Class" or tt == "Enum" or tt == "Trait" or tt == "Prot" or tt == "Impl":
            return parseTypeDeclStatement()

        // Expression statement
        expr = parseExpr(0)
        if expr == null: return null
        if expr.kind == "ErrorNode": return expr
        ExpressionStatement(expr, l, c)

    // ===================================================================
    // STATEMENT: if
    // ===================================================================
    fn parseIfStatement():
        l = current().line
        c = current().col
        advance() // consume 'if'
        skipNewlines()

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        condition = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        if current().type == "OpenBrace":
            thenBranch = parseBlock()
        else if current().type == "Colon":
            advance()
            skipNewlines()
            thenBranch = parseBlock()
        else
            thenBranch = parseStatement()
            if thenBranch == null: thenBranch = BlockStatement([], l, c)

        skipNewlines()

        elseBranch = null
        if current().type == "Else":
            advance()
            skipNewlines()
            if current().type == "If":
                elseBranch = parseIfStatement()
            else if current().type == "OpenBrace":
                elseBranch = parseBlock()
            else if current().type == "Colon":
                advance()
                skipNewlines()
                elseBranch = parseBlock()
            else
                elseBranch = parseStatement()
                if elseBranch == null: elseBranch = BlockStatement([], l, c)

        IfStatement(condition, thenBranch, elseBranch, l, c)

    // ===================================================================
    // STATEMENT: while
    // ===================================================================
    fn parseWhileStatement():
        l = current().line
        c = current().col
        advance() // consume 'while'
        skipNewlines()

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        condition = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        WhileStatement(condition, body, l, c)

    // ===================================================================
    // STATEMENT: for
    // ===================================================================
    fn parseForStatement():
        l = current().line
        c = current().col
        advance() // consume 'for'
        skipNewlines()

        // Parse iterator variable(s) — may be parenthesized
        names = []
        if current().type == "OpenParen":
            advance()
            skipNewlines()
            while current().type != "CloseParen" and notEOF():
                skipNewlines()
                names.push(advance().value)
                skipNewlines()
                if current().type == "Comma": advance()
            expect("CloseParen")
        else
            names.push(advance().value)

        skipNewlines()

        // Expect 'in'
        if current().type == "In":
            advance()
        else
            return error("Expected 'in' in for statement", l, c)

        skipNewlines()
        iterator = parseExpr(0)
        skipNewlines()

        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        // If multiple names, use first as name and add keyVar
        name = names[0]
        node = ForStatement(name, iterator, body, l, c)
        if names.len > 1:
            node.keyVar = names[0]
            node.name = names[1]
        node

    // ===================================================================
    // STATEMENT: loop
    // ===================================================================
    fn parseLoopStatement():
        l = current().line
        c = current().col
        advance() // consume 'loop'
        skipNewlines()

        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        LoopStatement(body, l, c)

    // ===================================================================
    // STATEMENT: repeat
    // ===================================================================
    fn parseRepeatStatement():
        l = current().line
        c = current().col
        advance() // consume 'repeat'
        skipNewlines()

        prevSugar = allowBraceSugar
        allowBraceSugar = false
        count = parseExpr(0)
        allowBraceSugar = prevSugar

        skipNewlines()

        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            body = parseStatement()
            if body == null: body = BlockStatement([], l, c)

        RepeatStatement(count, body, l, c)

    // ===================================================================
    // STATEMENT: return
    // ===================================================================
    fn parseReturnStatement():
        l = current().line
        c = current().col
        advance() // consume 'return' or 'ret'
        skipNewlines()

        // @ without following identifier -> return this
        if current().type == "At" and at(1).type != "Identifier":
            advance()
            return ReturnStatement(Identifier("this", l, c), l, c)

        value = null
        // Return value is optional — check if next token can start expression
        if canStartExpr(current().type) or (current().type == "Not" and isNotIn()) or current().type == "Minus" or current().type == "Plus":
            value = parseExpr(0)

        ReturnStatement(value, l, c)

    // ===================================================================
    // STATEMENT: throw
    // ===================================================================
    fn parseThrowStatement():
        l = current().line
        c = current().col
        advance() // consume 'throw'
        skipNewlines()
        value = parseExpr(0)
        ThrowStatement(value, l, c)

    // ===================================================================
    // STATEMENT: try/catch/finally
    // ===================================================================
    fn parseTryStatement():
        l = current().line
        c = current().col
        advance() // consume 'try'
        skipNewlines()

        tryBlock = parseBlock()
        skipNewlines()

        catchParam = null
        catchBlock = null
        finallyBlock = null

        if current().type == "Catch":
            advance()
            skipNewlines()
            if current().type == "Identifier":
                catchParam = advance().value
            skipNewlines()
            catchBlock = parseBlock()
            skipNewlines()

        if current().type == "Finally":
            advance()
            skipNewlines()
            finallyBlock = parseBlock()

        TryStatement(tryBlock, catchParam, catchBlock, finallyBlock, l, c)

    // ===================================================================
    // STATEMENT: switch
    // ===================================================================
    fn parseSwitchStatement():
        l = current().line
        c = current().col
        advance() // consume 'switch'
        skipNewlines()

        subject = parseExpr(0)
        skipNewlines()

        if current().type == "OpenBrace":
            advance()
        else if current().type == "Colon":
            advance()
        else
            return error("Expected '{' or ':' after switch", l, c)

        cases = []
        skipNewlines()
        while current().type != "CloseBrace" and notEOF() and current().type != "EOF":
            skipNewlines()
            if current().type == "CloseBrace": break

            if current().type == "Case":
                advance()
                test = parseExpr(0)
            else if current().type == "Default":
                advance()
                test = null
            else
                // expression as case
                test = parseExpr(0)

            skipNewlines()

            if current().type == "Arrow":
                advance()
            else if current().type == "Colon":
                advance()
            else
                // Try to continue anyway
                pass

            skipNewlines()
            body = parseBlock()
            cases.push({test: test, body: body})
            skipNewlines()

        if current().type == "CloseBrace":
            advance()

        // Represent as MatchExpression (switch is syntactic sugar for match)
        matchCases = []
        for c in cases:
            matchCases.push(MatchCase(c.test, null, c.body, l, c))
        MatchExpression(subject, matchCases, l, c)

    // ===================================================================
    // STATEMENT: del
    // ===================================================================
    fn parseDelStatement():
        l = current().line
        c = current().col
        advance() // consume 'del'
        skipNewlines()

        // del(...) as function call or del expr
        if current().type == "OpenParen":
            // Could be del(expr) — parse as call
            callee = Identifier("del", l, c)
            args = parseCallArgs()
            return ExpressionStatement(CallExpression(callee, args, l, c), l, c)

        target = parseExpr(0)
        node = ExpressionStatement(target, l, c)
        node.isDel = true
        node

    // ===================================================================
    // STATEMENT: fn declaration
    // ===================================================================
    fn parseFnDeclaration():
        l = current().line
        c = current().col
        advance() // consume 'fn'
        skipNewlines()

        // Function name
        name = advance().value
        skipNewlines()

        // Params
        params = []
        if current().type == "OpenParen":
            advance()
            skipNewlines()
            while current().type != "CloseParen" and notEOF():
                skipNewlines()
                if current().type == "CloseParen": break
                // Param name
                pname = advance().value
                params.push(pname)
                skipNewlines()
                // Type annotation
                if current().type == "Colon":
                    advance()
                    advance() // consume type name (skip for now)
                    skipNewlines()
                // Default value
                if current().type == "Assign":
                    advance()
                    parseExpr(0) // parse but don't store for now
                    skipNewlines()
                // Variadic
                if current().type == "Spread":
                    advance()
                    skipNewlines()
                if current().type == "Comma": advance()
            expect("CloseParen")
            skipNewlines()

        // Return type annotation
        if current().type == "ReturnType":
            advance()
            advance() // consume type name
            skipNewlines()

        // Body
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            // Expression body
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        FnDeclaration(name, params, body, l, c)

    // ===================================================================
    // STATEMENT: let / val declaration
    // ===================================================================
    fn parseLetDecl(keyword):
        l = current().line
        c = current().col
        advance() // consume 'let'/'val'/'const'
        skipNewlines()

        // Parse name(s) — may be destructuring
        name = advance().value
        skipNewlines()

        value = null
        if current().type == "Assign":
            advance()
            skipNewlines()
            value = parseExpr(0)
        else if current().type == "Colon":
            // Type annotation without assignment
            advance()
            advance() // type name
            skipNewlines()
            if current().type == "Assign":
                advance()
                skipNewlines()
                value = parseExpr(0)

        if keyword == "Let":
            LetDeclaration(name, value, l, c)
        else
            ValDeclaration(name, value, l, c)

    // ===================================================================
    // STATEMENT: import
    // ===================================================================
    fn parseImportStatement():
        l = current().line
        c = current().col
        advance() // consume 'import'
        skipNewlines()

        module = advance().value
        skipNewlines()

        names = []
        if current().type == "OpenBrace":
            advance()
            skipNewlines()
            while current().type != "CloseBrace" and notEOF():
                skipNewlines()
                if current().type == "CloseBrace": break
                n = advance().value
                // import { a as b }
                if current().type == "As":
                    advance()
                    alias = advance().value
                    names.push(n + " as " + alias)
                else
                    names.push(n)
                skipNewlines()
                if current().type == "Comma": advance()
            expect("CloseBrace")

        ImportStatement(module, names, l, c)

    // ===================================================================
    // STATEMENT: use
    // ===================================================================
    fn parseUseStatement():
        l = current().line
        c = current().col
        advance() // consume 'use'
        skipNewlines()

        // use { names } from "module" or use "module"
        names = []
        if current().type == "OpenBrace":
            advance()
            skipNewlines()
            while current().type != "CloseBrace" and notEOF():
                skipNewlines()
                if current().type == "CloseBrace": break
                n = advance().value
                if current().type == "As":
                    advance()
                    alias = advance().value
                    names.push(n + " as " + alias)
                else
                    names.push(n)
                skipNewlines()
                if current().type == "Comma": advance()
            expect("CloseBrace")
            skipNewlines()
            if current().type == "From":
                advance()
                skipNewlines()
            module = advance().value
        else
            module = advance().value

        UseStatement(module, names, l, c)

    // ===================================================================
    // STATEMENT: hotkey binding
    // ===================================================================
    fn parseHotkeyStatement():
        l = current().line
        c = current().col

        // Collect the hotkey token(s)
        key = ""
        if current().type == "Hotkey":
            key = advance().value
        else if current().type == "At":
            advance()
            if current().type == "Identifier":
                key = "@" + advance().value
            else
                key = "@"

        skipNewlines()

        // Optional when/if prefix condition
        condition = null
        if current().type == "When" or current().type == "If":
            advance()
            condition = parseExpr(BP_ASSIGN)

        skipNewlines()

        // Expect => or {
        if current().type == "Arrow":
            advance()
            skipNewlines()
        else if current().type != "OpenBrace" and current().type != "Colon":
            return error("Expected '=>' or '{' after hotkey", l, c)

        // Parse body
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)

        node = HotkeyBinding(key, body, l, c)
        if condition != null: node.condition = condition
        node

    // ===================================================================
    // STATEMENT: config block
    // ===================================================================
    fn parseConfigBlockStatement():
        l = current().line
        c = current().col
        advance() // consume 'config'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        ConfigBlock(name, body, l, c)

    // ===================================================================
    // STATEMENT: on
    // ===================================================================
    fn parseOnStatement():
        l = current().line
        c = current().col
        advance() // consume 'on'
        skipNewlines()
        // on <event> => body or on <event> { body }
        event = advance().value
        skipNewlines()
        if current().type == "Arrow":
            advance()
            skipNewlines()
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        node = HotkeyBinding(event, body, l, c)
        node.isEvent = true
        node

    // ===================================================================
    // STATEMENT: mode block
    // ===================================================================
    fn parseModeBlockStatement():
        l = current().line
        c = current().col
        advance() // consume 'mode'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        ConfigBlock("mode:" + name, body, l, c)

    // ===================================================================
    // STATEMENT: group
    // ===================================================================
    fn parseGroupStatement():
        l = current().line
        c = current().col
        advance() // consume 'group'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        ConfigBlock("group:" + name, body, l, c)

    // ===================================================================
    // STATEMENT: signal
    // ===================================================================
    fn parseSignalStatement():
        l = current().line
        c = current().col
        advance() // consume 'signal'
        skipNewlines()
        name = advance().value
        skipNewlines()
        value = null
        if current().type == "Assign":
            advance()
            value = parseExpr(0)
        node = LetDeclaration(name, value, l, c)
        node.isSignal = true
        node

    // ===================================================================
    // STATEMENT: pool
    // ===================================================================
    fn parsePoolStatement():
        l = current().line
        c = current().col
        advance() // consume 'pool'
        skipNewlines()
        name = advance().value
        skipNewlines()
        body = parseBlock()
        ConfigBlock("pool:" + name, body, l, c)

    // ===================================================================
    // STATEMENT: devices block
    // ===================================================================
    fn parseDevicesBlockStatement():
        l = current().line
        c = current().col
        advance() // consume 'devices'
        skipNewlines()
        body = parseBlock()
        ConfigBlock("devices", body, l, c)

    // ===================================================================
    // STATEMENT: thread/interval/timeout sugar
    // ===================================================================
    fn parseThreadStatement():
        l = current().line
        c = current().col
        advance() // consume 'thread'
        skipNewlines()
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        node = FnDeclaration("__thread__", [], body, l, c)
        node.isThread = true
        node

    fn parseIntervalStatement():
        l = current().line
        c = current().col
        advance() // consume 'interval'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        node = FnDeclaration("__interval__", [], body, l, c)
        node.isInterval = true
        node.intervalDuration = duration
        node

    fn parseTimeoutStatement():
        l = current().line
        c = current().col
        advance() // consume 'timeout'
        skipNewlines()
        duration = parseExpr(0)
        skipNewlines()
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            bodyExpr = parseExpr(0)
            body = BlockStatement([ExpressionStatement(bodyExpr, l, c)], l, c)
        node = FnDeclaration("__timeout__", [], body, l, c)
        node.isTimeout = true
        node.timeoutDuration = duration
        node

    // ===================================================================
    // STATEMENT: type declarations (stub — just consume and return error)
    // ===================================================================
    fn parseTypeDeclStatement():
        l = current().line
        c = current().col
        advance() // consume struct/class/etc
        skipNewlines()
        name = advance().value
        skipNewlines()
        // Try to parse body
        if current().type == "OpenBrace" or current().type == "Colon":
            body = parseBlock()
        else
            body = BlockStatement([], l, c)
        ConfigBlock("type:" + name, body, l, c)

    // ===================================================================
    // PRODUCE AST — main entry point
    // ===================================================================
    fn produceAST():
        skipNewlines()
        stmts = []

        while notEOF() and current().type != "EOF":
            skipNewlinesAndSemicolons()
            if !notEOF() or current().type == "EOF": break

            s = parseStatement()
            if s != null and s.kind != "ErrorNode":
                stmts.push(s)
            else if s != null and s.kind == "ErrorNode":
                // Skip past error token and continue
                if pos < tokens.len: advance()
            else
                // Null statement — skip
                if pos < tokens.len: advance()

        Program(stmts, 1, 1)

    // Return the parser interface
    {
        parseExpr: parseExpr,
        parseStatement: parseStatement,
        parseBlock: parseBlock,
        produceAST: produceAST,
        errors: errors,
        pos: pos,
        tokens: tokens,
    }

// ===================================================================
// PUBLIC API
// ===================================================================

fn parse(source):
    tokenList = tokenize(source)
    p = Parser(tokenList)
    ast = p.produceAST()
    {ast: ast, errors: p.errors}

fn parseTokens(tokenList):
    p = Parser(tokenList)
    ast = p.produceAST()
    {ast: ast, errors: p.errors}
