use { parse } from "pratt"

src = 'fn double(n) n * 2\ndouble(21)'
r = parse(src)
fnDecl = r.ast.body[0]
print("fn name: " + fnDecl.name)
print("params count: " + str(#fnDecl.params))
if #fnDecl.params > 0 {
    print("param0: " + str(fnDecl.params[0]))
    print("param0 name: " + str(fnDecl.params[0].name))
    print("param0 kind: " + str(fnDecl.params[0].kind))

}