use fs
use { tokenize } from "lexer"
use { parseTokens } from "pratt"
use { prettyPrint } from "ast"

src = 'struct CustData { id, name, email }'
tokens = tokenize(src)
res = parseTokens(tokens)
print("Errors:")
for err in res.errors {
    print(err.msg + " at " + str(err.line) + ":" + str(err.col))
}
prettyPrint(res.ast)
