use { parse, parseTokens } from pratt
use { tokenize } from lexer
use { isNode } from ast

r1 = parse("{ 42 }")
if r1.ast != null:
    print("brace block: OK")
else:
    print("brace block: FAIL " + str(r1.errors))

r2 = parse("42")
if r2.ast != null:
    print("number: OK")
else:
    print("number: FAIL " + str(r2.errors))

r3 = parse("fn foo():\n  42")
if r3.ast != null:
    print("colon fn: OK")
else:
    print("colon fn: FAIL " + str(r3.errors))
