// Test: inline the emitStmt logic to avoid module boundary issues
use { Emitter, Scope, scopeResolve, globalIdx, emitExpr } from "emitter"
use { NumberLiteral, ValDeclaration } from "ast"

fn myEmitStmt(emitter, node):
    if node == null: return
    k = node.kind
    if k == "LetDeclaration" || k == "ValDeclaration":
        if node.value != null:
            emitExpr(emitter, node.value)
        else:
            bc.emit("PUSH_NULL")
        resolved = scopeResolve(emitter.scope, node.name)
        if resolved != null:
            if k == "ValDeclaration":
                bc.emit("STORE_IMMUT_VAR", resolved.index)
            else:
                bc.emit("STORE_VAR", resolved.index)
        else:
            if k == "ValDeclaration":
                bc.emit("STORE_IMMUT_GLOBAL", bc.str_id(globalIdx(emitter, node.name)))
            else:
                bc.emit("STORE_GLOBAL", bc.str_id(globalIdx(emitter, node.name)))
    else:
        print("unsupported stmt kind: " + k)

em = Emitter()
bc.reset()
bc.func_new("__main__", 0, 32)
em.scope = Scope(null)

val_decl = ValDeclaration("x", NumberLiteral(42, 0, 0), 0, 0)
myEmitStmt(em, val_decl)

bc.emit("PUSH_NULL")
bc.emit("RETURN")

bc.execute("__main__")
print("inline emitter test ok")
