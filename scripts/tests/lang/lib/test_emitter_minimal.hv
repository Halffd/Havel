use { Emitter, globalIdx, emitStmt, emitExpr, Scope, scopeDeclare, scopeResolve } from "emitter"
use { NumberLiteral, ValDeclaration } from "ast"

em = Emitter()
bc.reset()
bc.func_new("__main__", 0, 32)
em.scope = Scope(null)

val_decl = ValDeclaration("x", NumberLiteral(42, 0, 0), 0, 0)
print("calling emitStmt...")
emitStmt(em, val_decl)
print("emitStmt returned")

bc.emit("PUSH_NULL")
bc.emit("RETURN")

print("executing...")
bc.execute("__main__")
print("ok")
