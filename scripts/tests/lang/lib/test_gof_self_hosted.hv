use fs
use { tokenize } from "lexer"
use { parseTokens } from "pratt"
use { Emitter, compileProgram } from "emitter"

print("Reading int_gof_patterns.hv...")
content = fs.read("scripts/integration/int_gof_patterns.hv")

print("Parsing int_gof_patterns.hv with self-hosted pratt.hv...")
print("Content length: " + str(#content))
tokens = tokenize(content)
print("Token count: " + str(#tokens))

res = parseTokens(tokens)
ast = res.ast
print("Parse finished. AST body length: " + str(#ast.body))

emitter = Emitter()
print("Emitter created.")
compileProgram(emitter, ast)
print("Compilation finished.")
