use fs
use { tokenize } from "lexer"
use { parseTokens } from "pratt"
use { Emitter, compileProgram } from "emitter"

print("Reading int_gof_patterns.hv...")
content = fs.read("scripts/integration/int_gof_patterns.hv")

tokens = tokenize(content)
res = parseTokens(tokens)
ast = res.ast

emitter = Emitter()
compileProgram(emitter, ast, true)

print("Searching __main__ disassembly for CustData...")
dasm = bc.disasm()
lines = []
acc = ""
for c in dasm {
    if c == "\n" {
        lines.push(acc)
        acc = ""
    } else {
        acc = acc + c
    }
}
lines.push(acc)

for line in lines {
    // manually search substring CustData since we don't have regex
    found = false
    for i in 0..(#line - 8) {
        sub = ""
        for j in 0..7 {
            sub = sub + line[i + j]
        }
        if sub == "CustData" {
            found = true
        }
    }
    if found {
        print(line)
    }
}
