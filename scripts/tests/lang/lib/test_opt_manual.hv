use { constantFold, deadCodeElim } from "optimizer"
use { NumberLiteral, BinaryExpression, BooleanLiteral, IfStatement, ExpressionStatement, Program } from "ast"

// Build AST for "1 + 2" manually
left = NumberLiteral(1, 1, 1)
right = NumberLiteral(2, 1, 5)
binExpr = BinaryExpression(left, "+", right, 1, 3)
exprStmt = ExpressionStatement(binExpr, 1, 1)
prog = Program([exprStmt], 1, 1)

folded = constantFold(prog)
if folded.kind == "Program" && #folded.body == 1 {
    e = folded.body[0]
    if e.kind == "ExpressionStatement" && e.expr.kind == "NumberLiteral" && e.expr.value == 3 {
        print("PASS: constant fold 1+2 -> 3")
    } else {
        print("FAIL: got kind=" + e.expr.kind + " val=" + str(e.expr.value))
    }
} else {
    print("FAIL: structure wrong")
}

// Test dead code elim: if false { A } else { B }
cond = BooleanLiteral(false, 1, 1)
thenBr = ExpressionStatement(NumberLiteral(1, 1, 1), 1, 1)
elseBr = ExpressionStatement(NumberLiteral(2, 1, 1), 1, 1)
ifStmt = IfStatement(cond, thenBr, elseBr, 1, 1)
prog2 = Program([ifStmt], 1, 1)

dce = deadCodeElim(prog2)
if dce.kind == "Program" && #dce.body == 1 {
    s = dce.body[0]
    if s.kind == "NullLiteral" || (s.kind == "ExpressionStatement" && s.expr.kind == "NumberLiteral" && s.expr.value == 2) {
        print("PASS: dead code elim if false")
    } else {
        print("FAIL: DCE got kind=" + s.kind)
    }
} else {
    print("FAIL: DCE structure")
}

// Test constant fold comparison
left3 = NumberLiteral(5, 1, 1)
right3 = NumberLiteral(3, 1, 5)
cmpExpr = BinaryExpression(left3, ">", right3, 1, 3)
exprStmt3 = ExpressionStatement(cmpExpr, 1, 1)
prog3 = Program([exprStmt3], 1, 1)

folded3 = constantFold(prog3)
e3 = folded3.body[0]
if e3.expr.kind == "BooleanLiteral" && e3.expr.value == true {
    print("PASS: constant fold 5>3 -> true")
} else {
    print("FAIL: fold cmp got kind=" + e3.expr.kind + " val=" + str(e3.expr.value))
}

// Test constant fold unary negation
operand = NumberLiteral(42, 1, 1)
unary = {kind: "UnaryExpression", oper: "-", operand: operand, line: 1, col: 1}
exprStmt4 = ExpressionStatement(unary, 1, 1)
prog4 = Program([exprStmt4], 1, 1)

folded4 = constantFold(prog4)
e4 = folded4.body[0]
if e4.expr.kind == "NumberLiteral" && e4.expr.value == -42 {
    print("PASS: constant fold -42 -> -42")
} else {
    print("FAIL: fold unary got kind=" + e4.expr.kind + " val=" + str(e4.expr.value))
}

print("optimizer tests done")
