use { parse, parseTokens } from pratt
use { tokenize } from lexer
use { isNode } from ast

r1 = parse("fn double(n) n * 2")
if r1.ast != null:
    print("T1: expression-body fn - OK")
else:
    print("T1: expression-body fn - FAIL: " + str(r1.errors))

r2 = parse("fn foo():\n  42")
if r2.ast != null:
    fn2 = r2.ast
    if isNode(fn2, "Program"):
        fn2 = fn2.body[0]
    print("T2: colon-body fn kind=" + fn2.kind)
    if fn2.body != null:
        print("T2: body kind=" + fn2.body.kind)
    else:
        print("T2: body is null")
else:
    print("T2: colon-body fn - FAIL: " + str(r2.errors))

r3 = parse("42")
if r3.ast != null:
    print("T3: simple number - OK")
else:
    print("T3: simple number - FAIL: " + str(r3.errors))
