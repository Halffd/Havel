// End-to-end test for the pure-Havel Pratt parser
// Exercises: lexing → parsing → AST structure verification

use { parse, parseTokens } from "pratt"
use { tokenize } from "lexer"
use { prettyPrint, isNode } from "ast"

passed = 0
failed = 0

fn check(name, cond) {
  if cond {
    passed = passed + 1
  }
  else {
    failed = failed + 1
    print("FAIL: " + name)

  }
}
fn nodeKind(ast, idx) {
  if idx < #ast.body: ast.body[idx].kind
  else: null

}
fn exprKind(ast, idx) {
  s = ast.body[idx]
  if s != null and s.kind == "ExpressionStatement" and s.expr != null: s.expr.kind
  else: null

}
fn firstExpr(ast) {
  if #ast.body > 0 and ast.body[0].kind == "ExpressionStatement": ast.body[0].expr
  else: null

}
fn firstStmt(ast) {
  if #ast.body > 0: ast.body[0]
  else: null

}
// ============================================================
// 1. Literals
// ============================================================
r = parse("42")
check("number literal kind", r.ast.kind == "Program")
check("number literal body len", #r.ast.body == 1)
check("number literal expr", exprKind(r.ast, 0) == "NumberLiteral")
check("number literal value", firstExpr(r.ast).value == "42")
check("number no errors", #r.errors == 0)

r = parse('"hello"')
check("string literal kind", exprKind(r.ast, 0) == "StringLiteral")
check("string literal value", firstExpr(r.ast).value == "hello")

r = parse("true")
check("bool true kind", exprKind(r.ast, 0) == "BooleanLiteral")
check("bool true value", firstExpr(r.ast).value == true)

r = parse("false")
check("bool false kind", exprKind(r.ast, 0) == "BooleanLiteral")
check("bool false value", firstExpr(r.ast).value == false)

r = parse("null")
check("null kind", exprKind(r.ast, 0) == "NullLiteral")

// ============================================================
// 2. Identifiers
// ============================================================
r = parse("x")
check("identifier kind", exprKind(r.ast, 0) == "Identifier")
check("identifier name", firstExpr(r.ast).name == "x")

// ============================================================
// 3. Binary expressions
// ============================================================
r = parse("1 + 2")
e = firstExpr(r.ast)
check("binary kind", e.kind == "BinaryExpression")
check("binary op", e.oper == "+")
check("binary left", e.left.kind == "NumberLiteral")
check("binary right", e.right.kind == "NumberLiteral")

// Precedence: 1 + 2 * 3 should parse as 1 + (2 * 3)
r = parse("1 + 2 * 3")
e = firstExpr(r.ast)
check("precedence: top is +", e.oper == "+")
check("precedence: right is *", e.right.oper == "*")

// Left associativity: 1 - 2 - 3 should be (1-2)-3
r = parse("1 - 2 - 3")
e = firstExpr(r.ast)
check("left assoc: top is -", e.oper == "-")
check("left assoc: left is -", e.left.oper == "-")

// Power is right-assoc: 2 ** 3 ** 4 should be 2 ** (3 ** 4)
r = parse("2 ** 3 ** 4")
e = firstExpr(r.ast)
check("power right assoc: top is **", e.oper == "**")
check("power right assoc: right is **", e.right.oper == "**")

// ============================================================
// 4. Unary expressions
// ============================================================
r = parse("-x")
e = firstExpr(r.ast)
check("unary neg kind", e.kind == "UnaryExpression")
check("unary neg op", e.oper == "-")
check("unary neg operand", e.operand.kind == "Identifier")

r = parse("!flag")
e = firstExpr(r.ast)
check("unary not kind", e.kind == "UnaryExpression")
check("unary not op", e.oper == "!")

r = parse("not x")
e = firstExpr(r.ast)
check("unary not-word kind", e.kind == "UnaryExpression")
check("unary not-word op", e.oper == "not")

// ============================================================
// 5. Comparison and logical
// ============================================================
r = parse("a == b")
check("equality op", firstExpr(r.ast).oper == "==")

r = parse("a != b")
check("inequality op", firstExpr(r.ast).oper == "!=")

r = parse("a < b")
check("less than op", firstExpr(r.ast).oper == "<")

r = parse("a && b")
check("logical and", firstExpr(r.ast).oper == "&&")

r = parse("a || b")
check("logical or", firstExpr(r.ast).oper == "||")

r = parse("a ?? b")
check("nullish coalesce", firstExpr(r.ast).oper == "??")

// ============================================================
// 6. Assignment
// ============================================================
r = parse("x = 10")
e = firstExpr(r.ast)
check("assign kind", e.kind == "AssignmentExpression")
check("assign target", e.target.kind == "Identifier")
check("assign value", e.value.kind == "NumberLiteral")

r = parse("x += 5")
e = firstExpr(r.ast)
check("compound assign kind", e.kind == "CompoundAssignment")
check("compound assign op", e.oper == "+=")

// ============================================================
// 7. Member access and calls
// ============================================================
r = parse("obj.field")
e = firstExpr(r.ast)
check("member kind", e.kind == "MemberExpression")
check("member obj", e.obj.kind == "Identifier")
check("member prop", e.property == "field")

r = parse("foo()")
e = firstExpr(r.ast)
check("call kind", e.kind == "CallExpression")
check("call callee", e.callee.kind == "Identifier")
check("call args empty", #e.args == 0)

r = parse("foo(1, 2)")
e = firstExpr(r.ast)
check("call with args", #e.args == 2)

r = parse("obj.method(1)")
e = firstExpr(r.ast)
check("method call kind", e.kind == "CallExpression")
check("method call callee is member", e.callee.kind == "MemberExpression")

// ============================================================
// 8. Index expressions
// ============================================================
r = parse("arr[0]")
e = firstExpr(r.ast)
check("index kind", e.kind == "IndexExpression")
check("index obj", e.obj.kind == "Identifier")

// ============================================================
// 9. Ternary
// ============================================================
r = parse("a ? b : c")
e = firstExpr(r.ast)
check("ternary kind", e.kind == "TernaryExpression")
check("ternary cond", e.condition.kind == "Identifier")
check("ternary true", e.true_expr.kind == "Identifier")
check("ternary false", e.false_expr.kind == "Identifier")

// ============================================================
// 10. Array literal
// ============================================================
r = parse("[1, 2, 3]")
e = firstExpr(r.ast)
check("array kind", e.kind == "ArrayLiteral")
check("array elements", #e.elements == 3)

// ============================================================
// 11. Object literal
// ============================================================
r = parse('{name: "test", age: 30}')
e = firstExpr(r.ast)
check("object kind", e.kind == "ObjectLiteral")
check("object fields", #e.fields == 2)

// ============================================================
// 12. Let/val declarations
// ============================================================
r = parse("val x = 10")
s = firstStmt(r.ast)
check("val kind", s.kind == "ValDeclaration")
check("val name", s.name == "x")
check("val value", s.value.kind == "NumberLiteral")

r = parse("let y = 20")
s = firstStmt(r.ast)
check("let kind", s.kind == "LetDeclaration")
check("let name", s.name == "y")

// ============================================================
// 13. If statement
// ============================================================
r = parse("if x > 0 { print(x) }")
s = firstStmt(r.ast)
check("if kind", s.kind == "IfStatement")
check("if condition", s.condition.kind == "BinaryExpression")
check("if then", s.then.kind == "BlockStatement")
check("if no else", s.else == null)

r = parse("if x { a } else { b }")
s = firstStmt(r.ast)
check("if-else has else", s.else != null)

// ============================================================
// 14. While statement
// ============================================================
r = parse("while x > 0 { x = x - 1 }")
s = firstStmt(r.ast)
check("while kind", s.kind == "WhileStatement")
check("while condition", s.condition.kind == "BinaryExpression")

// ============================================================
// 15. For statement
// ============================================================
r = parse("for i in items { print(i) }")
s = firstStmt(r.ast)
check("for kind", s.kind == "ForStatement")
check("for name", s.name == "i")
check("for iterator", s.iterator.kind == "Identifier")

// ============================================================
// 16. Fn declaration
// ============================================================
r = parse("fn add(a, b) a + b")
s = firstStmt(r.ast)
check("fn kind", s.kind == "FnDeclaration")
check("fn name", s.name == "add")
check("fn params", #s.params == 2)

r = parse('fn greet(name) { print("hello") }')
s = firstStmt(r.ast)
check("fn with block body", s.body.kind == "BlockStatement")

// ============================================================
// 17. Return statement
// ============================================================
r = parse("return x")
s = firstStmt(r.ast)
check("return kind", s.kind == "ReturnStatement")
check("return value", s.value.kind == "Identifier")

r = parse("return")
s = firstStmt(r.ast)
check("return void", s.kind == "ReturnStatement")
check("return void no value", s.value == null)

// ============================================================
// 18. Break/Continue
// ============================================================
r = parse("break")
check("break kind", firstStmt(r.ast).kind == "BreakStatement")

r = parse("continue")
check("continue kind", firstStmt(r.ast).kind == "ContinueStatement")

// ============================================================
// 19. Lambda expressions
// ============================================================
r = parse("fn (x) x + 1")
e = firstExpr(r.ast)
check("lambda kind", e.kind == "LambdaExpression")
check("lambda params", #e.params == 1)

r = parse("(x) => x + 1")
e = firstExpr(r.ast)
check("arrow lambda kind", e.kind == "LambdaExpression")

// ============================================================
// 20. Range expressions
// ============================================================
r = parse("1..10")
e = firstExpr(r.ast)
check("range kind", e.kind == "RangeExpression")

r = parse("1..=10")
e = firstExpr(r.ast)
check("range inclusive kind", e.kind == "RangeExpression")

// ============================================================
// 21. Pipeline expression
// ============================================================
r = parse("x |> f")
e = firstExpr(r.ast)
check("pipe kind", e.kind == "PipelineExpression")

// ============================================================
// 22. Try/catch
// ============================================================
r = parse('try { x } catch e { print(e) }')
s = firstStmt(r.ast)
check("try kind", s.kind == "TryStatement")
check("try block", s.try_block.kind == "BlockStatement")
check("try catch param", s.catch_param == "e")

// ============================================================
// 23. Throw
// ============================================================
r = parse('throw "error"')
s = firstStmt(r.ast)
check("throw kind", s.kind == "ThrowStatement")

// ============================================================
// 24. Match expression
// ============================================================
r = parse("match x { 1 => \"one\" 2 => \"two\" }")
e = firstExpr(r.ast)
check("match kind", e.kind == "MatchExpression")

// ============================================================
// 25. Use statement
// ============================================================
r = parse('use { foo } from "bar"')
s = firstStmt(r.ast)
check("use kind", s.kind == "UseStatement")

// ============================================================
// 26. Loop statement
// ============================================================
r = parse("loop { x = x - 1 }")
s = firstStmt(r.ast)
check("loop kind", s.kind == "LoopStatement")

// ============================================================
// 27. Repeat statement
// ============================================================
r = parse("repeat 5 { print(i) }")
s = firstStmt(r.ast)
check("repeat kind", s.kind == "RepeatStatement")

// ============================================================
// 28. Import statement
// ============================================================
r = parse('import "math"')
s = firstStmt(r.ast)
check("import kind", s.kind == "ImportStatement")

// ============================================================
// 29. Postfix ++/--
// ============================================================
r = parse("x++")
e = firstExpr(r.ast)
check("postfix ++ kind", e.kind == "UpdateExpression")
check("postfix ++ op", e.oper == "++")
check("postfix not prefix", e.prefix == false)

r = parse("x--")
e = firstExpr(r.ast)
check("postfix -- kind", e.kind == "UpdateExpression")

r = parse("++x")
e = firstExpr(r.ast)
check("prefix ++ kind", e.kind == "UpdateExpression")
check("prefix ++ is prefix", e.prefix == true)

// ============================================================
// 30. Nested member + call chains
// ============================================================
r = parse("a.b.c(1)")
e = firstExpr(r.ast)
check("chained call kind", e.kind == "CallExpression")
check("chained call callee is member", e.callee.kind == "MemberExpression")

// ============================================================
// 31. Complex expressions
// ============================================================
r = parse("(a + b) * (c - d)")
e = firstExpr(r.ast)
check("grouped expr is *", e.oper == "*")
check("grouped left is +", e.left.oper == "+")
check("grouped right is -", e.right.oper == "-")

// ============================================================
// 32. Multiple statements
// ============================================================
r = parse('val a = 1\nval b = 2\nval c = a + b')
check("multi stmt body len", #r.ast.body == 3)
check("multi stmt kinds", nodeKind(r.ast, 0) == "ValDeclaration" and nodeKind(r.ast, 1) == "ValDeclaration" and nodeKind(r.ast, 2) == "ValDeclaration")

// ============================================================
// 33. Bitwise operations
// ============================================================
r = parse("a & b")
tokens = tokenize("a & b")
for t in tokens: print("TOK: " + t.type + " " + t.value)
print("DEBUG and: body0kind=" + r.ast.body[0].kind + " body0exprkind=" + str(r.ast.body[0].expr.kind))
check("bitwise and", firstExpr(r.ast).oper == "&")

tokens = tokenize("a | b")
for t in tokens: print("TOK: " + t.type + " " + t.value)
print("DEBUG or: body0kind=" + r.ast.body[0].kind + " body0exprkind=" + str(r.ast.body[0].expr.kind))
r = parse("a | b")
check("bitwise or", firstExpr(r.ast).oper == "|")

tokens = tokenize("a ^ b")
for t in tokens: print("TOK: " + t.type + " " + t.value)
print("DEBUG xor: body0kind=" + r.ast.body[0].kind + " body0exprkind=" + str(r.ast.body[0].expr.kind))
r = parse("a ^ b")
check("bitwise xor", firstExpr(r.ast).oper == "^")

r = parse("a << 2")
check("left shift", firstExpr(r.ast).oper == "<<")

r = parse("a >> 2")
check("right shift", firstExpr(r.ast).oper == ">>")

// ============================================================
// 34. in / not in
// ============================================================
r = parse("x in list")
e = firstExpr(r.ast)
check("in operator", e.oper == "in")

r = parse("x not in list")
e = firstExpr(r.ast)
check("not in operator", e.oper == "not in")

// ============================================================
// 35. is operator
// ============================================================
r = parse("x is String")
e = firstExpr(r.ast)
check("is operator", e.oper == "is")

// ============================================================
// 36. Slice desugaring
// ============================================================
r = parse("arr[1..5]")
e = firstExpr(r.ast)
// slice should desugar to arr.slice(1, 5) call
check("slice desugars to call", e.kind == "CallExpression")

// ============================================================
// 37. Pipeline with call prepend
// ============================================================
r = parse("x |> f(1)")
e = firstExpr(r.ast)
// x |> f(1) should become f(x, 1)
check("pipe prepend: callee is f", e.right.callee.name == "f")
check("pipe prepend: first arg is x", e.right.args[0].kind == "Identifier")

// ============================================================
// 38. Sleep statement
// ============================================================
r = parse("sleep 100")
s = firstStmt(r.ast)
check("sleep kind", s.kind == "SleepStatement")

// ============================================================
// 39. @ and @@ expressions
// ============================================================
r = parse("@field")
e = firstExpr(r.ast)
check("@ expr kind", e.kind == "AtExpression")

r = parse("@@field")
e = firstExpr(r.ast)
check("@@ expr kind", e.kind == "AtAtExpression")

// ============================================================
// 40. Spread in array
// ============================================================
r = parse("[1, ...arr, 2]")
e = firstExpr(r.ast)
// Check that one element is a spread
has_spread = false
for el in e.elements {
 if el.kind == "SpreadExpression": has_spread = true
}
check("spread in array", has_spread)

// ============================================================
// 41. String interpolation
// ============================================================
r = parse('"hello {name}"')
e = firstExpr(r.ast)
check("interpolated string kind", e.kind == "InterpolatedString")

// ============================================================
// 42. Backtick / shell command
// ============================================================
r = parse("`ls -la`")
e = firstExpr(r.ast)
check("backtick kind", e.kind == "ShellCommand" or e.kind == "BacktickExpression")

// ============================================================
// 43. Regex literal
// ============================================================
r = parse("/[a-z]+/gi")
e = firstExpr(r.ast)
check("regex kind", e.kind == "RegexLiteral")

// ============================================================
// 44. For with key-value
// ============================================================
r = parse("for k, v in dict { print(k) }")
s = firstStmt(r.ast)
check("for kv kind", s.kind == "ForStatement")

// ============================================================
// 45. try/finally
// ============================================================
r = parse('try { x } finally { cleanup() }')
s = firstStmt(r.ast)
check("try-finally kind", s.kind == "TryStatement")
check("try-finally has finally", s.finally_block != null)

// ============================================================
// 46. For-else
// ============================================================
r = parse("for i in items { print(i) } else { print('empty') }")
s = firstStmt(r.ast)
check("for-else kind", s.kind == "ForStatement")

// ============================================================
// 47. While-else
// ============================================================
r = parse("while x > 0 { x-- } else { print('done') }")
s = firstStmt(r.ast)
check("while-else kind", s.kind == "WhileStatement")

// ============================================================
// 48. Complex fn declaration with defaults
// ============================================================
r = parse("fn add(a, b = 0) a + b")
s = firstStmt(r.ast)
check("fn with defaults kind", s.kind == "FnDeclaration")

// ============================================================
// 49. Fn with variadic
// ============================================================
r = parse("fn variadic(a, ...rest) a")
s = firstStmt(r.ast)
check("fn variadic kind", s.kind == "FnDeclaration")

// ============================================================
// 50. Empty program
// ============================================================
r = parse("")
check("empty program", r.ast.kind == "Program" and #r.ast.body == 0)

// ============================================================
// 51. prettyPrint smoke test
// ============================================================
r = parse("1 + 2 * 3")
print("--- prettyPrint smoke test ---")
prettyPrint(r.ast)

// ============================================================
// Summary
// ============================================================
print("")
print("============================")
print("passed: " + passed)
print("failed: " + failed)
if failed == 0 {
 print("all parser tests passed")
}
else {
 print("some tests failed")

}