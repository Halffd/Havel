// Test lambda with closure capturing outer vars
fn make_counter() {
    count = 0
    fn increment() {
        count = count + 1
        count
    }
    increment

}
c = make_counter()
print(c())
print(c())
print(c())

fn make_adder(x) {
    fn add(y) {
        x + y
    }
    add

}
add5 = make_adder(5)
add10 = make_adder(10)
print(add5(3))
print(add10(3))
