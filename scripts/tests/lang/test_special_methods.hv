class MyClass
    value

    fn @(v)
        @value = v

    fn repr()
        "MyClass(value=$@value)"

    fn code()
        "class MyClass"

    fn ""()
        "String: $@value"
    
    fn #()
        42

obj = MyClass(100)
print(obj.repr())
print(obj.code())
print(""obj)
print(#obj)

class Vec2
    x, y

    fn @(x, y)
        @x = x
        @y = y

    fn @-()
        print("Vec2 destroyed")

    fn +(other)
        Vec2(@x + other.x, @y + other.y)

    fn ""()
        "Vec2($@x, $@y)"

v = Vec2(1, 2)
print(v)
print(v + Vec2(3, 4))