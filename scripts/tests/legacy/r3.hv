// Each pair is [value_in, value_out]
// ratio = value_out / value_in
known_pairs = [[14, 10], [8, 6], [32, 20]]
print("Known pairs: " + str(known_pairs))
target_value = 3
print("Target value: " + str(target_value))

fn estimate_simple_ratio(pairs, input_value) {
  first_in = pairs[0][0]
  first_out = pairs[0][1]
  input_value * first_out / first_in
}

fn estimate_average_ratio(pairs, input_value) {
  sum_of_estimates = 0.0
  count = 0

  for in_value, out_value in pairs {
    try {
      ratio_estimate = input_value * out_value / in_value
      sum_of_estimates += ratio_estimate
      count += 1
    } catch (e) {
      print("Error calculating ratio for pair: " + str([in_value, out_value]) + " - " + str(e))
      continue
    }
  }

  sum_of_estimates / count
}

fn estimate_compounded_ratio(pairs, input_value) {
  compounded_result = input_value

  for in_value, out_value in pairs {
    compounded_result = compounded_result * out_value / in_value
  }
  compounded_result
}

simple_result = estimate_simple_ratio(known_pairs, target_value)
average_result = estimate_average_ratio(known_pairs, target_value)
compound_result = estimate_compounded_ratio(known_pairs, target_value)

print("Result (simple): " + str(simple_result))
print("Result (average): " + str(average_result))
print("Result (compound): " + str(compound_result))

results = known_pairs.map(fn(pair) {
  in_val = pair[0]
  out_val = pair[1]
  out_val * target_value / in_val
})

print("Simple: " + str(results[0]))
print("Average: " + str(results.sum() / results.len()))

compound = target_value
for in_val, out_val in known_pairs {
  compound = compound * out_val / in_val
}
print("Compound: " + str(compound))

fn estimate(p, t) {    
    th = 1.2
    p * {"fp32": 4, "fp16": 2, "int8": 1, "int4": 0.5}.get(t) * th
}
fn max_params(vram_gb, precision) {
    bytes = {"fp32": 4, "fp16": 2, "int8": 1, "int4": 0.5}
    overhead = 1.2
    vram_gb / (bytes[precision] * overhead)
}
for i in ["fp32", "fp16", "int8", "int4"] {
    for p in [1, 2, 3, 4, 8, 14, 45, 64, 144] {
        print("P: " + i + ", N: " + str(p) + ", Estimate: " + str(estimate(p, i)))
    }
}
vram = sys.hardware().gpu.vram
b = max_params(vram, "fp16")
try {
    print("Max params for fp16: " + str(b))
    run(f"ollama run --model qwen3:$b --prompt 'What is 2+2?'")
} catch (e) {
    print("Error calculating max params: " + str(e))
}