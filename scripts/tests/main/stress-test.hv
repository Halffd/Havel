Esc => {
    print("exiting")
    exit(0)
}
count = 0
F1 => {
    print("f1 pressed")
    interval 1000 {
        count += 1
        print("count: $count")
    }
}
F2 => {
    print("f2 pressed")
    interval 1000 {
        count += 5
        print("count: $count")
    }
}
Backspace => {
    print("backspace pressed")
    count = 0
}

go fn() {
    print("goroutine 1: hello from go")
    loop {
        print("goroutine 1: tick")
        sleep(500)
    }
}

go fn() {
    print("goroutine 2: hello from go")
    n = 0
    while true {
        n += 1
    }
}

n = 0
while true {
   n += 1
}
