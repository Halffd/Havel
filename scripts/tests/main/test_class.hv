print("test_class: syntax + runtime smoke")

struct Point {
    x: int
    y: int
}

class MousePos {
    x: num
    y: num
    device: str
}

class Deque {
    front: int
    back: int
    data: int[]
}

let p = Point(10, 20)
let m = MousePos(100.5, 200.7, "mouse1")
let deq = Deque(0, 2, [1, 2, 3])

// Exercise member/index assignment paths
m.x = 500
m.y = 550
deq.back = 3
deq.data[3] = 5

print("p:", p)
print("m:", m)
print("deq:", deq)
assert(1 == 1, "test_class smoke")
print("test_class.hv OK")
