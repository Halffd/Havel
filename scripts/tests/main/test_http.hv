let patchResp = http.patch(patchUrl, patchBody, {
  headers: { "Content-Type": "application/json" }
})
if patchResp.ok {
  print(f"PATCH Success! Status: {patchResp.status}")
  print(patchResp.body)
} else {
  print(f"PATCH Failed: {patchResp.status}")
}
