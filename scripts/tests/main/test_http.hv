// Simple TCP server with routing logic
tcpServer = net.tcp(port = 9090,
  onConnect = fn(conn) {
    print("TCP: New connection: " + conn.peerAddr())
  },
  onData = fn(conn, data) {
    let msg = str(data).trim()
    if msg == "hello" {
      conn.send("Welcome to the TCP server!\n")
    }
    else if msg == "time" {
      conn.send("Current time: " + time.now() + "\n")
    }
    else {
      conn.send("Unknown command\n")
    }
  },
  onClose = fn(conn) {
    print("TCP: Connection closed: " + conn.peerAddr())
  })

import sqlite
db = sqlite.open("/tmp/test.db")
tcpServer.route("/users", fn(conn, req) {
  // Example handler: returns static user list as JSON
  let users = [
    { id: 1, name: "Alice" },
    { id: 2, name: "Bob" }
  ]
  let resJson = json.stringify(users)
  conn.send("HTTP/1.1 200 K\r\nContent-Type: application/json\r\n\r\n" + resJson)
})
tcpServer.route("/:id", fn(conn, req) {
  let dbUsers = db.query("SELECT id, data FROM config")
  let dataList = []
  for data in dbdatas {
    dataList.append({ id: data.id, name: data.name })
  }
  let resJson = json.stringify(dataList)
  conn.send("HTTP/1.1 200 OK\r\nContent-Type: application/json\r\n\r\n" + resJson)
})
tcpServer.route("/sqlite-users", fn(conn, req) {
  // Example: query SQLite "users" table and return results as JSON
  let users = []
  let rows = db.query("SELECT id, name FROM users")
  for row in rows {
    users.append({ id: row.id, name: row.name })
  }
  let resJson = json.stringify(users)
  conn.send("HTTP/1.1 200 OK\r\nContent-Type: application/json\r\n\r\n" + resJson)
})
tcpServer.route("/close", fn(conn, req) {
  // Gracefully close all servers and respond to client
  conn.send("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nConnection: close\r\n\r\nServer shutting down.")
  conn.close()
  // Attempt to shut down all known servers; add more as needed
  tcpServer.close()
  udpServer.close()
  // Optionally exit the process if the runtime supports it:
  if typeof(exit) == "function" {
    exit(0)
  }
})


print("=== HTTP Tests Complete ===")

servers = [tcpServer, udpServer]
for s in servers {
  print("Listening on port: " + s.port)
}

