// Test 4: http.post
print("4. Testing http.post:")
let postUrl = "https://httpbin.org/post"
let postBody = json.stringify({ foo: "bar", count: 42 })
let postResp = http.post(postUrl, postBody, {
  timeout: 5000,
  headers: {
    "Content-Type": "application/json",
    "Custom-Header": "test"
  },
  follow_redirects: true,
  verify_ssl: true
})
if postResp.ok {
  print(f"POST Success! Status: {postResp.status}")
  try {
    print(postResp.json())
  } catch {
    print("POST not json")
  }
} else {
  print(f"POST Failed: {postResp.status}")
}
print("")

// Test 5: http.put
print("5. Testing http.put:")
let putUrl = "https://httpbin.org/put"
let putBody = json.stringify({ update: "something", num: 7 })
let putResp = http.put(putUrl, putBody, {
  headers: { "Content-Type": "application/json" },
  timeout: 3000
})
if putResp.ok {
  print(f"PUT Success! Status: {putResp.status}")
  print(putResp.body)
} else {
  print(f"PUT Failed: {putResp.status}")
}
print("")

