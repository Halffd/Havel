// Test 3: http.download
print("3. Testing http.download:")
let downloadUrl = "https://httpbin.org/bytes/100"
let downloadPath = "/tmp/test_download.bin"
let downloadSuccess = http.download(downloadUrl, downloadPath, 5000)
print("  Download success: ")
