// test string indexing and substring slicing

s = "hello world"

// string index
assert(s[0] == "h", {"s[0] should be h, got {s[0]}"})
assert(s[1] == "e", {"s[1] should be e, got {s[1]}"})
assert(s[-1] == "d", {"s[-1] should be d, got {s[-1]}"})
assert(s[-2] == "l", {"s[-2] should be l, got {s[-2]}"})

// string slice with colon
assert(s[0:5] == "hello", {"s[0:5] should be hello, got {s[0:5]}"})
assert(s[6:] == "world", {"s[6:] should be world, got {s[6:]}"})
assert(s[:5] == "hello", {"s[:5] should be hello, got {s[:5]}"})
assert(s[6:11] == "world", {"s[6:11] should be world, got {s[6:11]}"})

// string .slice() method
assert(s.slice(0, 5) == "hello", {"s.slice(0,5) should be hello"})
assert(s.slice(6) == "world", {"s.slice(6) should be world"})

// array indexing
a = [10, 20, 30, 40, 50]
assert(a[0] == 10, {"a[0] should be 10"})
assert(a[2] == 30, {"a[2] should be 30"})
assert(a[-1] == 50, {"a[-1] should be 50"})

// array slice with colon
assert(a[1:3] == [20, 30], {"a[1:3] should be [20,30]"})
assert(a[:2] == [10, 20], {"a[:2] should be [10,20]"})
assert(a[2:] == [30, 40, 50], {"a[2:] should be [30,40,50]"})

// array .slice() method
assert(a.slice(1, 3) == [20, 30], {"a.slice(1,3) should be [20,30]"})
assert(a.slice(3) == [40, 50], {"a.slice(3) should be [40,50]"})

// out of bounds string index returns null
assert(s[100] == null, {"s[100] should be null"})

print("all string/array indexing and slicing tests passed")
