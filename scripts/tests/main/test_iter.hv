// Test iteration protocol
print("=== Iteration Protocol Tests ===")

// Test 1: Array iteration
print("\n1. Array iteration:")
arr = [1, 2, 3]
for x in arr {
  print("  ")
  print(x)
}

// Test 2: String iteration (character by character)
print("\n2. String iteration:")
str = "abc"
for c in str {
  print("  '")
  print(c)
  print("'")
}

// Test 3: Object iteration (key by key)
print("\n3. Object iteration:")
obj = {"a": 1, "b": 2, "c": 3}
for entry, n in obj {
  print(f"  key: $entry")
  print(f"  2nd: {n}")
}
for entry in obj {
  print(f"  entry: $entry")
}
for x in 1..100..3 {
  print(x, end=" ")
}

print("\n=== All Tests Passed ===")
