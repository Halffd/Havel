// Test match expression

print("=== Match Expression Tests ===\n")

// Test 1: Simple match
print("1. Testing simple match:")
let x = 2
let result = match x {
  1 => "one"
  2 => "two"
  3 => "three"
  _ => "other"
}
print("  match 2 = ")
print(result)
print("")

// Test 2: Match with enum
print("2. Testing match with enum:")
let ok = newEnum("Result", "Ok", 42)
let variant = getVariant(ok)
let msg = match variant {
  "Ok" => "Success"
  "Err" => "Failed"
  _ => "Unknown"
}
print("  match Ok variant = ")
print(msg)
print("")

// Test 3: Match without default
print("3. Testing match without default:")
let y = 1
let r = match y {
  1 => "yes"
  0 => "no"
}
print("  match 1 = ")
print(r)
print("")

print("=== Match Tests Complete ===")
