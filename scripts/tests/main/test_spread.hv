// Test spread operator

print("=== Spread Operator Tests ===\n")

// Test 1: Array spread
print("1. Testing array spread:")
let arr1 = [1, 2, 3]
let arr2 = [...arr1, 4, 5, 6]
print("  arr2: ")
print(arr2)
print("")

// Test 2: Multiple spreads
print("2. Testing multiple spreads:")
let a = [1, 2]
let b = [3, 4]
let c = [...a, ...b, 5, 6]
print("  c: ")
print(c)
print("")

// Test 3: Spread at end
print("3. Testing spread at end:")
let d = [0, ...arr1]
print("  d: ")
print(d)
print("")

print("=== Spread Tests Complete ===")
