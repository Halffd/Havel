// Test structs (value types) and classes (reference types)

print("=== Struct and Class Test ===\n")

// Test 1: Struct value type semantics - copy on assignment
print("1. Testing struct value semantics:")
let Point = struct.define("Point", ["x", "y"])
let p1 = struct.new(Point, 10, 20)
let p2 = p1  // Should copy p1
struct.set(p2, "x", 30)

print("  p1.x after p2.x = 30: " + str(struct.get(p1, "x")))  // Should be 10
print("  p2.x after p2.x = 30: " + str(struct.get(p2, "x")))  // Should be 30

if struct.get(p1, "x") == 10 && struct.get(p2, "x") == 30 {
  print("  ✓ Struct copy semantics work correctly\n")
} else {
  print("  ✗ Struct copy semantics FAILED\n")
}

// Test 2: Class reference type semantics - shared identity
print("2. Testing class reference semantics:")
let Window = class.define("Window", ["x", "y"])
let w1 = class.new(Window, 100, 200)
let w2 = w1  // Should reference the same object
class.set(w2, "x", 300)

print("  w1.x after w2.x = 300: " + str(class.get(w1, "x")))  // Should be 300
print("  w2.x after w2.x = 300: " + str(class.get(w2, "x")))  // Should be 300

if class.get(w1, "x") == 300 && class.get(w2, "x") == 300 {
  print("  ✓ Class reference semantics work correctly\n")
} else {
  print("  ✗ Class reference semantics FAILED\n")
}

// Test 3: Struct operations
print("3. Testing struct operations:")
let p3 = struct.new(Point, 5, 10)
print("  p3.x: " + str(struct.get(p3, "x")))
print("  p3.y: " + str(struct.get(p3, "y")))

if struct.get(p3, "x") == 5 && struct.get(p3, "y") == 10 {
  print("  ✓ Struct get/set work correctly\n")
} else {
  print("  ✗ Struct get/set FAILED\n")
}

// Test 4: Class operations
print("4. Testing class operations:")
let w3 = class.new(Window, 50, 75)
print("  w3.x: " + str(class.get(w3, "x")))
print("  w3.y: " + str(class.get(w3, "y")))

if class.get(w3, "x") == 50 && class.get(w3, "y") == 75 {
  print("  ✓ Class get/set work correctly\n")
} else {
  print("  ✗ Class get/set FAILED\n")
}

// Test 5: Multiple struct instances
print("5. Testing multiple struct instances:")
let p4 = struct.new(Point, 1, 2)
let p5 = struct.new(Point, 3, 4)
struct.set(p4, "x", 100)

print("  p4.x after set: " + str(struct.get(p4, "x")))  // Should be 100
print("  p5.x (unchanged): " + str(struct.get(p5, "x")))  // Should be 3

if struct.get(p4, "x") == 100 && struct.get(p5, "x") == 3 {
  print("  ✓ Multiple struct instances are independent\n")
} else {
  print("  ✗ Multiple struct instances FAILED\n")
}

// Test 6: Multiple class instances
print("6. Testing multiple class instances:")
let w4 = class.new(Window, 10, 20)
let w5 = class.new(Window, 30, 40)
class.set(w4, "x", 999)

print("  w4.x after set: " + str(class.get(w4, "x")))  // Should be 999
print("  w5.x (unchanged): " + str(class.get(w5, "x")))  // Should be 30

if class.get(w4, "x") == 999 && class.get(w5, "x") == 30 {
  print("  ✓ Multiple class instances are independent\n")
} else {
  print("  ✗ Multiple class instances FAILED\n")
}

print("=== All tests completed ===")
