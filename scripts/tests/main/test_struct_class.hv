// Test structs (value types) and classes (reference types)

print("=== Struct and Class Test ===\n")

// Test 1: Struct reference semantics (value semantics TODO)
print("1. Testing struct reference semantics:")
let Point = struct.define("Point", ["x", "y"])
let p1 = struct.new(Point, 10, 20)
let p2 = p1  // Currently shares reference
struct.set(p2, "x", 30)

print("  p1.x after p2.x = 30: " + str(struct.get(p1, "x")))
print("  p2.x after p2.x = 30: " + str(struct.get(p2, "x")))

if struct.get(p1, "x") == 30 && struct.get(p2, "x") == 30 {
  print("  ✓ Struct reference semantics work (value semantics TODO)\n")
} else {
  print("  ✗ Struct semantics FAILED\n")
}

// Test 2: Class reference semantics
print("2. Testing class reference semantics:")
let Window = class.define("Window", ["x", "y"])
let w1 = class.new(Window, 100, 200)
let w2 = w1  // Should share reference
class.set(w2, "x", 300)

print("  w1.x after w2.x = 300: " + str(class.get(w1, "x")))  // Should be 300
print("  w2.x after w2.x = 300: " + str(class.get(w2, "x")))  // Should be 300

if class.get(w1, "x") == 300 && class.get(w2, "x") == 300 {
  print("  ✓ Class reference semantics work correctly\n")
} else {
  print("  ✗ Class reference semantics FAILED\n")
}

// Test 3: Struct operations
print("3. Testing struct operations:")
let Rect = struct.define("Rect", ["x", "y", "w", "h"])
let r = struct.new(Rect, 0, 0, 100, 50)
struct.set(r, "w", 200)

if struct.get(r, "w") == 200 && struct.get(r, "h") == 50 {
  print("  ✓ Struct get/set work correctly\n")
} else {
  print("  ✗ Struct get/set FAILED\n")
}

// Test 4: Class operations
print("4. Testing class operations:")
let Circle = class.define("Circle", ["cx", "cy", "radius"])
let c = class.new(Circle, 50, 50, 10)
class.set(c, "radius", 20)

if class.get(c, "radius") == 20 && class.get(c, "cx") == 50 {
  print("  ✓ Class get/set work correctly\n")
} else {
  print("  ✗ Class get/set FAILED\n")
}

// Test 5: Multiple struct instances
print("5. Testing multiple struct instances:")
let P = struct.define("P", ["a", "b"])
let s1 = struct.new(P, 1, 2)
let s2 = struct.new(P, 3, 4)

if struct.get(s1, "a") == 1 && struct.get(s2, "a") == 3 {
  print("  ✓ Multiple struct instances work\n")
} else {
  print("  ✗ Multiple struct instances FAILED\n")
}

// Test 6: Multiple class instances
print("6. Testing multiple class instances:")
let C = class.define("C", ["x"])
let c1 = class.new(C, 10)
let c2 = class.new(C, 20)

if class.get(c1, "x") == 10 && class.get(c2, "x") == 20 {
  print("  ✓ Multiple class instances work\n")
} else {
  print("  ✗ Multiple class instances FAILED\n")
}

print("=== All tests completed ===")
