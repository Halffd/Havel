// Test Phase 3: VM-level coroutines (Lua-style)
// This tests yield and coroutine state management

print("=== Testing yield ===")

fn generator() {
  yield 1
  sleep(1000) // Simulate some work
  yield 2
  sleep(500) // Simulate some work
  yield 3
  sleep(100) // Simulate some work
  return "done"
}
let gen = generator()
print("Generator created, resuming...")
print("Yielded value: " + str(next gen)) // Should print 1
print("Yielded value: " + str(next gen)) // Should print 2
print("Yielded value: " + str(next gen)) // Should print 3
print("Generator return value: " + str(next gen)) // Should print "done"

print("=== Testing coroutine creation and resume ===")

fn simple_yield() {
  print("Before yield")
  yield "yielded value"
  print("After yield")
}

print("Testing simple yield function...")
// The yield will return the value to the caller
let co = simple_yield()
print("Yield returned: " + next result) // Should print "yielded value"
print("Resuming coroutine...")
next result // Should print "After yield"

print("=== Testing coroutine with state ===")

fn counter() {
  let i = 0
  while i < 3 {
    i = i + 1
    yield i
  }
  return "finished"
}

print("Testing counter coroutine...")

let count = counter()
for i in 1..3 {
  print("Counter yielded: " + str(next count)) // Should print 1, then 2, then 3
}
print("Counter return value: " + str(next count)) // Should print "finished"

print("=== Phase 3 tests completed ===")

print("=== Testing channels ===")
// Channel creation
let [tx, rx] = channel()        // unbounded (or bounded with .bounded())
let [tx, rx] = channel(10)      // bounded with capacity 10

// Send
tx.send(42)
tx.send("hello")

// Receive (blocks)
let val = rx.recv()

// Try receive (non-blocking)
let val = rx.try()  // returns null if empty

// Receive with timeout
let val = rx.timeout(1000)  // wait 1 second

// Channel properties
print(rx.len())    // items waiting
print(rx.cap())    // capacity
print(rx.isEmpty())
print(rx.isFull())
print(rx.isClosed())

// Close
tx.close()
rx.close()  // also works

// Iteration
for val in rx {
    print(val)
}

select {
    val = rx.recv() => print(val),
    _ = tx.send(42) => print("sent"),
    timeout(1000) => print("timeout"),
}

print("=== Testing multiple receivers ===")
let [tx, rx] = channel()
let rx2 = rx.clone()  // multiple receivers

go {
    loop {
        let val = rx2.recv()
        print("Worker 1: " + val)
    }
}

go {
    loop {
        let val = rx.recv()
        print("Worker 2: " + val)
    }
}

sleep(500) // Give workers time to start
tx.send("work")  // goes to one worker
sleep(500)
rx.send("more work")  // goes to the other worker
tx.stop()  // stop the channel
rx2.stop() // also stop the clone

// yield from nested function
fn outer() {
    fn inner() {
        yield 42  // Should suspend outer()
    }
    inner()
    print("This runs after inner yields")
}

let gen = outer()
print(next gen)  // 42

// Solution: yield to nearest generator context
fn outer() {
    fn inner() {
        yield 42      // Yields from outer()
        yield 43      // Also from outer()
    }
    inner()
    yield 44          // From outer()
}

let g = outer()
print(next g)  // 42
print(next g)  // 43
print(next g)  // 44

// Explicit yield target
fn outer() {
    fn inner() {
        yield outer 42    // Explicit target
        yield current 43  // Current context
    }
}
fn broken() {
    yield 1
    throw "Something went wrong"
    yield 2  // Never reached
}

let gen = broken()
print(next gen)  // 1

// Error propagation
try {
    print(next gen)  // Throws error
} catch e {
    print("Coroutine error: " + e)
}

// Check if coroutine is dead
if gen.dead() {
    print("Coroutine is dead")
}

// Propagate error to parent
fn parent() {
    try {
        let child = broken()
        next child
        next child  // Error propagates here
    } catch e {
        print("Caught from child: " + e)
    }
}

// Example: using a coroutine as a generator
fn count_up_to(n) {
    let i = 0
    while i < n {
        yield i
        i = i + 1
    }
}
let counter = count_up_to(5)
for val in counter {
    print(val)  // Should print 0, 1, 2, 3
}
