print("=== Phase 1 tests completed ===")

print("=== Testing interval and timeout ===")
let counter = 0
let intv = interval 500 {
  counter = counter + 1
  print("Interval tick: " + str(counter))
}

print("Interval started, waiting for ticks...")
sleep(2200)

print("Stopping interval")
intv.stop()

let timeout_triggered = false
let n = 0
let tim = timeout 1000 {
  timeout_triggered = true
  n++
  print("Timeout triggered!")
}

print("Timeout scheduled, waiting...")
tim.wait()

if timeout_triggered {
  print("Timeout test PASSED")
} else {
  print("Timeout test FAILED")
}
print(n)
print("=== Testing timeout_cancel ===")

let timeout_triggered2 = false
let tim2 = timeout 2000 {
  timeout_triggered2 = true
  n++
  print("This should not print")
}

print("Timeout scheduled, cancelling now...")
tim2.stop()

sleep(2500)

if !timeout_triggered2 {
  print("Timeout cancel test PASSED")
} else {
  print("Timeout cancel test FAILED")
}

print("Starting interval pause/resume test...")

counter = 0
let expected_final_value = 5
let i2 = 50
let i3 = 120
let intv2 = interval i2 {
  counter = counter + 1
  print("Interval 2 tick: " + str(counter))
}
let intv3 = interval i3 {
  counter = counter - 1
  print("Interval 3 tick: " + str(counter))
}
let offset = 3 // Offset to account for the initial ticks before pausing
/*
i2 = 50
i3 = 120
1000 / i2 = 20 ticks of i2
1000 / i3 = 8.33 ticks of i3
20 * i3 = 2400 ms 
The formula is: (1000 / i2) * i3 = 2400 ms for 20 ticks of i2 and 8.33 ticks of i3, which should result in a counter value of 20 - 8.33 = 11.67 (approximately). After pausing interval 2, we should see the counter decrease by about 8.33 ticks of interval 3, resulting in a counter value of around 3.34 before resuming interval 2. After resuming, we should see the counter increase again by about 20 ticks of interval 2, resulting in a final counter value of around 23.34 before stopping both intervals. Offsetting by 4 to account for the initial ticks before pausing, we expect the final counter value to be around 19.34, which would indicate that the pause and resume functionality is working correctly.
At the end of the test, we expect the counter to be around 5, which would indicate that the pause and resume functionality is working correctly. 
*/
print("Interval 2 and 3 started, waiting for ticks...")
sleep(1000 + offset) // Wait for a few ticks of both intervals before pausing
print(counter)
print("Pausing interval 2")
intv2.pause()
until0 = (1000 / i2) * i3 + offset // Wait for enough time for interval 3 to tick a few times while interval 2 is paused
sleep(until0) // Wait for a few ticks of interval 3
print("Counter after pausing interval 2: " + str(counter))
print("Resuming interval 2")
intv2.resume()
sleep(500 + offset) // Wait for a few more ticks of both intervals
intv2.stop()
intv3.stop()
print("Final counter value: " + str(counter))
if counter == expected_final_value {
  print("Interval pause/resume test PASSED")
} else {
  // if around 5, then it's likely that the pause and resume functionality is working correctly, but there may be some timing variations. If it's significantly less than 5, it may indicate that the pause functionality is not working correctly, and if it's significantly greater than 5, it may indicate that the resume functionality is not working correctly.
  
  let diff = abs(counter - expected_final_value)
  if diff <= 2 {
      print("PASS (within tolerance)")
  } else {
    if counter < expected_final_value {
      print("Interval pause/resume test FAILED: Counter is less than expected final value.")
    } else {
      print("Interval pause/resume test FAILED: Counter is greater than expected final value.")
    }
    print("Interval pause/resume test FAILED")
  }
}
