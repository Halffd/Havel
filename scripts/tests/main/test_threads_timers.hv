// Test Phase 1: threads
fn task(name) {
  print("Task " + name + " started")
  run("ping -c 3 localhost") // Simulate some work by running a command that takes time (pinging localhost 3 times, should take around 3 seconds)
  print("Task " + name + " completed")
}

print("=== Testing thread_spawn ===")
let t1 = go task("A")
let t2 = go task("B")
let tLambda = go {
  print("Lambda task started")
  run("sleep 2") // Simulate some work by sleeping for 2 seconds
  print("Lambda task completed")
}

print("Threads spawned")

t1.join()
t2.join()
tLambda.join()

print("Threads joined")
let t3N = 0
fn receiver() {
  on msg {
    print("Received: " + msg)
  }
  loop {
    t3N++
    sleep(100) // Keep the receiver alive to receive messages
    if t3N > 10 {
      break // Exit after some time to prevent infinite loop in case of issues
    }
  }
}

let t3 = go receiver
sleep(500) // Give the receiver some time to start
print("t3N: ", t3N)
t3.send("Hello from main!")
t3.join()
if t3N > 0 {
  print("Message passing test PASSED")
} else {
  print("Message passing test FAILED")
}

let n4 = 0
go {
  while true {
    n4 = n4 + 1
    if n4 >= 500000 {
      return
    }
  }
}

{
