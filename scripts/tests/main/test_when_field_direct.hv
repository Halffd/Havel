// Test: when blocks tracking object field changes directly
// Uses direct dot notation (not bracket) to ensure OBJECT_SET code path

print("=== test_when_field_direct ===")

obj = { x: 0, y: 0 }
state = ""
notified = false

when obj.x >= 3 {
    print("obj.x reached threshold: " + obj.x)
    state = "x_threshold"
    notified = true
}

when obj.y >= 5 {
    print("obj.y reached threshold: " + obj.y)
    state = "y_threshold"
}

print("initial: x=" + obj.x + " y=" + obj.y)

obj.x = 1
print("x=1")
sleep(50)

obj.x = 2
print("x=2")
sleep(50)

obj.x = 3
print("x=3")
sleep(50)

print("state=" + state)
print("notified=" + notified)

if state == "x_threshold" && notified {
    print("PASS: field-reactive when works")
} else {
    print("FAIL: field-reactive when did not fire")
    exit(1)
}

obj.y = 5
print("y=5")
sleep(50)

print("state=" + state)
if state == "y_threshold" {
    print("PASS: multiple field tracking works")
} else {
    print("FAIL: y threshold did not fire")
    exit(1)
}

exit(0)
