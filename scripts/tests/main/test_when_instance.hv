print("=== test_when_instance ===")

a = { val: 0 }
b = { val: 0 }
fired = false

when a.val >= 5 {
    print("a.val threshold reached")
    fired = true
}

b.val = 5
print("set b.val=5")
sleep(50)
print("fired after b.val=5: " + fired)
if fired {
    print("FAIL: B's change triggered A's watcher (lack of instance precision)")
    exit(1)
}

a.val = 5
print("set a.val=5")
sleep(50)
print("fired after a.val=5: " + fired)
if !fired {
    print("FAIL: A's change did not trigger watcher")
    exit(1)
}

print("PASS: object instance precision works")
exit(0)
