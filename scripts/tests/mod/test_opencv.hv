use opencv as cv

if cv.hasLibs == false {
    print("OpenCV libraries not available, skipping test")
    return
}

im = cv.create(800, 600, 3)
if im == null || im == 0 {
    print("Failed to create image")
    return
}

w = cv.width(im)
h = cv.height(im)
c = cv.channels(im)
print(f"Image: {w}x{h}x{c}")
assert w == 800
assert h == 600
assert c == 3
print("Dimensions correct")

cv.release(im)
print("Release OK")

im2 = cv.create(100, 100, 1)
assert cv.width(im2) == 100
assert cv.height(im2) == 100
assert cv.channels(im2) == 1
print("1-channel image OK")

cv.release(im2)
print("All OpenCV tests passed")