// Test async.hv utilities
use async
use io

print("=== Testing async utilities ===")

// Test 1: sleep
print("\n1. Testing sleep...")
start = time.now()
async.sleep(50)
elapsed = time.now() - start
print("  sleep(50) elapsed: " + str(elapsed) + "ms (expected ~50)")
assert(elapsed >= 40 && elapsed <= 200, "sleep timing off")

// Test 2: go + await
print("\n2. Testing go + await...")
ch = async.chan()
async.go(fn() {
    async.sleep(20)
    ch.send("hello from goroutine")
})
result = ch.receive()
print("  Received: " + result)
assert(result == "hello from goroutine", "go/channel failed")

// Test 3: debounce
print("\n3. Testing debounce...")
counter = 0
debounced = async.debounce(fn(x) { counter += x }, 50)
debounced(1)
debounced(2)
debounced(3)
async.sleep(80)
print("  Counter after debounced calls: " + str(counter))
assert(counter == 3, "debounce should only fire last call")

debounced.cancel()
debounced(10)
async.sleep(80)
print("  Counter after cancel: " + str(counter))
assert(counter == 3, "debounce.cancel should prevent firing")

// Test 4: throttle
print("\n4. Testing throttle...")
counter = 0
throttled = async.throttle(fn(x) { counter += x }, 50)
throttled(1)
throttled(2)
throttled(3)
async.sleep(80)
print("  Counter after throttled calls: " + str(counter))
assert(counter == 1, "throttle should only fire first call")

throttled(10)
async.sleep(80)
print("  Counter after second window: " + str(counter))
assert(counter == 11, "throttle should fire once per window")

throttled.cancel()

// Test 5: retry
print("\n5. Testing retry...")
attempts = 0
result = async.retry(fn() {
    attempts += 1
    if attempts < 3 { throw "fail" }
    return "success"
}, 5, 10)
print("  Result: " + result + " (attempts: " + str(attempts) + ")")
assert(result == "success" && attempts == 3, "retry failed")

// Test 6: timeout
print("\n6. Testing timeout...")
res = async.timeout(fn() { 
    async.sleep(10)
    return "done" 
}, 100)
print("  Fast result: " + str(res))
assert(res.ok && res.value == "done", "timeout should succeed for fast fn")

res = async.timeout(fn() { 
    async.sleep(200)
    return "slow" 
}, 50)
print("  Slow result: " + str(res))
assert(!res.ok, "timeout should fail for slow fn")

// Test 7: race
print("\n7. Testing race...")
ch1 = async.chan()
ch2 = async.chan()
async.go(fn() { async.sleep(50); ch1.send("slow") })
async.go(fn() { async.sleep(10); ch2.send("fast") })
winner = async.race([fn() { ch1.receive() }, fn() { ch2.receive() }])
print("  Winner: " + str(winner))
assert(winner.ok && winner.value == "fast", "race should pick first")

// Test 8: once
print("\n8. Testing once...")
callCount = 0
onceFn = async.once(fn() { callCount += 1; return callCount })
print("  First call: " + str(onceFn()))
print("  Second call: " + str(onceFn()))
print("  Third call: " + str(onceFn()))
assert(callCount == 1, "once should only call once")

// Test 9: every
print("\n9. Testing every...")
counter = 0
everyId = async.every(fn() { counter += 1 }, 30)
async.sleep(100)
everyId.stop()
print("  Counter: " + str(counter))
assert(counter >= 2 && counter <= 5, "every should fire periodically")

// Test 10: parallelMap
print("\n10. Testing parallelMap...")
items = [1, 2, 3, 4, 5]
results = async.parallelMap(items, fn(x) { async.sleep(10); return x * 2 }, 2)
print("  Results: " + str(results))
assert(results == [2, 4, 6, 8, 10], "parallelMap failed")

// Test 11: waitgroup
print("\n11. Testing waitgroup...")
wg = async.waitgroup()
wg.add(3)
async.go(fn() { async.sleep(10); wg.done() })
async.go(fn() { async.sleep(20); wg.done() })
async.go(fn() { async.sleep(30); wg.done() })
wg.wait()
print("  waitgroup completed")

// Test 12: channel basics
print("\n12. Testing channel...")
ch = async.chan(2)
ch.send("a")
ch.send("b")
print("  Received: " + ch.receive() + ", " + ch.receive())
ch.close()

// Test 13: merge
print("\n13. Testing merge...")
ch1 = async.chan()
ch2 = async.chan()
merged = async.merge([ch1, ch2])
async.go(fn() { ch1.send(1); ch1.send(3); ch1.close() })
async.go(fn() { ch2.send(2); ch2.send(4); ch2.close() })
vals = []
for v in merged { vals.push(v) }
print("  Merged: " + str(vals))
assert(vals == [1, 2, 3, 4] || vals == [2, 1, 3, 4] || vals == [1, 3, 2, 4], "merge failed")

// Test 14: circuit breaker
print("\n14. Testing circuit breaker...")
failCount = 0
cb = async.circuitBreaker(fn() { 
    failCount += 1
    if failCount <= 3 { throw "fail" }
    return "ok" 
}, 3, 1000)

for i in 0..5 {
    try { cb() } catch e { }
}
print("  State after 3 failures: " + str(failCount))
assert(failCount == 3, "circuit breaker should open after threshold")

// Wait for reset
async.sleep(1100)
try { cb() } catch e { print("  After reset: " + str(e)) }
assert(failCount == 4, "circuit breaker should half-open after timeout")

print("\n=== All tests passed! ===")