// Test async primitives directly
print("Testing sleep...")
start = time.now()
sleep(50)
elapsed = time.now() - start
print("sleep elapsed: " + str(elapsed) + "ms")
assert(elapsed >= 40 && elapsed <= 200, "sleep timing off")

print("\nTesting go + channel...")
ch = channel.new()
go(fn() {
    sleep(20)
    ch.send("hello")
})
result = ch.receive()
print("Received: " + result)
assert(result == "hello", "channel failed")

print("\nTesting debounce...")
counter = 0
timer = nil
debounced = fn(x) {
    if timer != nil { timeout.cancel(timer) }
    timer = timeout 50 { counter += x }
}
debounced(1)
debounced(2)
debounced(3)
sleep(80)
print("Counter after debounce: " + str(counter))
assert(counter == 3, "debounce failed")

print("\nAll tests passed!")