// Smoke test: bc.* host function API

// Test 1: basic constant + return
bc.reset()
bc.func_new("__main__", 0, 2)
idx = bc.add_const(42)
bc.emit("LOAD_CONST", idx)
bc.emit("RETURN")
result = bc.execute("__main__")
assert(result == 42, "test1 failed")
print("test1 basic return: ok")

// Test 2: arithmetic
bc.reset()
bc.func_new("__main__", 0, 4)
a = bc.add_const(10)
b = bc.add_const(20)
bc.emit("LOAD_CONST", a)
bc.emit("LOAD_CONST", b)
bc.emit("ADD")
bc.emit("RETURN")
result2 = bc.execute("__main__")
assert(result2 == 30, "test2 failed")
print("test2 arithmetic: ok")

// Test 3: local variables
bc.reset()
bc.func_new("__main__", 0, 4)
d = bc.add_const(7)
bc.emit("LOAD_CONST", d)
bc.emit("STORE_VAR", 0)
bc.emit("LOAD_VAR", 0)
bc.emit("RETURN")
result3 = bc.execute("__main__")
assert(result3 == 7, "test3 failed")
print("test3 local vars: ok")

// Test 4: conditional
bc.reset()
bc.func_new("__main__", 0, 4)
t = bc.add_const(1)
hundred = bc.add_const(100)
zero_val = bc.add_const(0)
bc.emit("LOAD_CONST", t)
jump_ip = bc.emit("JUMP_IF_FALSE", 0)
bc.emit("LOAD_CONST", hundred)
end_ip = bc.emit("JUMP", 0)
bc.patch_jump(jump_ip, end_ip)
bc.emit("LOAD_CONST", zero_val)
bc.patch_jump(end_ip, bc.instr_count())
bc.emit("RETURN")
result4 = bc.execute("__main__")
assert(result4 == 100, "test4 failed")
print("test4 conditional: ok")

// Test 5: function calls
bc.reset()
bc.func_new("add", 2, 4)
bc.emit("LOAD_VAR", 0)
bc.emit("LOAD_VAR", 1)
bc.emit("ADD")
bc.emit("RETURN")
bc.func_new("__main__", 0, 4)
three = bc.add_const(3)
four = bc.add_const(4)
bc.emit("CLOSURE", 0)
bc.emit("LOAD_CONST", three)
bc.emit("LOAD_CONST", four)
bc.emit("CALL", 2)
bc.emit("RETURN")
result5 = bc.execute("__main__")
assert(result5 == 7, "test5 failed")
print("test5 function call: ok")

// Test 6: string constants
bc.reset()
bc.func_new("__main__", 0, 4)
s = bc.add_string("hello")
bc.emit("LOAD_CONST", s)
bc.emit("RETURN")
result6 = bc.execute("__main__")
print("test6 string const: " + str(result6))

// Test 7: global variables
bc.reset()
bc.func_new("__main__", 0, 4)
xname = bc.add_chunk_string("myvar")
xval = bc.add_const(99)
bc.emit("LOAD_CONST", xval)
bc.emit("STORE_GLOBAL", bc.str_id(xname))
bc.emit("LOAD_GLOBAL", bc.str_id(xname))
bc.emit("RETURN")
result7 = bc.execute("__main__")
assert(result7 == 99, "test7 failed")
print("test7 global var: ok")

print("all bc.* tests passed!")
