// test_crypto.hv - Test suite for FFI-backed crypto module
// NOTE: sign/box keypair generation must happen early due to VM FFI alloc limit

use crypto
passed = 0
failed = 0

fn assertEq(got, expected, name) {
    if got == expected {
        passed += 1
    } else {
        print("FAIL: " + name + " => expected '" + expected + "', got '" + got + "'")
        failed += 1
    }
}

fn assertTrue(got, name) {
    if got {
        passed += 1
    } else {
        print("FAIL: " + name + " => expected true, got false")
        failed += 1
    }
}

fn assertFalse(got, name) {
    if !got {
        passed += 1
    } else {
        print("FAIL: " + name + " => expected false, got true")
        failed += 1
    }
}

fn assertNotNull(got, name) {
    if got != null {
        passed += 1
    } else {
        print("FAIL: " + name + " => unexpected null")
        failed += 1
    }
}

fn assertNull(got, name) {
    if got == null {
        passed += 1
    } else {
        print("FAIL: " + name + " => expected null, got '" + got + "'")
        failed += 1
    }
}

// =================== KEYS (call early to stay within VM FFI limit) ===================
signKp = crypto.signKeypair()
assertNotNull(signKp, "signKeypair non-null")

boxKp = crypto.boxKeypair()
assertNotNull(boxKp, "boxKeypair non-null")

// =================== Encoding ===================
h = crypto.hexEncode([0, 16, 32, 255])
assertEq(h, "001020ff", "hexEncode basic")

b = crypto.hexDecode("001020ff")
assertEq(b[0], 0, "hexDecode[0]")
assertEq(b[1], 16, "hexDecode[1]")
assertEq(b[2], 32, "hexDecode[2]")
assertEq(b[3], 255, "hexDecode[3]")

b64 = crypto.base64Encode([72, 101, 108, 108, 111])
assertEq(b64, "SGVsbG8=", "base64Encode 'Hello'")

raw = crypto.base64Decode("SGVsbG8=")
assertEq(#raw, 5, "base64Decode len")

// =================== SHA-256 ===================
h256 = crypto.sha256("hello")
if h256 != null {
    assertEq(#h256, 64, "sha256 hex length")
    assertEq(h256, "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824", "sha256('hello')")
}

// =================== SHA-512 ===================
h512 = crypto.sha512("hello")
if h512 != null {
    assertEq(#h512, 128, "sha512 hex length")
}

// =================== BLAKE2b ===================
hb = crypto.blake2b("hello")
if hb != null {
    assertEq(#hb, 128, "blake2b default hex length")
}

hb32 = crypto.blake2b("hello", 32)
if hb32 != null {
    assertEq(#hb32, 64, "blake2b 32-byte hex length")
}

// =================== HMAC-SHA256 ===================
hm = crypto.hmacSha256("key", "hello")
if hm != null {
    assertEq(#hm, 64, "hmacSha256 hex length")
}

// =================== Symmetric Encryption ===================
secKey = crypto.secretKey()
secNon = crypto.secretNonce()
if secKey != null && secNon != null {
    assertEq(#secKey, 64, "secretKey hex length")
    assertEq(#secNon, 48, "secretNonce hex length")

    ct = crypto.secretBox("hello world", secNon, secKey)
    assertNotNull(ct, "secretBox non-null")

    if ct != null {
        pt = crypto.secretBoxOpen(ct, secNon, secKey)
        assertEq(pt, "hello world", "secretBoxOpen roundtrip")

        ctBad = ct[0:52] + "zz"
        ptBad = crypto.secretBoxOpen(ctBad, secNon, secKey)
        assertNull(ptBad, "secretBoxOpen tampered returns null")
    }
}

// =================== UUID ===================
u = crypto.uuid()
assertEq(#u, 36, "uuid format length")
assertEq(u[8:9], "-", "uuid format dash 1")
assertEq(u[13:14], "-", "uuid format dash 2")
assertEq(u[18:19], "-", "uuid format dash 3")
assertEq(u[23:24], "-", "uuid format dash 4")
assertEq(u[14:15], "4", "uuid version nibble")

// =================== Ed25519 Signatures ===================
if signKp != null {
    pk = signKp.publicKey
    ssk = signKp.secretKey
    assertEq(#pk, 64, "sign publicKey hex length")
    assertEq(#ssk, 128, "sign secretKey hex length")

    sig = crypto.sign("test message", ssk)
    assertNotNull(sig, "sign non-null")
    if sig != null {
        assertEq(#sig, 128, "signature hex length")
        assertTrue(crypto.signVerify("test message", sig, pk), "signVerify valid signature")
        assertFalse(crypto.signVerify("wrong message", sig, pk), "signVerify wrong message")
    }
}

// =================== Public-Key Encryption ===================
if boxKp != null {
    assertEq(#boxKp.publicKey, 64, "box publicKey hex length")
    assertEq(#boxKp.secretKey, 64, "box secretKey hex length")

    bn = crypto.boxNonce()
    if bn != null {
        assertEq(#bn, 48, "boxNonce hex length")

        bct = crypto.box("secret data", bn, boxKp.publicKey, boxKp.secretKey)
        assertNotNull(bct, "box non-null")

        if bct != null {
            bpt = crypto.boxOpen(bct, bn, boxKp.publicKey, boxKp.secretKey)
            assertEq(bpt, "secret data", "boxOpen roundtrip")
        }
    }
}

// =================== Key Derivation ===================
mk = crypto.kdfKeygen()
if mk != null {
    assertEq(#mk, 64, "kdfKeygen hex length")

    dk = crypto.kdfDerive(mk, "ctx1234!", 1, 32)
    assertNotNull(dk, "kdfDerive non-null")
    if dk != null {
        assertEq(#dk, 64, "kdfDerived key hex length")
    }
}

// =================== Password Hashing ===================
salt = crypto.pwSalt()
if salt != null {
    assertEq(#salt, 32, "pwSalt hex length")

    ph = crypto.pwHash("mypassword", salt)
    assertNotNull(ph, "pwHash non-null")

    if ph != null {
        assertEq(#ph, 256, "pwHash hex length")
    }
}

stored = crypto.pwHashStr("mypassword")
if stored != null {
    ok = crypto.pwHashVerify(stored, "mypassword")
    assertTrue(ok, "pwHashVerify correct password")

    bad = crypto.pwHashVerify(stored, "wrongpassword")
    assertFalse(bad, "pwHashVerify wrong password")
}

// =================== Summary ===================
print("================================")
print("crypto: " + passed + "/" + (passed + failed) + " tests passed")
if failed > 0 {
    print("crypto: " + failed + " FAILURES")
}
print("================================")
