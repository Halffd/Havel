// Test: what exactly fails after many FFI operations?
h = ffi.open("libsodium.so.26")
if h == 0 { println("FAIL: can't open libsodium"); exit(1) }

sodium_init = ffi.sym(h, "sodium_init")
if sodium_init != 0 { ffi.call(sodium_init, "int32", []) }

randombytes_buf = ffi.sym(h, "randombytes_buf")
crypto_sign_keypair = ffi.sym(h, "crypto_sign_keypair")

println("sodium_init: " + sodium_init)
println("randombytes_buf: " + randombytes_buf)
println("crypto_sign_keypair: " + crypto_sign_keypair)

count = 0
while count < 100 {
  // 2 allocates + 1 call + 1 get (per iter in _hexFrom)
  // Simplified: just alloc/free repeatedly
  buf = ffi.allocBytes(64)
  if buf == 0 { println("FAIL: allocBytes returned null at count " + count); exit(1) }
  ffi.free(buf)
  count += 1
  if count % 20 == 0 { println("  alloc/free " + count + " OK") }
}

println("PASS: 100 alloc/free cycles OK")

// Now try calling sign_keypair
pk = ffi.allocBytes(32)
sk = ffi.allocBytes(64)
println("alloc pk: " + pk)
println("alloc sk: " + sk)
if pk == 0 || sk == 0 {
  println("FAIL: alloc returned null after " + count + " alloc/free cycles")
  exit(1)
}
rc = ffi.call(crypto_sign_keypair, "int32", ["pointer", "pointer"], pk, sk)
println("sign_keypair rc: " + rc)
if rc == 0 {
  println("PASS: sign_keypair succeeded after " + count + " alloc/free cycles")
} else {
  println("FAIL: sign_keypair failed with rc=" + rc)
}
ffi.free(sk)
ffi.free(pk)
