// Test generics: type parameters on struct, class, enum, fn
// syntax: struct List(T) { ... }, fn identity(T)(x: T) -> T { x }

pass = 0
fail = 0
fn check(n, a, e) { if a == e { pass += 1 } else { fail += 1; print("FAIL $n: got $a, expected $e") } }

// 1. generic struct with type parameter
struct Box(T) {
    value
    fn @(v) {
        @value = v
    }
    fn get() { @value }
    fn set(v) { @value = v }
}

b1 = Box(42)
check("generic-struct-int", b1.get(), 42)

b2 = Box("hello")
check("generic-struct-str", b2.get(), "hello")

b1.set(99)
check("generic-struct-set", b1.get(), 99)

// 2. generic class with two type parameters
class Pair(T, E) {
    first, second
    fn @(a, b) {
        @first = a
        @second = b
    }
    fn fst() { @first }
    fn snd() { @second }
}

p1 = Pair(1, "one")
check("generic-class-fst", p1.fst(), 1)
check("generic-class-snd", p1.snd(), "one")

// 3. generic enum
enum Result(T, E) {
    Ok
    Err
}

check("generic-enum-ok", Result.Ok, Result.Ok)
check("generic-enum-err", Result.Err, Result.Err)

// 4. generic function with type parameter
fn identity(T)(x: T) -> T { x }

check("generic-fn-int", identity(42), 42)
check("generic-fn-str", identity("world"), "world")
check("generic-fn-bool", identity(true), true)

// 5. generic struct with method operating on values
struct Stack(T) {
    items
    fn @() { @items = [] }
    fn push(v) { @items.push(v) }
    fn pop() { @items.pop() }
    fn len() { @items.len() }
    fn isEmpty() { @items.len() == 0 }
}

s = Stack()
s.push(10)
s.push(20)
s.push(30)
check("generic-stack-len", s.len(), 3)
check("generic-stack-pop", s.pop(), 30)
check("generic-stack-empty", s.isEmpty(), false)

// 6. generic struct with different instantiations
struct Container(T) {
    item
    fn @(v) { @item = v }
    fn unwrap() { @item }
}

inner = Container(true)
check("generic-container-bool", inner.unwrap(), true)

inner2 = Container(3.14)
check("generic-container-num", inner2.unwrap(), 3.14)

// 7. nested generic instantiation
struct Wrapper(T) {
    inner
    fn @(v) { @inner = v }
    fn value() { @inner }
}

w = Wrapper(Box(77))
check("generic-nested", w.value().get(), 77)

// summary
print("\nGenerics: $pass passed, $fail failed")
