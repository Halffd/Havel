// test go scheduling - no timeout to avoid STORE_GLOBAL bug

go fn() {
    n = 0
    loop {
        n += 1
        if n % 10000 == 0 {
            print("goroutine 1: n=$n")
        }
        if n >= 50000 {
            return
        }
    }
}

go fn() {
    m = 0
    loop {
        m += 1
        if m % 10000 == 0 {
            print("goroutine 2: m=$m")
        }
        if m >= 50000 {
            return
        }
    }
}

// Main script also loops
n = 0
loop {
    n += 1
    if n % 100000 == 0 {
        print("main: n=$n")
    }
    if n >= 500000 {
        print("done")
        exit(0)
    }
}
