// Test hotkey mode/policy attribute syntax
// Only test parsing — hotkeys registered here will not fire in this context

F1 policy="replace" => { print("F1 replace") }
F2 mode="gaming" => { print("F2 gaming mode") }
^F3 mode="default" policy="queue" => { print("Ctrl+F3 default queue") }
+F4 policy="coalesce" => { print("Shift+F4 coalesce") }
#F5 policy="drop" => { print("Super+F5 drop") }

print("hotkey attributes parsed ok")
