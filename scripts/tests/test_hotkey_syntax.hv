// Test hotkey syntax forms

// Basic hotkey
F1 => { print("F1") }

// Modifier prefix
^F2 => { print("Ctrl+F2") }

// Chord: identifier & identifier
RShift & WheelUp => { print("chord") }

// Timing modifier: key:up, key:down
numpad5:up => { print("numpad5 up") }
numpad5:down => { print("numpad5 down") }

// != hotkey (Alt+Equals)
!= => { print("alt+equals") }

// Pipe passthrough prefix
|F3 => { print("passthrough F3") }

// More chord combinations
LCtrl & Space => { print("ctrl+space chord") }

// More timing modifiers
numpadmult:up => { print("numpad mult up") }
numpadenter:down => { print("numpad enter down") }
numpad1:up => { print("numpad1 up") }

// Passthrough with modifier
|+Print => { print("passthrough shift+print") }
|#Print => { print("passthrough super+print") }

// Chord with timing modifier
LShift & a:up => { print("shift+a up chord") }

print("all hotkey syntax parsed ok")
