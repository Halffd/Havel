x = ['a', '~', 'c', 0]
f1 => {
   if #x < 1 return
   xv = x.pop()
   send("xxxxxxxxxxx $xv")
}
a => print "hello"
b => {
  try {
      print(rand())
      print 1/0
  } catch e {
    if type e == 'string'
       return
    print e
  }
}
c => {
    if 1 > 0 {
       print 1 > 0
    } else  {
       print 0
    }
}
!d => send "#d"
RShift => print 'zoom'
// dhk  assigned below
dhk=d => {
  print @id
  print @alias
  print @key
  @disable()
  print @status
  print d
}
e => {
  exit(0)
}
f => {
  run("firefox")
}
print dhk