// test_just_sign.hv - crypto module test
// KeyPairs MUST be called first (VM FFI limit workaround)
use crypto

passed = 0
failed = 0

fn assertOk(label, cond) {
  if cond {
    passed += 1
    print("PASS: " + label)
  } else {
    failed += 1
    print("FAIL: " + label)
  }
}

fn assertNotNull(label, v) {
  assertOk(label, v != null)
}

// 1. KEYPAIRS FIRST (before any other FFI ops)
kp = crypto.signKeypair()
assertNotNull("signKeypair", kp)

bkp = crypto.boxKeypair()
assertNotNull("boxKeypair", bkp)

// 2. Hash functions
h = crypto.sha256("hello")
assertOk("sha256 len=64", h != null && #h == 64)

h2 = crypto.sha512("hello")
assertOk("sha512 len=128", h2 != null && #h2 == 128)

// 3. secretBox roundtrip
nonce = crypto.randomHex(24)
key = crypto.randomHex(32)
ct = crypto.secretBox("hello world", nonce, key)
assertNotNull("secretBox", ct)

pt = crypto.secretBoxOpen(ct, nonce, key)
assertOk("secretBoxOpen roundtrip", pt == "hello world")

// 4. uuid
u = crypto.uuid()
assertOk("uuid len=36", u != null && #u == 36)

// 5. kdf
mk = crypto.kdfKeygen()
assertNotNull("kdfKeygen", mk)

print("---")
print("ALL: " + str(passed) + "/" + str(passed + failed) + " passed")
if failed > 0 {
  print("FAILURES: " + str(failed))
}
