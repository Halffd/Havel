// test_lazy_modules.hv
// Verify lazy module loading: modules init on first use, not at startup

// Test 1: use regex triggers lazy load → Regex global available
use regex
val r1 = Regex.search("hello world", "wor")
assert(r1 == true)

// Test 2: second use returns cached (no re-init)
use regex
val r2 = Regex.match("test123", "\\d+")
assert(r2 != nil)

// Test 3: use fs triggers lazy load
use fs
val exists = fs.exists("/tmp")
assert(exists == true)

// Test 4: use random triggers lazy load
use random
val rn = random.int(1, 100)
assert(rn >= 1 && rn <= 100)

// Test 5: regex also accessible as lowercase after use
val r3 = regex.search("abc", "b")
assert(r3 == true)

print("Lazy modules: 5 passed, 0 failed")
