use ffi

_lib = ffi.open("libsodium.so.26")
if _lib == 0 { _lib = ffi.open("libsodium.so") }

_skp = ffi.sym(_lib, "crypto_sign_keypair")
print("crypto_sign_keypair = " + _skp)

_bkp = ffi.sym(_lib, "crypto_box_keypair")
print("crypto_box_keypair = " + _bkp)

if _skp != 0 {
    pk = ffi.allocBytes(32)
    sk = ffi.allocBytes(64)
    rc = ffi.call(_skp, "int32", ["pointer", "pointer"], pk, sk)
    print("rc = " + rc)
    ffi.free(sk)
    ffi.free(pk)
} else {
    print("SYMBOL NOT FOUND")
}
