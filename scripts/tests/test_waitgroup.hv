// test_waitgroup.hv - smoke test for waitgroup keyword
// WaitGroup: add/done/wait synchronization

wg = waitgroup()
print("created waitgroup")

wg.add(3)
print("added 3")

wg.done()
print("done 1")
wg.done()
print("done 2")
wg.done()
print("done 3 - counter should be 0")

wait wg
print("wait completed (counter is 0)")
