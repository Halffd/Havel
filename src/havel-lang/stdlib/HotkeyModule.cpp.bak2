        }

        int hotkeyId = static_cast<int>(api.toNumber(args[0]));

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // bool success = service.disableHotkey(hotkeyId);
        // return api.makeBool(success);

        // Placeholder for now
        return api.makeBool(false);
      });

  // hotkey.list() - List all registered hotkeys
  api.registerFunction(
      "hotkey.list",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (!args.empty()) {
          throw std::runtime_error("hotkey.list() takes no arguments");
        }

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // auto hotkeys = service.listHotkeys();
        // auto result = api.makeArray();
        //
