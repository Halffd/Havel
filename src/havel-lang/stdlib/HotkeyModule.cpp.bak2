        //     "enabled", api.makeBool(info.enabled)); api.setField(hotkeyObj,
        //     "type", api.makeString(info.type)); api.arrayPush(result,
        //     hotkeyObj);
        // }
        //
        // return result;

        // Placeholder for now
        return api.makeArray();
      });

  // hotkey.isEnabled(id) - Check if hotkey is enabled
  api.registerFunction(
      "hotkey.isEnabled",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "hotkey.isEnabled() requires exactly one argument (hotkeyId)");
        }

        int hotkeyId = static_cast<int>(api.toNumber(args[0]));

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // bool enabled = service.isHotkeyEnabled(hotkeyId);
        // return api.makeBool(enabled);

        // Placeholder for now
        return api.makeBool(false);
      });

  // Create hotkey object with methods
  auto hotkeyObj = api.makeObject();

  // Add methods
  api.setField(hotkeyObj, "register", api.makeFunction("hotkey.register"));
  api.setField(hotkeyObj, "unregister", api.makeFunction("hotkey.unregister"));
  api.setField(hotkeyObj, "enable", api.makeFunction("hotkey.enable"));
  api.setField(hotkeyObj, "disable", api.makeFunction("hotkey.disable"));
  api.setField(hotkeyObj, "list", api.makeFunction("hotkey.list"));
  api.setField(hotkeyObj, "isEnabled", api.makeFunction("hotkey.isEnabled"));

  // Register global hotkey object
  api.setGlobal("hotkey", hotkeyObj);
