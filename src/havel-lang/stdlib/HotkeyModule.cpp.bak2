  // Register hotkey functions

  // hotkey.register(key, callback) - Register a hotkey
  api.registerFunction(
      "hotkey.register",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 2) {
          throw std::runtime_error("hotkey.register() requires exactly two "
                                   "arguments (key, callback)");
        }

        std::string key = api.toString(args[0]);

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // static havel::host::HotkeyService service(hotkeyManager);
        //
        // // Store callback reference for execution
        // static std::unordered_map<int, BytecodeValue> hotkeyCallbacks;
        // static int nextHotkeyId = 1;
        //
        // int hotkeyId = nextHotkeyId++;
        // hotkeyCallbacks[hotkeyId] = args[1];  // Store callback function
        //
        // bool success = service.registerHotkey(key, [hotkeyId]() {
        //     // Execute stored callback when hotkey is triggered
        //     if (hotkeyCallbacks.find(hotkeyId) != hotkeyCallbacks.end()) {
        //         // This would need VM context to execute the callback
        //         // For now, this is a placeholder
        //     }
        // }, hotkeyId);
        //
        // return api.makeNumber(success ? hotkeyId : 0);

        // Placeholder for now
        return api.makeNumber(0);
      });

  // hotkey.unregister(id) - Unregister a hotkey
  api.registerFunction(
      "hotkey.unregister",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "hotkey.unregister() requires exactly one argument (hotkeyId)");
        }

        int hotkeyId = static_cast<int>(api.toNumber(args[0]));

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // bool success = service.unregisterHotkey(hotkeyId);
        //
        // // Remove stored callback
        // hotkeyCallbacks.erase(hotkeyId);
        //
        // return api.makeBool(success);

        // Placeholder for now
        return api.makeBool(false);
      });

  // hotkey.enable(id) - Enable a hotkey
  api.registerFunction(
      "hotkey.enable",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "hotkey.enable() requires exactly one argument (hotkeyId)");
        }

        int hotkeyId = static_cast<int>(api.toNumber(args[0]));

        // TODO: Initialize HotkeyService with proper HotkeyManager
        // bool success = service.enableHotkey(hotkeyId);
        // return api.makeBool(success);

        // Placeholder for now
        return api.makeBool(false);
      });

  // hotkey.disable(id) - Disable a hotkey
  api.registerFunction(
      "hotkey.disable",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
