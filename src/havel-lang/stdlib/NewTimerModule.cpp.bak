/*
 * TimerModule.cpp
 *
 * Timer module implementation using VApi system.
 * Provides timer operations with clean host service integration.
 */
#include "NewTimerModule.hpp"
#include <chrono>
#include <functional>
#include <thread>
#include <unordered_map>

using namespace havel::compiler;

namespace havel::stdlib {

void registerNewTimerModule(havel::compiler::VMApi &api) {
  // Helper: convert BytecodeValue to number
  auto toNumber = [](const BytecodeValue &v) -> double {
    if (std::holds_alternative<int64_t>(v))
      return static_cast<double>(std::get<int64_t>(v));
    if (std::holds_alternative<double>(v))
      return std::get<double>(v);
    return 0.0;
  };

  // Simple timer implementation using C++ chrono
  static std::unordered_map<int, std::function<void()>> timerCallbacks;
  static std::unordered_map<int, bool> timerActive;
  static std::unordered_map<int, std::thread> timerThreads;
  static int nextTimerId = 1;

  // timer.setTimeout(callback, delay) - Set a one-shot timer
  api.registerFunction(
      "timer.setTimeout",
      [toNumber,
       &api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 2) {
          throw std::runtime_error("timer.setTimeout() requires exactly two "
                                   "arguments (callback, delay)");
        }

        // Store callback for later execution
        int timerId = nextTimerId++;
        timerCallbacks[timerId] = [callback = args[1]]() {
          // This would need VM context to execute the callback
          // For now, this is a placeholder that stores the callback
          // In a real implementation, this would execute the callback
        };

        // Get delay in milliseconds
        int64_t delayMs = static_cast<int64_t>(toNumber(args[1]));

        // Start timer thread
        timerActive[timerId] = true;
        timerThreads[timerId] = std::thread([timerId, delayMs]() {
          std::this_thread::sleep_for(std::chrono::milliseconds(delayMs));

          if (timerActive[timerId] &&
              timerCallbacks.find(timerId) != timerCallbacks.end()) {
            // Execute callback (placeholder)
            timerCallbacks[timerId]();

            // Clean up one-shot timer
            timerActive.erase(timerId);
            timerCallbacks.erase(timerId);
          }
        });

        return api.makeNumber(timerId);
      });

  // timer.setInterval(callback, interval) - Set a repeating timer
  api.registerFunction(
      "timer.setInterval",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 2) {
          throw std::runtime_error("timer.setInterval() requires exactly two "
                                   "arguments (callback, interval)");
        }

        // Store callback for later execution
        int timerId = nextTimerId++;
        timerCallbacks[timerId] = [callback = args[1]]() {
          // This would need VM context to execute the callback
          // For now, this is a placeholder that stores the callback
        };

        // Get interval in milliseconds
        int64_t intervalMs = static_cast<int64_t>(toNumber(args[1]));

        // Start timer thread
        timerActive[timerId] = true;
        timerThreads[timerId] = std::thread([timerId, intervalMs]() {
          while (timerActive[timerId]) {
            std::this_thread::sleep_for(std::chrono::milliseconds(intervalMs));

            if (timerActive[timerId] &&
                timerCallbacks.find(timerId) != timerCallbacks.end()) {
              // Execute callback (placeholder)
              timerCallbacks[timerId]();
            }
          }
        });

        return api.makeNumber(timerId);
      });

  // timer.clearTimeout(id) - Clear a one-shot timer
  api.registerFunction(
      "timer.clearTimeout",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "timer.clearTimeout() requires exactly one argument (timerId)");
        }

        int timerId = static_cast<int>(toNumber(args[0]));

        // Stop timer
        timerActive[timerId] = false;

        // Wait for thread to finish and clean up
        if (timerThreads.find(timerId) != timerThreads.end()) {
          if (timerThreads[timerId].joinable()) {
            timerThreads[timerId].join();
          }
          timerThreads.erase(timerId);
        }

        // Remove callback
        timerCallbacks.erase(timerId);

        return BytecodeValue(true);
      });

  // timer.clearInterval(id) - Clear a repeating timer
  api.registerFunction(
      "timer.clearInterval",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "timer.clearInterval() requires exactly one argument (timerId)");
        }

        int timerId = static_cast<int>(toNumber(args[0]));

        // Stop timer
        timerActive[timerId] = false;

        // Wait for thread to finish and clean up
        if (timerThreads.find(timerId) != timerThreads.end()) {
          if (timerThreads[timerId].joinable()) {
            timerThreads[timerId].join();
          }
          timerThreads.erase(timerId);
        }

        // Remove callback
        timerCallbacks.erase(timerId);

        return BytecodeValue(true);
      });

  // timer.now() - Get current timestamp in milliseconds
  api.registerFunction(
      "timer.now",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (!args.empty()) {
          throw std::runtime_error("timer.now() takes no arguments");
        }

        auto now = std::chrono::steady_clock::now();
        auto timestamp = std::chrono::duration_cast<std::chrono::milliseconds>(
                             now.time_since_epoch())
                             .count();
        return BytecodeValue(timestamp);
      });

  // timer.sleep(ms) - Sleep for specified milliseconds
  api.registerFunction(
      "timer.sleep",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "timer.sleep() requires exactly one argument (milliseconds)");
        }

        int64_t ms = static_cast<int64_t>(toNumber(args[0]));
        std::this_thread::sleep_for(std::chrono::milliseconds(ms));

        return BytecodeValue(true);
      });

  // timer.active(id) - Check if timer is active
  api.registerFunction(
      "timer.active",
      [&api](const std::vector<BytecodeValue> &args) -> BytecodeValue {
        if (args.size() != 1) {
          throw std::runtime_error(
              "timer.active() requires exactly one argument (timerId)");
        }

        int timerId = static_cast<int>(toNumber(args[0]));
        bool active = timerActive.find(timerId) != timerActive.end() &&
                      timerActive[timerId];
        return BytecodeValue(active);
      });

  // Create timer object with methods
  auto timerObj = api.makeObject();

  // Add methods
  api.setField(timerObj, "setTimeout", api.makeFunctionRef("timer.setTimeout"));
  api.setField(timerObj, "setInterval",
               api.makeFunctionRef("timer.setInterval"));
  api.setField(timerObj, "clearTimeout",
               api.makeFunctionRef("timer.clearTimeout"));
  api.setField(timerObj, "clearInterval",
               api.makeFunctionRef("timer.clearInterval"));
  api.setField(timerObj, "now", api.makeFunctionRef("timer.now"));
  api.setField(timerObj, "sleep", api.makeFunctionRef("timer.sleep"));
  api.setField(timerObj, "active", api.makeFunctionRef("timer.active"));

  // Register global timer object
  api.setGlobal("timer", timerObj);
}

} // namespace havel::stdlib
