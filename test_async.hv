// Test async module functionality

print "=== Testing Async Module ==="

// Test 1: Channel creation and basic operations
print "Test 1: Channel operations"
let ch = channel()
print "Channel created with ID: $ch.id"

// Test send and receive
ch.send("Hello from channel!")
let value = ch.receive()
print "Received from channel: $value"

// Test non-blocking receive
ch.send("Second message")
let value2 = ch.tryReceive()
print "Non-blocking receive: $value2"

// Test channel size
print "Channel size: $ch.size()"

// Test 2: Spawn and await
print "\nTest 2: Spawn and await"
let task = spawn(fn() {
  print "Task executing..."
  return "Task completed successfully!"
})

print "Task spawned with ID: $task"
let result = await(task)
print "Task result: $result"

// Test 3: Multiple channels
print "\nTest 3: Multiple channels"
let ch1 = channel()
let ch2 = channel()

ch1.send("Channel 1 message")
ch2.send("Channel 2 message")

print "Channel 1: $ch1.receive()"
print "Channel 2: $ch2.receive()"

// Test 4: Yield functionality
print "\nTest 4: Yield functionality"
print "Before yield"
yield()
print "After yield"

// Test 5: Channel closing
print "\nTest 5: Channel closing"
let ch3 = channel()
ch3.send("Final message")
print "Before close - size: $ch3.size()"
ch3.close()
print "After close - isClosed: $ch3.isClosed()"

print "\n=== Async Module Tests Complete ==="
