// Test automatic MapManager profile activation on startup

print "=== Testing MapManager Auto-Profile Activation ==="

// Test 1: Initialize MapManager (should auto-create and activate default profile)
print "Test 1: MapManager initialization"
let success = mapmanager.init()
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Check active profile
print "\nTest 2: Check active profile"
let activeProfile = mapmanager.getActiveProfile()
if (activeProfile && activeProfile != "No active profile") {
  print "✅ Active profile: " + activeProfile.name
  print "   ID: " + activeProfile.id
  print "   Description: " + activeProfile.description
  print "   Mapping count: " + activeProfile.mappingCount
} else {
  print "❌ No active profile found"
}

// Test 3: Register hotkeys to active profile
print "\nTest 3: Register hotkeys to active profile"
let registered = mapmanager.registerHotkeys()
if (registered) {
  print "✅ Hotkeys registered to active profile"
} else {
  print "❌ Failed to register hotkeys"
}

// Test 4: Add a custom mapping to default profile
print "\nTest 4: Add custom mapping"
let mappingAdded = mapmanager.addMapping("default", "F1", "Ctrl+C")
if (mappingAdded) {
  print "✅ Added mapping: F1 -> Ctrl+C"
} else {
  print "❌ Failed to add mapping"
}

// Test 5: Verify mapping was added
print "\nTest 5: Verify mapping"
let updatedProfile = mapmanager.getActiveProfile()
if (updatedProfile && updatedProfile.mappingCount > 0) {
  print "✅ Profile now has " + updatedProfile.mappingCount + " mappings"
} else {
  print "❌ Mapping not properly added"
}

print "\n=== MapManager Auto-Profile Tests Complete ==="
print "\n🎯 Summary:"
print "- Default profile auto-created on initialization"
print "- Default profile auto-activated on startup"  
print "- Hotkeys auto-registered to active profile"
print "- Custom mappings can be added to active profile"
print "- Full profile management API available"
