// Test Configurable Autofire Functionality

print "=== Testing Configurable Autofire Functionality ==="

// Initialize MapManager
print "Test 1: Initialize MapManager"
let success = mapmanager.init(true)
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Create basic autofire mapping
print "\nTest 2: Create basic autofire mapping"
mapmanager.addMapping("default", "BasicAutofire", "F1", "Space")
print "✅ Created basic autofire: F1 -> Space"

// Test 3: Create configurable autofire mapping
print "\nTest 3: Create configurable autofire mapping"
mapmanager.addMapping("default", "ConfigurableAutofire", "F2", "Enter")
print "✅ Created configurable autofire: F2 -> Enter"

// Test 4: Configure autofire settings
print "\nTest 4: Configure autofire settings"
let mappings = mapmanager.getMappings("default")
if (mappings && mappings.length > 0) {
  // Find the configurable autofire mapping
  let configMapping = null
  for (let i = 0; i < mappings.length; i++) {
    let mapping = mappings[i]
    if (mapping.name == "ConfigurableAutofire") {
      configMapping = mapping
      break
    }
  }
  
  if (configMapping) {
    print "✅ Found configurable autofire mapping: " + configMapping.id
    
    // Set autofire rate to 150ms
    mapmanager.setAutofireRate(configMapping.id, 150)
    print "✅ Set autofire rate to 150ms"
    
    // Set burst count to 5 shots
    mapmanager.setAutofireBurstCount(configMapping.id, 5)
    print "✅ Set burst count to 5 shots"
    
    // Set burst delay to 1000ms
    mapmanager.setAutofireBurstDelay(configMapping.id, 1000)
    print "✅ Set burst delay to 1000ms"
    
    // Set mode to "burst"
    mapmanager.setAutofireMode(configMapping.id, "burst")
    print "✅ Set autofire mode to 'burst'"
    
    // Set condition to "always"
    mapmanager.setAutofireCondition(configMapping.id, "always")
    print "✅ Set condition to 'always'"
    
    // Verify configuration
    let updatedMappings = mapmanager.getMappings("default")
    for (let i = 0; i < updatedMappings.length; i++) {
      let mapping = updatedMappings[i]
      if (mapping.id == configMapping.id) {
        print "✅ Updated mapping configuration:"
        print "      Rate: " + mapping.autofireRate + "ms"
        print "      Burst Count: " + mapping.autofireBurstCount
        print "      Burst Delay: " + mapping.autofireBurstDelay + "ms"
        print "      Mode: " + mapping.autofireMode
        print "      Condition: " + mapping.autofireCondition
        break
      }
    }
  } else {
    print "❌ Configurable autofire mapping not found"
  }
} else {
  print "❌ No mappings found"
}

// Test 5: Test different autofire modes
print "\nTest 5: Test different autofire modes"

// Create mappings for different modes
mapmanager.addMapping("default", "NormalMode", "F3", "A")
mapmanager.setAutofireMode("NormalMode", "normal")
print "✅ Created normal mode autofire: F3 -> A"

mapmanager.addMapping("default", "BurstMode", "F4", "B")
mapmanager.setAutofireBurstCount("BurstMode", 3)
mapmanager.setAutofireBurstDelay("BurstMode", 500)
mapmanager.setAutofireMode("BurstMode", "burst")
print "✅ Created burst mode autofire: F4 -> B (3 shots, 500ms delay)"

mapmanager.addMapping("default", "HoldMode", "F5", "C")
mapmanager.setAutofireMode("HoldMode", "hold")
print "✅ Created hold mode autofire: F5 -> C (hold while pressed)"

mapmanager.addMapping("default", "SmartMode", "F6", "D")
mapmanager.setAutofireMode("SmartMode", "smart")
print "✅ Created smart mode autofire: F6 -> D (adaptive rate)"

// Test 6: Test conditional autofire
print "\nTest 6: Test conditional autofire"
mapmanager.addMapping("default", "WindowConditional", "F7", "E")
mapmanager.setAutofireCondition("WindowConditional", "window:firefox")
print "✅ Created window-conditional autofire: F7 -> E (only in Firefox)"

mapmanager.addMapping("default", "TimeConditional", "F8", "F")
mapmanager.setAutofireCondition("TimeConditional", "time:14")
print "✅ Created time-conditional autofire: F8 -> F (only at 14:00)"

// Test 7: Check autofire status
print "\nTest 7: Check autofire status"
let allMappings = mapmanager.getMappings("default")
if (allMappings && allMappings.length > 0) {
  print "✅ Checking autofire status for all mappings:"
  
  for (let i = 0; i < allMappings.length; i++) {
    let mapping = allMappings[i]
    if (mapping.autofire) {
      let isActive = mapmanager.isAutofireActive(mapping.id)
      print "  [" + i + "] " + mapping.name + " (" + mapping.id + ") - " + (isActive ? "ACTIVE" : "INACTIVE")
      print "      Mode: " + mapping.autofireMode
      print "      Rate: " + mapping.autofireRate + "ms"
      print "      Burst: " + mapping.autofireBurstCount + " shots"
      print "      Condition: " + mapping.autofireCondition
    }
  }
} else {
  print "❌ No mappings found"
}

// Test 8: Demonstrate autofire control
print "\nTest 8: Demonstrate autofire control"
if (allMappings && allMappings.length > 0) {
  // Find and control normal mode autofire
  for (let i = 0; i < allMappings.length; i++) {
    let mapping = allMappings[i]
    if (mapping.name == "NormalMode") {
      print "✅ Testing normal mode autofire control for: " + mapping.name
      
      // Check if active
      let wasActive = mapmanager.isAutofireActive(mapping.id)
      print "  Initial state: " + (wasActive ? "ACTIVE" : "INACTIVE")
      
      // Start if not active
      if (!wasActive) {
        print "  Triggering autofire by simulating F3 press..."
        // Note: In real usage, this would be triggered by actually pressing F3
        // For this test, we'll check if it becomes active
      }
      
      // Check status after a moment
      let isActive = mapmanager.isAutofireActive(mapping.id)
      print "  After trigger: " + (isActive ? "ACTIVE" : "INACTIVE")
      
      // Stop autofire
      mapmanager.stopAutofire(mapping.id)
      let isStillActive = mapmanager.isAutofireActive(mapping.id)
      print "  After stop: " + (isStillActive ? "ACTIVE" : "INACTIVE")
      
      break
    }
  }
} else {
  print "❌ No mappings found for control test"
}

// Test 9: Show configuration summary
print "\nTest 9: Show configuration summary"
let finalMappings = mapmanager.getMappings("default")
if (finalMappings && finalMappings.length > 0) {
  print "✅ Final autofire configuration summary:"
  
  let autofireCount = 0
  let totalMappings = finalMappings.length
  
  for (let i = 0; i < finalMappings.length; i++) {
    let mapping = finalMappings[i]
    if (mapping.autofire) {
      autofireCount++
      
      print "  [" + autofireCount + "] " + mapping.name + " -> " + 
             (mapping.targetKeys ? mapping.targetKeys.join(", ") : "None") +
             " (Rate: " + mapping.autofireRate + "ms" +
             ", Mode: " + mapping.autofireMode +
             ", Burst: " + mapping.autofireBurstCount +
             ", Delay: " + mapping.autofireBurstDelay + "ms" +
             ", Condition: " + mapping.autofireCondition + ")"
    }
  }
  
  print "\n📊 Summary Statistics:"
  print "  Total mappings: " + totalMappings
  print "  Autofire mappings: " + autofireCount
  print "  Regular mappings: " + (totalMappings - autofireCount)
  print "  Autofire percentage: " + ((autofireCount / totalMappings) * 100) + "%"
} else {
  print "❌ No mappings found for final summary"
}

