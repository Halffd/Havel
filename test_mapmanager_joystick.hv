// Test Joystick/Gamepad Device Detection

print "=== Testing Joystick/Gamepad Device Detection ==="

// Initialize MapManager
print "Test 1: Initialize MapManager"
let success = mapmanager.init(true)
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Check if any joystick/gamepad is connected
print "\nTest 2: Check joystick/gamepad connection"
let isConnected = mapmanager.isJoystickConnected()
if (isConnected) {
  print "✅ Joystick/gamepad device(s) detected"
} else {
  print "ℹ️ No joystick/gamepad devices found"
}

// Test 3: Get joystick/gamepad count
print "\nTest 3: Get joystick/gamepad count"
let count = mapmanager.getJoystickCount()
print "📊 Number of joystick/gamepad devices: " + count

// Test 4: Detect all joystick/gamepad devices
print "\nTest 4: Detect all joystick/gamepad devices"
let gamepads = mapmanager.detectJoystickDevices()
if (gamepads && gamepads.length > 0) {
  print "✅ Found " + gamepads.length + " joystick/gamepad devices:"
  
  for (let i = 0; i < gamepads.length; i++) {
    let gamepad = gamepads[i]
    print "  [" + i + "] " + gamepad.name
    print "      Path: " + gamepad.path
    print "      Type: " + gamepad.type
    print "      Confidence: " + gamepad.confidence
    
    // Show capabilities
    let caps = gamepad.capabilities
    print "      Capabilities:"
    print "        Total Keys: " + caps.totalKeys
    print "        Gamepad Buttons: " + caps.gamepadButtons
    print "        Joystick Buttons: " + caps.joystickButtons
    print "        Mouse Buttons: " + caps.mouseButtons
    print "        Letter Keys: " + caps.letterKeys
    print "        Number Keys: " + caps.numberKeys
    print "        Modifier Keys: " + caps.modifierKeys
    print "        Has Analog Sticks: " + caps.hasAnalogSticks
    print "        Has D-Pad: " + caps.hasDPad
    print "        Has Movement: " + caps.hasMovement
    print "        Has Absolute Axes: " + caps.hasAbsoluteAxes
    print "        Has Relative Axes: " + caps.hasRelativeAxes
  }
} else {
  print "ℹ️ No joystick/gamepad devices detected"
}

// Test 5: Get detailed info for first joystick/gamepad
print "\nTest 5: Get detailed joystick/gamepad info"
if (count > 0) {
  let gamepadInfo = mapmanager.getJoystickInfo(0)
  if (gamepadInfo && gamepadInfo.name) {
    print "✅ Retrieved detailed info for joystick/gamepad:"
    print "  Name: " + gamepadInfo.name
    print "  Path: " + gamepadInfo.path
    print "  Type: " + gamepadInfo.type
    print "  Confidence: " + gamepadInfo.confidence
    
    // Show detailed capabilities
    let caps = gamepadInfo.capabilities
    print "  Detailed Capabilities:"
    print "    Total Keys: " + caps.totalKeys
    print "    Gamepad Buttons: " + caps.gamepadButtons
    print "    Joystick Buttons: " + caps.joystickButtons
    print "    Mouse Buttons: " + caps.mouseButtons
    print "    Letter Keys: " + caps.letterKeys
    print "    Number Keys: " + caps.numberKeys
    print "    Modifier Keys: " + caps.modifierKeys
    print "    Has Analog Sticks: " + caps.hasAnalogSticks
    print "    Has D-Pad: " + caps.hasDPad
    print "    Has Movement: " + caps.hasMovement
    print "    Has Absolute Axes: " + caps.hasAbsoluteAxes
    print "    Has Relative Axes: " + caps.hasRelativeAxes
  } else {
    print "❌ Failed to get joystick/gamepad info"
  }
} else {
  print "ℹ️ No joystick/gamepad available for detailed info"
}

// Test 6: Search for specific joystick/gamepad by name
print "\nTest 6: Search for joystick/gamepad by name"
let searchResult = mapmanager.getJoystickInfo("xbox")
if (searchResult && searchResult.name) {
  print "✅ Found joystick/gamepad matching 'xbox':"
  print "  Name: " + searchResult.name
  print "  Path: " + searchResult.path
  print "  Type: " + searchResult.type
  print "  Confidence: " + searchResult.confidence
} else if (searchResult == "Joystick/gamepad not found") {
  print "ℹ️ No joystick/gamepad found matching 'xbox'"
} else {
  print "ℹ️ Search result: " + searchResult
}

// Test 7: Get all input devices (not just joysticks)
print "\nTest 7: Get all input devices"
let allDevices = mapmanager.getAllInputDevices()
if (allDevices && allDevices.length > 0) {
  print "✅ Found " + allDevices.length + " total input devices:"
  
  let keyboardCount = 0
  let mouseCount = 0
  let gamepadCount = 0
  let joystickCount = 0
  let otherCount = 0
  
  for (let i = 0; i < allDevices.length; i++) {
    let device = allDevices[i]
    let deviceType = "Unknown"
    
    if (device.type == 0) deviceType = "Keyboard"
    else if (device.type == 1) deviceType = "Mouse"
    else if (device.type == 2) deviceType = "Gamepad"
    else if (device.type == 3) deviceType = "Joystick"
    else if (device.type == 4) deviceType = "Button"
    else if (device.type == 5) deviceType = "Audio"
    else deviceType = "Other"
    
    // Count device types
    if (device.type == 0) keyboardCount++
    else if (device.type == 1) mouseCount++
    else if (device.type == 2) gamepadCount++
    else if (device.type == 3) joystickCount++
    else otherCount++
    
    print "  [" + i + "] " + device.name + " (" + deviceType + ")"
    print "      Path: " + device.path
    print "      Confidence: " + device.confidence
    print "      Reason: " + device.classificationReason
    
    // Show key capabilities for gamepads/joysticks
    if (device.type == 2 || device.type == 3) {
      let caps = device.capabilities
      print "      Buttons: " + caps.gamepadButtons + " gamepad, " + caps.joystickButtons + " joystick"
      print "      Features: " + (caps.hasAnalogSticks ? "Analog sticks, " : "") + (caps.hasDPad ? "D-Pad, " : "") + (caps.hasMovement ? "Movement" : "")
    }
  }
  
  print "\n📊 Device Summary:"
  print "  Keyboards: " + keyboardCount
  print "  Mice: " + mouseCount
  print "  Gamepads: " + gamepadCount
  print "  Joysticks: " + joystickCount
  print "  Other: " + otherCount
  print "  Total: " + allDevices.length
} else {
  print "❌ No input devices found"
}

// Test 8: Create mappings for detected joystick/gamepad
print "\nTest 8: Create mappings for detected joystick/gamepad"
if (count > 0) {
  let gamepadInfo = mapmanager.getJoystickInfo(0)
  if (gamepadInfo && gamepadInfo.name) {
    print "✅ Creating mappings for: " + gamepadInfo.name
    
    // Create mappings for gamepad buttons
    let caps = gamepadInfo.capabilities
    
    if (caps.gamepadButtons >= 4) {
      // Standard gamepad buttons (A, B, X, Y)
      mapmanager.addMapping("default", "Joy1", "Space")      // A button
      mapmanager.addMapping("default", "Joy2", "Escape")     // B button
      mapmanager.addMapping("default", "Joy3", "Enter")      // X button
      mapmanager.addMapping("default", "Joy4", "Tab")        // Y button
      print "✅ Created mappings for 4 gamepad buttons"
    }
    
    if (caps.joystickButtons > 0) {
      // Additional joystick buttons
      mapmanager.addMapping("default", "Joy5", "Ctrl")       // Additional button
      mapmanager.addMapping("default", "Joy6", "Shift")      // Additional button
      print "✅ Created mappings for joystick buttons"
    }
    
    // Create toggle mapping for gamepad
    mapmanager.addToggleMapping("default", "Joy7", "Alt")
    print "✅ Created toggle mapping for gamepad button"
    
    // Create script callback for gamepad
    let gamepadScript = "
print('Gamepad button pressed!');
let currentMappings = mapmanager.getMappings('default');
print('Total mappings: ' + currentMappings.length);
"
    mapmanager.addScriptCallbackMapping("default", "Joy8", gamepadScript)
    print "✅ Created script callback for gamepad button"
    
  } else {
    print "❌ No gamepad available for mapping creation"
  }
} else {
  print "ℹ️ No joystick/gamepad available for mapping creation"
}

// Test 9: Verify joystick/gamepad mappings
print "\nTest 9: Verify joystick/gamepad mappings"
let mappings = mapmanager.getMappings("default")
if (mappings && mappings.length > 0) {
  print "✅ Found " + mappings.length + " total mappings:"
  
  let joystickMappings = 0
  for (let i = 0; i < mappings.length; i++) {
    let mapping = mappings[i]
    if (mapping.sourceKey && mapping.sourceKey.indexOf("Joy") >= 0) {
      joystickMappings++
      print "  [" + i + "] " + mapping.name + " -> " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "Script")
      print "      Source: " + mapping.sourceKey
      
      let mappingType = "Unknown"
      if (mapping.actionType == 0) mappingType = "Press"
      else if (mapping.actionType == 1) mappingType = "Hold"
      else if (mapping.actionType == 2) mappingType = "Toggle"
      else if (mapping.actionType == 5) mappingType = "Macro/Script"
      
      print "      Type: " + mappingType
    }
  }
  
  print "📊 Joystick/Gamepad Mappings: " + joystickMappings
} else {
  print "❌ No mappings found"
}

print "\n=== Joystick/Gamepad Device Detection Tests Complete ==="
print "\n🎯 Summary of Joystick/Gamepad Detection Features:"
print "- ✅ Comprehensive device detection (gamepads and joysticks)"
print "- ✅ Device capability analysis (buttons, axes, features)"
print "- ✅ Device classification with confidence scores"
print "- ✅ Search by index or name"
print "- ✅ All input device enumeration"
print "- ✅ Integration with MapManager mapping system"
print "- ✅ Support for both gamepads and joysticks"
print ""
print "🎮 Joystick/Gamepad Detection API Functions:"
print "- detectJoystickDevices() - Get all gamepad/joystick devices"
print "- getAllInputDevices() - Get all input devices (keyboard, mouse, etc.)"
print "- getJoystickCount() - Get number of gamepad/joystick devices"
print "- isJoystickConnected() - Check if any gamepad/joystick is connected"
print "- getJoystickInfo(index/name) - Get detailed device information"
print ""
print "🔍 Device Information Provided:"
print "- Device name and path"
print "- Device type (Gamepad, Joystick, Keyboard, Mouse, etc.)"
print "- Classification confidence score"
print "- Detailed capabilities:"
print "  • Total keys/buttons"
print "  • Gamepad buttons (A, B, X, Y, etc.)"
print "  • Joystick buttons (additional buttons)"
print "  • Mouse buttons (if present)"
print "  • Letter/number/modifier keys"
print "  • Analog sticks presence"
print "  • D-Pad presence"
print "  • Movement capabilities"
print "  • Absolute/relative axes"
print ""
print "🏆 MapManager now provides complete joystick/gamepad device detection!"
