// Test Key Recording functionality in MapManager

print "=== Testing Key Recording ==="

// Initialize MapManager
print "Test 1: Initialize MapManager"
let success = mapmanager.init(true)
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Create a test mapping to update
print "\nTest 2: Create test mapping for key recording"
let testMapping = mapmanager.addMapping("default", "TestKey", "Ctrl+T")
if (testMapping) {
  print "✅ Created test mapping: TestKey -> Ctrl+T"
} else {
  print "❌ Failed to create test mapping"
}

// Test 3: Check initial recording state
print "\nTest 3: Check initial recording state"
let isRecording = mapmanager.isKeyRecording()
if (!isRecording) {
  print "✅ Key recording is initially off"
} else {
  print "❌ Key recording is unexpectedly on"
}

// Test 4: Start key recording
print "\nTest 4: Start key recording"
let startRecording = mapmanager.startKeyRecording()
if (startRecording) {
  print "✅ Started key recording"
  print "   Press any key/button to record..."
  
  // Check recording state
  let nowRecording = mapmanager.isKeyRecording()
  if (nowRecording) {
    print "✅ Key recording is now active"
  } else {
    print "❌ Key recording failed to start"
  }
} else {
  print "❌ Failed to start key recording"
}

// Test 5: Simulate key detection (in real implementation, this would wait for input)
print "\nTest 5: Simulate key detection"
// In a real implementation, this would wait for user input
// For now, let's simulate detecting different input sources

// Test keyboard input detection
let keyboardSource = mapmanager.detectInputSource(30)  // 'A' key code
print "✅ Detected keyboard input source: " + keyboardSource

// Test mouse input detection  
let mouseSource = mapmanager.detectInputSource(272)  // Mouse button code
print "✅ Detected mouse input source: " + mouseSource

// Test joystick input detection
let joystickSource = mapmanager.detectInputSource(288)  // Joystick button code
print "✅ Detected joystick input source: " + joystickSource

// Test 6: Key code to string conversion
print "\nTest 6: Key code to string conversion"
let keyboardKey = mapmanager.keyCodeToString(30, "evdev")
print "✅ Evdev code 30 -> " + keyboardKey

let mouseKey = mapmanager.keyCodeToString(272, "mouse")
print "✅ Mouse code 272 -> " + mouseKey

let joystickKey = mapmanager.keyCodeToString(288, "joystick")
print "✅ Joystick code 288 -> " + joystickKey

// Test 7: Get last recorded key (simulated)
print "\nTest 7: Get last recorded key"
let recordedKey = mapmanager.getLastRecordedKey()
if (recordedKey) {
  print "✅ Retrieved recorded key:"
  print "   Key Name: " + recordedKey.keyName
  print "   Key Code: " + recordedKey.keyCode
  print "   Source: " + recordedKey.source
  print "   Modifiers: " + recordedKey.modifiers
  print "   Is Mouse: " + recordedKey.isMouse
  print "   Is Joystick: " + recordedKey.isJoystick
} else {
  print "❌ No recorded key found"
}

// Test 8: Stop key recording
print "\nTest 8: Stop key recording"
let stopRecording = mapmanager.stopKeyRecording()
if (stopRecording) {
  print "✅ Stopped key recording"
  
  // Verify recording is stopped
  let stillRecording = mapmanager.isKeyRecording()
  if (!stillRecording) {
    print "✅ Key recording is confirmed stopped"
  } else {
    print "❌ Key recording is still active"
  }
} else {
  print "❌ Failed to stop key recording"
}

// Test 9: Record and set key functionality
print "\nTest 9: Record and set key functionality"
print "   This would normally open a recording dialog..."
print "   User presses a key, and it gets set to the mapping"

// Simulate the record and set process
let mappings = mapmanager.getMappings("default")
if (mappings && mappings.length > 0) {
  for (let i = 0; i < mappings.length; i++) {
    let mapping = mappings[i]
    if (mapping.name && mapping.name.indexOf("TestKey") >= 0) {
      print "   Found test mapping: " + mapping.name + " -> " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
      
      // In a real GUI, this would open a "Record Key" dialog
      // User clicks "Record", presses a key, and it gets set
      print "   Would open 'Record Key' dialog for this mapping"
      print "   User presses key -> mapping.sourceKey gets updated"
      break
    }
  }
}

// Test 10: Clear recorded key
print "\nTest 10: Clear recorded key"
let clearKey = mapmanager.clearRecordedKey()
if (clearKey) {
  print "✅ Cleared recorded key"
  
  // Verify key is cleared
  let clearedKey = mapmanager.getLastRecordedKey()
  if (!clearedKey || clearedKey.keyName == "") {
    print "✅ Recorded key is confirmed cleared"
  } else {
    print "❌ Recorded key still exists: " + clearedKey.keyName
  }
} else {
  print "❌ Failed to clear recorded key"
}

// Test 11: Advanced recording scenarios
print "\nTest 11: Advanced recording scenarios"
print "   Supported input sources for recording:"
print "   - Keyboard keys (A-Z, 0-9, F1-F12, Ctrl, Alt, Shift, etc.)"
print "   - Mouse buttons (Left, Right, Middle, Side buttons, etc.)"
print "   - Mouse wheel (Up, Down, Left, Right scroll)"
print "   - Joystick buttons (Joy1, Joy2, etc.)"
print "   - Joystick axes (X, Y, Z, etc.)"
print "   - Combinations (Ctrl+A, Alt+F4, etc.)"
print ""
print "   Recording features:"
print "   - Cross-platform input detection (Evdev, X11, Windows, macOS)"
print "   - Automatic source detection"
print "   - Key code conversion"
print "   - Modifier key detection"
print "   - Real-time recording feedback"
print "   - Integration with mapping system"

