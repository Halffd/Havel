// Test Mouse Bindings in MapManager

print "=== Testing Mouse Bindings ==="

// Initialize MapManager
print "Test 1: Initialize MapManager"
let success = mapmanager.init(true)
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Mouse button bindings
print "\nTest 2: Mouse button bindings"
let leftClick = mapmanager.addMouseButtonMapping("default", 1, "click", "Ctrl+C")
if (leftClick) {
  print "✅ Added left click mapping: Mouse1 -> Ctrl+C"
}

let rightClick = mapmanager.addMouseButtonMapping("default", 2, "click", "Ctrl+V")
if (rightClick) {
  print "✅ Added right click mapping: Mouse2 -> Ctrl+V"
}

let middleClick = mapmanager.addMouseButtonMapping("default", 3, "click", "Ctrl+X")
if (middleClick) {
  print "✅ Added middle click mapping: Mouse3 -> Ctrl+X"
}

let sideButton1 = mapmanager.addMouseButtonMapping("default", 4, "click", "Alt+Tab")
if (sideButton1) {
  print "✅ Added side button mapping: Mouse4 -> Alt+Tab"
}

// Test 3: Mouse wheel bindings
print "\nTest 3: Mouse wheel bindings"
let wheelUp = mapmanager.addMouseWheelMapping("default", "up", "scroll", "PageUp")
if (wheelUp) {
  print "✅ Added wheel up mapping: MouseWheelUp -> PageUp"
}

let wheelDown = mapmanager.addMouseWheelMapping("default", "down", "scroll", "PageDown")
if (wheelDown) {
  print "✅ Added wheel down mapping: MouseWheelDown -> PageDown"
}

let wheelLeft = mapmanager.addMouseWheelMapping("default", "left", "scroll", "Ctrl+Tab")
if (wheelLeft) {
  print "✅ Added wheel left mapping: MouseWheelLeft -> Ctrl+Tab"
}

let wheelRight = mapmanager.addMouseWheelMapping("default", "right", "scroll", "Ctrl+Shift+Tab")
if (wheelRight) {
  print "✅ Added wheel right mapping: MouseWheelRight -> Ctrl+Shift+Tab"
}

// Test 4: Mouse movement bindings
print "\nTest 4: Mouse movement bindings"
let moveX = mapmanager.addMouseMoveMapping("default", "x", 1.5, 0.1, "Right")
if (moveX) {
  print "✅ Added X-axis movement mapping: MouseMoveX -> Right (sensitivity: 1.5)"
}

let moveY = mapmanager.addMouseMoveMapping("default", "y", 1.2, 0.1, "Down")
if (moveY) {
  print "✅ Added Y-axis movement mapping: MouseMoveY -> Down (sensitivity: 1.2)"
}

// Test 5: Mouse gesture bindings
print "\nTest 5: Mouse gesture bindings"
let circleGesture = mapmanager.addMouseGestureMapping("default", "circle", "Ctrl+Z")
if (circleGesture) {
  print "✅ Added circle gesture mapping: GestureCircle -> Ctrl+Z"
}

let swipeGesture = mapmanager.addMouseGestureMapping("default", "swipe", "Alt+F4")
if (swipeGesture) {
  print "✅ Added swipe gesture mapping: GestureSwipe -> Alt+F4"
}

// Test 6: Advanced mouse combinations
print "\nTest 6: Advanced mouse combinations"

// Toggle mouse binding
let toggleMouse = mapmanager.addToggleMapping("default", "Mouse5", "Shift")
if (toggleMouse) {
  print "✅ Added toggle mouse binding: Mouse5 -> Shift (toggle mode)"
}

// Multi-source mouse + keyboard
let mouseKeyboardCombo = ["Mouse1", "Ctrl"]
let comboMapping = mapmanager.addMultiSourceMapping("default", mouseKeyboardCombo, "Escape")
if (comboMapping) {
  print "✅ Added mouse+keyboard combo: Mouse1+Ctrl -> Escape"
}

// Script callback with mouse
let mouseScript = "
print('Mouse button clicked!');
let currentPos = mouse.getPosition();
print('Mouse position: ' + currentPos.x + ', ' + currentPos.y);
if (currentPos.x > 1000) {
  send('Ctrl+Shift+Right');
} else {
  send('Ctrl+Shift+Left');
}
"
let mouseScriptMapping = mapmanager.addScriptCallbackMapping("default", "Mouse6", mouseScript)
if (mouseScriptMapping) {
  print "✅ Added mouse script callback: Mouse6 -> Position-based script"
}

// Test 7: Mouse sensitivity adjustment
print "\nTest 7: Mouse sensitivity adjustment"
let mappings = mapmanager.getMappings("default")
if (mappings && mappings.length > 0) {
  for (let i = 0; i < mappings.length; i++) {
    let mapping = mappings[i]
    if (mapping.name && mapping.name.indexOf("MouseMove") >= 0) {
      print "   Found mouse movement mapping: " + mapping.name
      
      // Adjust sensitivity
      let sensitivitySet = mapmanager.setMouseSensitivity("default", mapping.id, 2.0)
      if (sensitivitySet) {
        print "   ✅ Set sensitivity to 2.0 for: " + mapping.name
      }
    }
  }
}

// Test 8: Get all mouse bindings
print "\nTest 8: Get all mouse bindings"
let mouseBindings = mapmanager.getMouseBindings("default")
if (mouseBindings && mouseBindings.length > 0) {
  print "✅ Found " + mouseBindings.length + " mouse bindings:"
  
  for (let i = 0; i < mouseBindings.length; i++) {
    let binding = mouseBindings[i]
    print "  [" + i + "] " + binding.name
    print "      Source: " + binding.sourceKey
    print "      Action: " + binding.mouseAction
    print "      Target: " + (binding.targetKey || "None")
    print "      Button: " + binding.mouseButton
    print "      Wheel: " + binding.mouseWheelDirection
    print "      Sensitivity: " + binding.sensitivity
    print "      Gesture: " + binding.mouseGesture
  }
} else {
  print "❌ No mouse bindings found"
}

// Test 9: Verify all mappings including mouse
print "\nTest 9: Verify all mappings including mouse"
let allMappings = mapmanager.getMappings("default")
if (allMappings && allMappings.length > 0) {
  print "✅ Found " + allMappings.length + " total mappings:"
  
  let mouseCount = 0
  let keyboardCount = 0
  let comboCount = 0
  
  for (let i = 0; i < allMappings.length; i++) {
    let mapping = allMappings[i]
    let mappingType = "Unknown"
    
    if (mapping.actionType == 0) mappingType = "Press"
    else if (mapping.actionType == 1) mappingType = "Hold"
    else if (mapping.actionType == 2) mappingType = "Toggle"
    else if (mapping.actionType == 3) mappingType = "Autofire"
    else if (mapping.actionType == 4) mappingType = "Turbo"
    else if (mapping.actionType == 5) mappingType = "Macro"
    else if (mapping.actionType == 6) mappingType = "MouseMove"
    else if (mapping.actionType == 7) mappingType = "MouseScroll"
    
    let features = ""
    if (mapping.name && mapping.name.indexOf("Multi") >= 0) {
      features += " [Multi-Source]"
      comboCount++
    }
    if (mapping.name && mapping.name.indexOf("toggle") >= 0) features += " [Toggle]"
    if (mapping.name && mapping.name.indexOf("Script") >= 0) features += " [Script]"
    if (mapping.name && mapping.name.indexOf("Mouse") >= 0) {
      features += " [Mouse]"
      mouseCount++
    } else {
      keyboardCount++
    }
    
    print "  [" + i + "] " + mapping.name + " -> " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "Script")
    print "      Type: " + mappingType + features
    print "      Source: " + mapping.sourceKey
  }
  
  print "\n📊 Mapping Summary:"
  print "  Mouse bindings: " + mouseCount
  print "  Keyboard bindings: " + keyboardCount
  print "  Combo bindings: " + comboCount
  print "  Total mappings: " + allMappings.length
} else {
  print "❌ No mappings found"
}

print "\n=== Mouse Bindings Tests Complete ==="
print "\n🎯 Summary of Mouse Binding Features:"
print "- ✅ Mouse button bindings (left, right, middle, side buttons)"
print "- ✅ Mouse wheel bindings (up, down, left, right)"
print "- ✅ Mouse movement bindings (X-axis, Y-axis with sensitivity)"
print "- ✅ Mouse gesture bindings (circle, swipe, custom gestures)"
print "- ✅ Advanced combinations (mouse+keyboard, toggle, script)"
print "- ✅ Sensitivity adjustment and threshold control"
print "- ✅ Comprehensive mouse binding management"
print ""
print "🖱️ Mouse Binding API Functions:"
print "- addMouseButtonMapping(profileId, mouseButton, actionType, targetKey)"
print "  • Mouse buttons: 1=left, 2=right, 3=middle, 4=side1, 5=side2, etc."
print "  • Action types: click, double-click, hold, release"
print ""
print "- addMouseWheelMapping(profileId, direction, actionType, targetKey)"
print "  • Directions: up, down, left, right"
print "  • Supports scroll wheel events"
print ""
print "- addMouseMoveMapping(profileId, axis, sensitivity, threshold, targetKey)"
print "  • Axes: x, y for horizontal/vertical movement"
print "  • Sensitivity and threshold control"
print ""
print "- addMouseGestureMapping(profileId, gestureName, targetKey)"
print "  • Gesture recognition with point sequences"
print "  • Custom gesture patterns"
print ""
print "- setMouseSensitivity(profileId, mappingId, sensitivity)"
print "  • Dynamic sensitivity adjustment"
print ""
print "- getMouseBindings(profileId)"
print "  • Retrieve all mouse-specific bindings"
print ""
print "🏆 MapManager now provides complete mouse binding support!"
