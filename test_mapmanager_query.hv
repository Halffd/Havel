// Test MapManager list, query, and filter functions

print "=== Testing MapManager List/Query/Filter Functions ==="

// Initialize MapManager
print "Test 1: Initialize MapManager"
let success = mapmanager.init()
if (success) {
  print "✅ MapManager initialized successfully"
} else {
  print "❌ MapManager initialization failed"
}

// Test 2: Add some test mappings to default profile
print "\nTest 2: Add test mappings"
mapmanager.addMapping("default", "F1", "Ctrl+C")
mapmanager.addMapping("default", "F2", "Ctrl+V")
mapmanager.addMapping("default", "F3", "Ctrl+X")
mapmanager.addMapping("default", "Space", "Enter")
print "✅ Added test mappings to default profile"

// Test 3: List all profiles
print "\nTest 3: List all profiles"
let profiles = mapmanager.listProfiles()
if (profiles && profiles.length > 0) {
  print "✅ Found " + profiles.length + " profiles:"
  for (let i = 0; i < profiles.length; i++) {
    let profile = profiles[i]
    print "  [" + i + "] " + profile.name + " (ID: " + profile.id + ")"
    print "      Description: " + profile.description
    print "      Enabled: " + profile.enabled
    print "      Mappings: " + profile.mappingCount
  }
} else {
  print "❌ No profiles found"
}

// Test 4: Get all mappings from default profile
print "\nTest 4: Get all mappings from default profile"
let mappings = mapmanager.getMappings("default")
if (mappings && mappings.length > 0) {
  print "✅ Found " + mappings.length + " mappings in default profile:"
  for (let i = 0; i < mappings.length; i++) {
    let mapping = mappings[i]
    print "  [" + i + "] " + mapping.name + " (" + mapping.id + ")"
    print "      Source: " + mapping.sourceKey
    print "      Target: " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
    print "      Enabled: " + mapping.enabled
    print "      Type: " + mapping.actionType
    print "      Autofire: " + mapping.autofire
    print "      Turbo: " + mapping.turbo
  }
} else {
  print "❌ No mappings found in default profile"
}

// Test 5: Find specific mapping
print "\nTest 5: Find specific mapping"
let f1Mapping = mapmanager.findMapping("default", "F1")
if (f1Mapping) {
  print "✅ Found F1 mapping:"
  print "  ID: " + f1Mapping.id
  print "  Name: " + f1Mapping.name
  print "  Source: " + f1Mapping.sourceKey
  print "  Target: " + (f1Mapping.targetKeys.length > 0 ? f1Mapping.targetKeys[0] : "None")
  print "  Enabled: " + f1Mapping.enabled
} else {
  print "❌ F1 mapping not found"
}

// Test 6: Filter mappings by enabled status
print "\nTest 6: Filter enabled mappings"
let enabledMappings = mapmanager.filterMappings("default", "enabled", "true")
if (enabledMappings && enabledMappings.length > 0) {
  print "✅ Found " + enabledMappings.length + " enabled mappings:"
  for (let i = 0; i < enabledMappings.length; i++) {
    let mapping = enabledMappings[i]
    print "  [" + i + "] " + mapping.name + " (" + mapping.id + ")"
    print "      Source: " + mapping.sourceKey + " -> Target: " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
  }
} else {
  print "❌ No enabled mappings found"
}

// Test 7: Filter mappings by source key pattern
print "\nTest 7: Filter mappings by source key pattern"
let fMappings = mapmanager.filterMappings("default", "sourceKey", "F")
if (fMappings && fMappings.length > 0) {
  print "✅ Found " + fMappings.length + " mappings with source key containing 'F':"
  for (let i = 0; i < fMappings.length; i++) {
    let mapping = fMappings[i]
    print "  [" + i + "] " + mapping.name + " (" + mapping.id + ")"
    print "      Source: " + mapping.sourceKey + " -> Target: " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
  }
} else {
  print "❌ No mappings found with source key pattern 'F'"
}

// Test 8: Filter mappings by action type
print "\nTest 8: Filter mappings by action type"
let pressMappings = mapmanager.filterMappings("default", "actionType", "0")
if (pressMappings && pressMappings.length > 0) {
  print "✅ Found " + pressMappings.length + " 'Press' type mappings:"
  for (let i = 0; i < pressMappings.length; i++) {
    let mapping = pressMappings[i]
    print "  [" + i + "] " + mapping.name + " (" + mapping.id + ")"
    print "      Source: " + mapping.sourceKey + " -> Target: " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
  }
} else {
  print "❌ No 'Press' type mappings found"
}

// Test 9: Filter autofire mappings
print "\nTest 9: Filter autofire mappings"
let autofireMappings = mapmanager.filterMappings("default", "autofire", "true")
if (autofireMappings && autofireMappings.length > 0) {
  print "✅ Found " + autofireMappings.length + " autofire mappings:"
  for (let i = 0; i < autofireMappings.length; i++) {
    let mapping = autofireMappings[i]
    print "  [" + i + "] " + mapping.name + " (" + mapping.id + ")"
    print "      Source: " + mapping.sourceKey + " -> Target: " + (mapping.targetKeys.length > 0 ? mapping.targetKeys[0] : "None")
    print "      Turbo: " + mapping.turbo
  }
} else {
  print "❌ No autofire mappings found"
}

// Test 10: Get active profile info
print "\nTest 10: Get active profile info"
let activeProfile = mapmanager.getActiveProfile()
if (activeProfile && activeProfile != "No active profile") {
  print "✅ Active profile:"
  print "  ID: " + activeProfile.id
  print "  Name: " + activeProfile.name
  print "  Description: " + activeProfile.description
  print "  Enabled: " + activeProfile.enabled
  print "  Mapping count: " + activeProfile.mappingCount
} else {
  print "❌ No active profile"
}

print "\n=== MapManager List/Query/Filter Tests Complete ==="
print "\n🎯 Summary of New Functions:"
print "- listProfiles(): Lists all available profiles with details"
print "- getMappings(profileId): Gets all mappings from specific profile"
print "- findMapping(profileId, sourceKey): Finds specific mapping by source key"
print "- filterMappings(profileId, field, value): Filters mappings by field/value"
print "\n🔍 Supported Filter Fields:"
print "- 'enabled': Filter by enabled status (true/false)"
print "- 'sourceKey': Filter by source key pattern (string match)"
print "- 'actionType': Filter by action type (0=Press, 1=Hold, etc.)"
print "- 'autofire': Filter by autofire status (true/false)"
print "- 'turbo': Filter by turbo mode (true/false)"
