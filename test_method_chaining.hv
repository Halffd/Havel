// Test method chaining and type conversion per docs

print("=== Testing Method Chaining on Literals ===");

// String methods (per docs)
print('"hello".upper() =', "hello".upper());
print('"HELLO".lower() =', "HELLO".lower());
print('"  hi  ".trim() =', "  hi  ".trim());

// Array methods (per docs)
print('[1,2,3].len() =', [1,2,3].len());
print('[3,1,2].sort() =', [3,1,2].sort());
print('[1,2,3].reverse() =', [1,2,3].reverse());

// Object methods
print('{"a": 1, "b": 2}.keys() =', {"a": 1, "b": 2}.keys());
print('{"a": 1, "b": 2}.values() =', {"a": 1, "b": 2}.values());

print("\n=== Testing Type Conversion (per docs) ===");

// Per docs: int(), num(), str()
print('int(42.9) =', int(42.9));
print('num("3.14") =', num("3.14"));
print('str(123) =', str(123));

print("\n=== All tests completed! ===");
