// Test all new features

print("=== Testing bool() and type() ===");
print("bool(0) =", bool(0));
print("bool(1) =", bool(1));
print("bool('') =", bool(""));
print("bool('hi') =", bool("hi"));
print("type(42) =", type(42));
print("type(3.14) =", type(3.14));
print("type('hi') =", type("hi"));
print("type(true) =", type(true));
print("type([1,2]) =", type([1,2]));
print("type({a:1}) =", type({a:1}));

print("\n=== Testing Method Chaining on Literals ===");
print('"hello".upper() =', "hello".upper());
print('"HELLO".lower() =', "HELLO".lower());
print('"  hi  ".trim() =', "  hi  ".trim());
print('[3,1,2].sort() =', [3,1,2].sort());
print('[1,2,3].reverse() =', [1,2,3].reverse());
print('[1,2,3].len() =', [1,2,3].len());
print('{"a": 1, "b": 2}.keys() =', {"a": 1, "b": 2}.keys());
print('{"a": 1, "b": 2}.values() =', {"a": 1, "b": 2}.values());

print("\n=== Testing Formatted Output ===");
print('Array:', [1, 2, 3]);
print('Object:', {"name": "test", "value": 42});

print("\n=== All tests completed! ===");
