// Simple test script for extracted stdlib modules
// Run with: ./build-release/havel --run test_simple.hv

print("=== Testing Extracted Stdlib Modules ===\n")

// Math Module Tests
print("--- Math Module ---")
print("math.abs(-5) = " + math.abs(-5))
print("math.ceil(3.2) = " + math.ceil(3.2))
print("math.floor(3.8) = " + math.floor(3.8))
print("math.round(3.5) = " + math.round(3.5))
print("math.sin(0) = " + math.sin(0))
print("math.cos(0) = " + math.cos(0))
print("math.sqrt(16) = " + math.sqrt(16))
print("math.pow(2, 3) = " + math.pow(2, 3))
print("math.PI = " + math.PI)
print("math.E = " + math.E)

print("")

// Type Module Tests (these ARE global)
print("--- Type Module ---")
print("int(3.7) = " + int(3.7))
print("int('42') = " + int("42"))
print("num('3.14') = " + num("3.14"))
print("str(42) = " + str(42))
print("str(3.14) = " + str(3.14))
print("type(42) = " + type(42))
print("type('hello') = " + type("hello"))
print("len('hello') = " + len("hello"))
print("len([1,2,3]) = " + len([1,2,3]))

print("")

// String Module Tests (these ARE global)
print("--- String Module ---")
print("upper('hello') = " + upper("hello"))
print("lower('WORLD') = " + lower("WORLD"))
print("trim('  hello  ') = '" + trim("  hello  ") + "'")
print("length('hello') = " + length("hello"))
print("contains('hello', 'ell') = " + contains("hello", "ell"))
print("startsWith('hello', 'he') = " + startsWith("hello", "he"))
print("endsWith('hello', 'lo') = " + endsWith("hello", "lo"))
print("replace('hello', 'l', 'x') = " + replace("hello", "l", "x"))
print("substr('hello', 1, 3) = " + substr("hello", 1, 3))
print("format('Hello {}', 'World') = " + format("Hello {}", "World"))

print("")

// Array Module Tests (these ARE global)
print("--- Array Module ---")
print("map([1,2,3], int) = " + map([1,2,3], int))
print("join([1,2,3], '-') = " + join([1,2,3], "-"))
print("split('a-b-c', '-') = " + split("a-b-c", "-"))

print("")

// File Module Tests
print("--- File Module ---")
file.write("/tmp/havel_test.txt", "Hello from Havel!")
print("file.exists('/tmp/havel_test.txt') = " + file.exists("/tmp/havel_test.txt"))
print("file.read('/tmp/havel_test.txt') = '" + file.read("/tmp/havel_test.txt") + "'")

print("")

// Regex Module Tests
print("--- Regex Module ---")
print("regex.match('hello world', 'world') = " + regex.match("hello world", "world"))
print("regex.match('hello world', 'cat') = " + regex.match("hello world", "cat"))
print("regex.findall('hello', 'l') = " + regex.findall("hello", "l"))
print("regex.replace('hello world', ' ', '_') = " + regex.replace("hello world", " ", "_"))
print("regex.split('a b c', ' ') = " + regex.split("a b c", " "))

print("")
print("=== All Tests Complete ===")
