use "net/socket" as sock

fn main() {
    print("Creating socket...")
    fd = sock.create(sock.AF_INET, sock.SOCK_STREAM, 0)
    print("Socket FD: {fd}")
    
    if fd < 0 {
        print("Failed to create socket")
        return
    }
    
    print("Binding to port 9000...")
    res = sock.bind(fd, "127.0.0.1", 9000, sock.AF_INET)
    print("Bind result: {res}")
    
    if res < 0 {
        print("Failed to bind")
        sock.close(fd)
        return
    }
    
    print("Listening...")
    sock.listen(fd, 1)
    
    print("Closing socket...")
    sock.close(fd)
    print("Done")
}

main()
