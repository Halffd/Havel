// Test VM-native stdlib functions

print("=== Testing Math Module ===");
print("math.abs(-5) = ", math.abs(-5));
print("math.sin(PI/2) = ", math.sin(PI/2));
print("math.cos(0) = ", math.cos(0));
print("math.tan(PI/4) = ", math.tan(PI/4));
print("math.sqrt(16) = ", math.sqrt(16));
print("math.log(E) = ", math.log(E));
print("math.exp(1) = ", math.exp(1));
print("math.pow(2, 10) = ", math.pow(2, 10));
print("math.min(3, 1, 2) = ", math.min(3, 1, 2));
print("math.max(1, 3, 2) = ", math.max(1, 3, 2));
print("math.random() = ", math.random());
print("PI = ", PI);
print("E = ", E);

print("\n=== Testing String Module ===");
print("string.len('hello') = ", string.len("hello"));
print("string.upper('hello') = ", string.upper("hello"));
print("string.lower('HELLO') = ", string.lower("HELLO"));
print("string.trim('  hi  ') = ", string.trim("  hi  "));
print("string.sub('hello', 1, 3) = ", string.sub("hello", 1, 3));
print("string.find('hello', 'ell') = ", string.find("hello", "ell"));
print("string.replace('hello', 'l', 'L') = ", string.replace("hello", "l", "L"));
print("string.startswith('hello', 'he') = ", string.startswith("hello", "he"));
print("string.endswith('hello', 'lo') = ", string.endswith("hello", "lo"));

print("\n=== Testing Type Module ===");
print("int('42') = ", int("42"));
print("float('3.14') = ", float("3.14"));
print("str(123) = ", str(123));
print("bool(1) = ", bool(1));
print("bool(0) = ", bool(0));
print("type(42) = ", type(42));
print("type('hi') = ", type("hi"));
print("type(3.14) = ", type(3.14));
print("abs(-5) = ", abs(-5));
print("min(3, 1, 2) = ", min(3, 1, 2));
print("max(1, 3, 2) = ", max(1, 3, 2));
print("round(3.7) = ", round(3.7));
print("ceil(3.2) = ", ceil(3.2));
print("floor(3.8) = ", floor(3.8));

print("\n=== Testing Utility Module ===");
print("range(5) = ", range(5));
print("range(2, 5) = ", range(2, 5));
print("range(0, 10, 2) = ", range(0, 10, 2));
print("list('hi') = ", list("hi"));

print("\n=== Testing Array Module ===");
arr = [1, 2, 3];
print("array.len(arr) = ", array.len(arr));
array.push(arr, 4);
print("after push: arr = ", arr);
print("array.concat([1], [2], [3]) = ", array.concat([1], [2], [3]));

print("\n=== All tests completed! ===");
