// Test VM-native stdlib functions

print("=== Testing String Methods ===");
print("Upper: ", String.upper("hello"));
print("Lower: ", String.lower("HELLO"));
print("Trim: ", String.trim("  spaces  "));
print("Sub: ", String.sub("Hello World", 0, 5));
print("Replace: ", String.replace("Hello World", "World", "Havel"));
print("StartsWith 'Hello': ", String.startswith("Hello World", "Hello"));
print("EndsWith 'World': ", String.endswith("Hello World", "World"));
print("Includes 'lo': ", String.includes("Hello World", "lo"));

print("\n=== Testing Array Methods ===");
arr = Array.concat([1, 2], [3, 4]);
print("Concat [1,2] + [3,4]: ", arr);
print("Length: ", Array.len(arr));

print("\n=== Testing Object Methods ===");
obj = {"a": 1, "b": 2};
print("Object: ", obj);
print("Keys: ", Object.keys(obj));
print("Values: ", Object.values(obj));
print("Has 'b': ", Object.has(obj, "b"));
print("Has 'x': ", Object.has(obj, "x"));

print("\n=== All tests completed! ===");
