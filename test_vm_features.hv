// Test VM features: type conversion, spread operator

print("=== Testing Type Conversion Functions ===");

// toInt()
print("toInt(42.7) =", toInt(42.7));
print("toInt('123') =", toInt("123"));
print("toInt(true) =", toInt(true));
print("toInt(false) =", toInt(false));

// toFloat()
print("toFloat(42) =", toFloat(42));
print("toFloat('3.14') =", toFloat("3.14"));
print("toFloat(true) =", toFloat(true));

// toString()
print("toString(123) =", toString(123));
print("toString(3.14) =", toString(3.14));
print("toString(true) =", toString(true));
print("toString(false) =", toString(false));

// toBool()
print("toBool(1) =", toBool(1));
print("toBool(0) =", toBool(0));
print("toBool('hello') =", toBool("hello"));
print("toBool('') =", toBool(""));

// typeof()
print("typeof(42) =", typeof(42));
print("typeof(3.14) =", typeof(3.14));
print("typeof('hello') =", typeof("hello"));
print("typeof(true) =", typeof(true));
print("typeof([1,2,3]) =", typeof([1,2,3]));
print("typeof({a: 1}) =", typeof({a: 1}));

print("\n=== Testing Built-in Functions ===");

// Test print with multiple arguments
print("Multiple args:", 1, "two", 3.0, true);

// Test clock_ms
print("Current time (ms):", clock_ms());

print("\n=== All tests completed! ===");
