// Test script for signal-mode-reaction pipeline
// Tests window.*, active.*, signal, when, and mode integration

// ============================================
// Test 1: Window Query Functions
// ============================================
print("Testing window query functions...")

// Test window.any() - check if any terminal window exists
let hasTerminal = window.any("class terminal")
print("Has terminal window: " + hasTerminal)

// Test window.count() - count all windows
let totalWindows = window.count()
print("Total windows: " + totalWindows)

// Test window.count() with selector
let chromeCount = window.count("exe chrome")
print("Chrome windows: " + chromeCount)

// Test window.filter() - get all windows matching a predicate
let terminals = window.filter("class terminal")
print("Found " + len(terminals) + " terminal windows")

// ============================================
// Test 2: Active Window Namespace
// ============================================
print("\nTesting active.* namespace...")

// Get active window info
let activeTitle = active.title()
let activeClass = active.class()
let activeExe = active.exe()
let activePid = active.pid()

print("Active window title: " + activeTitle)
print("Active window class: " + activeClass)
print("Active window exe: " + activeExe)
print("Active window pid: " + activePid)

// ============================================
// Test 3: Signal Definitions
// ============================================
print("\nTesting signal definitions...")

// Define signals based on window state
signal inBrowser when active.exe() == "chrome" || active.exe() == "firefox"
signal inTerminal when active.class() == "terminal"
signal hasCodeWindow when window.any("class code")

print("Signals defined: inBrowser, inTerminal, hasCodeWindow")

// ============================================
// Test 4: When Statement Reactions
// ============================================
print("\nTesting when statements...")

// React when entering browser
when inBrowser {
    print("Switched to browser - enabling web shortcuts")
    mode.set("browser")
}

// React when entering terminal
when inTerminal {
    print("Switched to terminal - enabling terminal shortcuts")
    mode.set("terminal")
}

// React when code window appears
when hasCodeWindow {
    print("Code window detected - enabling dev shortcuts")
}

// ============================================
// Test 5: Mode Integration with Window State
// ============================================
print("\nTesting mode integration...")

// Define modes with conditions using window queries
mode browser {
    condition: window.any("exe chrome")
    enter: { print("Entering browser mode") }
    exit: { print("Exiting browser mode") }
}

mode terminal {
    condition: window.any("class terminal")
    enter: { print("Entering terminal mode") }
    exit: { print("Exiting terminal mode") }
}

mode code {
    condition: window.any("class code")
    enter: { print("Entering code mode") }
    exit: { print("Exiting code mode") }
}

print("Modes defined: browser, terminal, code")

// ============================================
// Test 6: Complex Signal with Window Queries
// ============================================
print("\nTesting complex signal conditions...")

// Signal for productive work environment
signal productiveMode when (
    window.count("exe code") > 0 &&
    !window.any("exe discord") &&
    !window.any("exe steam")
)

// Signal for entertainment mode
signal entertainmentMode when (
    window.any("exe vlc") ||
    window.any("exe mpv") ||
    window.any("exe firefox") && active.title().contains("YouTube")
)

when productiveMode {
    print("Productive mode detected - disabling distractions")
    // Could trigger DND, notification filters, etc.
}

when entertainmentMode {
    print("Entertainment mode detected - enabling media controls")
    // Could enable media key bindings, etc.
}

// ============================================
// Test 7: Active Window Operations
// ============================================
print("\nTesting active window operations...")

// Example hotkeys using active.* (commented out for safety)
// Hotkey("Alt+Shift+M") {
//     active.min()
// }

// Hotkey("Alt+Shift+X") {
//     active.max()
// }

// Hotkey("Alt+Shift+C") {
//     active.close()
// }

// ============================================
// Test Summary
// ============================================
print("\n=== Test Summary ===")
print("Window query functions: any, count, filter - OK")
print("Active namespace: title, class, exe, pid - OK")
print("Signal definitions with window conditions - OK")
print("When statements for reactions - OK")
print("Mode integration with window queries - OK")
print("\nPipeline test complete!")
